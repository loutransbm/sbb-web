---
/**
 * BaseLayout — HTML shell cho mọi trang SBB
 * Loads fonts, design tokens, meta tags, schema.org, viewport reveal script
 */
export interface Props {
  title: string;
  description: string;
  ogImage?: string;
  canonical?: string;
  site?: 'sbb' | 'news' | 'learn';
  schemaType?: 'Organization' | 'Article' | 'WebPage';
}

const SITE_URL = 'https://sbb.edu.vn';

const {
  title,
  description,
  ogImage = '/brand/og-cover.png',
  canonical = '',
  site = 'sbb',
  schemaType = 'WebPage',
} = Astro.props;

const siteNames: Record<string, string> = {
  sbb: 'SBB',
  news: 'SBB News',
  learn: 'SBB Learn',
};

const fullTitle = `${title} — ${siteNames[site]}`;

// og:image + og:url PHẢI là URL tuyệt đối thì FB / Zalo / Messenger / Twitter mới đọc được ảnh.
const ogImageAbs = /^https?:\/\//.test(ogImage) ? ogImage : `${SITE_URL}${ogImage.startsWith('/') ? '' : '/'}${ogImage}`;
const pageUrl = canonical || `${SITE_URL}${Astro.url.pathname}`;

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'SBB',
  alternateName: 'Shine Beyond Borders',
  url: SITE_URL,
  logo: `${SITE_URL}/brand/apple-touch-icon.png`,
  description: 'Chúng tôi đồng hành cùng thế hệ trẻ Việt Nam trên hành trình phát triển sự nghiệp toàn cầu.',
};
---

<!doctype html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <!-- has-js: bật trạng thái ẩn ban đầu cho scroll-reveal NGAY (tránh chớp); JS lỗi thì fallback vẫn hiện -->
  <script is:inline>document.documentElement.classList.add('has-js');</script>
  <style is:global>
    /* Chặn tràn ngang do hiệu ứng trượt reveal (clip an toàn, không phá scroll/sticky) */
    body { overflow-x: clip; }

    /* ===== SCROLL REVEAL đa dạng — chỉ transform + opacity (nhẹ GPU) ===== */
    .has-js [data-reveal], .has-js .reveal { opacity: 0; }
    .has-js [data-reveal="up"], .has-js .reveal { transform: translate3d(0, 46px, 0); }
    .has-js [data-reveal="down"]  { transform: translate3d(0, -40px, 0); }
    .has-js [data-reveal="left"]  { transform: translate3d(-60px, 0, 0); }
    .has-js [data-reveal="right"] { transform: translate3d(60px, 0, 0); }
    .has-js [data-reveal="scale"] { transform: scale(.9); }
    .has-js [data-reveal="zoom"]  { transform: scale(1.08); }
    .has-js [data-reveal="rotate"]{ transform: rotate(-2.5deg) translate3d(0, 40px, 0); transform-origin: left bottom; }
    .has-js [data-reveal].is-in, .has-js .reveal.is-in {
      opacity: 1; transform: none;
      transition: opacity 1.15s cubic-bezier(.16,1,.3,1), transform 1.15s cubic-bezier(.16,1,.3,1);
    }

    /* Stagger: các con lần lượt hiện */
    .has-js [data-reveal-stagger] > *, .has-js .reveal-stagger > * {
      opacity: 0; transform: translate3d(0, 34px, 0);
    }
    .has-js [data-reveal-stagger].is-in > *, .has-js .reveal-stagger.is-in > * {
      opacity: 1; transform: none;
      transition: opacity 1.0s cubic-bezier(.16,1,.3,1), transform 1.0s cubic-bezier(.16,1,.3,1);
    }
    .has-js [data-reveal-stagger].is-in > *:nth-child(1) { transition-delay: .08s; }
    .has-js [data-reveal-stagger].is-in > *:nth-child(2) { transition-delay: .20s; }
    .has-js [data-reveal-stagger].is-in > *:nth-child(3) { transition-delay: .32s; }
    .has-js [data-reveal-stagger].is-in > *:nth-child(4) { transition-delay: .44s; }
    .has-js [data-reveal-stagger].is-in > *:nth-child(5) { transition-delay: .56s; }
    .has-js [data-reveal-stagger].is-in > *:nth-child(6) { transition-delay: .68s; }
    .has-js [data-reveal-stagger].is-in > *:nth-child(n+7) { transition-delay: .80s; }

    @media (prefers-reduced-motion: reduce) {
      .has-js [data-reveal], .has-js .reveal,
      .has-js [data-reveal-stagger] > *, .has-js .reveal-stagger > * {
        opacity: 1 !important; transform: none !important; transition: none !important;
      }
    }
  </style>
  <!-- Site nền SÁNG: chặn Chrome "Auto Dark Mode" bôi xám nền trắng -->
  <meta name="color-scheme" content="light" />
  <title>{fullTitle}</title>
  <meta name="description" content={description} />

  <!-- Canonical -->
  <link rel="canonical" href={pageUrl} />

  <!-- OpenGraph (thông tin hiện khi chia sẻ link: FB / Zalo / Messenger…) -->
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content={schemaType === 'Article' ? 'article' : 'website'} />
  <meta property="og:locale" content="vi_VN" />
  <meta property="og:site_name" content="SBB — Shine Beyond Borders" />
  <meta property="og:url" content={pageUrl} />
  <meta property="og:image" content={ogImageAbs} />
  <meta property="og:image:secure_url" content={ogImageAbs} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt" content={fullTitle} />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImageAbs} />

  <!-- Fonts: Cormorant Garamond (Headline) & Be Vietnam Pro (Body/UI) -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@200;300;400;500;600;700;800&family=Be+Vietnam+Pro:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,700&display=swap"
    rel="stylesheet"
  />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="apple-touch-icon" href="/brand/apple-touch-icon.png" />

  <!-- Schema.org -->
  {site === 'sbb' && (
    <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
  )}
</head>
<body>
  <slot />

  <!-- --sbw = bề rộng scrollbar dọc -> để break-out cụm tiêu đề sát 2 mép CHUẨN như thanh nav (tránh lệch do 100vw tính cả scrollbar). Dùng chung mọi trang nội dung. -->
  <script is:inline>
    (function () {
      var setSbw = function () {
        document.documentElement.style.setProperty('--sbw', (window.innerWidth - document.documentElement.clientWidth) + 'px');
      };
      setSbw();
      window.addEventListener('resize', setSbw, { passive: true });
      window.addEventListener('load', setSbw);
    })();
  </script>

  <!-- GSAP & Lenis CDN -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js" is:inline></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js" is:inline></script>
  <script src="https://cdn.jsdelivr.net/npm/@studio-freight/lenis@1.0.28/dist/lenis.min.js" is:inline></script>

  <!-- Viewport reveal & Smooth Scroll animation -->
  <script is:inline>
    // Only run animations if user doesn't prefer reduced motion
    if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      // Initialize Lenis
      if (typeof Lenis !== 'undefined') {
        const lenis = new Lenis({
          duration: 1.0,
          easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
          smoothWheel: true,
          touchMultiplier: 1.5,
        });
        // 1 DRIVER rAF duy nhất. Trước đây vừa requestAnimationFrame vừa gsap.ticker cùng gọi lenis.raf
        // -> chạy 2 lần/khung = giật/rung. Bỏ gsap.ticker, chỉ dùng rAF.
        function raf(time) { lenis.raf(time); requestAnimationFrame(raf); }
        requestAnimationFrame(raf);
        if (typeof ScrollTrigger !== 'undefined') lenis.on('scroll', ScrollTrigger.update);
      }

    }

    // ===== SCROLL REVEAL đa dạng (IntersectionObserver + CSS — nhẹ hơn ScrollTrigger, chạy 1 lần/phần tử) =====
    (function () {
      var SEL = '[data-reveal],[data-reveal-stagger],.reveal,.reveal-stagger';
      var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      // Auto-gán hiệu ứng LUÂN PHIÊN cho mọi <section> chưa gắn reveal thủ công (đa dạng, áp mọi trang). Bỏ mục đầu/hero.
      var VARS = ['up', 'scale', 'zoom', 'up', 'right', 'scale', 'left', 'up', 'zoom', 'scale'];
      var main = document.querySelector('main') || document.body;
      var vi = 0;
      Array.prototype.forEach.call(main.querySelectorAll('section'), function (sec, i) {
        if (i === 0 || /hero/i.test(sec.className)) return;
        if (sec.matches(SEL) || sec.querySelector(SEL)) return;
        sec.setAttribute('data-reveal', VARS[vi % VARS.length]); vi++;
      });

      var targets = Array.prototype.slice.call(document.querySelectorAll(SEL));
      if (reduce || !('IntersectionObserver' in window)) {
        targets.forEach(function (el) { el.classList.add('is-in'); });
        return;
      }
      var io = new IntersectionObserver(function (entries) {
        entries.forEach(function (e) { if (e.isIntersecting) { e.target.classList.add('is-in'); io.unobserve(e.target); } });
      }, { rootMargin: '0px 0px -8% 0px', threshold: 0.06 });
      targets.forEach(function (el) { if (!el.classList.contains('is-in')) io.observe(el); });
    })();
  </script>
</body>
</html>

