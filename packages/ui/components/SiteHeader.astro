---
/**
 * SiteHeader — nav kiểu omni: logo trái · menu giữa · CTA phải.
 * Hỗ trợ overlay trong suốt trên hero full-bleed (prop `overlay`).
 */
export interface Props {
  site: 'sbb' | 'news' | 'learn';
  currentPath?: string;
  overlay?: boolean;
}

const { site, currentPath = '', overlay = false } = Astro.props;

const sbbLinks = [
  { label: 'Home', href: '/' },
  { label: 'About SBB', href: '/about' },
  { label: 'Programs', href: '/programs' },
  { label: 'News', href: '/news' },
  { label: 'Learn', href: '/learn' },
  { label: 'Community', href: '/community' },
  { label: 'Liên hệ', href: '/apply' },
];

const newsLinks = [
  { label: 'Trang chủ News', href: '/' },
  { label: 'Câu chuyện', href: '/stories' },
  { label: 'Reality Check', href: '/reality-check' },
  { label: 'Tiếng nói SV', href: '/student-voices' },
  { label: 'Learn', href: 'https://learn.sbb.vn' },
  { label: 'SBB', href: 'https://sbb.vn' },
];

const learnLinks = [
  { label: 'Trang chủ Learn', href: '/' },
  { label: 'Lộ trình', href: '/paths' },
  { label: 'Tìm kiếm', href: '/search' },
  { label: 'Phụ huynh', href: '/parent-corner' },
  { label: 'News', href: 'https://news.sbb.vn' },
  { label: 'SBB', href: 'https://sbb.vn' },
];

const allLinks = site === 'sbb' ? sbbLinks : site === 'news' ? newsLinks : learnLinks;
// Tách link cuối thành nút CTA bên phải — kiểu omni
const ctaLink = site === 'sbb' ? allLinks[allLinks.length - 1] : null;
const links = ctaLink ? allLinks.slice(0, -1) : allLinks;
const logoHref = site === 'sbb' ? '/' : 'https://sbb.vn';
const subLabel = site === 'news' ? 'News' : site === 'learn' ? 'Learn' : '';
---

<header class:list={['site-header', { 'site-header--overlay': overlay }]} id="site-header">
  <div class="header-inner container">
    <!-- Logo SBB (bản cam — ngoặc trắng + S xanh + chữ trắng/xanh, dùng trên nav nền cam) -->
    <a href={logoHref} class="logo" aria-label="SBB — Shine Beyond Borders">
      <img src="/brand/sbb-logo-light.svg" alt="SBB — Shine Beyond Borders" class="logo-img" width="124" height="32" />
    </a>

    <!-- Menu giữa -->
    <nav class="nav-desktop" aria-label="Menu chính">
      {links.map((link) => (
        <a href={link.href} class:list={['nav-link', { 'is-active': currentPath === link.href }]}>{link.label}</a>
      ))}
    </nav>

    <!-- Phải: CTA + nút menu mobile -->
    <div class="header-right">
      {ctaLink && <a href={ctaLink.href} class="nav-cta">{ctaLink.label}</a>}
      <button
        type="button"
        class="menu-toggle"
        id="menu-toggle"
        aria-label="Mở menu"
        aria-expanded="false"
        aria-controls="mobile-drawer"
      >
        <span class="menu-toggle__bar"></span>
        <span class="menu-toggle__bar"></span>
      </button>
    </div>
  </div>
</header>

<!-- Drawer điều hướng cho mobile (ẩn hoàn toàn ≥900px) -->
<div class="mobile-drawer" id="mobile-drawer" aria-hidden="true">
  <div class="mobile-drawer__panel" role="dialog" aria-modal="true" aria-label="Menu chính">
    <div class="mobile-drawer__top container">
      <a href={logoHref} class="logo" aria-label="SBB — Shine Beyond Borders">
        <img src="/brand/sbb-logo-light.svg" alt="SBB — Shine Beyond Borders" class="logo-img" width="124" height="32" />
      </a>
      <div class="mobile-drawer__top-right">
        {ctaLink && <a href={ctaLink.href} class="nav-cta nav-cta--drawer">{ctaLink.label}</a>}
        <button type="button" class="drawer-close" id="drawer-close" aria-label="Đóng menu">
          <span></span><span></span>
        </button>
      </div>
    </div>
    <nav class="mobile-nav container" aria-label="Menu chính">
      {links.map((link, i) => (
        <a
          href={link.href}
          class:list={['mobile-nav__link', { 'is-active': currentPath === link.href }]}
          style={`--i:${i}`}
        >{link.label}</a>
      ))}
    </nav>
  </div>
</div>

<style>
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 100;
    background-color: transparent;
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
    border-bottom: none;
    padding-top: var(--space-6);
    pointer-events: none;
    transition: padding var(--duration-normal) var(--ease-out),
                transform var(--duration-normal) var(--ease-out);
    will-change: transform;
  }
  .site-header.is-scrolled {
    padding-top: var(--space-3);
  }
  /* Ẩn khi cuộn xuống, hiện lại khi cuộn lên */
  .site-header.is-hidden {
    transform: translateY(-130%);
  }

  /* Overlay trong suốt trên hero (mặc định đã là trong suốt nhờ floating capsule) */
  .site-header--overlay {
    /* Đã kế thừa kiểu floating */
  }

  .header-inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: var(--space-4);
    min-height: 3.5rem; /* Fixed comfortable height */
    background: transparent; /* Nav TRONG SUỐT tối giản — logo + menu nổi thẳng trên hero */
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
    border: 1px solid transparent;
    box-shadow: none;
    border-radius: 100px;
    padding-left: 1.5rem;  /* Optical alignment: more left padding */
    padding-right: 0.5rem; /* Optical alignment: less right padding because CTA has internal padding */
    width: calc(100% - 4rem) !important;   /* Gần sát lề: chừa 2rem mỗi bên (khớp --section-px) */
    max-width: 120rem !important;          /* Cho thanh dài ra về 2 phía trên màn rộng (cap ~1920px chống kéo dãn trên ultrawide) */
    margin-inline: auto;
    pointer-events: auto;
    transition: background-color var(--duration-normal) var(--ease-out),
                border-color var(--duration-normal) var(--ease-out),
                box-shadow var(--duration-normal) var(--ease-out),
                min-height var(--duration-normal) var(--ease-out);
  }
  .site-header.is-scrolled .header-inner {
    background: rgba(18, 5, 2, 0.72); /* kính NÂU TỐI mờ khi cuộn -> chữ kem rõ trên dark fire */
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-color: rgba(255, 255, 255, 0.08);
    box-shadow: 0 6px 20px -8px rgba(0, 0, 0, 0.5);
    min-height: 2.85rem;
  }

  /* ---- Entrance Animations ---- */
  @keyframes headerStaggerIn {
    0% { opacity: 0; transform: translateY(-20px); }
    100% { opacity: 1; transform: translateY(0); }
  }
  .logo { animation: headerStaggerIn 1.0s cubic-bezier(0.16, 1, 0.3, 1) 0.15s backwards; }
  .nav-link:nth-child(1) { animation: headerStaggerIn 1.0s cubic-bezier(0.16, 1, 0.3, 1) 0.25s backwards; }
  .nav-link:nth-child(2) { animation: headerStaggerIn 1.0s cubic-bezier(0.16, 1, 0.3, 1) 0.35s backwards; }
  .nav-link:nth-child(3) { animation: headerStaggerIn 1.0s cubic-bezier(0.16, 1, 0.3, 1) 0.45s backwards; }
  .nav-link:nth-child(4) { animation: headerStaggerIn 1.0s cubic-bezier(0.16, 1, 0.3, 1) 0.55s backwards; }
  .nav-link:nth-child(5) { animation: headerStaggerIn 1.0s cubic-bezier(0.16, 1, 0.3, 1) 0.65s backwards; }
  .nav-link:nth-child(6) { animation: headerStaggerIn 1.0s cubic-bezier(0.16, 1, 0.3, 1) 0.75s backwards; }
  .nav-link:nth-child(7) { animation: headerStaggerIn 1.0s cubic-bezier(0.16, 1, 0.3, 1) 0.85s backwards; }
  .nav-cta { animation: headerStaggerIn 1.0s cubic-bezier(0.16, 1, 0.3, 1) 1.0s backwards; }

  /* ---- Logo ---- */
  .logo {
    justify-self: start;
    display: flex;
    align-items: center;
    gap: var(--space-2);
    text-decoration: none;
    color: var(--ink);
  }
  .logo-img {
    display: block;
    height: 2rem;
    width: auto;
    transition: opacity var(--duration-fast) var(--ease-out);
  }
  .logo:hover .logo-img { opacity: 0.85; }
  
  .logo-word {
    font-family: var(--font-headline);
    font-size: var(--text-xl);
    font-weight: var(--weight-extrabold);
    letter-spacing: var(--tracking-tight);
    display: inline-flex;
    align-items: baseline;
    gap: var(--space-1);
  }
  @media (min-width: 900px) {
    .logo-word {
      display: inline-flex; /* Show on desktop to balance visual weight of the right CTA */
    }
  }
  .logo-sub {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wider);
  }

  /* ---- Menu giữa ---- */
  .nav-desktop {
    justify-self: center;
    display: none;
    align-items: center;
    gap: clamp(0.75rem, 0.2rem + 2vw, 2.5rem);
  }
  @media (min-width: 900px) {
    .nav-desktop { display: flex; }
    .menu-toggle { display: none; }
  }

  .nav-link {
    position: relative;
    font-family: var(--font-headline);
    font-size: 12px; /* Slightly larger for readability */
    font-weight: 500;
    letter-spacing: 0.05em; /* Reduced spacing to avoid jagged reading */
    text-transform: uppercase;
    color: rgba(245, 237, 230, 0.72); /* kem sáng — đọc rõ trên nền dark fire */
    text-decoration: none;
    padding-block: var(--space-2);
    white-space: nowrap;
    transition: color var(--duration-fast) var(--ease-out);
  }
  .nav-link::after {
    content: '';
    position: absolute;
    left: 25%; right: 25%; bottom: -2px;
    height: 1.5px;
    background-color: var(--accent);
    transform: scaleX(0);
    transition: transform var(--duration-normal) var(--ease-out);
  }
  .nav-link:hover { color: #f2420b; }
  .nav-link:hover::after { transform: scaleX(1); }
  .nav-link.is-active { color: #f2420b; }
  .nav-link.is-active::after { transform: scaleX(1); }

  /* ---- Phải ---- */
  .header-right {
    justify-self: end;
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }
  .nav-cta {
    font-family: var(--font-headline);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: #FFFFFF;
    background-color: var(--accent);
    text-decoration: none;
    padding: 0 1.5rem;
    height: 2.5rem; /* Fixed height to perfectly fit inside header */
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 100px;
    white-space: nowrap;
    transition: background-color var(--duration-fast) var(--ease-out),
                transform var(--duration-fast) var(--ease-out),
                box-shadow var(--duration-fast) var(--ease-out);
  }
  .nav-cta:hover {
    background-color: var(--accent-2);
    transform: translateY(-1px);
    box-shadow: 0 8px 20px -6px rgba(242, 66, 11, 0.35);
  }
  /* Mobile: pill CTA "Liên hệ" VẪN hiện cạnh hamburger (giống Omni) — không ẩn */

  /* ====== Hamburger (mobile) — 2 gạch trần kiểu Omni ====== */
  .menu-toggle {
    justify-self: end;
    display: inline-flex;
    flex-direction: column;
    align-items: flex-end;
    justify-content: center;
    gap: 6px;
    width: 30px;
    height: 30px;
    padding: 0;
    border: 0;
    background: transparent;
    cursor: pointer;
    pointer-events: auto;
  }
  .menu-toggle__bar {
    display: block;
    width: 26px;
    height: 2px;
    background: #fff;
    border-radius: 2px;
    transition: width var(--duration-normal) var(--ease-out);
  }
  .menu-toggle__bar:last-child { width: 19px; } /* gạch dưới ngắn hơn cho tinh tế */
  .menu-toggle:hover .menu-toggle__bar:last-child { width: 26px; }
  @media (min-width: 900px) {
    .menu-toggle { display: none; }
    .mobile-drawer { display: none !important; }
  }

  /* ====== Drawer điều hướng mobile — neo ĐÁY, căn TRÁI, kẻ line, quầng cam góc dưới-trái (Omni) ====== */
  .mobile-drawer {
    position: fixed;
    inset: 0;
    z-index: 200;
    /* Nền tối + quầng lửa cam hắt từ GÓC DƯỚI-TRÁI — sáng/rực hơn (giống menu Omni) */
    background:
      radial-gradient(185% 135% at -8% 115%, rgba(255, 125, 65, 0.92) 0%, rgba(250, 80, 22, 0.6) 30%, rgba(242, 66, 11, 0.34) 52%, rgba(242, 66, 11, 0.16) 70%, rgba(242, 66, 11, 0.05) 84%, transparent 96%),
      rgba(14, 5, 2, 0.94);
    -webkit-backdrop-filter: blur(20px) saturate(125%);
    backdrop-filter: blur(20px) saturate(125%);
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    /* visibility chuyển NGAY khi mở, chỉ trễ khi đóng (sau khi mờ dần xong) */
    transition: opacity 0.34s var(--ease-out), visibility 0s linear 0.34s;
  }
  .mobile-drawer.is-open {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transition: opacity 0.34s var(--ease-out), visibility 0s linear 0s;
  }
  .mobile-drawer__panel {
    position: relative;
    z-index: 1;
    height: 100%;
    height: 100dvh;
    display: flex;
    flex-direction: column;
  }
  .mobile-drawer__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 1.5rem;
  }
  .mobile-drawer__top .logo-img { height: 1.55rem; width: auto; }
  .mobile-drawer__top-right {
    display: flex;
    align-items: center;
    gap: 0.85rem;
  }
  .drawer-close {
    position: relative;
    width: 30px;
    height: 30px;
    border: 0;
    background: transparent;
    cursor: pointer;
    flex: none;
  }
  .drawer-close span {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 24px;
    height: 2px;
    background: #fff;
    border-radius: 2px;
  }
  .drawer-close span:first-child { transform: translate(-50%, -50%) rotate(45deg); }
  .drawer-close span:last-child { transform: translate(-50%, -50%) rotate(-45deg); }

  /* List link: neo ĐÁY màn (margin-top:auto), căn TRÁI, chữ TO HOA, mỗi link 1 đường kẻ */
  .mobile-nav {
    margin-top: auto;
    display: flex;
    flex-direction: column;
    padding-bottom: clamp(1.75rem, 6vh, 3rem);
  }
  .mobile-nav__link {
    font-family: var(--font-headline);
    font-size: clamp(2.25rem, 11vw, 3.4rem);
    font-weight: 500;
    letter-spacing: -0.02em;
    line-height: 1.04;
    text-transform: uppercase;
    color: #f5ede6;
    text-decoration: none;
    padding: 0.6rem 0;
    border-top: 1px solid rgba(255, 255, 255, 0.14);
    transition: color var(--duration-fast) var(--ease-out),
                padding-left var(--duration-normal) var(--ease-out);
  }
  .mobile-nav__link:last-child { border-bottom: 1px solid rgba(255, 255, 255, 0.14); }
  .mobile-nav__link:hover,
  .mobile-nav__link:active { color: #ff5c26; padding-left: 0.5rem; }
  .mobile-nav__link.is-active { color: #f2420b; }
  /* Stagger nhẹ từ dưới lên khi mở */
  .mobile-drawer.is-open .mobile-nav__link {
    animation: drawerLinkIn 0.45s var(--ease-out) backwards;
    animation-delay: calc(0.05s * var(--i) + 0.06s);
  }
  @keyframes drawerLinkIn {
    0% { opacity: 0; transform: translateY(14px); }
    100% { opacity: 1; transform: translateY(0); }
  }
  @media (prefers-reduced-motion: reduce) {
    .mobile-drawer.is-open .mobile-nav__link { animation: none; }
  }

  /* === GLOBAL OMNI SYNC OVERRIDES === */
  .site-header {
    padding-top: 1.5rem !important; /* Float down from top edge */
  }
  .header-inner {
    background: transparent !important; /* Tuyệt đối trong suốt 100% */
    backdrop-filter: none !important; 
    -webkit-backdrop-filter: none !important;
    border: 1px solid rgba(255, 255, 255, 0.06) !important; /* Viền siêu mờ ảo, gần như tàng hình */
    min-height: 2.8rem !important; 
    height: 2.8rem !important;
    padding-right: 0.4rem !important;
    box-shadow: none !important; /* Xóa hoàn toàn bóng đen bên dưới */
  }
  .site-header.is-scrolled .header-inner {
    background: rgba(15, 3, 0, 0.6) !important; /* Chỉ hơi tối và mờ lại khi cuộn trang */
    backdrop-filter: blur(16px) !important;
    -webkit-backdrop-filter: blur(16px) !important;
    border-color: rgba(255, 255, 255, 0.12) !important;
    box-shadow: 0 10px 30px -10px rgba(0, 0, 0, 0.5) !important;
  }
  /* Shrink Logo to fit smaller pill */
  .logo-img {
    height: 1.4rem !important; 
    width: auto !important;
  }
  /* Navbar links: Pure white, smaller font */
  .nav-link { 
    color: #ffffff !important; 
    font-weight: 500 !important; 
    font-size: 10px !important; 
    letter-spacing: 0.08em !important; 
  }
  .nav-link:hover,
  .nav-link.is-active { 
    color: #ffffff !important; /* Giữ nguyên chữ màu trắng, giữ nguyên gạch cam gốc của theme */
  }
  /* Omni style CTA Button */
  .nav-cta { 
    background: #E64A00 !important; /* Solid Deep Orange Pill */
    color: #ffffff !important;
    border-radius: 100px !important;
    padding: 0 1.5rem !important; /* Thinner padding */
    height: 2rem !important; /* Reduced height */
    font-size: 10px !important; /* Tweak font size to fit */
    font-weight: 600 !important;
    border: 1px solid rgba(255, 255, 255, 0.1) !important;
  }
  .nav-cta:hover {
    background: #FF6600 !important;
    box-shadow: 0 8px 20px -6px rgba(230, 74, 0, 0.6) !important;
  }

  /* ===== KHỚP THANH NAV OMNI TRÊN MOBILE (≤899px) ===== */
  @media (max-width: 899px) {
    /* Bỏ viền capsule -> thanh nav TRONG SUỐT hẳn, item nổi thẳng trên hero như Omni */
    .site-header .header-inner {
      /* Grid 1fr auto 1fr bị dồn header-right vào cột giữa khi nav-desktop ẩn
         -> chuyển sang flex space-between: logo TRÁI ↔ pill+hamburger PHẢI.
         Dùng .site-header .header-inner (specificity cao hơn) để ÉP THẮNG viền omni. */
      display: flex !important;
      justify-content: space-between !important;
      align-items: center !important;
      border: 0 !important;            /* bỏ HẲN viền capsule "kẻ trên top" */
      background: transparent !important;
      box-shadow: none !important;
      width: calc(100% - 2.5rem) !important;  /* sát mép hơn (giống Omni) */
      padding-left: 0.25rem !important;
      padding-right: 0.25rem !important;
      height: 2.6rem !important;
      min-height: 2.6rem !important;
    }
    /* Khi cuộn KHÔNG hiện nền capsule (Omni: nav tự ẩn/hiện, không bo nền) */
    .site-header.is-scrolled .header-inner {
      background: transparent !important;
      backdrop-filter: none !important;
      -webkit-backdrop-filter: none !important;
      border-color: transparent !important;
      box-shadow: none !important;
    }
    /* Logo to hơn chút cho cân với pill (Omni logo đậm) */
    .logo-img { height: 1.55rem !important; }
    /* Hamburger: 2 gạch ĐỀU nhau, mảnh (Omni) */
    .menu-toggle { width: 28px !important; height: 28px !important; gap: 7px !important; }
    .menu-toggle__bar { width: 25px !important; height: 1.5px !important; }
    .menu-toggle__bar:last-child { width: 25px !important; }
    /* Pill: cam GRADIENT bóng, cỡ vừa như "CONTACT US" của Omni */
    .nav-cta {
      background: linear-gradient(180deg, #ff7a3d 0%, #ef5316 48%, #e2430b 100%) !important;
      font-size: 11px !important;
      letter-spacing: 0.06em !important;
      height: 2.3rem !important;
      padding: 0 1.25rem !important;
      border: none !important;
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.28),
                  0 6px 16px -6px rgba(230, 74, 0, 0.5) !important;
    }
    .header-right { gap: 0.7rem !important; }
  }
</style>

<script>
  const header = document.getElementById('site-header');
  let lastY = window.scrollY;

  const onScroll = () => {
    const y = window.scrollY;

    // Nền trong suốt sau khi cuộn
    header?.classList.toggle('is-scrolled', y > 40);

    // Ẩn khi cuộn xuống, hiện khi cuộn lên (bỏ qua rung lắc nhỏ)
    const delta = y - lastY;
    if (Math.abs(delta) > 4) {
      if (delta > 0 && y > 120) {
        header?.classList.add('is-hidden');     // cuộn xuống → ẩn
      } else if (delta < 0) {
        header?.classList.remove('is-hidden');  // cuộn lên → hiện
      }
      lastY = y;
    }

    // Luôn hiện khi ở gần đỉnh trang
    if (y <= 80) header?.classList.remove('is-hidden');
  };
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  /* ---- Drawer điều hướng mobile ---- */
  const toggle = document.getElementById('menu-toggle');
  const drawer = document.getElementById('mobile-drawer');
  const closeBtn = document.getElementById('drawer-close');

  const openMenu = () => {
    drawer?.classList.add('is-open');
    drawer?.setAttribute('aria-hidden', 'false');
    toggle?.setAttribute('aria-expanded', 'true');
    document.documentElement.style.overflow = 'hidden';
    document.body.style.overflow = 'hidden';
  };
  const closeMenu = () => {
    drawer?.classList.remove('is-open');
    drawer?.setAttribute('aria-hidden', 'true');
    toggle?.setAttribute('aria-expanded', 'false');
    document.documentElement.style.overflow = '';
    document.body.style.overflow = '';
  };

  toggle?.addEventListener('click', () => {
    drawer?.classList.contains('is-open') ? closeMenu() : openMenu();
  });
  closeBtn?.addEventListener('click', closeMenu);
  // Đóng khi bấm link hoặc bấm vùng nền ngoài panel
  drawer?.querySelectorAll('a').forEach((a) => a.addEventListener('click', closeMenu));
  drawer?.addEventListener('click', (e) => { if (e.target === drawer) closeMenu(); });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && drawer?.classList.contains('is-open')) closeMenu();
  });
  // Nếu phóng to qua desktop trong lúc menu mở → tự đóng để khỏi kẹt scroll-lock
  window.matchMedia('(min-width: 900px)').addEventListener('change', (e) => {
    if (e.matches) closeMenu();
  });
</script>
