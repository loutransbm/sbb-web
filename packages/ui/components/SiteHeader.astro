---
/**
 * SiteHeader — nav kiểu omni: logo trái · menu giữa · CTA phải.
 * Hỗ trợ overlay trong suốt trên hero full-bleed (prop `overlay`).
 */
export interface Props {
  site: 'sbb' | 'news' | 'learn';
  currentPath?: string;
  overlay?: boolean;
}

const { site, currentPath = '', overlay = false } = Astro.props;

const sbbLinks = [
  { label: 'Home', href: '/' },
  { label: 'About SBB', href: '/about' },
  { label: 'Programs', href: '/programs' },
  { label: 'News', href: '/news' },
  { label: 'Learn', href: '/learn' },
  { label: 'Community', href: '/community' },
  { label: 'Liên hệ', href: '/apply' },
];

const newsLinks = [
  { label: 'Trang chủ News', href: '/' },
  { label: 'Câu chuyện', href: '/stories' },
  { label: 'Reality Check', href: '/reality-check' },
  { label: 'Tiếng nói SV', href: '/student-voices' },
  { label: 'Learn', href: 'https://learn.sbb.vn' },
  { label: 'SBB', href: 'https://sbb.vn' },
];

const learnLinks = [
  { label: 'Trang chủ Learn', href: '/' },
  { label: 'Lộ trình', href: '/paths' },
  { label: 'Tìm kiếm', href: '/search' },
  { label: 'Phụ huynh', href: '/parent-corner' },
  { label: 'News', href: 'https://news.sbb.vn' },
  { label: 'SBB', href: 'https://sbb.vn' },
];

const allLinks = site === 'sbb' ? sbbLinks : site === 'news' ? newsLinks : learnLinks;
// Tách link cuối thành nút CTA bên phải — kiểu omni
const ctaLink = site === 'sbb' ? allLinks[allLinks.length - 1] : null;
const links = ctaLink ? allLinks.slice(0, -1) : allLinks;
const logoHref = site === 'sbb' ? '/' : 'https://sbb.vn';
const subLabel = site === 'news' ? 'News' : site === 'learn' ? 'Learn' : '';
---

<header class:list={['site-header', { 'site-header--overlay': overlay }]} id="site-header">
  <div class="header-inner container">
    <!-- Logo SBB (bản dark — logo trắng, dùng trên nền tối) -->
    <a href={logoHref} class="logo" aria-label="SBB — Shine Beyond Borders">
      <img src="/brand/sbb-logo-dark.svg" alt="SBB — Shine Beyond Borders" class="logo-img" width="124" height="32" />
    </a>

    <!-- Menu giữa -->
    <nav class="nav-desktop" aria-label="Menu chính">
      {links.map((link) => (
        <a href={link.href} class:list={['nav-link', { 'is-active': currentPath === link.href }]}>{link.label}</a>
      ))}
    </nav>

    <!-- Phải: CTA -->
    <div class="header-right">
      {ctaLink && <a href={ctaLink.href} class="nav-cta">{ctaLink.label}</a>}
    </div>
  </div>
</header>

<style>
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 100;
    background-color: transparent;
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
    border-bottom: none;
    padding-top: var(--space-6);
    pointer-events: none;
    transition: padding var(--duration-normal) var(--ease-out),
                transform var(--duration-normal) var(--ease-out);
    will-change: transform;
  }
  .site-header.is-scrolled {
    padding-top: var(--space-3);
  }
  /* Ẩn khi cuộn xuống, hiện lại khi cuộn lên */
  .site-header.is-hidden {
    transform: translateY(-130%);
  }

  /* Overlay trong suốt trên hero (mặc định đã là trong suốt nhờ floating capsule) */
  .site-header--overlay {
    /* Đã kế thừa kiểu floating */
  }

  .header-inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: var(--space-4);
    min-height: 3.5rem; /* Fixed comfortable height */
    background-color: transparent;        /* Omni: nền trong suốt hoàn toàn */
    backdrop-filter: blur(10px);          /* Omni: kính mờ blur 10px */
    -webkit-backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.2); /* Omni: viền trắng mảnh, rõ */
    border-radius: 100px;
    padding-left: 1.5rem;  /* Optical alignment: more left padding */
    padding-right: 0.5rem; /* Optical alignment: less right padding because CTA has internal padding */
    width: calc(100% - 4rem) !important;   /* Gần sát lề: chừa 2rem mỗi bên (khớp --section-px) */
    max-width: 120rem !important;          /* Cho thanh dài ra về 2 phía trên màn rộng (cap ~1920px chống kéo dãn trên ultrawide) */
    margin-inline: auto;
    pointer-events: auto;
    transition: background-color var(--duration-normal) var(--ease-out),
                border-color var(--duration-normal) var(--ease-out),
                box-shadow var(--duration-normal) var(--ease-out),
                min-height var(--duration-normal) var(--ease-out);
  }
  .site-header.is-scrolled .header-inner {
    background-color: transparent;
    border-color: transparent;
    box-shadow: none;
    min-height: 2.85rem;
  }

  /* ---- Entrance Animations ---- */
  @keyframes headerStaggerIn {
    0% { opacity: 0; transform: translateY(-20px); }
    100% { opacity: 1; transform: translateY(0); }
  }
  .logo { animation: headerStaggerIn 1.0s cubic-bezier(0.16, 1, 0.3, 1) 0.15s backwards; }
  .nav-link:nth-child(1) { animation: headerStaggerIn 1.0s cubic-bezier(0.16, 1, 0.3, 1) 0.25s backwards; }
  .nav-link:nth-child(2) { animation: headerStaggerIn 1.0s cubic-bezier(0.16, 1, 0.3, 1) 0.35s backwards; }
  .nav-link:nth-child(3) { animation: headerStaggerIn 1.0s cubic-bezier(0.16, 1, 0.3, 1) 0.45s backwards; }
  .nav-link:nth-child(4) { animation: headerStaggerIn 1.0s cubic-bezier(0.16, 1, 0.3, 1) 0.55s backwards; }
  .nav-link:nth-child(5) { animation: headerStaggerIn 1.0s cubic-bezier(0.16, 1, 0.3, 1) 0.65s backwards; }
  .nav-link:nth-child(6) { animation: headerStaggerIn 1.0s cubic-bezier(0.16, 1, 0.3, 1) 0.75s backwards; }
  .nav-link:nth-child(7) { animation: headerStaggerIn 1.0s cubic-bezier(0.16, 1, 0.3, 1) 0.85s backwards; }
  .nav-cta { animation: headerStaggerIn 1.0s cubic-bezier(0.16, 1, 0.3, 1) 1.0s backwards; }

  /* ---- Logo ---- */
  .logo {
    justify-self: start;
    display: flex;
    align-items: center;
    gap: var(--space-2);
    text-decoration: none;
    color: var(--ink);
  }
  .logo-img {
    display: block;
    height: 2rem;
    width: auto;
    transition: opacity var(--duration-fast) var(--ease-out);
  }
  .logo:hover .logo-img { opacity: 0.85; }
  
  .logo-word {
    font-family: var(--font-headline);
    font-size: var(--text-xl);
    font-weight: var(--weight-extrabold);
    letter-spacing: var(--tracking-tight);
    display: inline-flex;
    align-items: baseline;
    gap: var(--space-1);
  }
  @media (min-width: 900px) {
    .logo-word {
      display: inline-flex; /* Show on desktop to balance visual weight of the right CTA */
    }
  }
  .logo-sub {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wider);
  }

  /* ---- Menu giữa ---- */
  .nav-desktop {
    justify-self: center;
    display: none;
    align-items: center;
    gap: clamp(0.75rem, 0.2rem + 2vw, 2.5rem);
  }
  @media (min-width: 900px) {
    .nav-desktop { display: flex; }
    .menu-toggle { display: none; }
  }

  .nav-link {
    position: relative;
    font-family: var(--font-headline);
    font-size: 12px; /* Slightly larger for readability */
    font-weight: 500;
    letter-spacing: 0.05em; /* Reduced spacing to avoid jagged reading */
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.65);
    text-decoration: none;
    padding-block: var(--space-2);
    white-space: nowrap;
    transition: color var(--duration-fast) var(--ease-out);
  }
  .nav-link::after {
    content: '';
    position: absolute;
    left: 25%; right: 25%; bottom: -2px;
    height: 1.5px;
    background-color: var(--accent);
    transform: scaleX(0);
    transition: transform var(--duration-normal) var(--ease-out);
  }
  .nav-link:hover { color: #FFFFFF; }
  .nav-link:hover::after { transform: scaleX(1); }
  .nav-link.is-active { color: #FFFFFF; }
  .nav-link.is-active::after { transform: scaleX(1); }

  /* ---- Phải ---- */
  .header-right {
    justify-self: end;
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }
  .nav-cta {
    font-family: var(--font-headline);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: #FFFFFF;
    background-color: var(--accent);
    text-decoration: none;
    padding: 0 1.5rem;
    height: 2.5rem; /* Fixed height to perfectly fit inside header */
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 100px;
    white-space: nowrap;
    transition: background-color var(--duration-fast) var(--ease-out),
                transform var(--duration-fast) var(--ease-out),
                box-shadow var(--duration-fast) var(--ease-out);
  }
  .nav-cta:hover {
    background-color: var(--accent-2);
    transform: translateY(-1px);
    box-shadow: 0 8px 20px -8px rgba(255, 94, 58, 0.6);
  }
  @media (max-width: 899px) {
    .nav-cta { display: none; }
  }

</style>

<script>
  const header = document.getElementById('site-header');
  let lastY = window.scrollY;

  const onScroll = () => {
    const y = window.scrollY;

    // Nền trong suốt sau khi cuộn
    header?.classList.toggle('is-scrolled', y > 40);

    // Ẩn khi cuộn xuống, hiện khi cuộn lên (bỏ qua rung lắc nhỏ)
    const delta = y - lastY;
    if (Math.abs(delta) > 4) {
      if (delta > 0 && y > 120) {
        header?.classList.add('is-hidden');     // cuộn xuống → ẩn
      } else if (delta < 0) {
        header?.classList.remove('is-hidden');  // cuộn lên → hiện
      }
      lastY = y;
    }

    // Luôn hiện khi ở gần đỉnh trang
    if (y <= 80) header?.classList.remove('is-hidden');
  };
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();
</script>
