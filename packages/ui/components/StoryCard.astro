---
export interface Props {
  title: string;
  excerpt: string;
  href: string;
  date?: string;
}
const { title, excerpt, href, date } = Astro.props;
---
<a href={href} class="story-card reveal">
  {date && <time class="story-card__date">{date}</time>}
  <h3 class="story-card__title">{title}</h3>
  <p class="story-card__excerpt">{excerpt}</p>
  <span class="story-card__more">Đọc tiếp →</span>
</a>

<style>
  .story-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding: var(--space-6);
    text-decoration: none;
    color: var(--text-primary);
    position: relative;
    height: 100%;
  }

  .story-card__date {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--accent);
    font-weight: var(--weight-bold);
  }

  .story-card__title {
    font-family: var(--font-headline);
    font-size: var(--text-xl);
    font-weight: var(--weight-medium);
    line-height: var(--leading-snug);
    color: var(--text-primary);
  }

  .story-card__excerpt {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: var(--leading-normal);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .story-card__more {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    color: var(--accent);
    margin-top: auto;
    transition: color var(--duration-fast) var(--ease-out);
  }

  .story-card:hover .story-card__more {
    color: var(--interactive-hover);
  }
</style>


