---
export interface Props {
  headline: string;
  body: string;
  primaryCtaText: string;
  primaryCtaHref: string;
  secondaryCtaText?: string;
  secondaryCtaHref?: string;
}
const { headline, body, primaryCtaText, primaryCtaHref, secondaryCtaText, secondaryCtaHref } = Astro.props;
---
<section class="section cta-section">
  <!-- Soft warm wash behind the orange panel (subtle on light page) -->
  <div class="glow-orb orb-accent" style="top: 50%; left: 50%; transform: translate(-50%, -50%); opacity: 0.12;"></div>

  <div class="container container--narrow reveal" style="position: relative; z-index: 2;">
    <div class="cta-box">
      <h2 class="cta-section__headline">{headline}</h2>
      <p class="cta-section__body">{body}</p>
      <div class="cta-section__actions">
        <a href={primaryCtaHref} class="btn btn--primary">{primaryCtaText}</a>
        {secondaryCtaText && secondaryCtaHref && (
          <a href={secondaryCtaHref} class="btn btn--secondary">{secondaryCtaText}</a>
        )}
      </div>
    </div>
  </div>
</section>

<style>
  .cta-section {
    background-color: transparent;
    position: relative;
    overflow: hidden;
    padding-block: var(--space-20);
  }

  .cta-box {
    background-color: var(--accent); /* Orange CTA panel — #f2420b */
    border: 1px solid rgba(0, 0, 0, 0.10);
    padding: var(--space-12) var(--space-8);
    box-shadow: 0 18px 48px rgba(242, 66, 11, 0.18);
    text-align: center;
    position: relative;
  }

  .cta-section__headline {
    font-size: var(--text-3xl);
    margin-bottom: var(--space-6);
    color: var(--on-ink); /* White on orange panel */
  }

  .cta-section__body {
    font-size: var(--text-lg);
    color: rgba(255, 255, 255, 0.88); /* Soft white on orange panel */
    line-height: var(--leading-relaxed);
    margin-inline: auto;
    margin-bottom: var(--space-8);
    max-width: var(--max-w-prose);
  }

  .cta-section__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    justify-content: center;
  }

  /* On the orange panel: primary = BLUE (pops), secondary = white ghost */
  .cta-section__actions :global(.btn--primary) {
    background-color: var(--blue); /* -> #f2420b (đã gộp về cam đỏ) */
    color: var(--on-ink);
    border-color: var(--on-ink);
    box-shadow: 3px 3px 0px rgba(0, 0, 0, 0.25);
  }

  .cta-section__actions :global(.btn--primary:hover) {
    background-color: var(--blue-2); /* -> #ff5c26 */
    box-shadow: 4px 4px 0px rgba(0, 0, 0, 0.25);
  }

  .cta-section__actions :global(.btn--secondary) {
    background-color: transparent;
    color: var(--on-ink);
    border-color: rgba(255, 255, 255, 0.6);
    box-shadow: 3px 3px 0px rgba(255, 255, 255, 0.3);
  }

  .cta-section__actions :global(.btn--secondary:hover) {
    background-color: rgba(255, 255, 255, 0.12);
    border-color: var(--on-ink);
    box-shadow: 4px 4px 0px var(--on-ink);
  }
</style>

