---
export interface Props { cluster: string; }
const { cluster } = Astro.props;
const labels: Record<string, string> = {
  'tu-duy-ra-the-gioi': 'Tư duy ra thế giới',
  'reality-check': 'Reality Check',
  'internship-j1': 'Internship J-1',
  'grp': 'GRP',
  'office-tour': 'Office Tour',
  'tieng-noi-hanh-trinh': 'Tiếng nói hành trình',
};
---
<span class="cluster-badge">{labels[cluster] || cluster}</span>
<style>
  .cluster-badge {
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    color: var(--accent);
    background: var(--accent-light);
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-full);
    white-space: nowrap;
  }
</style>
