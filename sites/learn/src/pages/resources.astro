---
import PageLayout from '@ui/layouts/PageLayout.astro';
import SectionBlock from '@ui/components/SectionBlock.astro';
---

<PageLayout
  title="Tài liệu & Cẩm nang miễn phí — SBB Learn"
  description="Thư viện tài liệu miễn phí hỗ trợ chuẩn bị hồ sơ thực tập quốc tế, CV mẫu và checklist phỏng vấn."
  site="learn"
  currentPath="/resources"
>
  <section class="section resources-page">
    <div class="container container--narrow reveal">
      <h1 class="font-headline resources-title">Tài liệu miễn phí</h1>
      <p class="resources-desc">
        Các cẩm nang, checklist và biểu mẫu do đội ngũ SBB tổng hợp nhằm hỗ trợ bạn tự chuẩn bị hồ sơ một cách tốt nhất.
      </p>

      <div class="resources-grid">
        <div class="resource-card">
          <span class="resource-card__tag">PDF</span>
          <h2 class="font-headline resource-card__title">Mẫu CV chuẩn ATS (Tiếng Anh)</h2>
          <p class="resource-card__desc">
            Bản mẫu CV chuyên nghiệp chuẩn hóa dành cho các bạn sinh viên đăng ký chương trình J-1 hoặc nộp tuyển dụng quốc tế.
          </p>
          <a href="#" class="btn btn--secondary" download>Tải xuống (Mẫu)</a>
        </div>

        <div class="resource-card">
          <span class="resource-card__tag">PDF</span>
          <h2 class="font-headline resource-card__title">Checklist phỏng vấn Host Company Mỹ</h2>
          <p class="resource-card__desc">
            Tổng hợp các câu hỏi phỏng vấn thường gặp của doanh nghiệp Mỹ và hướng dẫn trả lời thể hiện tác phong chuyên nghiệp.
          </p>
          <a href="#" class="btn btn--secondary" download>Tải xuống (Mẫu)</a>
        </div>

        <div class="resource-card">
          <span class="resource-card__tag">Checklist</span>
          <h2 class="font-headline resource-card__title">Cẩm nang chuẩn bị hành lý đi Mỹ (J-1)</h2>
          <p class="resource-card__desc">
            Liệt kê các giấy tờ pháp lý bắt buộc (DS-2019, SEVIS), tiền mặt, đồ dùng thiết yếu và các lưu ý nhập cảnh hải quan Mỹ.
          </p>
          <a href="#" class="btn btn--secondary" download>Tải xuống (Mẫu)</a>
        </div>
      </div>
    </div>
  </section>
</PageLayout>

<style>
  .resources-page {
    padding-block: var(--space-16);
  }
  .resources-title {
    font-size: var(--text-3xl);
    margin-bottom: var(--space-2);
  }
  .resources-desc {
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-12);
  }

  .resources-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }
  @media (min-width: 640px) {
    .resources-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .resource-card {
    background: var(--paper-warm);
    border: 1px solid var(--line);
    padding: var(--space-6);
    border-radius: var(--radius-lg);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .resource-card__tag {
    font-size: var(--text-xs);
    font-weight: bold;
    text-transform: uppercase;
    color: var(--accent);
    background: var(--paper);
    padding: 2px 8px;
    border-radius: var(--radius-sm);
    border: 1px solid var(--line);
    margin-bottom: var(--space-3);
  }

  .resource-card__title {
    font-size: var(--text-xl);
    margin-bottom: var(--space-2);
    line-height: var(--leading-tight);
  }

  .resource-card__desc {
    color: var(--text-secondary);
    font-size: var(--text-sm);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-6);
    flex-grow: 1;
  }
</style>
