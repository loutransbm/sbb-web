---
import PageLayout from '@ui/layouts/PageLayout.astro';
import StoryCard from '@ui/components/StoryCard.astro';
import ClusterBadge from '@ui/components/ClusterBadge.astro';
import Tag from '@ui/components/Tag.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('news');
const sortedArticles = allArticles.sort((a, b) => b.data.published.getTime() - a.data.published.getTime());

const featuredArticle = sortedArticles.find(a => a.data.featured) || sortedArticles[0];
const otherArticles = sortedArticles.filter(a => a.id !== (featuredArticle?.id || ''));

const categories = [
  { slug: 'tu-duy-ra-the-gioi', label: 'Tư duy ra thế giới' },
  { slug: 'reality-check', label: 'Reality Check' },
  { slug: 'internship-j1', label: 'Internship J-1' },
  { slug: 'grp', label: 'GRP Foundation' },
  { slug: 'office-tour', label: 'Office Tour' },
  { slug: 'tieng-noi-hanh-trinh', label: 'Tiếng nói hành trình' }
];
---

<PageLayout
  title="SBB News — Góc nhìn chân thật về làm việc quốc tế"
  description="Tin tức, góc nhìn thực tế và các bài viết định hướng cho hành trình bước ra thế giới của người trẻ Việt."
  site="news"
  currentPath="/"
>
  <div class="news-home">
    <!-- Hero / Featured Section -->
    {featuredArticle ? (
      <section class="section news-hero">
        <div class="container grid-2">
          <div class="news-hero__content reveal">
            <div class="news-hero__meta">
              <ClusterBadge cluster={featuredArticle.data.cum_chinh} />
              <Tag label={featuredArticle.data.loai} />
            </div>
            <h1 class="news-hero__title">
              <a href={`/${featuredArticle.data.cum_chinh}/${featuredArticle.id}`}>
                {featuredArticle.data.title}
              </a>
            </h1>
            <p class="news-hero__excerpt">
              {featuredArticle.data.description || "Bài viết chia sẻ góc nhìn thực tế về cơ hội nghề nghiệp quốc tế..."}
            </p>
            <div class="news-hero__footer">
              <time class="news-hero__date">
                {featuredArticle.data.published.toLocaleDateString('vi-VN', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric'
                })}
              </time>
              <a href={`/${featuredArticle.data.cum_chinh}/${featuredArticle.id}`} class="btn btn--secondary">
                Đọc bài viết &rarr;
              </a>
            </div>
          </div>
          <div class="news-hero__cover reveal">
            <div class="placeholder-cover">
              <span class="placeholder-text">SBB NEWSROOM</span>
            </div>
          </div>
        </div>
      </section>
    ) : (
      <section class="section">
        <div class="container container--narrow text-center">
          <h1 class="font-headline" style="font-size: var(--text-3xl); margin-bottom: var(--space-4);">SBB Newsroom</h1>
          <p style="color: var(--text-secondary); margin-bottom: var(--space-8);">Đang cập nhật các bài viết và chuyên đề mới nhất từ SBB.</p>
        </div>
      </section>
    )}

    <!-- Category Filter Bar -->
    <nav class="category-bar">
      <div class="container">
        <h2 class="category-bar__title">Chuyên mục chính:</h2>
        <ul class="category-bar__list">
          {categories.map(cat => (
            <li>
              <a href={`/${cat.slug}`} class="category-bar__link">
                {cat.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </nav>

    <!-- Latest Articles Grid -->
    <section class="section latest-grid">
      <div class="container">
        <h2 class="section-title reveal">Bài viết mới nhất</h2>
        
        {otherArticles.length > 0 ? (
          <div class="grid-3">
            {otherArticles.map(article => (
              <StoryCard
                title={article.data.title}
                excerpt={article.data.description || "Góc nhìn từ SBB..."}
                href={`/${article.data.cum_chinh}/${article.id}`}
                date={article.data.published.toLocaleDateString('vi-VN', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric'
                })}
              />
            ))}
          </div>
        ) : (
          !featuredArticle && <p class="text-center" style="color: var(--text-secondary);">Chưa có bài viết nào khác.</p>
        )}
      </div>
    </section>

    <!-- Newsletter CTA -->
    <section class="section subscribe-section">
      <div class="container container--narrow text-center reveal">
        <h2 class="font-headline" style="font-size: var(--text-3xl); margin-bottom: var(--space-4);">Nhận bản tin từ SBB</h2>
        <p style="color: var(--text-secondary); margin-bottom: var(--space-8); max-width: 600px; margin-inline: auto;">
          Chúng tôi không gửi spam. Chỉ chia sẻ những câu chuyện thật, reality check định kỳ, và cập nhật quan trọng từ các chương trình.
        </p>
        <a href="/subscribe" class="btn btn--primary">Đăng ký nhận bản tin</a>
      </div>
    </section>
  </div>
</PageLayout>

<style>
  .news-hero {
    border-bottom: 1px solid var(--line);
    padding-bottom: var(--space-12);
  }
  .grid-2 {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
    align-items: center;
  }
  @media (min-width: 768px) {
    .grid-2 {
      grid-template-columns: 1.2fr 0.8fr;
    }
  }
  .news-hero__meta {
    display: flex;
    gap: var(--space-2);
    align-items: center;
    margin-bottom: var(--space-4);
  }
  .news-hero__title {
    font-family: var(--font-headline);
    font-size: var(--text-3xl);
    line-height: var(--leading-tight);
    margin-bottom: var(--space-4);
  }
  .news-hero__title a {
    color: inherit;
    text-decoration: none;
  }
  .news-hero__title a:hover {
    color: var(--accent);
  }
  .news-hero__excerpt {
    font-size: var(--text-base);
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-6);
  }
  .news-hero__footer {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
  }
  .news-hero__date {
    font-size: var(--text-sm);
    color: var(--text-secondary);
  }
  
  .news-hero__cover {
    height: 300px;
    background: var(--paper-warm);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .placeholder-cover {
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .placeholder-text {
    font-family: var(--font-headline);
    font-weight: bold;
    font-size: var(--text-lg);
    letter-spacing: 0.1em;
    color: var(--accent);
    opacity: 0.7;
  }

  .category-bar {
    background: var(--paper-warm);
    border-bottom: 1px solid var(--line);
    padding: var(--space-4) 0;
  }
  .category-bar__title {
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-secondary);
    margin-bottom: var(--space-2);
  }
  .category-bar__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
  }
  .category-bar__link {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--ink);
    text-decoration: none;
    padding: var(--space-1) var(--space-3);
    border: 1px solid var(--line);
    border-radius: var(--radius-full);
    background: var(--paper);
    transition: all var(--duration-normal) var(--ease-out);
  }
  .category-bar__link:hover {
    background: var(--accent);
    color: var(--paper);
    border-color: var(--accent);
  }

  .latest-grid {
    padding-top: var(--space-12);
  }
  .section-title {
    font-family: var(--font-headline);
    font-size: var(--text-2xl);
    margin-bottom: var(--space-8);
  }
  .grid-3 {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }
  @media (min-width: 640px) {
    .grid-3 {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 1024px) {
    .grid-3 {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .subscribe-section {
    background: var(--paper-warm);
    border-top: 1px solid var(--line);
    margin-top: var(--space-12);
  }
</style>
