# Supabase — đồng bộ tiến độ học GRP khi học viên đăng nhập.
# Để TRỐNG cả hai = web vẫn chạy bình thường bằng localStorage (không đăng nhập, không đồng bộ).
# Lấy tại: Supabase Dashboard > Project Settings > API
#   PUBLIC_SUPABASE_URL      = Project URL
#   PUBLIC_SUPABASE_ANON_KEY = anon public key  (KHÔNG dùng service_role key ở đây)
# Hai biến này được nhúng vào client (an toàn — bảo vệ thật là RLS trên Supabase).
# Sao chép file này thành .env rồi điền giá trị.

PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_ANON_KEY=
