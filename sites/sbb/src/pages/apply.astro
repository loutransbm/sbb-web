---
import PageLayout from '@ui/layouts/PageLayout.astro';

const steps = [
  {
    num: '01',
    title: 'Để lại thông tin',
    body: 'Bạn đăng ký qua form hoặc nhắn tin trực tiếp. Chỉ vài dòng về bạn là ai, đang quan tâm điều gì — không cần chuẩn bị gì phức tạp.',
  },
  {
    num: '02',
    title: 'Đánh giá năng lực miễn phí',
    body: 'SBB ngồi lại cùng bạn một buổi để nhìn thẳng vào hồ sơ, năng lực và mong muốn. Thẳng thắn, không vẽ vời — kể cả khi câu trả lời là "chưa nên đi vội".',
  },
  {
    num: '03',
    title: 'Nhận lộ trình cá nhân hoá',
    body: 'Dựa trên thực tế của bạn, SBB phác ra con đường phù hợp: nên chuẩn bị gì, đi hướng nào, chi phí minh bạch ngay từ đầu. Không cam kết suông.',
  },
  {
    num: '04',
    title: 'Bắt đầu đồng hành',
    body: 'Khi bạn sẵn sàng, SBB đi cùng bạn từng bước — tới khi bạn thật sự vững vàng ở môi trường quốc tế, chứ không buông tay giữa chừng.',
  },
];

const channels = [
  'Hotline & Zalo: 09xx xxx xxx — nhắn tin nhanh nhất, phản hồi trong giờ làm việc.',
  'Email: hello@sbb.vn — gửi hồ sơ hoặc câu hỏi dài, SBB trả lời trong 1–2 ngày.',
  'Văn phòng: ghé trực tiếp để nói chuyện sâu (vui lòng hẹn trước để SBB sắp xếp thời gian).',
];

const inputStyle =
  'width:100%;font-family:var(--font-body);font-size:1rem;padding:0.85rem 1.1rem;border:1px solid rgba(255,255,255,0.14);border-radius:14px;background:rgba(255,255,255,0.03);color:#fff;';
const labelStyle =
  'display:block;font-family:var(--font-headline);font-weight:600;font-size:0.8rem;letter-spacing:0.05em;text-transform:uppercase;color:var(--ink-soft);margin-bottom:0.55rem;';
---

<PageLayout
  title="Liên hệ"
  description="Đặt lịch tư vấn cùng SBB: để lại thông tin, đánh giá năng lực miễn phí và nhận lộ trình cá nhân hoá."
  site="sbb"
  currentPath="/apply"
>
  <!-- ===== HERO ===== -->
  <section class="o-hero">
    <div class="container">
      <span class="o-eyebrow">Liên hệ</span>
      <h1 class="o-mega">ĐẶT LỊCH <span class="o-accent">TƯ VẤN</span></h1>
      <p class="o-lead">Khi nào bạn thấy sẵn sàng, SBB cùng bạn ngồi nói chuyện một buổi. Không chốt sale, không hối — chỉ một buổi nói thẳng để cùng nhìn xem con đường nào thật sự hợp với bạn.</p>
    </div>
  </section>

  <!-- ===== WHAT HAPPENS NEXT ===== -->
  <section class="o-section">
    <div class="container">
      <div class="o-head">
        <span class="o-head-eyebrow">Quy trình</span>
        <h2 class="o-head-title">WHAT HAPPENS <span class="o-stroke">NEXT</span></h2>
        <p class="o-head-desc">Sau khi bạn liên hệ, đây là bốn bước SBB đi cùng bạn — minh bạch từ đầu đến cuối, không ràng buộc, không áp lực.</p>
      </div>
      <div class="o-rows">
        {steps.map((s) => (
          <article class="o-row">
            <span class="o-row__num">{s.num}</span>
            <div>
              <h3 class="o-row__title">{s.title}</h3>
              <p class="o-row__body">{s.body}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== CHANNELS + REASSURANCE ===== -->
  <section class="o-section o-section--tint o-section--glow">
    <div class="container">
      <div class="o-split o-split--top">
        <div>
          <span class="o-head-eyebrow">Reach Us</span>
          <h2 class="o-head-title">TALK TO <span class="o-stroke">SBB</span></h2>
          <ul class="o-checks o-mt-lg">
            {channels.map((c) => (<li>{c}</li>))}
          </ul>
          <div class="o-actions o-mt-lg">
            <a href="#contact-form" class="o-btn o-btn--primary">Nhắn tin cho SBB</a>
            <a href="/programs" class="o-btn o-btn--ghost">Xem chương trình</a>
          </div>
        </div>
        <div>
          <p class="o-statement">Bạn không cần sẵn sàng hoàn hảo. Bạn chỉ cần <span class="o-accent">sẵn sàng bắt đầu</span> một cuộc trò chuyện.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== FORM ===== -->
  <section class="o-section" id="contact-form">
    <div class="container">
      <div class="o-head">
        <span class="o-head-eyebrow">Để lại thông tin</span>
        <h2 class="o-head-title">SEND A <span class="o-stroke">MESSAGE</span></h2>
        <p class="o-head-desc">Điền vài dòng để SBB hiểu bạn hơn trước buổi nói chuyện. Thông tin của bạn được bảo mật, SBB sẽ liên hệ lại sớm nhất.</p>
      </div>

      <div class="o-card" style="max-width:46rem;">
        <form action="#" method="POST" style="display:flex;flex-direction:column;gap:1.4rem;">
          <div>
            <label for="name" style={labelStyle}>Họ tên <span style="color:var(--accent);">*</span></label>
            <input type="text" id="name" name="name" required autocomplete="name" placeholder="Tên của bạn" style={inputStyle} />
          </div>

          <div>
            <label for="contact" style={labelStyle}>Email hoặc số điện thoại <span style="color:var(--accent);">*</span></label>
            <input type="text" id="contact" name="contact" required placeholder="Để SBB liên hệ lại" style={inputStyle} />
          </div>

          <div>
            <span style={labelStyle}>Bạn là</span>
            <div style="display:flex;flex-wrap:wrap;gap:1.4rem;">
              <label style="display:flex;align-items:center;gap:0.5rem;color:var(--ink-soft);"><input type="radio" name="role" value="sinh-vien" checked style="accent-color:var(--accent);width:1.1em;height:1.1em;" /> <span>Sinh viên</span></label>
              <label style="display:flex;align-items:center;gap:0.5rem;color:var(--ink-soft);"><input type="radio" name="role" value="phu-huynh" style="accent-color:var(--accent);width:1.1em;height:1.1em;" /> <span>Phụ huynh</span></label>
              <label style="display:flex;align-items:center;gap:0.5rem;color:var(--ink-soft);"><input type="radio" name="role" value="khac" style="accent-color:var(--accent);width:1.1em;height:1.1em;" /> <span>Khác</span></label>
            </div>
          </div>

          <div>
            <label for="interest" style={labelStyle}>Ngành / Mối quan tâm</label>
            <input type="text" id="interest" name="interest" placeholder="Ví dụ: Hospitality, IT, J-1..." style={inputStyle} />
          </div>

          <div>
            <label for="message" style={labelStyle}>Lời nhắn</label>
            <textarea id="message" name="message" rows="4" placeholder="Bạn muốn SBB biết thêm điều gì?" style={inputStyle + 'resize:vertical;min-height:7rem;'}></textarea>
          </div>

          <div class="o-actions" style="margin-top:0.4rem;">
            <button type="submit" class="o-btn o-btn--primary">Gửi thông tin</button>
          </div>
          <p style="font-size:0.85rem;color:var(--ink-muted);line-height:1.6;margin:0;">Thông tin của bạn được bảo mật. SBB không chia sẻ dữ liệu cá nhân với bên thứ ba.</p>
        </form>
      </div>
    </div>
  </section>

  <!-- ===== CTA ===== -->
  <section class="o-cta">
    <div class="container">
      <h2 class="o-cta__title">SẴN SÀNG NÓI CHUYỆN?</h2>
      <p class="o-cta__sub">Một buổi trò chuyện thẳng thắn không khiến bạn mất gì, nhưng có thể giúp bạn nhìn rõ con đường phía trước.</p>
      <div class="o-actions">
        <a href="#contact-form" class="o-btn o-btn--primary">Nhắn tin cho SBB</a>
        <a href="/programs" class="o-btn o-btn--ghost">Xem chương trình</a>
      </div>
    </div>
  </section>
</PageLayout>
