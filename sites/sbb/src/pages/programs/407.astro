<script>
  /* CASE STUDIES: carousel kéo/vuốt + tab BUSINESS/HOSPITALITY/MARKETING (bê từ Global Internship) */
  document.addEventListener('DOMContentLoaded', () => {
    const wrapper = document.querySelector('.cs-cards-wrapper');
    const track = document.getElementById('cs-track');
    const tabs = [...document.querySelectorAll('.cs-tab')];
    const cards = [...document.querySelectorAll('.cs-card')];
    const prevBtn = document.getElementById('cs-prev');
    const nextBtn = document.getElementById('cs-next');
    if (!wrapper || !track || !cards.length) return;

    const total = cards.length;
    let index = 0;

    function update() {
      track.style.transform = `translateX(${-index * 100}%)`;
      tabs.forEach((t, k) => t.classList.toggle('active', k === index));
      cards.forEach((c, k) => c.classList.toggle('active', k === index));
      if (prevBtn) prevBtn.disabled = index === 0;
      if (nextBtn) nextBtn.disabled = index === total - 1;
    }
    function goTo(i) { index = Math.max(0, Math.min(total - 1, i)); update(); }

    tabs.forEach((tab, k) => tab.addEventListener('click', () => goTo(k)));
    prevBtn && prevBtn.addEventListener('click', () => goTo(index - 1));
    nextBtn && nextBtn.addEventListener('click', () => goTo(index + 1));

    let startX = 0, startY = 0, dragging = false, axis = null, dx = 0;
    wrapper.addEventListener('pointerdown', (e) => {
      if (e.target.closest('.cs-nav')) return;
      startX = e.clientX; startY = e.clientY;
      dragging = true; axis = null; dx = 0;
    });
    wrapper.addEventListener('pointermove', (e) => {
      if (!dragging) return;
      const mx = e.clientX - startX, my = e.clientY - startY;
      if (axis === null && (Math.abs(mx) > 8 || Math.abs(my) > 8)) {
        axis = Math.abs(mx) > Math.abs(my) ? 'x' : 'y';
        if (axis === 'x') {
          track.classList.add('is-dragging');
          try { wrapper.setPointerCapture(e.pointerId); } catch (_) {}
        }
      }
      if (axis === 'x') {
        e.preventDefault();
        dx = mx;
        const pct = -index * 100 + (mx / wrapper.offsetWidth) * 100;
        track.style.transform = `translateX(${pct}%)`;
      }
    });
    function endDrag() {
      if (!dragging) return;
      dragging = false;
      if (axis === 'x') {
        track.classList.remove('is-dragging');
        const threshold = wrapper.offsetWidth * 0.16;
        if (dx < -threshold) goTo(index + 1);
        else if (dx > threshold) goTo(index - 1);
        else update();
      }
      axis = null; dx = 0;
    }
    wrapper.addEventListener('pointerup', endDrag);
    wrapper.addEventListener('pointercancel', endDrag);
    wrapper.addEventListener('dragstart', (e) => e.preventDefault());

    window.addEventListener('keydown', (e) => {
      const r = wrapper.getBoundingClientRect();
      const visible = r.top < window.innerHeight * 0.8 && r.bottom > window.innerHeight * 0.2;
      if (!visible) return;
      if (e.key === 'ArrowRight') goTo(index + 1);
      else if (e.key === 'ArrowLeft') goTo(index - 1);
    });

    update();
  });
</script>

<script>
  /* WHAT YOU'LL DO: bấm card mở modal bảng điều kiện cơ bản theo ngành */
  document.addEventListener('DOMContentLoaded', () => {
    const modal = document.getElementById('condModal');
    if (!modal) return;
    const titleEl = modal.querySelector('.cond-modal__title');
    const bodyEl = modal.querySelector('.cond-modal__body');
    const closeBtn = modal.querySelector('.cond-modal__close');
    let lastFocused = null;

    function openModal(card) {
      const tpl = card.querySelector('template');
      if (!tpl) return;
      lastFocused = document.activeElement;
      titleEl.textContent = card.dataset.name || '';
      bodyEl.replaceChildren(tpl.content.cloneNode(true));
      modal.classList.add('is-open');
      modal.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
      closeBtn.focus();
    }
    function closeModal() {
      modal.classList.remove('is-open');
      modal.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
      if (lastFocused && lastFocused.focus) lastFocused.focus();
    }

    document.querySelectorAll('.ind-card').forEach((card) => {
      card.addEventListener('click', () => openModal(card));
    });
    modal.querySelectorAll('[data-close]').forEach((el) => el.addEventListener('click', closeModal));
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && modal.classList.contains('is-open')) closeModal();
    });
  });
</script>

<script>
  /* Dropdown CUSTOM cho form (bê từ trang chủ) — progressive enhancement, giữ <select> thật để submit/fallback */
  (function () {
    function enhance(select) {
      const wrap = select.closest('.lf-select-wrap');
      if (!wrap || wrap.classList.contains('is-enhanced')) return;
      const opts = Array.prototype.slice.call(select.options);
      const placeholder = opts.filter(function (o) { return o.disabled; })[0] || null;
      const choices = opts.filter(function (o) { return !o.disabled; });
      const dd = document.createElement('div');
      dd.className = 'lf-dd';
      const trigger = document.createElement('button');
      trigger.type = 'button';
      trigger.className = 'lf-dd-trigger';
      trigger.setAttribute('aria-haspopup', 'listbox');
      trigger.setAttribute('aria-expanded', 'false');
      const valueEl = document.createElement('span');
      valueEl.className = 'lf-dd-value';
      const caret = document.createElement('span');
      caret.className = 'lf-dd-caret';
      caret.setAttribute('aria-hidden', 'true');
      caret.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg>';
      trigger.appendChild(valueEl);
      trigger.appendChild(caret);
      const panel = document.createElement('ul');
      panel.className = 'lf-dd-panel';
      panel.setAttribute('role', 'listbox');
      let activeIdx = -1;
      function syncDisplay() {
        const sel = select.options[select.selectedIndex];
        const isPlaceholder = !!(sel && sel.disabled);
        valueEl.textContent = sel ? sel.text : (placeholder ? placeholder.text : '');
        valueEl.classList.toggle('is-placeholder', isPlaceholder);
        const curVal = sel ? sel.value : '';
        Array.prototype.forEach.call(panel.children, function (li) {
          li.classList.toggle('is-selected', !isPlaceholder && li.getAttribute('data-value') === curVal);
        });
      }
      function choose(opt) {
        select.value = opt.value;
        select.dispatchEvent(new Event('change', { bubbles: true }));
        syncDisplay();
      }
      choices.forEach(function (opt) {
        const li = document.createElement('li');
        li.className = 'lf-dd-option';
        li.setAttribute('role', 'option');
        li.setAttribute('data-value', opt.value);
        li.textContent = opt.text;
        li.addEventListener('click', function () { choose(opt); closeDd(); trigger.focus(); });
        panel.appendChild(li);
      });
      function setActive(i) {
        activeIdx = i;
        Array.prototype.forEach.call(panel.children, function (li, idx) { li.classList.toggle('is-active', idx === i); });
        if (i >= 0 && panel.children[i]) panel.children[i].scrollIntoView({ block: 'nearest' });
      }
      function openDd() {
        dd.classList.add('is-open');
        trigger.setAttribute('aria-expanded', 'true');
        let selIdx = -1;
        const cur = select.options[select.selectedIndex];
        if (cur && !cur.disabled) selIdx = choices.map(function (o) { return o.value; }).indexOf(cur.value);
        setActive(selIdx >= 0 ? selIdx : 0);
      }
      function closeDd() { dd.classList.remove('is-open'); trigger.setAttribute('aria-expanded', 'false'); setActive(-1); }
      function isOpen() { return dd.classList.contains('is-open'); }
      trigger.addEventListener('click', function (e) { e.stopPropagation(); isOpen() ? closeDd() : openDd(); });
      trigger.addEventListener('keydown', function (e) {
        switch (e.key) {
          case 'ArrowDown': e.preventDefault(); isOpen() ? setActive(Math.min(choices.length - 1, activeIdx + 1)) : openDd(); break;
          case 'ArrowUp': e.preventDefault(); isOpen() ? setActive(Math.max(0, activeIdx - 1)) : openDd(); break;
          case 'Enter': case ' ': e.preventDefault(); if (!isOpen()) openDd(); else if (activeIdx >= 0) { choose(choices[activeIdx]); closeDd(); } break;
          case 'Escape': if (isOpen()) { e.preventDefault(); closeDd(); } break;
          case 'Tab': if (isOpen()) closeDd(); break;
        }
      });
      document.addEventListener('click', function (e) { if (isOpen() && !dd.contains(e.target)) closeDd(); });
      dd.appendChild(trigger);
      dd.appendChild(panel);
      wrap.appendChild(dd);
      /* Astro scope CSS theo attr data-astro-cid-*; element tạo bằng JS không có -> copy cid từ .lf-select-wrap sang */
      var cidAttr = null;
      for (var i = 0; i < wrap.attributes.length; i++) { if (wrap.attributes[i].name.indexOf('data-astro-cid-') === 0) { cidAttr = wrap.attributes[i].name; break; } }
      if (cidAttr) { dd.setAttribute(cidAttr, ''); var all = dd.querySelectorAll('*'); for (var j = 0; j < all.length; j++) all[j].setAttribute(cidAttr, ''); }
      wrap.classList.add('is-enhanced');
      syncDisplay();
    }
    function init() { Array.prototype.forEach.call(document.querySelectorAll('.lf-select'), enhance); }
    if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
    else init();
  })();

  /* --sbw = bề rộng scrollbar dọc -> break-out tiêu đề CTA sát 2 mép chuẩn như homepage */
  (function () {
    var setSbw = function () {
      document.documentElement.style.setProperty('--sbw', (window.innerWidth - document.documentElement.clientWidth) + 'px');
    };
    setSbw();
    window.addEventListener('resize', setSbw, { passive: true });
  })();

  /* FAQ: mở mục này thì các mục khác tự đóng (bê từ trang chủ) */
  (function () {
    const items = Array.prototype.slice.call(document.querySelectorAll('.faq-item'));
    items.forEach((it) => it.addEventListener('toggle', () => {
      if (it.open) items.forEach((o) => { if (o !== it) o.open = false; });
    }));
  })();
</script>
