<script>
  /* CASE STUDIES: carousel kéo/vuốt + tab BUSINESS/HOSPITALITY/MARKETING (bê từ Global Internship) */
  document.addEventListener('DOMContentLoaded', () => {
    const wrapper = document.querySelector('.cs-cards-wrapper');
    const track = document.getElementById('cs-track');
    const tabs = [...document.querySelectorAll('.cs-tab')];
    const cards = [...document.querySelectorAll('.cs-card')];
    const prevBtn = document.getElementById('cs-prev');
    const nextBtn = document.getElementById('cs-next');
    if (!wrapper || !track || !cards.length) return;

    const total = cards.length;
    let index = 0;

    function update() {
      track.style.transform = `translateX(${-index * 100}%)`;
      tabs.forEach((t, k) => t.classList.toggle('active', k === index));
      cards.forEach((c, k) => c.classList.toggle('active', k === index));
      if (prevBtn) prevBtn.disabled = index === 0;
      if (nextBtn) nextBtn.disabled = index === total - 1;
    }
    function goTo(i) { index = Math.max(0, Math.min(total - 1, i)); update(); }

    tabs.forEach((tab, k) => tab.addEventListener('click', () => goTo(k)));
    prevBtn && prevBtn.addEventListener('click', () => goTo(index - 1));
    nextBtn && nextBtn.addEventListener('click', () => goTo(index + 1));

    let startX = 0, startY = 0, dragging = false, axis = null, dx = 0;
    wrapper.addEventListener('pointerdown', (e) => {
      if (e.target.closest('.cs-nav')) return;
      startX = e.clientX; startY = e.clientY;
      dragging = true; axis = null; dx = 0;
    });
    wrapper.addEventListener('pointermove', (e) => {
      if (!dragging) return;
      const mx = e.clientX - startX, my = e.clientY - startY;
      if (axis === null && (Math.abs(mx) > 8 || Math.abs(my) > 8)) {
        axis = Math.abs(mx) > Math.abs(my) ? 'x' : 'y';
        if (axis === 'x') {
          track.classList.add('is-dragging');
          try { wrapper.setPointerCapture(e.pointerId); } catch (_) {}
        }
      }
      if (axis === 'x') {
        e.preventDefault();
        dx = mx;
        const pct = -index * 100 + (mx / wrapper.offsetWidth) * 100;
        track.style.transform = `translateX(${pct}%)`;
      }
    });
    function endDrag() {
      if (!dragging) return;
      dragging = false;
      if (axis === 'x') {
        track.classList.remove('is-dragging');
        const threshold = wrapper.offsetWidth * 0.16;
        if (dx < -threshold) goTo(index + 1);
        else if (dx > threshold) goTo(index - 1);
        else update();
      }
      axis = null; dx = 0;
    }
    wrapper.addEventListener('pointerup', endDrag);
    wrapper.addEventListener('pointercancel', endDrag);
    wrapper.addEventListener('dragstart', (e) => e.preventDefault());

    window.addEventListener('keydown', (e) => {
      const r = wrapper.getBoundingClientRect();
      const visible = r.top < window.innerHeight * 0.8 && r.bottom > window.innerHeight * 0.2;
      if (!visible) return;
      if (e.key === 'ArrowRight') goTo(index + 1);
      else if (e.key === 'ArrowLeft') goTo(index - 1);
    });

    update();
  });
</script>

<script>
  /* WHAT YOU'LL DO: bấm card mở modal bảng điều kiện cơ bản theo ngành */
  document.addEventListener('DOMContentLoaded', () => {
    const modal = document.getElementById('condModal');
    if (!modal) return;
    const titleEl = modal.querySelector('.cond-modal__title');
    const bodyEl = modal.querySelector('.cond-modal__body');
    const closeBtn = modal.querySelector('.cond-modal__close');
    let lastFocused = null;

    function openModal(card) {
      const tpl = card.querySelector('template');
      if (!tpl) return;
      lastFocused = document.activeElement;
      titleEl.textContent = card.dataset.name || '';
      bodyEl.replaceChildren(tpl.content.cloneNode(true));
      modal.classList.add('is-open');
      modal.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
      closeBtn.focus();
    }
    function closeModal() {
      modal.classList.remove('is-open');
      modal.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
      if (lastFocused && lastFocused.focus) lastFocused.focus();
    }

    document.querySelectorAll('.ind-card').forEach((card) => {
      card.addEventListener('click', () => openModal(card));
    });
    modal.querySelectorAll('[data-close]').forEach((el) => el.addEventListener('click', closeModal));
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && modal.classList.contains('is-open')) closeModal();
    });
  });
</script>
