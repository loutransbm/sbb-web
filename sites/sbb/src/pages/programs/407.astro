  .pr-h2 { font-family: var(--font-headline); font-weight: 400; font-size: clamp(2rem, 4vw, 3.4rem); line-height: 1.08; color: #fff; letter-spacing: -0.02em; margin: 0; text-transform: none; }
  .pr-desc { font-family: 'Inter', sans-serif; font-weight: 300; font-size: clamp(0.96rem, 1.1vw, 1.08rem); line-height: 1.65; color: rgba(255,255,255,0.6); margin: 0.9rem 0 0; max-width: 60ch; }

  /* ===== CARD = KÍNH TỐI PHỦ LỬA (KHÔNG nền trắng) ===== */
  .pr-grid { display: grid; gap: clamp(1.2rem, 2vw, 1.8rem); }
  .pr-grid--3 { grid-template-columns: repeat(3, 1fr); }
  .pr-card {
    position: relative; display: flex; flex-direction: column;
    background: rgba(255,255,255,0.025);
    -webkit-backdrop-filter: blur(10px); backdrop-filter: blur(10px);
    border: 1px solid rgba(255,255,255,0.10); border-radius: 1.6rem;
    padding: clamp(1.6rem, 2.2vw, 2.3rem);
    box-shadow: 0 8px 24px rgba(0,0,0,0.40);
    transition: transform .4s ease, box-shadow .4s ease, border-color .4s ease, background .4s ease;
  }
  .pr-card:hover {
    transform: translateY(-8px);
    background:
      radial-gradient(150% 150% at 100% 100%,
        rgba(255,126,72,0.40) 0%, rgba(255,100,30,0.26) 26%, rgba(242,66,11,0.14) 50%, rgba(20,10,5,0.30) 80%, rgba(10,5,2,0.40) 100%),
      rgba(255,255,255,0.03);
    border-color: rgba(242,66,11,0.40);
    box-shadow: 0 26px 64px -24px rgba(0,0,0,0.55);
  }
  .pr-card__tag { align-self: flex-start; font-family: 'Inter', sans-serif; font-weight: 400; font-size: 0.66rem; letter-spacing: 0.08em; text-transform: uppercase; color: #ffb59c; background: rgba(242,66,11,0.18); border: 1px solid rgba(242,66,11,0.30); border-radius: 999px; padding: 0.28rem 0.7rem; }
  .pr-card__title { font-family: var(--font-headline); font-weight: 400; font-size: clamp(1.2rem, 1.6vw, 1.5rem); color: #F5EDE6; margin: 0.8rem 0 0.7rem; letter-spacing: -0.01em; text-transform: none; }
  .pr-card__body { font-family: 'Inter', sans-serif; font-weight: 300; font-size: 0.96rem; line-height: 1.6; color: rgba(255,255,255,0.78); margin: 0; }

  /* ===== SECTORS — card từng ngành kiểu Industries J-1 (quầng lửa đậm như hero stat) ===== */
  .ind-head { margin-bottom: clamp(3.75rem, 6vw, 6rem); }
  /* Tiêu đề bậc thang nối: chữ Y nằm dưới chữ T, chữ D nằm dưới chữ L.
     Dùng "chữ bóng" ẩn (cùng metrics) để canh tuyệt đối ở mọi cỡ chữ/letter-spacing. */
  .ind-title .cs-line { line-height: 0.9; }
  .ind-title .ghost { visibility: hidden; }
  /* Desktop: cho tiêu đề bậc thang to hơn base một xíu (≥981px; tablet/phone giữ nguyên vì bị rule !important đè) */
  .ind-title .cs-line-1 { font-size: clamp(9.5rem, 13.3vw, 12rem); }
  /* Màn hẹp: dòng dài nhất ("…DO") của bậc thang nối rộng ~5.7em, sẽ tràn ở điện thoại.
     Thu nhỏ riêng tiêu đề này để vừa khít mà vẫn canh đúng chữ. Tablet/desktop giữ nguyên cỡ. */
  @media (max-width: 600px) {
    .ind-title .cs-line-1 { font-size: clamp(2.5rem, 13.5vw, 4rem) !important; white-space: nowrap !important; }
  }
  .ind-desc { margin: clamp(1rem, 1.6vw, 1.6rem) 0 0; max-width: 42rem; font-family: var(--font-body); font-weight: 300; font-size: clamp(1rem, 1.1vw, 1.15rem); color: rgba(255,255,255,0.6); line-height: 1.55; }
  .ind-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(15.5rem, 1fr)); gap: clamp(0.9rem, 1.2vw, 1.3rem); }
  .ind-card {
    position: relative; overflow: hidden;
    border-radius: 22px;
    border: 1px solid rgba(255,255,255,0.09);
    min-height: clamp(200px, 22vh, 240px);
    padding: clamp(1.5rem, 1.9vw, 2rem);
    display: flex; flex-direction: column; justify-content: flex-end;
    background:
      radial-gradient(125% 125% at 0% 100%, rgba(255,120,50,0.62) 0%, rgba(248,82,26,0.44) 24%, rgba(242,66,11,0.24) 45%, rgba(20,10,5,0.50) 72%, rgba(10,5,2,0.55) 100%),
      rgba(255,255,255,0.03);
    transition: transform 0.4s cubic-bezier(0.16,1,0.3,1), border-color 0.4s ease, box-shadow 0.4s ease;
  }
  .ind-card:hover { transform: translateY(-5px); border-color: rgba(242,66,11,0.55); box-shadow: 0 20px 44px -16px rgba(242,66,11,0.45); }
  .ind-card__num { margin: 0 0 auto; font-family: var(--font-headline); font-weight: 400; font-size: 0.8rem; letter-spacing: 0.14em; color: rgba(255,255,255,0.55); }
  .ind-card__name { margin: 0 0 0.7rem; font-family: var(--font-headline); font-weight: 400; font-size: clamp(1.12rem, 1.32vw, 1.36rem); line-height: 1.14; color: #fff; }
  .ind-card__list { margin: 0; padding: 0; list-style: none; display: flex; flex-direction: column; gap: 0.4rem; }
  .ind-card__list li { position: relative; padding-left: 1rem; font-family: var(--font-body); font-weight: 300; font-size: 0.875rem; color: rgba(255,255,255,0.72); line-height: 1.4; }
  .ind-card__list li::before { content: ''; position: absolute; left: 0; top: 0.52em; width: 5px; height: 5px; border-radius: 50%; background: #f2420b; }

  /* WHAT YOU'LL DO — card bấm được để mở bảng điều kiện */
  .ind-card { cursor: pointer; }
  .ind-card__more { align-self: flex-start; margin-top: 1.1rem; display: inline-flex; align-items: center; gap: 0.45rem; padding: 0; background: none; border: none; font-family: var(--font-body); font-weight: 400; font-size: 0.82rem; letter-spacing: 0.02em; color: #ff7a45; cursor: pointer; transition: gap .25s ease, color .25s ease; }
  .ind-card:hover .ind-card__more { gap: 0.75rem; color: #ff8a5a; }
  .ind-card__more:focus-visible { outline: 2px solid #f2420b; outline-offset: 3px; border-radius: 4px; }

  /* MODAL bảng điều kiện */
  .cond-modal { position: fixed; inset: 0; z-index: 1000; display: flex; align-items: center; justify-content: center; padding: clamp(1rem, 4vw, 2.5rem); opacity: 0; visibility: hidden; transition: opacity .28s ease, visibility .28s ease; }
  .cond-modal.is-open { opacity: 1; visibility: visible; }
  .cond-modal__overlay { position: absolute; inset: 0; background: rgba(8,3,1,0.74); backdrop-filter: blur(6px); }
  .cond-modal__panel { position: relative; z-index: 1; width: min(40rem, 100%); max-height: 86vh; overflow-y: auto; border-radius: 24px; border: 1px solid rgba(242,66,11,0.32); background: radial-gradient(130% 130% at 0% 0%, rgba(255,120,50,0.20) 0%, rgba(20,10,5,0.96) 46%, rgba(10,5,2,0.98) 100%), #120502; padding: clamp(1.7rem, 3vw, 2.8rem); box-shadow: 0 40px 90px -28px rgba(0,0,0,0.82); transform: translateY(14px) scale(0.985); transition: transform .32s cubic-bezier(.16,1,.3,1); }
  .cond-modal.is-open .cond-modal__panel { transform: none; }
  .cond-modal__close { position: absolute; top: 0.85rem; right: 0.95rem; width: 2.2rem; height: 2.2rem; border-radius: 50%; border: 1px solid rgba(255,255,255,0.18); background: rgba(255,255,255,0.06); color: #fff; font-size: 1.35rem; line-height: 1; cursor: pointer; transition: background .2s ease, border-color .2s ease; }
  .cond-modal__close:hover { background: rgba(242,66,11,0.26); border-color: rgba(242,66,11,0.5); }
  .cond-modal__eyebrow { margin: 0 0 0.45rem; font-family: var(--font-headline); font-weight: 400; font-size: 0.72rem; letter-spacing: 0.2em; text-transform: uppercase; color: #f2420b; }
  .cond-modal__title { margin: 0 0 1.15rem; font-family: var(--font-headline); font-weight: 500; font-size: clamp(1.5rem, 3vw, 2.1rem); line-height: 1.05; color: #fff; }
  .cond-modal :global(.cond-who) { margin: 0 0 1.35rem; font-family: var(--font-body); font-weight: 300; font-size: 0.98rem; line-height: 1.6; color: rgba(255,255,255,0.7); }
  .cond-modal :global(.cond-list) { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.9rem; }
  .cond-modal :global(.cond-list li) { position: relative; padding-left: 1.7rem; font-family: var(--font-body); font-weight: 300; font-size: 0.95rem; line-height: 1.55; color: rgba(255,255,255,0.82); }
  .cond-modal :global(.cond-list li::before) { content: ''; position: absolute; left: 0; top: 0.5em; width: 7px; height: 7px; border-radius: 50%; background: #f2420b; box-shadow: 0 0 0 3px rgba(242,66,11,0.16); }
  .cond-modal__foot { margin: 1.65rem 0 0; padding-top: 1.2rem; border-top: 1px solid rgba(255,255,255,0.1); font-family: var(--font-body); font-weight: 300; font-size: 0.82rem; line-height: 1.5; color: rgba(255,255,255,0.5); }
  @media (max-width: 600px) { .cond-modal__panel { border-radius: 18px; } }
  @media (max-width: 700px) { .ind-grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 480px) { .ind-grid { grid-template-columns: 1fr; } }

  /* ===== ROWS ===== */
  .pr-rows { display: flex; flex-direction: column; gap: 0.7rem; }
  .pr-row { display: flex; gap: 1.4rem; align-items: flex-start; padding: 1.3rem 1.5rem; border-radius: 18px; border: 1px solid rgba(255,255,255,0.08); background: rgba(255,255,255,0.02); transition: border-color .3s ease, background .3s ease; }
  .pr-row:hover { border-color: rgba(242,66,11,0.3); background: rgba(242,66,11,0.04); }
  .pr-row__num { flex: 0 0 auto; font-family: var(--font-headline); font-weight: 400; font-size: 1.3rem; color: #f2420b; line-height: 1.4; min-width: 2.2rem; }
  .pr-row__title { font-family: var(--font-headline); font-weight: 400; font-size: 1.1rem; color: #fff; margin: 0 0 0.4rem; text-transform: none; }
  .pr-row__body { font-family: 'Inter', sans-serif; font-weight: 300; font-size: 0.96rem; line-height: 1.6; color: rgba(255,255,255,0.62); margin: 0; }

  /* ===== ROADMAP — timeline (line lửa + node số), bê từ trang J-1, chữ theo chuẩn không-đậm của 407 ===== */
  .rm-head { margin-bottom: clamp(3.5rem, 6vw, 6rem); }
  .rm-desc { margin: clamp(1rem, 1.6vw, 1.6rem) 0 0; max-width: 42rem; font-family: var(--font-body); font-weight: 300; font-size: clamp(1rem, 1.1vw, 1.15rem); color: rgba(255,255,255,0.6); line-height: 1.55; }
  .rm-card { position: relative; overflow: hidden; border-radius: clamp(24px, 2.6vw, 40px); border: 1px solid rgba(255,255,255,0.08); background: linear-gradient(180deg, rgba(255,255,255,0.028) 0%, rgba(255,255,255,0.008) 60%, rgba(255,255,255,0.004) 100%); padding: clamp(2.75rem, 5vw, 5rem) clamp(2rem, 4.5vw, 4.5rem); }
  .rm-timeline { --node: clamp(46px, 4.6vw, 56px); position: relative; display: flex; flex-direction: column; gap: clamp(2rem, 3.5vw, 3.2rem); }
  .rm-timeline::before { content: ''; position: absolute; left: 50%; top: calc(var(--node) / 2); bottom: calc(var(--node) / 2); width: 2px; transform: translateX(-1px); background: linear-gradient(to bottom, rgba(255,92,38,0.75) 0%, rgba(242,66,11,0.4) 55%, rgba(242,66,11,0.10) 100%); }
  .rm-step { position: relative; display: grid; grid-template-columns: 1fr var(--node) 1fr; column-gap: clamp(1.5rem, 3vw, 3rem); align-items: center; }
  .rm-marker { grid-column: 2; display: flex; justify-content: center; position: relative; z-index: 1; }
  .rm-node { width: var(--node); height: var(--node); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-family: var(--font-headline); font-weight: 400; font-size: clamp(0.92rem, 1vw, 1.08rem); color: #fff; background: radial-gradient(circle at 50% 32%, rgba(242,66,11,0.5) 0%, rgba(22,9,4,0.96) 78%); border: 1px solid rgba(255,120,60,0.55); box-shadow: 0 0 0 5px rgba(242,66,11,0.05), 0 0 26px rgba(242,66,11,0.22); transition: transform 0.35s ease, box-shadow 0.35s ease, border-color 0.35s ease; }
  .rm-step:hover .rm-node { transform: scale(1.07); border-color: rgba(255,140,80,0.85); box-shadow: 0 0 0 6px rgba(242,66,11,0.09), 0 0 36px rgba(242,66,11,0.34); }
  .rm-title { margin: 0 0 0.45rem; font-family: var(--font-headline); font-weight: 400; font-size: clamp(1.12rem, 1.35vw, 1.4rem); color: #fff; line-height: 1.15; text-transform: none; }
  .rm-body { margin: 0; font-family: var(--font-body); font-weight: 300; font-size: 0.95rem; color: rgba(255,255,255,0.6); line-height: 1.55; }
  .rm-step:nth-child(odd) .rm-content { grid-column: 1; text-align: right; }
  .rm-step:nth-child(odd) .rm-body { margin-left: auto; max-width: 27rem; }
  .rm-step:nth-child(even) .rm-content { grid-column: 3; text-align: left; }
  .rm-step:nth-child(even) .rm-body { margin-right: auto; max-width: 27rem; }
  .rm-note { margin: clamp(2.5rem, 4vw, 3.75rem) auto 0; padding-top: clamp(1.5rem, 2.5vw, 2rem); border-top: 1px solid rgba(255,255,255,0.08); max-width: 52rem; text-align: center; font-family: var(--font-body); font-weight: 300; font-size: 0.95rem; color: rgba(255,255,255,0.55); line-height: 1.6; }
  .rm-note strong { color: #ff7a52; font-weight: 400; }
  @media (max-width: 760px) {
    .rm-timeline::before { left: calc(var(--node) / 2); }
    .rm-step { grid-template-columns: var(--node) 1fr; column-gap: clamp(1.1rem, 3vw, 1.6rem); align-items: start; }
    .rm-marker { grid-column: 1; }
    .rm-step .rm-content { grid-column: 2 !important; text-align: left !important; }
    .rm-step .rm-body { margin: 0 !important; max-width: none !important; }
  }

  /* ===== PILLS ===== */
  .pr-pills { display: flex; flex-wrap: wrap; gap: 0.7rem; }
  .pr-pill { font-family: var(--font-headline); font-weight: 400; font-size: 0.9rem; color: #fff; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.16); border-radius: 999px; padding: 0.6rem 1.2rem; }

  /* ===== CTA ===== */
  .pr-cta-sec { padding-block: clamp(3rem, 6vw, 6rem) clamp(4rem, 8vw, 8rem); }
  .pr-cta { text-align: center; border-radius: 28px; padding: clamp(2.6rem, 5vw, 4rem) clamp(1.5rem, 4vw, 3rem); background: linear-gradient(135deg, #f2420b, #c2380a); box-shadow: 0 28px 66px -24px rgba(242,66,11,0.6); }
  .pr-cta__title { font-family: var(--font-headline); font-weight: 400; font-size: clamp(1.7rem, 3vw, 2.4rem); color: #fff; margin: 0 0 0.8rem; }
  .pr-cta__sub { font-family: 'Inter', sans-serif; font-weight: 300; font-size: 1.05rem; line-height: 1.6; color: rgba(255,255,255,0.92); margin: 0 auto 1.8rem; max-width: 52ch; }

  /* ===== ALL PARTNERS — marquee logo đối tác (bê từ J-1) ===== */
  .allp-sec { text-align: center; overflow: clip; }
  .allp-eyebrow { font-family: var(--font-headline); font-weight: 400; font-size: 0.82rem; letter-spacing: 0.2em; text-transform: uppercase; color: #f2420b; margin: 0 auto clamp(1rem, 1.6vw, 1.4rem); }
  .allp-desc { margin: 0 auto clamp(2.75rem, 4.5vw, 4rem); max-width: 44rem; font-family: var(--font-body); font-weight: 300; font-size: clamp(1rem, 1.1vw, 1.15rem); color: rgba(255,255,255,0.6); line-height: 1.55; }
  .marquee-wrapper { width: 100%; overflow: hidden; position: relative; display: flex; flex-direction: column; gap: clamp(2.5rem, 4vw, 4.5rem); }
  .marquee-wrapper::before, .marquee-wrapper::after { content: ""; position: absolute; top: 0; width: 12%; height: 100%; z-index: 2; pointer-events: none; -webkit-backdrop-filter: blur(8px); backdrop-filter: blur(8px); }
  .marquee-wrapper::before { left: 0; -webkit-mask-image: linear-gradient(to right, black 0%, transparent 100%); mask-image: linear-gradient(to right, black 0%, transparent 100%); }
  .marquee-wrapper::after { right: 0; -webkit-mask-image: linear-gradient(to left, black 0%, transparent 100%); mask-image: linear-gradient(to left, black 0%, transparent 100%); }
  .marquee-track { display: flex; width: max-content; animation: marqueeScroll 45s linear infinite; }
  .marquee-track--reverse { animation-direction: reverse; }
  .marquee-content { display: flex; align-items: center; gap: clamp(3.5rem, 6vw, 7rem); padding-inline: clamp(1.75rem, 3vw, 3.5rem); }
  .partner-logo { display: flex; align-items: center; justify-content: center; user-select: none; }
  .partner-logo img { height: clamp(54px, 6vw, 78px); width: auto; object-fit: contain; image-rendering: -webkit-optimize-contrast; transform: translateZ(0); backface-visibility: hidden; will-change: transform, filter; filter: brightness(0) invert(1) opacity(0.58); transition: filter 0.3s ease, transform 0.3s ease; }
  .partner-logo img:hover { filter: brightness(0) invert(1) opacity(1); transform: scale(1.05) translateZ(0); }
  @keyframes marqueeScroll { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }
  @media (prefers-reduced-motion: reduce) { .marquee-track { animation: none; } }

  /* ===== SPONSOR — hàng logo bảo trợ (mono trắng như J-1) ===== */
  .spon-sec { text-align: center; padding-top: clamp(4.25rem, 7vw, 6rem); }
  .spon-eyebrow { font-family: var(--font-headline); font-weight: 400; font-size: 0.82rem; letter-spacing: 0.2em; text-transform: uppercase; color: #f2420b; margin: 0 auto clamp(3.75rem, 6vw, 5.25rem); }
  .spon-row { display: flex; flex-wrap: wrap; align-items: center; justify-content: center; gap: clamp(3rem, 6.5vw, 7rem); }
  .spon-logo img { height: clamp(128px, 15vw, 172px); width: auto; object-fit: contain; filter: brightness(0) invert(1); transition: transform 0.3s ease; }
  .spon-logo img:hover { transform: scale(1.04); }
  /* Số liệu năng lực Australian Internships (hàng stat cam, label English) */
  .spon-stats { display: flex; flex-wrap: wrap; justify-content: center; gap: clamp(1.8rem, 4vw, 3.2rem) clamp(2rem, 5vw, 4.5rem); margin: clamp(3rem, 5.5vw, 4.75rem) auto 0; max-width: 66rem; }
  .spon-stat { display: flex; flex-direction: column; align-items: center; gap: 0.45rem; }
  .spon-stat__num { font-family: 'Inter', sans-serif; font-weight: 400; font-size: clamp(2.1rem, 3.4vw, 3.25rem); line-height: 1; color: #f2420b; letter-spacing: -0.02em; }
  .spon-stat__label { font-family: var(--font-headline); font-weight: 400; font-size: clamp(0.62rem, 0.85vw, 0.78rem); letter-spacing: 0.08em; text-transform: uppercase; color: rgba(255,255,255,0.7); max-width: 11rem; line-height: 1.32; }
  .spon-note { margin: clamp(3rem, 5vw, 4.25rem) auto 0; max-width: 40rem; font-family: var(--font-body); font-weight: 300; font-size: 0.98rem; color: rgba(255,255,255,0.55); line-height: 1.6; }
  .spon-note strong { color: #fff; font-weight: 400; }
  @media (max-width: 600px) {
    .spon-stats { gap: 2rem 1.6rem; }
    .spon-stat { flex: 0 1 40%; }
    .spon-stat__label { font-size: 0.6rem; }
  }

  /* ===== CASE STUDIES — bê từ Global Internship (bản DARK FIRE; card lửa đã dark sẵn ở base) ===== */
  .case-studies-section { position: relative; background: transparent; padding: var(--sec-pad) 0; z-index: 10; }
  /* Case studies căn SÁT 2 mép hơn các section khác (chip + card chính rộng gần kín màn) */
  .case-studies-section .pr-wrap { width: calc(100% - 2rem); max-width: 140rem; }
  /* BASE glass-pill (407 không có ở hero nên phải khai báo ở đây) — card kính + chữ letter-spacing:normal (fix chữ chồng do kế thừa -13px từ cs-line-1) */
  .cs-glass-pill {
    position: relative; z-index: 20; align-self: center; transform: translate(-1.8rem, 2.2rem);
    display: inline-flex; flex-direction: column; flex-shrink: 0; gap: 0.5rem;
    width: 16rem; min-height: 6.5rem; justify-content: center; text-align: left;
    padding: 1rem 1.2rem; border-radius: 20px;
    background: rgba(255, 255, 255, 0.045);
    -webkit-backdrop-filter: blur(14px); backdrop-filter: blur(14px);
    border: 1px solid rgba(255, 255, 255, 0.12);
    box-shadow:
      0 34px 50px -12px rgba(0, 0, 0, 0.80),
      0 16px 28px -10px rgba(0, 0, 0, 0.58),
      0 0 40px rgba(242, 66, 11, 0.12),
      inset 0 1px 1px rgba(255, 255, 255, 0.12);
  }
  .cs-glass-title { font-family: var(--font-headline); font-size: clamp(1.1rem, 1.4vw, 1.4rem); font-weight: 400; color: #ffffff; line-height: 1.1; letter-spacing: normal; white-space: nowrap; }
  .cs-glass-sub { font-family: 'Inter', sans-serif; font-size: 11px; font-weight: 400; color: var(--ink-soft); line-height: 1.45; letter-spacing: normal; white-space: normal; margin: 0; }
  /* Header line tweaks — SCOPE trong section để KHÔNG đụng hero (hero cũng dùng .cs-line-2 / .cs-glass-pill) */
  .case-studies-section .cs-header { margin-bottom: clamp(3rem, 5vw, 5rem); }
  .case-studies-section .cs-line-2, .case-studies-section .cs-line-3 {
