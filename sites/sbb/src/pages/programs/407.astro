  <!-- ===== ABOUT — card kính + glow đáy (kiểu ABOUT trang J-1) ===== -->
  <section class="pr-sec about-sec" id="about">
    <div class="pr-wrap">
      <div class="about-card">
        <div class="about-card__inner">
          <div class="cs-header about-title">
            <div class="cs-line cs-line-1"><span class="cs-text-white">ABOUT</span></div>
            <div class="cs-line cs-line-1 cs-line-2"><span class="cs-text-white">VISA 407</span></div>
          </div>
          <p class="about-body">Visa 407 là diện Training của đường Úc: bạn sang Úc để học nghề và làm việc thực tế có giám sát tại doanh nghiệp tiếp nhận, không phải du học thuần tuý. Trọng tâm là Aged Care, Child Care và Hospitality, triển khai cùng đối tác Australian Internships.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== SPONSOR — Australian Internships (1 đối tác triển khai) ===== -->
  <section class="pr-sec spon-sec">
    <div class="pr-wrap">
      <p class="spon-eyebrow">Official Sponsor</p>
      <div class="spon-row">
        <div class="spon-logo"><img src="/images/partners/australian-internships.png" alt="Australian Internships" /></div>
      </div>
      <div class="spon-stats">
        <div class="spon-stat"><span class="spon-stat__num">16,531</span><span class="spon-stat__label">Internship programs arranged</span></div>
        <div class="spon-stat"><span class="spon-stat__num">90+</span><span class="spon-stat__label">Nationalities</span></div>
        <div class="spon-stat"><span class="spon-stat__num">1,308</span><span class="spon-stat__label">Active candidates</span></div>
        <div class="spon-stat"><span class="spon-stat__num">12,000+</span><span class="spon-stat__label">Active host organisations</span></div>
        <div class="spon-stat"><span class="spon-stat__num">24</span><span class="spon-stat__label">Australian cities</span></div>
      </div>
      <p class="spon-note">SBB là <strong>đại diện độc quyền tại Việt Nam</strong> của Australian Internships, tổ chức đào tạo và tiếp nhận thực tập uy tín hàng đầu nước Úc.</p>
    </div>
  </section>

