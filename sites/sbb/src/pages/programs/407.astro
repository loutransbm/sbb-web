---
// Trang 407 — Đường Úc. Hệ bespoke dark-fire (đồng bộ hub/trang chủ).
import PageLayout from '@ui/layouts/PageLayout.astro';

const stats = [
  { num: '407', label: 'Loại visa (Training)' },
  { num: 'ÚC', label: 'Điểm đến' },
  { num: '03', label: 'Mảng ngành trọng tâm' },
];

const fields = [
  { num: '01', tag: 'Aged Care', title: 'Chăm sóc người cao tuổi', body: 'Một trong những mảng nhu cầu lớn và ổn định nhất tại Úc. Hợp với người muốn theo nghề chăm sóc bài bản, có tâm và có nghề.' },
  { num: '02', tag: 'Child Care', title: 'Chăm sóc & giáo dục trẻ', body: 'Môi trường làm việc đề cao chuẩn mực và sự tận tâm. Phù hợp nếu bạn yêu thích công việc với trẻ nhỏ và muốn học cách làm chuyên nghiệp.' },
  { num: '03', tag: 'Hospitality', title: 'Du lịch & Khách sạn', body: 'Mảng dịch vụ rộng, dễ tiếp cận với người có nền tảng ngoại ngữ và tác phong tốt, cũng là thế mạnh quen thuộc của hệ sinh thái SBB.' },
];

const eligibility = [
  'Nhắm đúng một trong các mảng Aged Care, Child Care hoặc Hospitality.',
  'Có nền tảng ngoại ngữ đủ dùng cho công việc và phỏng vấn.',
  'Tác phong nghiêm túc, sẵn sàng làm thật và học thật ở môi trường quốc tế.',
  'Hồ sơ rõ ràng và trung thực, yếu tố quyết định khi đối tác xét duyệt.',
];

const steps = [
  { num: '01', title: 'Đánh giá ban đầu', body: 'Nói chuyện thẳng thắn với SBB để xem hồ sơ của bạn có thật sự hợp với đường Úc qua visa 407 hay không. Không hợp, SBB nói thẳng.' },
  { num: '02', title: 'Chuẩn bị nền tảng', body: 'Xây dựng tư duy toàn cầu, tác phong chuyên nghiệp và ngoại ngữ trước khi bước vào quá trình xét duyệt và kết nối vị trí.' },
  { num: '03', title: 'Kết nối qua đối tác', body: 'Hồ sơ được làm việc cùng đối tác Australian Internships để tìm vị trí tiếp nhận phù hợp với ngành bạn nhắm tới.' },
  { num: '04', title: 'Xét duyệt & khởi hành', body: 'Hoàn tất hồ sơ bảo trợ, xin visa 407 và chuẩn bị sang Úc bắt đầu hành trình làm việc thực tế.' },
];

const truths = [
  { title: 'Đào tạo, không phải lao động giá rẻ', body: 'Visa 407 là diện training: bạn sang Úc để học nghề và nâng năng lực thực tế, không phải để làm thuê giá rẻ. Điều này định hình cả cách SBB chuẩn bị hồ sơ cho bạn.' },
  { title: 'Không phải mũi nhọn hiện tại', body: 'Mũi nhọn của SBB vẫn là đường Mỹ qua J-1. Đường Úc dành cho người nhắm đúng các ngành phù hợp, nên hãy hỏi để biết bạn có thật sự hợp hay không.' },
  { title: 'Chính sách có thể thay đổi', body: 'Quy định visa và nhập cảnh của Úc có thể biến động theo thời điểm. SBB đồng hành và xử lý linh hoạt, nhưng không cam kết thay cho quyết định của cơ quan chức năng.' },
];
---

<PageLayout
  title="Chương trình 407 — Đường Úc"
  description="Đường Úc qua visa 407 cho Aged Care, Child Care và Hospitality. Đào tạo nghề thực tế cùng đối tác Australian Internships."
  site="sbb"
  currentPath="/programs/407"
>
  <!-- ===== HERO ===== -->
  <section class="pr-hero">
    <div class="pr-hero__beam" aria-hidden="true"></div>
    <div class="pr-hero__wrap">
      <span class="pr-eyebrow">Chương trình · Đường Úc</span>
      <div class="cs-header">
        <div class="cs-line cs-line-1"><span class="cs-text-white">AUSTRALIA 407</span></div>
      </div>
      <p class="pr-lead">Ngoài đường Mỹ qua J-1, SBB có đường Úc qua visa 407 cho một số mảng nghề như Aged Care, Child Care và Hospitality. Đây không phải mũi nhọn hiện tại, nhưng nếu bạn đang nhắm đúng các ngành này, hãy hỏi SBB để xem có hợp không.</p>
      <div class="pr-actions">
        <a href="/apply" class="pr-btn pr-btn--primary">Đăng ký tư vấn</a>
        <a href="#fields" class="pr-btn pr-btn--ghost">Xem mảng ngành</a>
      </div>
    </div>
  </section>

  <!-- ===== OVERVIEW + STATS ===== -->
  <section class="pr-sec">
    <div class="pr-wrap">
      <div class="pr-split">
        <div>
          <span class="pr-eyebrow">Tổng quan</span>
          <p class="pr-statement">Một con đường nghề <span class="pr-accent">nghiêm túc</span> tới Úc.</p>
        </div>
        <ul class="pr-checks">
          <li>Visa 407 là diện training: sang Úc để học nghề và làm thật, không phải du học thuần tuý.</li>
          <li>Tập trung vào các mảng nhu cầu cao và ổn định tại Úc.</li>
          <li>Triển khai cùng đối tác đào tạo quốc tế Australian Internships.</li>
          <li>Cùng tinh thần với hệ SBB: chuẩn bị để bạn được tin và trọng dụng, không chỉ “được đi”.</li>
        </ul>
      </div>
      <div class="pr-stats">
        {stats.map((s) => (
          <div class="pr-stat"><span class="pr-stat__num">{s.num}</span><span class="pr-stat__label">{s.label}</span></div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== FIELDS ===== -->
  <section class="pr-sec pr-sec--beam" id="fields">
    <div class="pr-beam pr-beam--right" aria-hidden="true"></div>
    <div class="pr-wrap">
      <div class="pr-head">
        <span class="pr-eyebrow">Mảng ngành</span>
        <h2 class="pr-h2">Bạn sẽ <span class="pr-accent">làm gì</span></h2>
        <p class="pr-desc">Visa 407 mở đường vào những mảng nghề mà nước Úc đang thật sự cần người. Đây là ba hướng SBB tập trung.</p>
      </div>
      <div class="pr-grid pr-grid--3">
        {fields.map((f) => (
          <article class="pr-card">
            <span class="pr-card__num">{f.num}</span>
            <span class="pr-card__tag">{f.tag}</span>
            <h3 class="pr-card__title">{f.title}</h3>
            <p class="pr-card__body">{f.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== ELIGIBILITY ===== -->
  <section class="pr-sec">
    <div class="pr-wrap">
      <div class="pr-split">
        <div>
          <span class="pr-eyebrow">Điều kiện</span>
          <h2 class="pr-h2">Bạn có <span class="pr-accent">hợp</span> không</h2>
          <p class="pr-desc">Đường Úc không hợp với tất cả mọi người. Dưới đây là những điều nên có trước khi bạn nghĩ tới visa 407.</p>
        </div>
        <ul class="pr-checks">
          {eligibility.map((e) => <li>{e}</li>)}
        </ul>
      </div>
    </div>
  </section>

  <!-- ===== STEPS ===== -->
  <section class="pr-sec pr-sec--beam">
    <div class="pr-beam pr-beam--left" aria-hidden="true"></div>
    <div class="pr-wrap">
      <div class="pr-head">
        <span class="pr-eyebrow">Lộ trình</span>
        <h2 class="pr-h2">Cách <span class="pr-accent">vận hành</span></h2>
        <p class="pr-desc">Bốn bước từ buổi nói chuyện đầu tiên đến lúc bạn đặt chân sang Úc, minh bạch ngay từ đầu.</p>
      </div>
      <div class="pr-rows">
        {steps.map((s) => (
          <article class="pr-row">
            <span class="pr-row__num">{s.num}</span>
            <div><h3 class="pr-row__title">{s.title}</h3><p class="pr-row__body">{s.body}</p></div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== REALITY + PARTNER ===== -->
  <section class="pr-sec">
    <div class="pr-wrap">
      <div class="pr-head">
        <span class="pr-eyebrow">Reality Check</span>
        <h2 class="pr-h2">Sự thật <span class="pr-accent">trước</span></h2>
        <p class="pr-desc">SBB chọn nói thật trước. Đây là những điều bạn nên biết trước khi đi đường Úc.</p>
      </div>
      <div class="pr-grid pr-grid--3">
        {truths.map((t) => (
          <article class="pr-card">
            <span class="pr-card__tag">Lưu ý</span>
            <h3 class="pr-card__title">{t.title}</h3>
            <p class="pr-card__body">{t.body}</p>
          </article>
        ))}
      </div>
      <div class="pr-pills" style="margin-top:1.8rem;">
        <span class="pr-pill">Đối tác triển khai · Australian Internships</span>
      </div>
    </div>
  </section>

  <!-- ===== CTA ===== -->
  <section class="pr-cta-sec">
    <div class="pr-wrap">
      <div class="pr-cta">
        <h2 class="pr-cta__title">ĐƯỜNG ÚC CÓ HỢP VỚI BẠN?</h2>
        <p class="pr-cta__sub">Đặt lịch nói chuyện để SBB đánh giá thẳng thắn xem visa 407 có phải con đường phù hợp với bạn, hoặc xem các chương trình khác.</p>
        <div class="pr-actions pr-actions--center">
          <a href="/apply" class="pr-btn pr-btn--onfire">Đăng ký tư vấn</a>
          <a href="/programs" class="pr-btn pr-btn--light">Xem chương trình khác</a>
        </div>
      </div>
    </div>
  </section>
</PageLayout>

<style>
  /* ===== WRAP đồng bộ nav ===== */
  .pr-wrap, .pr-hero__wrap { width: calc(100% - 4rem); max-width: 120rem; margin-inline: auto; position: relative; z-index: 2; }
  .pr-eyebrow { display: inline-block; font-family: var(--font-headline); font-weight: 700; font-size: 0.8rem; letter-spacing: 0.18em; text-transform: uppercase; color: #f2420b; margin-bottom: 1.4rem; }
  .pr-accent { color: #f2420b; }

  /* ===== HERO (cascade) ===== */
  .pr-hero { position: relative; overflow: clip; padding-top: clamp(7rem, 9vw, 11rem); padding-bottom: clamp(3rem, 6vw, 6rem); min-height: 78vh; display: flex; align-items: center; }
  .pr-hero__beam { position: absolute; top: -40px; left: 84%; transform: translateX(-50%); width: 1180px; height: 860px; pointer-events: none; z-index: 0;
    background: radial-gradient(ellipse 50% 50% at 50% 42%, rgba(255,112,60,0.60) 0%, rgba(248,82,26,0.46) 22%, rgba(242,66,11,0.30) 44%, rgba(242,66,11,0.12) 64%, transparent 84%); filter: blur(76px); }
  .cs-header { font-family: 'Inter', sans-serif; font-weight: 500; line-height: 0.95; letter-spacing: -0.045em; }
  .cs-line { display: flex; align-items: center; gap: 1.5rem; }
  .cs-line-1 { font-size: clamp(3rem, 10.4vw, 10.5rem); letter-spacing: -0.075em; line-height: 0.95; white-space: nowrap; position: relative; z-index: 10; }
  .cs-text-white { color: #ffffff; }

  .pr-lead { margin: clamp(1.6rem, 3vw, 2.6rem) 0 0; max-width: 60ch; font-family: 'Inter', sans-serif; font-weight: 300; font-size: clamp(1rem, 1.2vw, 1.15rem); line-height: 1.7; color: rgba(255,255,255,0.66); }
  .pr-actions { display: flex; flex-wrap: wrap; gap: 0.9rem; margin-top: clamp(1.6rem, 3vw, 2.4rem); }
  .pr-actions--center { justify-content: center; }
  .pr-btn { display: inline-flex; align-items: center; justify-content: center; font-family: var(--font-headline); font-weight: 700; font-size: 0.9rem; text-decoration: none; border-radius: 999px; padding: 0.85rem 1.7rem; transition: transform .25s ease, background .25s ease, box-shadow .25s ease, border-color .25s ease, color .25s ease; }
  .pr-btn--primary { background: #f2420b; color: #fff; box-shadow: 0 14px 30px -12px rgba(242,66,11,0.7); }
  .pr-btn--primary:hover { background: #ff5c26; transform: translateY(-2px); }
  .pr-btn--ghost { background: rgba(255,255,255,0.04); color: #fff; border: 1px solid rgba(255,255,255,0.2); }
  .pr-btn--ghost:hover { border-color: rgba(242,66,11,0.55); background: rgba(242,66,11,0.08); }
  .pr-btn--onfire { background: #fff; color: #c2380a; }
  .pr-btn--onfire:hover { transform: translateY(-2px); background: #fff5f1; }
  .pr-btn--light { background: transparent; color: #fff; border: 1px solid rgba(255,255,255,0.55); }
  .pr-btn--light:hover { background: rgba(255,255,255,0.12); }

  /* ===== SECTIONS ===== */
  .pr-sec { position: relative; overflow: clip; padding-block: clamp(3.5rem, 7vw, 7rem); }
  .pr-sec--beam { z-index: 1; }
  .pr-beam { position: absolute; top: -60px; width: 900px; height: 760px; pointer-events: none; z-index: 0; filter: blur(80px);
    background: radial-gradient(ellipse 50% 50% at 50% 42%, rgba(255,112,60,0.30) 0%, rgba(242,66,11,0.16) 40%, rgba(242,66,11,0.05) 66%, transparent 86%); }
  .pr-beam--right { left: 86%; transform: translateX(-50%); }
  .pr-beam--left { left: 14%; transform: translateX(-50%); }

  .pr-split { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(2rem, 4vw, 4rem); align-items: start; }
  .pr-statement { font-family: var(--font-headline); font-weight: 700; font-size: clamp(1.7rem, 3vw, 2.6rem); line-height: 1.15; color: #fff; margin: 0; letter-spacing: -0.01em; }
  .pr-checks { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.9rem; }
  .pr-checks li { position: relative; padding-left: 1.8rem; font-family: 'Inter', sans-serif; font-weight: 300; font-size: 1rem; line-height: 1.6; color: rgba(255,255,255,0.72); }
  .pr-checks li::before { content: ''; position: absolute; left: 0; top: 0.55em; width: 0.65rem; height: 0.65rem; border-radius: 999px; background: #f2420b; box-shadow: 0 0 0 4px rgba(242,66,11,0.18); }

  .pr-stats { display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 1.5rem; margin-top: clamp(2.5rem, 5vw, 4rem); padding-top: clamp(2rem, 4vw, 3rem); border-top: 1px solid rgba(255,255,255,0.12); }
  .pr-stat__num { display: block; font-family: var(--font-headline); font-weight: 700; font-size: clamp(2rem, 3.5vw, 3rem); color: #f2420b; line-height: 1; }
  .pr-stat__label { display: block; margin-top: 0.5rem; font-family: 'Inter', sans-serif; font-weight: 300; font-size: 0.86rem; color: rgba(255,255,255,0.6); }

  .pr-head { max-width: 60ch; margin-bottom: clamp(2.2rem, 4vw, 3.4rem); }
  .pr-h2 { font-family: var(--font-headline); font-weight: 700; font-size: clamp(2rem, 4vw, 3.4rem); line-height: 1.08; color: #fff; letter-spacing: -0.02em; margin: 0; text-transform: none; }
  .pr-desc { font-family: 'Inter', sans-serif; font-weight: 300; font-size: clamp(0.96rem, 1.1vw, 1.08rem); line-height: 1.65; color: rgba(255,255,255,0.6); margin: 0.9rem 0 0; max-width: 60ch; }

  /* ===== CARD KÍNH TRẮNG FROSTED ===== */
  .pr-grid { display: grid; gap: clamp(1.2rem, 2vw, 1.8rem); }
  .pr-grid--2 { grid-template-columns: repeat(2, 1fr); }
  .pr-grid--3 { grid-template-columns: repeat(3, 1fr); }
  .pr-card { position: relative; display: flex; flex-direction: column; background: #ffffff; border: 1px solid rgba(0,0,0,0.08); border-radius: 1.6rem; padding: clamp(1.6rem, 2.2vw, 2.3rem); box-shadow: 0 14px 40px -16px rgba(0,0,0,0.5); transition: transform .4s ease, box-shadow .4s ease, border-color .4s ease, background .4s ease; }
  .pr-card:hover { transform: translateY(-8px); background: #fff7f3; border-color: rgba(242,66,11,0.25); box-shadow: 0 26px 56px -22px rgba(0,0,0,0.55); }
  .pr-card__num { font-family: var(--font-headline); font-weight: 300; font-size: 1.5rem; color: #f2420b; letter-spacing: 0.02em; }
  .pr-card__tag { align-self: flex-start; font-family: 'Inter', sans-serif; font-weight: 600; font-size: 0.66rem; letter-spacing: 0.08em; text-transform: uppercase; color: #c2380a; background: rgba(242,66,11,0.1); border-radius: 999px; padding: 0.28rem 0.7rem; }
  .pr-card__title { font-family: var(--font-headline); font-weight: 700; font-size: clamp(1.2rem, 1.6vw, 1.5rem); color: #1a1a1a; margin: 0.8rem 0 0.7rem; letter-spacing: -0.01em; text-transform: none; }
  .pr-card__body { font-family: 'Inter', sans-serif; font-weight: 400; font-size: 0.96rem; line-height: 1.6; color: #5a5a5a; margin: 0; }
  .pr-card__detail { font-family: 'Inter', sans-serif; font-weight: 600; font-size: 0.95rem; line-height: 1.5; color: #c2380a; margin: 1rem 0 0; }

  /* ===== ROWS ===== */
  .pr-rows { display: flex; flex-direction: column; gap: 0.7rem; }
  .pr-row { display: flex; gap: 1.4rem; align-items: flex-start; padding: 1.3rem 1.5rem; border-radius: 18px; border: 1px solid rgba(255,255,255,0.08); background: rgba(255,255,255,0.02); transition: border-color .3s ease, background .3s ease; }
  .pr-row:hover { border-color: rgba(242,66,11,0.3); background: rgba(242,66,11,0.04); }
  .pr-row__num { flex: 0 0 auto; font-family: var(--font-headline); font-weight: 700; font-size: 1.3rem; color: #f2420b; line-height: 1.4; min-width: 2.2rem; }
  .pr-row__title { font-family: var(--font-headline); font-weight: 700; font-size: 1.1rem; color: #fff; margin: 0 0 0.4rem; text-transform: none; }
  .pr-row__body { font-family: 'Inter', sans-serif; font-weight: 300; font-size: 0.96rem; line-height: 1.6; color: rgba(255,255,255,0.62); margin: 0; }

  /* ===== PILLS ===== */
  .pr-pills { display: flex; flex-wrap: wrap; gap: 0.7rem; }
  .pr-pill { font-family: var(--font-headline); font-weight: 700; font-size: 0.9rem; color: #fff; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.16); border-radius: 999px; padding: 0.6rem 1.2rem; }

  /* ===== CTA ===== */
  .pr-cta-sec { padding-block: clamp(3rem, 6vw, 6rem) clamp(4rem, 8vw, 8rem); }
  .pr-cta { text-align: center; border-radius: 28px; padding: clamp(2.6rem, 5vw, 4rem) clamp(1.5rem, 4vw, 3rem); background: linear-gradient(135deg, #f2420b, #c2380a); box-shadow: 0 28px 66px -24px rgba(242,66,11,0.6); }
  .pr-cta__title { font-family: var(--font-headline); font-weight: 700; font-size: clamp(1.7rem, 3vw, 2.4rem); color: #fff; margin: 0 0 0.8rem; }
  .pr-cta__sub { font-family: 'Inter', sans-serif; font-weight: 300; font-size: 1.05rem; line-height: 1.6; color: rgba(255,255,255,0.92); margin: 0 auto 1.8rem; max-width: 52ch; }

  @media (max-width: 980px) {
    .cs-line { flex-wrap: wrap; gap: 0.5rem; }
    .cs-line-1 { font-size: clamp(3rem, 13vw, 5rem); white-space: normal; }
    .pr-split { grid-template-columns: 1fr; }
    .pr-grid--3 { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 600px) {
    .pr-grid--2, .pr-grid--3 { grid-template-columns: 1fr; }
  }
</style>
