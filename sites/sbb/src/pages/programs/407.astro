  /* ===== FAQ (bê thiết kế y hệt J-1; chữ theo chuẩn KHÔNG-đậm của 407) ===== */
  .faq-section { position: relative; padding: var(--sec-pad) 0; background: transparent; overflow: visible; }
  /* Glow nền FAQ: dời tâm XUỐNG (50% 270px) để đỉnh quầng KHÔNG nằm ngay mép trên — tránh tạo đường chia cắt với section Visa phía trên (mép trên fade về 0). */
  .faq-section::before { content: ''; position: absolute; inset: 0; z-index: 0; pointer-events: none; background: radial-gradient(ellipse 70% 340px at 50% 270px, rgba(242,66,11,0.11) 0%, rgba(242,66,11,0.045) 40%, transparent 72%); }
  .faq-container { position: relative; z-index: 1; }
  .faq-mega { font-family: 'Inter', sans-serif; font-weight: 500; font-size: clamp(8.5rem, 12vw, 11rem); line-height: 0.95; letter-spacing: -0.085em; text-transform: uppercase; color: #ffffff; margin: 0 0 clamp(3.5rem, 6.5vw, 6.25rem); }
  .faq-list { display: flex; flex-direction: column; gap: clamp(1.1rem, 1.6vw, 1.6rem); }
  .faq-item {
    position: relative; border: 1px solid rgba(242,66,11,0.35); border-radius: 40px; overflow: hidden;
    background: radial-gradient(150% 150% at 0% 100%, rgba(255,112,60,0.80) 0%, rgba(248,82,26,0.70) 25%, rgba(242,66,11,0.50) 50%, rgba(20,10,5,0.85) 80%, rgba(10,5,2,0.95) 100%);
    backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.05), 0 10px 30px -10px rgba(0,0,0,0.5);
    transition: background 0.3s ease, border-color 0.3s ease;
  }
  .faq-item:hover, .faq-item[open] {
    border-color: rgba(242,66,11,0.65);
    background: radial-gradient(150% 150% at 0% 100%, rgba(255,126,72,0.90) 0%, rgba(248,92,32,0.80) 25%, rgba(242,66,11,0.60) 50%, rgba(20,10,5,0.85) 80%, rgba(10,5,2,0.95) 100%);
  }
  .faq-q {
    display: flex; align-items: center; justify-content: space-between; gap: clamp(1.5rem, 3vw, 3rem);
    list-style: none; cursor: pointer; padding: clamp(2.9rem, 4.6vw, 4.25rem) clamp(2rem, 3.2vw, 3rem);
    font-family: var(--font-headline); font-weight: 500; font-size: clamp(1.15rem, 1.6vw, 1.7rem);
    text-transform: uppercase; letter-spacing: 0.01em; line-height: 1.2; color: #ffffff; transition: color 0.25s ease;
  }
  .faq-q::-webkit-details-marker { display: none; }
  .faq-icon { position: relative; flex: 0 0 42px; width: 42px; height: 42px; }
  .faq-icon::before, .faq-icon::after { content: ''; position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); background: rgba(255,120,50,0.8); border-radius: 2px; }
  .faq-icon::before { width: 24px; height: 1px; }
  .faq-icon::after { width: 1px; height: 24px; transition: transform 0.3s ease; }
  .faq-item[open] .faq-icon::after { transform: translate(-50%, -50%) scaleY(0); }
  .faq-a { padding: 0 clamp(2.5rem, 7vw, 7rem) clamp(2.2rem, 3.2vw, 2.9rem) clamp(2rem, 3.2vw, 3rem); max-width: none; animation: faqReveal 0.4s ease; }
  .faq-a p { margin: 0 0 1.05rem; max-width: none; font-weight: 300; color: rgba(255,255,255,0.80); line-height: 1.75; font-size: clamp(1.02rem, 1.2vw, 1.15rem); }
