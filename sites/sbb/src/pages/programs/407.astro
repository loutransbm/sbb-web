  /* ===== CASE STUDIES mobile (bê từ Global Internship — chỉ rule riêng case-studies) ===== */
  @media (max-width: 768px) {
    /* mobile: THIS IS WHAT ↔ REAL GROWTH sát lại (margin-top nhỏ); REAL GROWTH ↔ tabs CÁCH thêm */
    .cs-header-bottom { gap: 2.2rem !important; margin-top: 0.35rem !important; }

    /* PILL "REAL RESULTS" lên TRÊN tiêu đề + HẠ SÁT đỉnh chữ THIS IS WHAT */
    #case-studies .cs-line-1 {
      flex-direction: column !important;
      align-items: flex-start !important;
      font-size: clamp(3.5rem, 16.8vw, 4.55rem) !important;  /* THIS IS WHAT: RẤT TO, tràn 2 mép */
      line-height: 0.9 !important;
      letter-spacing: -0.097em !important;                   /* siết chữ thêm để chữ to vẫn vừa 1 dòng */
      white-space: nowrap !important;                        /* ép 1 dòng */
    }
    /* Pill lên TRÊN + ĐÈ đỉnh chữ + dịch phải */
    #case-studies .cs-glass-pill {
      order: -1 !important;
      margin: 0 0 -1.3rem 1.6rem !important;   /* đè nhẹ + DỊCH PHẢI vào trong 1 chút */
      width: 34vw !important;                   /* DÀI tới qua chữ I của IS */
      min-width: 138px !important;
      max-width: 168px !important;
      padding: 0.7rem 0.95rem !important;        /* đệm thoáng kiểu Omni */
      gap: 0.3rem !important;
      position: relative; z-index: 5;
    }
    /* Chữ trong pill CÂN ĐỐI như Omni: title TO + đậm + trắng (1 dòng), sub xám đọc được */
    #case-studies .cs-glass-title {
      font-size: 0.92rem !important;
      font-weight: 400 !important;
      letter-spacing: 0.015em !important;
      color: #ffffff !important;
      white-space: normal !important;
      line-height: 1.05 !important;
    }
    #case-studies .cs-glass-sub {
      font-size: 0.7rem !important;
      line-height: 1.35 !important;
      letter-spacing: normal !important;
      color: rgba(255, 255, 255, 0.5) !important;
      max-width: 100% !important;
    }
    /* Dòng 2 (REAL GROWTH/LOOKS LIKE): TO nhưng nhỏ hơn dòng 1 */
    #case-studies .cs-line-2,
    #case-studies .cs-line-3 {
      font-size: clamp(2.4rem, 11.4vw, 3.2rem) !important;
      line-height: 0.96 !important;
      letter-spacing: -0.045em !important;
    }
    /* không cho dòng tiêu đề tràn mép -> tự xuống dòng thay vì bị cắt */
    #case-studies .cs-line { max-width: 100% !important; }

    /* TAB = 3 chip bằng nhau, vừa hàng ngang (cân đối) */
    .cs-tabs {
      flex-wrap: nowrap !important;
      gap: 0.4rem !important;
      width: 100% !important;
    }
    .cs-tab {
      flex: 1 !important;
      text-align: center !important;
      white-space: nowrap !important;
      padding: 0.65rem 0.3rem !important;
      font-size: 0.72rem !important;
      min-width: 0 !important;
      letter-spacing: 0.06em !important;
    }

    /* CARD theo bố cục Omni: 1 cột — TÊN to · 2 khối · ẢNH · 3 SỐ ngang ở ĐÁY */
    .cs-cards-wrapper { min-height: 0 !important; border-radius: 26px !important; margin-top: 1.4rem !important; }
    .cs-card { padding: 1.6rem !important; gap: 1.25rem !important; border-radius: 26px !important; }
    #case-studies .cs-card-title { font-size: clamp(2.9rem, 14vw, 4rem) !important; }
    .cs-card-role { font-size: 0.72rem !important; margin-top: 0.5rem !important; }
    .cs-card-left { gap: 0.9rem !important; }
    .cs-content-block { gap: 0.45rem !important; }
    .cs-content-block + .cs-content-block { padding-top: 0.8rem !important; }
    .cs-block-title { font-size: 1.02rem !important; }
    .cs-block-desc { font-size: 0.83rem !important; line-height: 1.45 !important; }
    /* Ảnh học viên đứng ĐÚNG VỊ TRÍ biểu đồ của Omni (giữ ảnh, không dùng chart) */
    .cs-card-right { gap: 1.1rem !important; }
    .cs-photo { height: clamp(220px, 35vh, 320px) !important; margin-bottom: 0 !important; border-radius: 16px !important; }
    /* 3 SỐ NẰM NGANG, to ở ĐÁY, CĂN GIỮA trang */
    .cs-stats-row { flex-direction: row !important; justify-content: center !important; gap: 1.6rem !important; padding-top: 1.3rem !important; }
    .cs-stat-item { flex: 0 1 auto !important; min-width: 0 !important; gap: 0.25rem !important; text-align: center !important; align-items: center !important; }
    .cs-stats-row--meta .cs-stat-value { font-size: clamp(1.1rem, 4.8vw, 1.45rem) !important; font-weight: 400 !important; line-height: 1.05 !important; }
    .cs-stat-label { font-size: 0.55rem !important; letter-spacing: 0.03em !important; line-height: 1.3 !important; }
  }

  /* ===== ABOUT — card kính + glow đáy (bê y hệt ABOUT trang J-1) ===== */
  .about-sec { position: relative; padding-bottom: clamp(1.75rem, 3vw, 2.75rem); }
  .about-card { position: relative; z-index: 1; display: flex; flex-direction: column; justify-content: center; border-radius: clamp(28px, 3vw, 46px); border: 1px solid rgba(255,255,255,0.08); background: linear-gradient(180deg, rgba(255,255,255,0.035) 0%, rgba(255,255,255,0.012) 42%, rgba(255,255,255,0.004) 100%); padding: clamp(3rem, 6vw, 6.5rem) clamp(2rem, 5vw, 5.5rem); min-height: clamp(520px, 58vh, 640px); overflow: hidden; }
  .about-card::after { content: ''; position: absolute; left: 50%; bottom: 0; transform: translateX(-50%); width: min(74%, 58rem); height: clamp(190px, 25vw, 300px); z-index: 0; pointer-events: none; background: radial-gradient(60% 100% at 50% 100%, rgba(255,92,38,0.32) 0%, rgba(242,66,11,0.15) 36%, rgba(242,66,11,0.05) 62%, transparent 78%); filter: blur(14px); }
  .about-card__inner { position: relative; z-index: 1; display: flex; justify-content: space-between; align-items: flex-start; gap: clamp(2rem, 6vw, 6rem); flex-wrap: wrap; }
