---
// Career Training Program — TRANG TỔNG QUAN (umbrella). Chỉ giới thiệu + liệt kê hạng mục.
// Mỗi hạng mục bấm vào NHẢY SANG TRANG RIÊNG (J-1 Trainee, Visa 407).
// Hệ dark-fire đồng bộ hub/trang chủ. KHÔNG card trắng.
import PageLayout from '@ui/layouts/PageLayout.astro';

const items = [
  { state: 'open', tag: 'Hoa Kỳ · Đang mở', title: 'J-1 Trainee', body: 'Diện tu nghiệp của visa J-1 dành cho người đã có bằng cấp và kinh nghiệm. Tu nghiệp tối đa 18 tháng tại doanh nghiệp Mỹ.', href: '/programs/j1-trainee' },
  { state: 'open', tag: 'Úc · Đang mở', title: 'Visa 407', body: 'Đường Úc qua visa 407 cho các mảng Aged Care, Child Care và Hospitality. Triển khai cùng đối tác Australian Internships.', href: '/programs/407' },
  { state: 'soon', tag: 'Đang phát triển', title: 'Điểm đến mới', body: 'SBB tiếp tục mở rộng các chương trình đào tạo nghề quốc tế sang nhiều quốc gia khác. Thông tin sẽ được công bố khi sẵn sàng.' },
];
---

<PageLayout
  title="Career Training — Đào tạo nghề Quốc tế"
  description="Career Training của SBB: đào tạo nghề quốc tế có trả lương cho người đã có nền tảng. Hai hạng mục đang mở: J-1 Trainee (Mỹ) và Visa 407 (Úc)."
  site="sbb"
  currentPath="/programs/career-training"
>
  <!-- ===== HERO ===== -->
  <section class="pr-hero">
    <div class="pr-hero__beam" aria-hidden="true"></div>
    <div class="pr-hero__wrap">
      <div class="cs-header">
        <div class="cs-line cs-line-1"><span class="cs-text-white">CAREER TRAINING</span></div>
      </div>
      <p class="pr-lead">Đào tạo nghề quốc tế có trả lương, dành cho người đã có nền tảng và muốn nâng tay nghề ở môi trường toàn cầu. Hiện có hai hạng mục: J-1 Trainee tại Mỹ và visa 407 tại Úc.</p>
    </div>
  </section>

  <!-- ===== TỔNG QUAN ===== -->
  <section class="pr-sec">
    <div class="pr-wrap">
      <div class="pr-split">
        <div>
          <span class="pr-eyebrow">Overview</span>
          <p class="pr-statement">Đào tạo nghề <span class="pr-accent">chuyên sâu</span> ở môi trường quốc tế.</p>
        </div>
        <ul class="pr-checks">
          <li>Diện training: sang để học nghề và làm thật, không phải du học thuần tuý.</li>
          <li>Dành cho người đã có bằng cấp hoặc kinh nghiệm, muốn lên tay nghề bài bản.</li>
          <li>Được trả lương trong thời gian tu nghiệp, theo kế hoạch đào tạo rõ ràng.</li>
          <li>Có sponsor tại Mỹ và đối tác Australian Internships tại Úc đồng hành.</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- ===== HẠNG MỤC (mỗi cái 1 trang riêng) ===== -->
  <section class="pr-sec pr-sec--beam" id="items">
    <div class="pr-beam pr-beam--right" aria-hidden="true"></div>
    <div class="pr-wrap">
      <div class="pr-head">
        <span class="pr-eyebrow">Tracks</span>
        <div class="cs-header pr-sec-head">
          <div class="cs-line cs-line-1"><span class="cs-text-white">CHOOSE</span></div>
          <div class="cs-line cs-line-1"><span class="cs-text-white">A&nbsp;PATH</span></div>
        </div>
        <p class="pr-desc">Hai con đường đang mở, hai điểm đến. Bấm vào để xem chi tiết từng hạng mục. Các điểm đến mới đang được hoàn thiện.</p>
      </div>
      <div class="pr-grid pr-grid--3">
        {items.map((t) => (
          t.state === 'open' ? (
            <a href={t.href} class="pr-card pr-card--flagship">
              <span class="pr-card__tag">{t.tag}</span>
              <h3 class="pr-card__title">{t.title}</h3>
              <p class="pr-card__body">{t.body}</p>
              <span class="pr-card__more">Xem chi tiết</span>
            </a>
          ) : (
            <div class="pr-card pr-card--soon" aria-disabled="true">
              <span class="pr-card__tag pr-card__tag--soon">{t.tag}</span>
              <h3 class="pr-card__title">{t.title}</h3>
              <p class="pr-card__body">{t.body}</p>
              <span class="pr-card__more pr-card__more--soon">Sắp ra mắt</span>
            </div>
          )
        ))}
      </div>
    </div>
  </section>

  <!-- ===== CTA ===== -->
  <section class="pr-cta-sec">
    <div class="pr-wrap">
      <div class="pr-cta">
        <h2 class="pr-cta__title">WHICH PATH FITS YOU?</h2>
        <p class="pr-cta__sub">Đặt lịch nói chuyện để SBB đánh giá thẳng thắn xem J-1 Trainee hay visa 407 phù hợp với bạn, hoặc xem các chương trình khác.</p>
        <div class="pr-actions pr-actions--center">
          <a href="/apply" class="pr-btn pr-btn--onfire">Đăng ký tư vấn</a>
          <a href="/programs" class="pr-btn pr-btn--light">Xem chương trình khác</a>
        </div>
      </div>
    </div>
  </section>
</PageLayout>

<style>
  .pr-wrap, .pr-hero__wrap { width: calc(100% - 4rem); max-width: 120rem; margin-inline: auto; position: relative; z-index: 2; }
  .pr-eyebrow { display: inline-block; font-family: var(--font-headline); font-weight: 700; font-size: 0.8rem; letter-spacing: 0.18em; text-transform: uppercase; color: #f2420b; margin-bottom: 1.4rem; }
  .pr-accent { color: #f2420b; }

  .pr-hero { position: relative; overflow: clip; padding-top: clamp(7rem, 9vw, 11rem); padding-bottom: clamp(3rem, 6vw, 6rem); min-height: 78vh; display: flex; align-items: center; }
  .pr-hero__beam { position: absolute; top: -40px; left: 84%; transform: translateX(-50%); width: 1180px; height: 860px; pointer-events: none; z-index: 0;
    background: radial-gradient(ellipse 50% 50% at 50% 42%, rgba(255,112,60,0.60) 0%, rgba(248,82,26,0.46) 22%, rgba(242,66,11,0.30) 44%, rgba(242,66,11,0.12) 64%, transparent 84%); filter: blur(76px); }
  .cs-header { font-family: 'Inter', sans-serif; font-weight: 500; line-height: 0.95; letter-spacing: -0.045em; }
  .cs-line { display: flex; align-items: center; gap: 1.5rem; }
  .cs-line-1 { font-size: clamp(3rem, 10.4vw, 10.5rem); letter-spacing: -0.075em; line-height: 0.95; white-space: nowrap; position: relative; z-index: 10; }
  .cs-text-white { color: #ffffff; }

  .pr-lead { margin: clamp(1.6rem, 3vw, 2.6rem) 0 0; max-width: 46ch; font-family: 'Inter', sans-serif; font-weight: 300; font-size: clamp(0.8rem, 0.95vw, 0.92rem); line-height: 1.6; color: rgba(255,255,255,0.66); }
  .pr-actions { display: flex; flex-wrap: wrap; gap: 0.9rem; margin-top: clamp(1.6rem, 3vw, 2.4rem); }
  .pr-actions--center { justify-content: center; }
  .pr-btn { display: inline-flex; align-items: center; justify-content: center; font-family: var(--font-headline); font-weight: 700; font-size: 0.9rem; text-decoration: none; border-radius: 999px; padding: 0.85rem 1.7rem; transition: transform .25s ease, background .25s ease, box-shadow .25s ease, border-color .25s ease, color .25s ease; }
  .pr-btn--primary { background: #f2420b; color: #fff; box-shadow: 0 14px 30px -12px rgba(242,66,11,0.7); }
  .pr-btn--primary:hover { background: #ff5c26; transform: translateY(-2px); }
  .pr-btn--ghost { background: rgba(255,255,255,0.04); color: #fff; border: 1px solid rgba(255,255,255,0.2); }
  .pr-btn--ghost:hover { border-color: rgba(242,66,11,0.55); background: rgba(242,66,11,0.08); }
  .pr-btn--onfire { background: #fff; color: #c2380a; }
  .pr-btn--onfire:hover { transform: translateY(-2px); background: #fff5f1; }
  .pr-btn--light { background: transparent; color: #fff; border: 1px solid rgba(255,255,255,0.55); }
  .pr-btn--light:hover { background: rgba(255,255,255,0.12); }

  .pr-sec { position: relative; overflow: clip; padding-block: clamp(3.5rem, 7vw, 7rem); }
  .pr-sec--beam { z-index: 1; }
  .pr-beam { position: absolute; top: -60px; width: 900px; height: 760px; pointer-events: none; z-index: 0; filter: blur(80px);
    background: radial-gradient(ellipse 50% 50% at 50% 42%, rgba(255,112,60,0.30) 0%, rgba(242,66,11,0.16) 40%, rgba(242,66,11,0.05) 66%, transparent 86%); }
  .pr-beam--right { left: 86%; transform: translateX(-50%); }
  .pr-beam--left { left: 14%; transform: translateX(-50%); }

  .pr-split { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(2rem, 4vw, 4rem); align-items: start; }
  .pr-statement { font-family: var(--font-headline); font-weight: 700; font-size: clamp(1.7rem, 3vw, 2.6rem); line-height: 1.15; color: #fff; margin: 0; letter-spacing: -0.01em; }
  .pr-checks { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.9rem; }
  .pr-checks li { position: relative; padding-left: 1.8rem; font-family: 'Inter', sans-serif; font-weight: 300; font-size: 1rem; line-height: 1.6; color: rgba(255,255,255,0.72); }
  .pr-checks li::before { content: ''; position: absolute; left: 0; top: 0.55em; width: 0.65rem; height: 0.65rem; border-radius: 999px; background: #f2420b; box-shadow: 0 0 0 4px rgba(242,66,11,0.18); }

  .pr-head { max-width: 60ch; margin-bottom: clamp(2.2rem, 4vw, 3.4rem); }
  .pr-h2 { font-family: var(--font-headline); font-weight: 700; font-size: clamp(2rem, 4vw, 3.4rem); line-height: 1.08; color: #fff; letter-spacing: -0.02em; margin: 0; text-transform: none; }
  .pr-desc { font-family: 'Inter', sans-serif; font-weight: 300; font-size: clamp(0.96rem, 1.1vw, 1.08rem); line-height: 1.65; color: rgba(255,255,255,0.6); margin: 0.9rem 0 0; max-width: 60ch; }

  /* ===== CARD = KÍNH TỐI PHỦ LỬA (KHÔNG nền trắng) ===== */
  .pr-grid { display: grid; gap: clamp(1.2rem, 2vw, 1.8rem); }
  .pr-grid--2 { grid-template-columns: repeat(2, 1fr); }
  .pr-grid--3 { grid-template-columns: repeat(3, 1fr); }
  .pr-card {
    position: relative; display: flex; flex-direction: column; text-decoration: none;
    background: rgba(255,255,255,0.025);
    -webkit-backdrop-filter: blur(10px); backdrop-filter: blur(10px);
    border: 1px solid rgba(255,255,255,0.10); border-radius: 1.6rem;
    padding: clamp(1.6rem, 2.2vw, 2.3rem);
    box-shadow: 0 8px 24px rgba(0,0,0,0.40);
    transition: transform .4s ease, box-shadow .4s ease, border-color .4s ease, background .4s ease;
  }
  .pr-card:hover {
    transform: translateY(-8px);
    background:
      radial-gradient(150% 150% at 100% 100%,
        rgba(255,126,72,0.40) 0%, rgba(255,100,30,0.26) 26%, rgba(242,66,11,0.14) 50%, rgba(20,10,5,0.30) 80%, rgba(10,5,2,0.40) 100%),
      rgba(255,255,255,0.03);
    border-color: rgba(242,66,11,0.40);
    box-shadow: 0 26px 64px -24px rgba(0,0,0,0.55);
  }
  .pr-card--flagship {
    background:
      radial-gradient(150% 150% at 100% 100%,
        rgba(255,112,60,0.34) 0%, rgba(248,82,26,0.22) 26%, rgba(242,66,11,0.12) 50%, rgba(20,10,5,0.34) 80%, rgba(10,5,2,0.42) 100%),
      rgba(255,255,255,0.025);
    border-color: rgba(242,66,11,0.30);
  }
  .pr-card--soon { opacity: 0.66; cursor: default; }
  .pr-card--soon:hover { transform: none; background: rgba(255,255,255,0.025); border-color: rgba(255,255,255,0.10); box-shadow: 0 8px 24px rgba(0,0,0,0.40); }
  .pr-card__tag { align-self: flex-start; font-family: 'Inter', sans-serif; font-weight: 600; font-size: 0.66rem; letter-spacing: 0.08em; text-transform: uppercase; color: #ffb59c; background: rgba(242,66,11,0.18); border: 1px solid rgba(242,66,11,0.30); border-radius: 999px; padding: 0.28rem 0.7rem; }
  .pr-card__tag--soon { color: rgba(255,255,255,0.7); background: rgba(255,255,255,0.06); border-color: rgba(255,255,255,0.16); }
  .pr-card__title { font-family: var(--font-headline); font-weight: 700; font-size: clamp(1.2rem, 1.6vw, 1.5rem); color: #F5EDE6; margin: 0.8rem 0 0.7rem; letter-spacing: -0.01em; text-transform: none; }
  .pr-card__body { font-family: 'Inter', sans-serif; font-weight: 300; font-size: 0.96rem; line-height: 1.6; color: rgba(255,255,255,0.78); margin: 0; }
  .pr-card__more { margin-top: auto; padding-top: 1.4rem; font-family: var(--font-headline); font-weight: 700; font-size: 0.82rem; letter-spacing: 0.04em; text-transform: uppercase; color: #ff7a52; }
  .pr-card__more--soon { color: rgba(255,255,255,0.45); }

  /* ===== CTA ===== */
  .pr-cta-sec { padding-block: clamp(3rem, 6vw, 6rem) clamp(4rem, 8vw, 8rem); }
  .pr-cta { text-align: center; border-radius: 28px; padding: clamp(2.6rem, 5vw, 4rem) clamp(1.5rem, 4vw, 3rem); background: linear-gradient(135deg, #f2420b, #c2380a); box-shadow: 0 28px 66px -24px rgba(242,66,11,0.6); }
  .pr-cta__title { font-family: var(--font-headline); font-weight: 700; font-size: clamp(1.7rem, 3vw, 2.4rem); color: #fff; margin: 0 0 0.8rem; }
  .pr-cta__sub { font-family: 'Inter', sans-serif; font-weight: 300; font-size: 1.05rem; line-height: 1.6; color: rgba(255,255,255,0.92); margin: 0 auto 1.8rem; max-width: 52ch; }

  @media (max-width: 980px) {
    .cs-line { flex-wrap: wrap; gap: 0.5rem; }
    .cs-line-1 { font-size: clamp(3.5rem, 16.8vw, 4.55rem) !important; letter-spacing: -0.097em !important; line-height: 0.92 !important; white-space: normal; }
    .pr-split { grid-template-columns: 1fr; }
    .pr-grid--3 { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 600px) {
    .pr-grid--2, .pr-grid--3 { grid-template-columns: 1fr; }
  }
</style>
