// J-1 Hoa Kỳ — TRANG CHI TIẾT (1 hạng mục của Global Internship). Nhánh Intern.
// Bấm từ trang tổng quan /programs/global-internship nhảy sang đây.
// Hệ dark-fire đồng bộ hub/trang chủ. KHÔNG card trắng.
import PageLayout from '@ui/layouts/PageLayout.astro';

const stats = [
  { num: '12', label: 'Tháng thực tập tối đa (Intern)' },
  { num: 'J-1', label: 'Visa Exchange Visitor' },
  { num: '300K+', label: 'Người đến Mỹ mỗi năm' },
  { num: '10+', label: 'Nhóm ngành tiếp nhận' },
];

const industries = [
  'Hospitality & Tourism · Du lịch, Khách sạn',
  'Business & Commerce · Kinh doanh, Thương mại',
  'Finance & Accounting · Tài chính, Kế toán',
  'Information Technology · Công nghệ thông tin',
  'Engineering · Kỹ thuật',
  'Architecture & Design · Kiến trúc, Thiết kế',
  'Media & Communications · Truyền thông',
  'Sciences · Khoa học ứng dụng',
  'Agriculture · Nông nghiệp công nghệ cao',
  'Arts & Culture · Nghệ thuật, Văn hóa',
];

const steps = [
  { num: '01', title: 'Tìm hiểu & đánh giá ban đầu', body: 'Nói chuyện thẳng thắn với SBB để hiểu rõ hồ sơ của bạn có thật sự hợp với J-1 hay không.' },
  { num: '02', title: 'Chuẩn bị nền tảng với GRP', body: 'Xây dựng tư duy toàn cầu, tác phong chuyên nghiệp và ngoại ngữ trước khi bước vào phỏng vấn.' },
  { num: '03', title: 'Kết nối host company tại Mỹ', body: 'Tìm kiếm doanh nghiệp tiếp nhận và phỏng vấn trực tiếp cho vị trí thực tập của bạn.' },
  { num: '04', title: 'Sponsor xét duyệt DS-2019', body: 'Tổ chức bảo trợ được Bộ Ngoại giao Mỹ cấp phép duyệt hồ sơ và cấp DS-2019 cho hành trình.' },
  { num: '05', title: 'Phỏng vấn visa & khởi hành', body: 'Nhận visa J-1, hoàn tất chuẩn bị hành lý và bay sang Mỹ bắt đầu làm việc thật.' },
];

const truths = [
  { title: 'Đào tạo, không phải lao động giá rẻ', body: 'Visa J-1 được thiết kế để học hỏi và phát triển chuyên môn thật qua một Training Plan chi tiết. Bạn được trả lương bình đẳng, và doanh nghiệp Mỹ có nghĩa vụ đào tạo bạn.' },
  { title: 'Quy tắc cư trú 2 năm', body: 'Một số trường hợp nhận tài trợ chính phủ hoặc thuộc danh sách ngành khan hiếm cần quay về Việt Nam tối thiểu 2 năm sau chương trình trước khi chuyển sang visa định cư hoặc làm việc dài hạn tại Mỹ.' },
  { title: 'Chính sách có thể thay đổi', body: 'Quy định nhập cảnh và quản lý visa của Mỹ có thể biến động. SBB cam kết đồng hành và xử lý linh hoạt, nhưng không ai cam kết trước quyết định pháp lý của cơ quan ngoại giao.' },
];

const sponsors = ['CIEE', 'CETUSA', 'Alliance Abroad (AAG)', 'IEEX'];

const svg = (paths: string) =>
  `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">${paths}</svg>`;

const benefits = [
  { icon: svg('<circle cx="12" cy="12" r="10"/><path d="M16 8h-6a2 2 0 1 0 0 4h4a2 2 0 1 1 0 4H8"/><path d="M12 18V6"/>'), title: 'EQUAL PAY', body: 'Được trả lương như nhân sự bản địa cùng vị trí. Đào tạo có thu nhập thật sự.' },
  { icon: svg('<path d="M21.4 10.9a1 1 0 0 0 0-1.8l-8.6-3.9a2 2 0 0 0-1.7 0L2.6 9.1a1 1 0 0 0 0 1.8l8.6 3.9a2 2 0 0 0 1.7 0z"/><path d="M22 10v6"/><path d="M6 12.5V16a6 3 0 0 0 12 0v-3.5"/>'), title: 'REAL TRAINING', body: 'Làm việc theo Training Plan chuẩn tại host company được Mỹ cấp phép, phát triển chuyên môn thật.' },
  { icon: svg('<path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/><path d="m9 12 2 2 4-4"/>'), title: 'OFFICIAL SPONSOR', body: 'Designated Sponsor do Bộ Ngoại giao Mỹ chỉ định bảo trợ hồ sơ và cấp DS-2019.' },
  { icon: svg('<circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/>'), title: 'GLOBAL EXPOSURE', body: 'Sống và làm việc thật tại Mỹ, mở rộng tư duy toàn cầu và mạng lưới nghề nghiệp.' },
  { icon: svg('<polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/>'), title: 'CAREER LAUNCH', body: 'Kinh nghiệm và ngoại ngữ tích lũy thành lợi thế cạnh tranh cho bước tiếp theo.' },
  { icon: svg('<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>'), title: 'FLEXIBLE TERM', body: 'Thời gian thực tập linh hoạt, tối đa 12 tháng cho nhánh Intern.' },
];
---

<PageLayout
  title="J-1 Hoa Kỳ — Thực tập tại Mỹ"
  description="J-1 Hoa Kỳ, một hạng mục của Global Internship: thực tập có trả lương tại doanh nghiệp Mỹ theo visa J-1 Exchange Visitor (nhánh Intern)."
  site="sbb"
  currentPath="/programs/internship-j1"
>
  <!-- ===== HERO (kiểu Omni: tiêu đề lớn + hàng stat card quầng lửa) ===== -->
  <section class="pr-hero">
    <div class="pr-hero__wrap">
      <div class="hero-top">
        <a class="pr-eyebrow pr-eyebrow--back" href="/programs/global-internship">← Global Internship</a>
        <div class="cs-header">
          <div class="cs-line cs-line-1"><span class="cs-text-white">INTERNSHIP</span></div>
          <div class="cs-line cs-line-1 cs-line-2"><span class="cs-int-wrap"><span class="cs-text-white">J-1 USA</span></span></div>
        </div>
      </div>
      <div class="hero-stats">
        {stats.map((s) => (
          <div class="hero-stat">
            <div class="hero-stat__num">{s.num}</div>
            <div class="hero-stat__label">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ SECTION VIDEO · "LIFE BEYOND BORDERS" (bê nguyên từ trang chủ) ============ -->
  <section class="moments-section" id="moments">
    <div class="mv-container">
      <div class="mv-stage">
        <div class="mv-track" id="mv-track">
          <div class="mv-card mv-card--video" data-tt="7611267613485944085" aria-label="Clip học viên SBB"><div class="mv-photo"><video src="/videos/clip-01.mp4" poster="/images/tiktok/clip-01.jpg" muted loop playsinline preload="none"></video></div></div>
          <div class="mv-card mv-card--video" data-tt="7611425724079099156" aria-label="Clip học viên SBB"><div class="mv-photo"><video src="/videos/clip-02.mp4" poster="/images/tiktok/clip-02.jpg" muted loop playsinline preload="none"></video></div></div>
          <div class="mv-card mv-card--video" data-tt="7611806050404109588" aria-label="Clip học viên SBB"><div class="mv-photo"><video src="/videos/clip-03.mp4" poster="/images/tiktok/clip-03.jpg" muted loop playsinline preload="none"></video></div></div>
          <div class="mv-card mv-card--video" data-tt="7612365856525323541" aria-label="Clip học viên SBB"><div class="mv-photo"><video src="/videos/clip-04.mp4" poster="/images/tiktok/clip-04.jpg" muted loop playsinline preload="none"></video></div></div>
          <div class="mv-card mv-card--video" data-tt="7612710561922649364" aria-label="Clip học viên SBB"><div class="mv-photo"><video src="/videos/clip-05.mp4" poster="/images/tiktok/clip-05.jpg" muted loop playsinline preload="none"></video></div></div>
          <div class="mv-card mv-card--video" data-tt="7617199471293762836" aria-label="Clip học viên SBB"><div class="mv-photo"><video src="/videos/clip-06.mp4" poster="/images/tiktok/clip-06.jpg" muted loop playsinline preload="none"></video></div></div>
          <div class="mv-card mv-card--video" data-tt="7622542919370706197" aria-label="Clip học viên SBB"><div class="mv-photo"><video src="/videos/clip-07.mp4" poster="/images/tiktok/clip-07.jpg" muted loop playsinline preload="none"></video></div></div>
          <div class="mv-card mv-card--video" data-tt="7626529298366647572" aria-label="Clip học viên SBB"><div class="mv-photo"><video src="/videos/clip-08.mp4" poster="/images/tiktok/clip-08.jpg" muted loop playsinline preload="none"></video></div></div>
          <div class="mv-card mv-card--video" data-tt="7640959047910346004" aria-label="Clip học viên SBB"><div class="mv-photo"><video src="/videos/clip-09.mp4" poster="/images/tiktok/clip-09.jpg" muted loop playsinline preload="none"></video></div></div>
        </div>

        <button class="mv-nav mv-nav--prev" id="mv-prev" type="button" aria-label="Khoảnh khắc trước">&#8249;</button>
        <button class="mv-nav mv-nav--next" id="mv-next" type="button" aria-label="Khoảnh khắc sau">&#8250;</button>
        <div class="mv-pp" id="mv-pp" aria-hidden="true"></div>
      </div>
    </div>
  </section>

  <!-- Lightbox phát clip (tự host MP4) -->
  <div class="mv-lightbox" id="mv-lightbox" aria-hidden="true" role="dialog" aria-modal="true" aria-label="Trình phát clip">
    <button class="mv-lb-close" id="mv-lb-close" type="button" aria-label="Đóng">&times;</button>
    <div class="mv-lb-frame" id="mv-lb-frame"></div>
    <a class="mv-lb-tt" id="mv-lb-tt" href="https://www.tiktok.com/@duyendao222" target="_blank" rel="noopener">Mở trên TikTok ↗</a>
  </div>

  <!-- ===== ABOUT J-1 — card kính + glow đỉnh (kiểu MMRS CO.) ===== -->
  <section class="pr-sec about-sec" id="j1">
    <div class="pr-wrap">
      <div class="about-card">
        <div class="about-card__inner">
          <div class="cs-header about-title">
            <div class="cs-line cs-line-1"><span class="cs-text-white">ABOUT</span></div>
            <div class="cs-line cs-line-1 cs-line-2"><span class="cs-text-white">J-1 USA</span></div>
          </div>
          <p class="about-body">J-1 USA là nhánh Intern của Global Internship: thực tập có trả lương tại doanh nghiệp Mỹ theo visa J-1 Exchange Visitor. Dành cho sinh viên đang học hoặc mới tốt nghiệp, thời gian tối đa 12 tháng.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== SPONSORS — hàng logo bảo trợ (ngay dưới ABOUT) ===== -->
  <section class="pr-sec spon-sec">
    <div class="pr-wrap">
      <p class="spon-eyebrow">Official Sponsors</p>
      <div class="spon-row">
        <div class="spon-logo"><img src="/images/partners/ciee.png" alt="CIEE" /></div>
        <div class="spon-logo"><img src="/images/partners/cetusa.png" alt="CETUSA" /></div>
        <div class="spon-logo"><img src="/images/partners/alliance.png" alt="Alliance Abroad (AAG)" /></div>
        <div class="spon-logo"><img src="/images/partners/iee.png" alt="IEEX" /></div>
      </div>
      <p class="spon-note">Được bảo trợ bởi các Designated Sponsor do Bộ Ngoại giao Mỹ chỉ định.</p>
    </div>
  </section>

  <!-- ===== BENEFITS — lợi ích chương trình ===== -->
  <section class="pr-sec ben-sec">
    <div class="pr-wrap">
      <div class="ben-head">
        <div class="cs-header"><div class="cs-line cs-line-1"><span class="cs-text-white">BENEFITS</span></div></div>
        <p class="ben-desc">Những gì bạn thật sự nhận được khi đi J-1 USA cùng SBB.</p>
      </div>
      <div class="ben-grid">
        {benefits.map((b, i) => (
          <article class="ben-card">
            <span class="ben-ico" set:html={b.icon} />
            <span class="ben-idx">{String(i + 1).padStart(2, '0')}</span>
            <h3 class="ben-title">{b.title}</h3>
            <p class="ben-body">{b.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== GALLERY J-1 USA — loạt ảnh thật (giữa Benefits & Industries) ===== -->
  <section class="pr-sec gal-sec">
    <div class="pr-wrap">
      <p class="gal-eyebrow">Life on J-1 · USA</p>
      <div class="gal-row">
        <figure class="gal-item"><img src="/images/case-studies/cs2.jpg" alt="Học viên SBB tại New York, Mỹ" loading="lazy" /></figure>
        <figure class="gal-item"><img src="/images/case-studies/cs1.jpg" alt="Học viên SBB cùng đồng nghiệp tại Mỹ" loading="lazy" /></figure>
        <figure class="gal-item"><img src="/images/case-studies/cs3.jpg" alt="Học viên SBB làm việc tại khách sạn Mỹ" loading="lazy" /></figure>
      </div>
    </div>
  </section>

  <!-- ===== INDUSTRIES — card từng ngành ===== -->
  <section class="pr-sec ind-sec">
    <div class="pr-wrap">
      <div class="ind-head">
        <div class="cs-header"><div class="cs-line cs-line-1"><span class="cs-text-white">INDUSTRIES</span></div></div>
        <p class="ind-desc">Mười nhóm ngành chính đang tiếp nhận ứng viên J-1. Suất thực tế tùy thuộc ngành nghề và thời điểm tuyển dụng của host company.</p>
      </div>
      <div class="ind-grid">
        {industries.map((name, i) => {
          const [en, vi] = name.split(' · ');
          return (
            <article class="ind-card">
              <span class="ind-card__num">{String(i + 1).padStart(2, '0')}</span>
              <h3 class="ind-card__name">{en}</h3>
              <p class="ind-card__vi">{vi}</p>
            </article>
          );
        })}
      </div>
    </div>
  </section>

  <!-- ===== ALL PARTNERS — marquee logo đối tác (giữa Industries & Roadmap) ===== -->
