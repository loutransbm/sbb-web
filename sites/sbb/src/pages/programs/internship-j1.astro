---
// Trang chi tiết Internship J-1 — DỰNG LẠI theo hệ bespoke dark-fire của site
// (đồng bộ với hub /programs + trang chủ): hero cascade + glass pill + glow beam,
// card kính trắng frosted, nền dark-fire. KHÔNG dùng omni-kit .o-*.
import PageLayout from '@ui/layouts/PageLayout.astro';

const tracks = [
  { num: '01', title: 'Intern', body: 'Dành cho sinh viên đang học đại học/cao đẳng, hoặc đã tốt nghiệp không quá 12 tháng tính đến thời điểm nộp hồ sơ.', detail: 'Thời gian thực tập tối đa: 12 tháng.' },
  { num: '02', title: 'Trainee', body: 'Dành cho người có bằng đại học/cao đẳng cộng ít nhất 1 năm kinh nghiệm liên quan, HOẶC có 5 năm kinh nghiệm trong lĩnh vực liên quan (không yêu cầu bằng cấp).', detail: 'Thời gian tu nghiệp tối đa: 18 tháng. Riêng ngành Hospitality tối đa 12 tháng (trừ vị trí quản lý).' },
];

const stats = [
  { num: '18', label: 'Tháng tu nghiệp tối đa' },
  { num: 'J-1', label: 'Visa Exchange Visitor' },
  { num: '300K+', label: 'Người đến Mỹ mỗi năm' },
  { num: '10+', label: 'Nhóm ngành tiếp nhận' },
];

const industries = [
  'Hospitality & Tourism · Du lịch, Khách sạn',
  'Business & Commerce · Kinh doanh, Thương mại',
  'Finance & Accounting · Tài chính, Kế toán',
  'Information Technology · Công nghệ thông tin',
  'Engineering · Kỹ thuật',
  'Architecture & Design · Kiến trúc, Thiết kế',
  'Media & Communications · Truyền thông',
  'Sciences · Khoa học ứng dụng',
  'Agriculture · Nông nghiệp công nghệ cao',
  'Arts & Culture · Nghệ thuật, Văn hóa',
];

const steps = [
  { num: '01', title: 'Tìm hiểu & đánh giá ban đầu', body: 'Nói chuyện thẳng thắn với SBB để hiểu rõ hồ sơ của bạn có thật sự hợp với J-1 hay không.' },
  { num: '02', title: 'Chuẩn bị nền tảng với GRP', body: 'Xây dựng tư duy toàn cầu, tác phong chuyên nghiệp và ngoại ngữ trước khi bước vào phỏng vấn.' },
  { num: '03', title: 'Kết nối host company tại Mỹ', body: 'Tìm kiếm doanh nghiệp tiếp nhận và phỏng vấn trực tiếp cho vị trí thực tập của bạn.' },
  { num: '04', title: 'Sponsor xét duyệt DS-2019', body: 'Tổ chức bảo trợ được Bộ Ngoại giao Mỹ cấp phép duyệt hồ sơ và cấp DS-2019 cho hành trình.' },
  { num: '05', title: 'Phỏng vấn visa & khởi hành', body: 'Nhận visa J-1, hoàn tất chuẩn bị hành lý và bay sang Mỹ bắt đầu làm việc thật.' },
];

const truths = [
  { title: 'Đào tạo, không phải lao động giá rẻ', body: 'Visa J-1 được thiết kế để học hỏi và phát triển chuyên môn thật qua một Training Plan chi tiết. Bạn được trả lương bình đẳng, và doanh nghiệp Mỹ có nghĩa vụ đào tạo bạn, không bóc lột sức lao động.' },
  { title: 'Quy tắc cư trú 2 năm', body: 'Một số trường hợp (nhận tài trợ chính phủ hoặc thuộc danh sách ngành khan hiếm) yêu cầu bạn quay về Việt Nam tối thiểu 2 năm sau chương trình mới được chuyển sang visa định cư hoặc làm việc dài hạn tại Mỹ.' },
  { title: 'Chính sách có thể thay đổi', body: 'Quy định nhập cảnh và quản lý visa của Mỹ có thể biến động. SBB cam kết đồng hành và xử lý linh hoạt, nhưng không ai có thể cam kết trước quyết định pháp lý của cơ quan ngoại giao Mỹ.' },
];

const sponsors = ['CIEE', 'CETUSA', 'Alliance Abroad (AAG)', 'IEEX'];
---

<PageLayout
  title="Thực tập & Tu nghiệp Quốc tế J-1"
  description="Chương trình thực tập và tu nghiệp quốc tế tại Mỹ theo visa J-1 Exchange Visitor. Đi làm thật ở doanh nghiệp Mỹ."
  site="sbb"
  currentPath="/programs/internship-j1"
>
  <!-- ===== HERO (cascade + glass pill + glow beam) ===== -->
  <section class="pr-hero">
    <div class="pr-hero__beam" aria-hidden="true"></div>
    <div class="pr-hero__wrap">
      <span class="pr-eyebrow">Chương trình · Internship J-1</span>
      <div class="cs-header">
        <div class="cs-line cs-line-1"><span class="cs-text-white">GLOBAL INTERNSHIP</span></div>
      </div>
      <p class="pr-lead">Mỗi năm hơn 300.000 người từ khắp thế giới đến Mỹ theo visa J-1 Exchange Visitor. Khác với du học thông thường, đây là con đường nghề nghiệp nghiêm túc để bạn trải nghiệm môi trường làm việc thực tế, nâng tầm năng lực và mang giá trị quốc tế trở về.</p>
      <div class="pr-actions">
        <a href="/apply" class="pr-btn pr-btn--primary">Đăng ký tư vấn</a>
        <a href="#how" class="pr-btn pr-btn--ghost">Xem lộ trình</a>
      </div>
    </div>
  </section>

  <!-- ===== OVERVIEW + STATS ===== -->
  <section class="pr-sec">
    <div class="pr-wrap">
      <div class="pr-split">
        <div>
          <span class="pr-eyebrow">Tổng quan</span>
          <p class="pr-statement">Một chương trình nghề <span class="pr-accent">đúng nghĩa</span>, không phải điểm dừng du lịch.</p>
        </div>
        <ul class="pr-checks">
          <li>Làm việc trực tiếp tại host company được Mỹ cấp phép, theo Training Plan rõ ràng.</li>
          <li>Được trả lương bình đẳng như nhân sự bản địa cùng vị trí.</li>
          <li>Bảo trợ bởi Designated Sponsor do Bộ Ngoại giao Mỹ chỉ định.</li>
          <li>SBB và GRP đồng hành từ đánh giá hồ sơ đến ngày khởi hành.</li>
        </ul>
      </div>
      <div class="pr-stats">
        {stats.map((s) => (
          <div class="pr-stat"><span class="pr-stat__num">{s.num}</span><span class="pr-stat__label">{s.label}</span></div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== INTERN OR TRAINEE ===== -->
  <section class="pr-sec pr-sec--beam">
    <div class="pr-beam pr-beam--right" aria-hidden="true"></div>
    <div class="pr-wrap">
      <div class="pr-head">
        <span class="pr-eyebrow">Bạn là ai</span>
        <h2 class="pr-h2">Intern hay <span class="pr-accent">Trainee</span></h2>
        <p class="pr-desc">Hai hướng đi, hai bộ điều kiện. Xác định đúng nhóm của bạn ngay từ đầu để chuẩn bị hồ sơ thuyết phục nhất.</p>
      </div>
      <div class="pr-grid pr-grid--2">
        {tracks.map((t) => (
          <article class="pr-card">
            <span class="pr-card__num">{t.num}</span>
            <h3 class="pr-card__title">{t.title}</h3>
            <p class="pr-card__body">{t.body}</p>
            <p class="pr-card__detail">{t.detail}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== INDUSTRIES ===== -->
  <section class="pr-sec">
    <div class="pr-wrap">
      <div class="pr-head">
        <span class="pr-eyebrow">Ngành nghề</span>
        <h2 class="pr-h2">Bạn sẽ vào <span class="pr-accent">đâu</span></h2>
        <p class="pr-desc">Mười nhóm ngành chính đang tiếp nhận ứng viên J-1. Suất thực tế tùy thuộc ngành nghề và thời điểm tuyển dụng của host company.</p>
      </div>
      <div class="pr-tags">
        {industries.map((name) => <span class="pr-tag">{name}</span>)}
      </div>
    </div>
  </section>

  <!-- ===== HOW IT WORKS ===== -->
  <section class="pr-sec pr-sec--beam" id="how">
    <div class="pr-beam pr-beam--left" aria-hidden="true"></div>
    <div class="pr-wrap">
      <div class="pr-head">
        <span class="pr-eyebrow">Lộ trình</span>
        <h2 class="pr-h2">Cách <span class="pr-accent">vận hành</span></h2>
        <p class="pr-desc">Năm bước rõ ràng từ buổi nói chuyện đầu tiên đến ngày bạn đặt chân tới Mỹ.</p>
      </div>
      <div class="pr-rows">
        {steps.map((s) => (
          <article class="pr-row">
            <span class="pr-row__num">{s.num}</span>
            <div><h3 class="pr-row__title">{s.title}</h3><p class="pr-row__body">{s.body}</p></div>
          </article>
        ))}
      </div>
      <p class="pr-note"><strong>Về chi phí:</strong> SBB không đưa ra biểu giá chung chung. Chi phí thực tế phụ thuộc vào ngành nghề, thời lượng và bang bạn làm việc, và sẽ được minh bạch chi tiết ngay từ buổi trao đổi đầu tiên.</p>
    </div>
  </section>

  <!-- ===== REALITY CHECK ===== -->
  <section class="pr-sec">
    <div class="pr-wrap">
      <div class="pr-head">
        <span class="pr-eyebrow">Reality Check</span>
        <h2 class="pr-h2">Sự thật <span class="pr-accent">trước</span></h2>
        <p class="pr-desc">Ba sự thật chúng tôi muốn bạn biết trước khi quyết định, để bạn đi với đôi mắt mở.</p>
      </div>
      <div class="pr-grid pr-grid--3">
        {truths.map((t) => (
          <article class="pr-card">
            <span class="pr-card__tag">Lưu ý</span>
            <h3 class="pr-card__title">{t.title}</h3>
            <p class="pr-card__body">{t.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== SPONSORS ===== -->
  <section class="pr-sec pr-sec--beam">
    <div class="pr-beam pr-beam--right" aria-hidden="true"></div>
    <div class="pr-wrap">
      <div class="pr-split">
        <div>
          <span class="pr-eyebrow">Sponsors</span>
          <p class="pr-statement">Được bảo trợ bởi tổ chức <span class="pr-accent">chính danh</span>.</p>
        </div>
        <div>
          <p class="pr-desc" style="margin-bottom:1.4rem;">SBB hợp tác chặt chẽ cùng các Designated Sponsor được Bộ Ngoại giao Mỹ cấp phép bảo trợ chương trình:</p>
          <div class="pr-pills">{sponsors.map((name) => <span class="pr-pill">{name}</span>)}</div>
          <p class="pr-desc" style="margin-top:1.2rem;font-style:italic;">và các tổ chức bảo trợ uy tín khác.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== CTA ===== -->
  <section class="pr-cta-sec">
    <div class="pr-wrap">
      <div class="pr-cta">
        <h2 class="pr-cta__title">BẮT ĐẦU HÀNH TRÌNH J-1</h2>
        <p class="pr-cta__sub">Đặt lịch nói chuyện trực tiếp để SBB đánh giá hồ sơ cá nhân và tư vấn con đường phù hợp nhất cho bạn.</p>
        <div class="pr-actions pr-actions--center">
          <a href="/apply" class="pr-btn pr-btn--onfire">Đăng ký tư vấn</a>
          <a href="/programs" class="pr-btn pr-btn--light">Xem chương trình khác</a>
        </div>
      </div>
    </div>
  </section>
</PageLayout>

<style>
  /* ===== WRAP đồng bộ nav (calc(100% - 4rem) / max 120rem) ===== */
  .pr-wrap, .pr-hero__wrap { width: calc(100% - 4rem); max-width: 120rem; margin-inline: auto; position: relative; z-index: 2; }
  .pr-eyebrow { display: inline-block; font-family: var(--font-headline); font-weight: 700; font-size: 0.8rem; letter-spacing: 0.18em; text-transform: uppercase; color: #f2420b; margin-bottom: 1.4rem; }
  .pr-accent { color: #f2420b; }

  /* ===== HERO (cascade) ===== */
  .pr-hero { position: relative; overflow: clip; padding-top: clamp(7rem, 9vw, 11rem); padding-bottom: clamp(3rem, 6vw, 6rem); min-height: 78vh; display: flex; align-items: center; }
  .pr-hero__beam {
    position: absolute; top: -40px; left: 84%; transform: translateX(-50%);
    width: 1180px; height: 860px; pointer-events: none; z-index: 0;
    background: radial-gradient(ellipse 50% 50% at 50% 42%,
      rgba(255,112,60,0.60) 0%, rgba(248,82,26,0.46) 22%, rgba(242,66,11,0.30) 44%, rgba(242,66,11,0.12) 64%, transparent 84%);
    filter: blur(76px);
  }
  .cs-header { font-family: 'Inter', sans-serif; font-weight: 500; line-height: 0.95; letter-spacing: -0.045em; }
  .cs-line { display: flex; align-items: center; gap: 1.5rem; }
  .cs-line-1 { font-size: clamp(3rem, 10.4vw, 10.5rem); letter-spacing: -0.075em; line-height: 0.95; white-space: nowrap; position: relative; z-index: 10; }
  .cs-text-white { color: #ffffff; }

  /* Glass pill (kính trắng frosted nhô vào cạnh chữ) — port từ hub */
  .cs-glass-pill {
    display: inline-flex; flex-direction: column; flex-shrink: 0; gap: 0.5rem;
    background: rgba(255,255,255,0.86); -webkit-backdrop-filter: blur(14px); backdrop-filter: blur(14px);
    border: 1px solid rgba(0,0,0,0.08); border-radius: 20px; padding: 1rem 1.2rem; width: 215px; min-height: 7rem;
    justify-content: center; text-align: left; box-shadow: 0 18px 40px -14px rgba(0,0,0,0.55);
    margin-left: 0.5rem; transform: translateY(1.2rem); position: relative; z-index: 20;
    letter-spacing: normal; line-height: 1.3;
  }
  .cs-glass-title { font-family: var(--font-headline); font-size: clamp(1.1rem, 1.4vw, 1.4rem); font-weight: 600; color: #f2420b; line-height: 1; letter-spacing: -0.01em; }
  .cs-glass-sub { font-size: 11px; font-weight: 400; color: #646464; line-height: 1.45; margin: 0; }

  .pr-lead { margin: clamp(1.6rem, 3vw, 2.6rem) 0 0; max-width: 60ch; font-family: 'Inter', sans-serif; font-weight: 300; font-size: clamp(1rem, 1.2vw, 1.15rem); line-height: 1.7; color: rgba(255,255,255,0.66); }

  .pr-actions { display: flex; flex-wrap: wrap; gap: 0.9rem; margin-top: clamp(1.6rem, 3vw, 2.4rem); }
  .pr-actions--center { justify-content: center; }
  .pr-btn { display: inline-flex; align-items: center; justify-content: center; font-family: var(--font-headline); font-weight: 700; font-size: 0.9rem; text-decoration: none; border-radius: 999px; padding: 0.85rem 1.7rem; transition: transform .25s ease, background .25s ease, box-shadow .25s ease, border-color .25s ease, color .25s ease; }
  .pr-btn--primary { background: #f2420b; color: #fff; box-shadow: 0 14px 30px -12px rgba(242,66,11,0.7); }
  .pr-btn--primary:hover { background: #ff5c26; transform: translateY(-2px); }
  .pr-btn--ghost { background: rgba(255,255,255,0.04); color: #fff; border: 1px solid rgba(255,255,255,0.2); }
  .pr-btn--ghost:hover { border-color: rgba(242,66,11,0.55); background: rgba(242,66,11,0.08); }
  .pr-btn--onfire { background: #fff; color: #c2380a; }
  .pr-btn--onfire:hover { transform: translateY(-2px); background: #fff5f1; }
  .pr-btn--light { background: transparent; color: #fff; border: 1px solid rgba(255,255,255,0.55); }
  .pr-btn--light:hover { background: rgba(255,255,255,0.12); }

  /* ===== SECTIONS ===== */
  .pr-sec { position: relative; overflow: clip; padding-block: clamp(3.5rem, 7vw, 7rem); }
  .pr-sec--beam { z-index: 1; }
  .pr-beam { position: absolute; top: -60px; width: 900px; height: 760px; pointer-events: none; z-index: 0; filter: blur(80px);
    background: radial-gradient(ellipse 50% 50% at 50% 42%, rgba(255,112,60,0.30) 0%, rgba(242,66,11,0.16) 40%, rgba(242,66,11,0.05) 66%, transparent 86%); }
  .pr-beam--right { left: 86%; transform: translateX(-50%); }
  .pr-beam--left { left: 14%; transform: translateX(-50%); }

  .pr-split { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(2rem, 4vw, 4rem); align-items: start; }
  .pr-statement { font-family: var(--font-headline); font-weight: 700; font-size: clamp(1.7rem, 3vw, 2.6rem); line-height: 1.15; color: #fff; margin: 0; letter-spacing: -0.01em; }
  .pr-checks { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.9rem; }
  .pr-checks li { position: relative; padding-left: 1.8rem; font-family: 'Inter', sans-serif; font-weight: 300; font-size: 1rem; line-height: 1.6; color: rgba(255,255,255,0.72); }
  .pr-checks li::before { content: ''; position: absolute; left: 0; top: 0.55em; width: 0.65rem; height: 0.65rem; border-radius: 999px; background: #f2420b; box-shadow: 0 0 0 4px rgba(242,66,11,0.18); }

  .pr-stats { display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 1.5rem; margin-top: clamp(2.5rem, 5vw, 4rem); padding-top: clamp(2rem, 4vw, 3rem); border-top: 1px solid rgba(255,255,255,0.12); }
  .pr-stat__num { display: block; font-family: var(--font-headline); font-weight: 700; font-size: clamp(2rem, 3.5vw, 3rem); color: #f2420b; line-height: 1; }
  .pr-stat__label { display: block; margin-top: 0.5rem; font-family: 'Inter', sans-serif; font-weight: 300; font-size: 0.86rem; color: rgba(255,255,255,0.6); }

  .pr-head { max-width: 60ch; margin-bottom: clamp(2.2rem, 4vw, 3.4rem); }
  .pr-h2 { font-family: var(--font-headline); font-weight: 700; font-size: clamp(2rem, 4vw, 3.4rem); line-height: 1.08; color: #fff; letter-spacing: -0.02em; margin: 0; text-transform: none; }
  .pr-desc { font-family: 'Inter', sans-serif; font-weight: 300; font-size: clamp(0.96rem, 1.1vw, 1.08rem); line-height: 1.65; color: rgba(255,255,255,0.6); margin: 0.9rem 0 0; max-width: 60ch; }

  /* ===== CARD KÍNH TRẮNG FROSTED (đồng bộ hub .case-card) ===== */
  .pr-grid { display: grid; gap: clamp(1.2rem, 2vw, 1.8rem); }
  .pr-grid--2 { grid-template-columns: repeat(2, 1fr); }
  .pr-grid--3 { grid-template-columns: repeat(3, 1fr); }
  .pr-card {
    position: relative; display: flex; flex-direction: column; background: #ffffff;
    border: 1px solid rgba(0,0,0,0.08); border-radius: 1.6rem; padding: clamp(1.6rem, 2.2vw, 2.3rem);
    box-shadow: 0 14px 40px -16px rgba(0,0,0,0.5); transition: transform .4s ease, box-shadow .4s ease, border-color .4s ease, background .4s ease;
  }
  .pr-card:hover { transform: translateY(-8px); background: #fff7f3; border-color: rgba(242,66,11,0.25); box-shadow: 0 26px 56px -22px rgba(0,0,0,0.55); }
  .pr-card__num { font-family: var(--font-headline); font-weight: 300; font-size: 1.5rem; color: #f2420b; letter-spacing: 0.02em; }
  .pr-card__tag { align-self: flex-start; font-family: 'Inter', sans-serif; font-weight: 600; font-size: 0.66rem; letter-spacing: 0.08em; text-transform: uppercase; color: #c2380a; background: rgba(242,66,11,0.1); border-radius: 999px; padding: 0.28rem 0.7rem; }
  .pr-card__title { font-family: var(--font-headline); font-weight: 700; font-size: clamp(1.2rem, 1.6vw, 1.5rem); color: #1a1a1a; margin: 0.8rem 0 0.7rem; letter-spacing: -0.01em; text-transform: none; }
  .pr-card__body { font-family: 'Inter', sans-serif; font-weight: 400; font-size: 0.96rem; line-height: 1.6; color: #5a5a5a; margin: 0; }
  .pr-card__detail { font-family: 'Inter', sans-serif; font-weight: 600; font-size: 0.95rem; line-height: 1.5; color: #c2380a; margin: 1rem 0 0; }

  /* ===== TAGS (ngành nghề) ===== */
  .pr-tags { display: flex; flex-wrap: wrap; gap: 0.7rem; }
  .pr-tag { font-family: 'Inter', sans-serif; font-weight: 400; font-size: 0.92rem; color: rgba(255,255,255,0.85); background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.12); border-radius: 999px; padding: 0.6rem 1.1rem; transition: border-color .25s ease, background .25s ease; }
  .pr-tag:hover { border-color: rgba(242,66,11,0.45); background: rgba(242,66,11,0.07); }

  /* ===== ROWS (lộ trình) ===== */
  .pr-rows { display: flex; flex-direction: column; gap: 0.7rem; }
