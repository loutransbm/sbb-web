---
import PageLayout from '@ui/layouts/PageLayout.astro';
import StepFlow from '@ui/components/StepFlow.astro';
import CTASection from '@ui/components/CTASection.astro';
---

<PageLayout
  title="Thực tập & Tu nghiệp Quốc tế J-1"
  description="Chương trình thực tập và tu nghiệp quốc tế tại Mỹ theo visa J-1 Exchange Visitor."
  site="sbb"
  currentPath="/programs"
>

  <!-- Block 1: Mở đầu Hero -->
  <section class="section">
    <div class="container container--narrow">
      <div class="reveal">
        <span class="eyebrow-label">CHƯƠNG TRÌNH</span>
        <h1 class="display-heading">Đi làm thật ở doanh nghiệp Mỹ</h1>
        <p class="j1-intro">Mỗi năm, hơn 300.000 người từ khắp thế giới đến Mỹ theo visa J-1 Exchange Visitor (tính cả các hạng mục). Đây không phải visa du học thông thường. Đây là con đường nghề nghiệp nghiêm túc giúp bạn trải nghiệm môi trường làm việc thực tế, nâng tầm năng lực và mang giá trị quốc tế về.</p>
      </div>
    </div>
  </section>

  <!-- Block 2: Intern hay Trainee -->
  <section class="section border-t" id="intern-or-trainee">
    <div class="container">
      <div class="reveal" style="margin-bottom: var(--space-8);">
        <span class="eyebrow-label">COMPARISON</span>
        <h2 class="section-heading">Bạn là Intern hay Trainee?</h2>
      </div>

      <div class="comparison-grid">
        <!-- Card 1: Intern -->
        <div class="numbered-card reveal">
          <span class="card-num">01</span>
          <h3 class="comparison-card__title">Intern</h3>
          <div class="comparison-card__body">
            <p>Dành cho sinh viên đang học đại học/cao đẳng hoặc đã tốt nghiệp không quá 12 tháng tính đến lúc nộp hồ sơ.</p>
            <p class="comparison-card__detail">Thời gian thực tập tối đa: <strong>12 tháng</strong>.</p>
          </div>
        </div>

        <!-- Card 2: Trainee -->
        <div class="numbered-card reveal">
          <span class="card-num">02</span>
          <h3 class="comparison-card__title">Trainee</h3>
          <div class="comparison-card__body">
            <p>Dành cho người có bằng đại học/cao đẳng cộng thêm ít nhất 1 năm kinh nghiệm liên quan, HOẶC có 5 năm kinh nghiệm làm việc trong lĩnh vực liên quan (không yêu cầu bằng cấp).</p>
            <p class="comparison-card__detail">Thời gian tu nghiệp tối đa: <strong>18 tháng</strong>.</p>
            <p class="comparison-card__note">Riêng ngành Hospitality: tối đa 12 tháng (trừ vị trí quản lý).</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- AnchorStat: Dữ kiện thật làm điểm neo thị giác -->
  <section class="section section-stat border-t">
    <div class="container container--narrow reveal text-center">
      <div class="anchor-stat">
        <span class="anchor-stat__num">TỐI ĐA 18 THÁNG</span>
        <p class="anchor-stat__caption">Thời gian tu nghiệp nghề nghiệp tại Mỹ theo visa J-1</p>
      </div>
    </div>
  </section>

  <!-- Block 3: Ngành nào đi được -->
  <section class="section border-t" id="industries">
    <div class="container container--narrow">
      <div class="reveal" style="margin-bottom: var(--space-8);">
        <span class="eyebrow-label">FIELDS</span>
        <h2 class="section-heading">Ngành nào đi được?</h2>
      </div>

      <div class="industry-grid reveal">
        <div class="industry-item">Hospitality & Tourism (Du lịch - Khách sạn)</div>
        <div class="industry-item">Business & Commerce (Kinh doanh - Thương mại)</div>
        <div class="industry-item">Finance & Accounting (Tài chính - Kế toán)</div>
        <div class="industry-item">Information Technology (Công nghệ thông tin)</div>
        <div class="industry-item">Engineering (Kỹ thuật)</div>
        <div class="industry-item">Architecture & Design (Kiến trúc - Thiết kế)</div>
        <div class="industry-item">Media & Communications (Truyền thông)</div>
        <div class="industry-item">Sciences (Khoa học ứng dụng)</div>
        <div class="industry-item">Agriculture (Nông nghiệp công nghệ cao)</div>
        <div class="industry-item">Arts & Culture (Nghệ thuật - Văn hóa)</div>
      </div>
      <p class="industry-note reveal">(*) Khả năng có suất thực tế tùy thuộc vào ngành nghề và thời điểm tuyển dụng của host company.</p>
    </div>
  </section>

  <!-- Block 4: Đi như thế nào -->
  <section class="section border-t" id="how">
    <div class="container container--narrow">
      <div class="reveal" style="margin-bottom: var(--space-8);">
        <span class="eyebrow-label">PROCESS</span>
        <h2 class="section-heading">Đi như thế nào?</h2>
      </div>

      <StepFlow
        steps={[
          { title: 'Tìm hiểu & đánh giá ban đầu', description: 'Nói chuyện thẳng thắn với SBB để hiểu rõ hồ sơ của bạn có hợp với J-1 hay không.' },
          { title: 'Chuẩn bị nền tảng với GRP', description: 'Xây dựng tư duy toàn cầu, tác phong chuyên nghiệp, và ngoại ngữ trước khi phỏng vấn.' },
          { title: 'Kết nối host company tại Mỹ', description: 'Tìm kiếm doanh nghiệp tiếp nhận và phỏng vấn trực tiếp vị trí thực tập.' },
          { title: 'Đối tác Sponsor xét duyệt DS-2019', description: 'Sponsor do Bộ Ngoại giao Mỹ cấp phép duyệt hồ sơ bảo trợ hành trình.' },
          { title: 'Phỏng vấn Visa & Khởi hành', description: 'Nhận visa J-1, hoàn tất chuẩn bị hành lý và bay sang Mỹ làm việc.' },
        ]}
      />
      <div class="cost-note reveal">
        <p><strong>Lưu ý về chi phí:</strong> SBB không đưa ra một biểu giá chung chung. Chi phí thực tế phụ thuộc vào ngành nghề của bạn, thời lượng và bang bạn làm việc. Mọi chi phí sẽ được minh bạch chi tiết ngay từ buổi trao đổi đầu tiên.</p>
      </div>
    </div>
  </section>

  <!-- Block 5: Sự thật nên biết (Heavy Section) -->
  <section class="section heavy-section" id="truths">
    <div class="container container--narrow reveal">
      <div style="margin-bottom: var(--space-10);">
        <span class="eyebrow-label" style="color: var(--accent-2);">REALITY CHECK</span>
        <h2>Sự thật nên biết</h2>
      </div>

      <div class="truth-grid">
        <div class="truth-card">
          <h3 class="truth-card__title">Đào tạo, không phải đi làm thuê giá rẻ</h3>
          <p>Visa J-1 được thiết kế cho việc học hỏi và phát triển chuyên môn thực tế thông qua Training Plan chi tiết. Bạn được trả lương bình đẳng, nhưng doanh nghiệp Mỹ có nghĩa vụ đào tạo bạn, không phải bóc lột sức lao động.</p>
        </div>
        <div class="truth-card">
          <h3 class="truth-card__title">Quy tắc cư trú 2 năm (Two-Year Rule)</h3>
          <p>Có một số trường hợp (như nhận tài trợ chính phủ hoặc thuộc danh sách ngành khan hiếm) yêu cầu bạn phải quay về Việt Nam tối thiểu 2 năm sau chương trình mới được chuyển đổi sang visa định cư hoặc làm việc dài hạn tại Mỹ.</p>
        </div>
        <div class="truth-card">
          <h3 class="truth-card__title">Chính sách có thể thay đổi</h3>
          <p>Quy định nhập cảnh và quản lý visa của chính phủ Mỹ có thể biến động. SBB cam kết đồng hành và xử lý linh hoạt, nhưng không ai có thể can thiệp hoặc cam kết trước quyết định pháp lý của cơ quan ngoại giao Mỹ.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Block 6: Đối tác -->
  <section class="section border-t" id="partners">
    <div class="container container--narrow text-center">
      <div class="reveal" style="margin-bottom: var(--space-8);">
        <span class="eyebrow-label">SPONSORS</span>
        <h2 class="section-heading">Designated Sponsors bảo trợ</h2>
      </div>
      <p class="partners-desc reveal">SBB hợp tác làm việc chặt chẽ cùng các tổ chức được Bộ Ngoại giao Mỹ cấp phép bảo trợ chương trình:</p>
      
      <div class="partner-row reveal">
        <span class="partner-logo">CIEE</span>
        <span class="partner-logo">CETUSA</span>
        <span class="partner-logo">Alliance Abroad (AAG)</span>
        <span class="partner-logo">IEEX</span>
      </div>
      <p class="partners-subtext reveal">và các tổ chức bảo trợ uy tín khác.</p>
    </div>
  </section>

  <!-- Block 7: Accordion FAQ -->
  <section class="section border-t" id="faq">
    <div class="container container--narrow">
      <div class="reveal" style="margin-bottom: var(--space-8);">
        <span class="eyebrow-label">FAQ</span>
        <h2 class="section-heading">Câu hỏi thường gặp</h2>
      </div>

      <div class="faq-accordion reveal">
        <details class="faq-item">
          <summary class="faq-question">Chương trình J-1 có giới hạn độ tuổi không?</summary>
          <div class="faq-answer">
            <p>Visa J-1 không giới hạn cứng độ tuổi trần, tuy nhiên bạn cần đáp ứng điều kiện về thời điểm tốt nghiệp (dưới 12 tháng đối với Intern) hoặc có kinh nghiệm làm việc thực tế (đối với Trainee) để đảm bảo hồ sơ thuyết phục Bộ Ngoại giao Mỹ.</p>
          </div>
        </details>

        <details class="faq-item">
          <summary class="faq-question">Tôi có được tự do chọn bang hoặc thành phố thực tập không?</summary>
          <div class="faq-answer">
            <p>Hồ sơ của bạn được kết nối với doanh nghiệp Mỹ phù hợp. Vị trí làm việc phụ thuộc vào việc doanh nghiệp tuyển dụng đặt trụ sở ở đâu. SBB ưu tiên kết nối với các doanh nghiệp uy tín, có môi trường hỗ trợ tốt hơn là chỉ nhắm vào các bang trung tâm.</p>
          </div>
        </details>

        <details class="faq-item">
          <summary class="faq-question">Tỷ lệ đạt visa J-1 tại đại sứ quán Mỹ là bao nhiêu?</summary>
          <div class="faq-answer">
            <p>J-1 là diện visa trao đổi văn hóa có tỷ lệ xét duyệt tương đối cởi mở hơn so với visa lao động thuần túy. Tuy nhiên, việc phỏng vấn thành công đòi hỏi bạn phải chứng minh được kế hoạch đào tạo thực tế rõ ràng và sự gắn kết quay trở về nước sau chương trình. SBB và GRP sẽ cùng bạn chuẩn bị kỹ lưỡng nội dung này.</p>
          </div>
        </details>
      </div>
    </div>
  </section>

  <!-- Block 8: CTA cuối -->
  <CTASection
    headline="Bắt đầu hành trình J-1"
    body="Đặt lịch nói chuyện trực tiếp để SBB đánh giá hồ sơ cá nhân và tư vấn con đường phù hợp nhất cho bạn."
    primaryCtaText="Đặt lịch nói chuyện về J-1"
    primaryCtaHref="/apply"
    secondaryCtaText="Hiểu sâu trên Learn"
    secondaryCtaHref="https://learn.sbb.vn/internship-j1"
  />

</PageLayout>

<style>
  .eyebrow-label {
    display: block;
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: var(--weight-bold);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: var(--space-4);
  }

  .display-heading {
    font-family: var(--font-headline);
    font-size: clamp(2.5rem, 5vw + 1rem, 5rem);
    line-height: 1.05;
    letter-spacing: var(--tracking-tight);
    margin-bottom: var(--space-6);
    color: var(--text-primary);
    text-transform: uppercase;
  }

  .j1-intro {
    font-size: var(--text-xl);
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
    max-width: var(--max-w-prose);
  }

  .section-heading {
    font-family: var(--font-headline);
    font-size: var(--text-3xl);
    font-weight: var(--weight-bold);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
  }

  .border-t {
    border-top: 1px solid var(--border);
  }

  /* Comparison Grid */
  .comparison-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
  }

  @media (min-width: 768px) {
    .comparison-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .numbered-card {
    border: 1px solid var(--line);
    background-color: var(--surface-card);
    padding: var(--space-8) var(--space-6);
    position: relative;
    border-radius: var(--radius-lg);
    transition: border-color var(--duration-normal) var(--ease-out),
                transform var(--duration-normal) var(--ease-out);
  }
  .numbered-card:hover {
    border-color: var(--accent);
    transform: translateY(-3px);
  }

  .card-num {
    position: absolute;
    top: var(--space-4);
    right: var(--space-6);
    font-family: var(--font-headline);
    font-size: var(--text-4xl);
    font-weight: var(--weight-bold);
    color: rgba(255, 255, 255, 0.07);
  }

  .comparison-card__title {
    font-family: var(--font-headline);
    font-size: var(--text-2xl);
    font-weight: var(--weight-bold);
    margin-bottom: var(--space-4);
    color: var(--accent);
    text-transform: uppercase;
  }

  .comparison-card__body p {
    font-size: var(--text-base);
    color: var(--text-secondary);
    line-height: var(--leading-normal);
    margin-bottom: var(--space-4);
  }

  .comparison-card__detail {
    font-size: var(--text-base);
    color: var(--text-primary) !important;
    border-top: 1px solid var(--line);
    padding-top: var(--space-3);
  }

  .comparison-card__note {
    font-size: var(--text-sm) !important;
    font-style: italic;
    color: var(--text-muted) !important;
  }

  /* AnchorStat block */
  .anchor-stat {
    display: inline-block;
    border: 1px solid var(--line);
    border-radius: var(--radius-xl);
    background: radial-gradient(circle at 50% 0%, rgba(255, 94, 58, 0.12), var(--surface-card) 70%);
    padding: var(--space-8) var(--space-12);
  }

  .anchor-stat__num {
    display: block;
    font-family: var(--font-headline);
    font-size: clamp(2.5rem, 5vw + 1rem, 4.5rem);
    font-weight: var(--weight-bold);
    color: var(--accent-2);
    line-height: 1;
    margin-bottom: var(--space-2);
  }

  .anchor-stat__caption {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--text-secondary);
    letter-spacing: var(--tracking-wide);
    margin: 0;
  }

  /* Industry Grid */
  .industry-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-3);
  }

  @media (min-width: 576px) {
    .industry-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .industry-item {
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: var(--text-secondary);
    padding: var(--space-3) var(--space-4);
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    background-color: var(--surface-card);
    transition: background-color var(--duration-fast) var(--ease-out),
                border-color var(--duration-fast) var(--ease-out),
                color var(--duration-fast) var(--ease-out);
  }

  .industry-item:hover {
    background-color: var(--surface-overlay);
    border-color: var(--accent);
    color: var(--ink);
  }

  .industry-note {
    font-size: var(--text-sm);
    color: var(--text-muted);
    font-style: italic;
    margin-top: var(--space-4);
  }

  /* StepFlow Cost Note */
  .cost-note {
    margin-top: var(--space-8);
    padding: var(--space-6);
    border: 2px dashed var(--line);
    font-style: italic;
  }

  .cost-note p {
    font-size: var(--text-base);
    color: var(--text-secondary);
    line-height: var(--leading-normal);
    margin: 0;
  }

  /* Truths Section */
  .truth-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
    margin-top: var(--space-10);
  }

  @media (min-width: 768px) {
    .truth-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .truth-card {
    border-left: 2px solid var(--accent-2);
    padding-left: var(--space-5);
  }

  .truth-card__title {
    font-family: var(--font-headline);
    font-size: var(--text-xl);
    font-weight: var(--weight-bold);
    color: var(--on-ink);
    margin-bottom: var(--space-3);
    text-transform: uppercase;
  }

  .truth-card p {
    font-size: var(--text-base);
    color: rgba(245, 241, 234, 0.7);
    line-height: var(--leading-normal);
  }

  /* Partners Section */
  .partners-desc {
    font-size: var(--text-base);
    color: var(--text-secondary);
    margin-bottom: var(--space-6);
  }

  .partner-row {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-8);
    margin-block: var(--space-6) var(--space-4);
  }

  .partner-logo {
    font-family: var(--font-headline);
    font-size: var(--text-xl);
    font-weight: var(--weight-bold);
    color: var(--text-primary);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
  }

  .partners-subtext {
    font-size: var(--text-xs);
    color: var(--text-muted);
    font-style: italic;
  }

  /* FAQ Accordion */
  .faq-accordion {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .faq-item {
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    background-color: var(--surface-card);
    overflow: hidden;
    transition: border-color var(--duration-fast) var(--ease-out);
  }

  .faq-item[open] {
    border-color: var(--line-dark);
  }

  .faq-question {
    font-family: var(--font-headline);
    font-size: var(--text-lg);
    font-weight: var(--weight-semibold);
    padding: var(--space-4) var(--space-6);
    cursor: pointer;
    user-select: none;
    outline: none;
    color: var(--text-primary);
  }

  .faq-answer {
    padding: 0 var(--space-6) var(--space-5);
    border-top: 1px solid var(--line);
  }

  .faq-answer p {
    font-size: var(--text-base);
    color: var(--text-secondary);
    line-height: var(--leading-normal);
    margin: var(--space-4) 0 0;
  }
</style>
