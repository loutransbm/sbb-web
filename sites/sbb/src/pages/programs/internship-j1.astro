---
import PageLayout from '@ui/layouts/PageLayout.astro';

// ===== Intern vs Trainee =====
const tracks = [
  {
    num: '01',
    title: 'Intern',
    body: 'Dành cho sinh viên đang học đại học/cao đẳng, hoặc đã tốt nghiệp không quá 12 tháng tính đến thời điểm nộp hồ sơ.',
    detail: 'Thời gian thực tập tối đa: 12 tháng.',
  },
  {
    num: '02',
    title: 'Trainee',
    body: 'Dành cho người có bằng đại học/cao đẳng cộng ít nhất 1 năm kinh nghiệm liên quan, HOẶC có 5 năm kinh nghiệm trong lĩnh vực liên quan (không yêu cầu bằng cấp).',
    detail: 'Thời gian tu nghiệp tối đa: 18 tháng. Riêng ngành Hospitality tối đa 12 tháng (trừ vị trí quản lý).',
  },
];

// ===== Stat chips =====
const stats = [
  { num: '18', label: 'Tháng tu nghiệp tối đa' },
  { num: 'J-1', label: 'Visa Exchange Visitor' },
  { num: '300K+', label: 'Người đến Mỹ mỗi năm' },
  { num: '10+', label: 'Nhóm ngành tiếp nhận' },
];

// ===== Industries =====
const industries = [
  'Hospitality & Tourism — Du lịch, Khách sạn',
  'Business & Commerce — Kinh doanh, Thương mại',
  'Finance & Accounting — Tài chính, Kế toán',
  'Information Technology — Công nghệ thông tin',
  'Engineering — Kỹ thuật',
  'Architecture & Design — Kiến trúc, Thiết kế',
  'Media & Communications — Truyền thông',
  'Sciences — Khoa học ứng dụng',
  'Agriculture — Nông nghiệp công nghệ cao',
  'Arts & Culture — Nghệ thuật, Văn hóa',
];

// ===== Process steps =====
const steps = [
  {
    num: '01',
    title: 'Tìm hiểu & đánh giá ban đầu',
    body: 'Nói chuyện thẳng thắn với SBB để hiểu rõ hồ sơ của bạn có thật sự hợp với J-1 hay không.',
  },
  {
    num: '02',
    title: 'Chuẩn bị nền tảng với GRP',
    body: 'Xây dựng tư duy toàn cầu, tác phong chuyên nghiệp và ngoại ngữ trước khi bước vào phỏng vấn.',
  },
  {
    num: '03',
    title: 'Kết nối host company tại Mỹ',
    body: 'Tìm kiếm doanh nghiệp tiếp nhận và phỏng vấn trực tiếp cho vị trí thực tập của bạn.',
  },
  {
    num: '04',
    title: 'Sponsor xét duyệt DS-2019',
    body: 'Tổ chức bảo trợ được Bộ Ngoại giao Mỹ cấp phép duyệt hồ sơ và cấp DS-2019 cho hành trình.',
  },
  {
    num: '05',
    title: 'Phỏng vấn visa & khởi hành',
    body: 'Nhận visa J-1, hoàn tất chuẩn bị hành lý và bay sang Mỹ bắt đầu làm việc thật.',
  },
];

// ===== Reality-check truths =====
const truths = [
  {
    title: 'Đào tạo, không phải lao động giá rẻ',
    body: 'Visa J-1 được thiết kế để học hỏi và phát triển chuyên môn thật qua một Training Plan chi tiết. Bạn được trả lương bình đẳng, và doanh nghiệp Mỹ có nghĩa vụ đào tạo bạn — không phải bóc lột sức lao động.',
  },
  {
    title: 'Quy tắc cư trú 2 năm',
    body: 'Một số trường hợp (nhận tài trợ chính phủ hoặc thuộc danh sách ngành khan hiếm) yêu cầu bạn quay về Việt Nam tối thiểu 2 năm sau chương trình mới được chuyển sang visa định cư hoặc làm việc dài hạn tại Mỹ.',
  },
  {
    title: 'Chính sách có thể thay đổi',
    body: 'Quy định nhập cảnh và quản lý visa của Mỹ có thể biến động. SBB cam kết đồng hành và xử lý linh hoạt, nhưng không ai có thể cam kết trước quyết định pháp lý của cơ quan ngoại giao Mỹ.',
  },
];

// ===== Sponsors =====
const sponsors = ['CIEE', 'CETUSA', 'Alliance Abroad (AAG)', 'IEEX'];
---

<PageLayout
  title="Thực tập & Tu nghiệp Quốc tế J-1"
  description="Chương trình thực tập và tu nghiệp quốc tế tại Mỹ theo visa J-1 Exchange Visitor — đi làm thật ở doanh nghiệp Mỹ."
  site="sbb"
  currentPath="/programs/internship-j1"
>
  <!-- ===== HERO ===== -->
  <section class="o-hero">
    <div class="container">
      <span class="o-eyebrow">Chương trình · Internship J-1</span>
      <h1 class="o-mega">ĐI LÀM THẬT<br />Ở DOANH NGHIỆP <span class="o-accent">MỸ</span></h1>
      <p class="o-lead">
        Mỗi năm hơn 300.000 người từ khắp thế giới đến Mỹ theo visa J-1 Exchange Visitor. Đây không phải visa du học thông thường — đây là con đường nghề nghiệp nghiêm túc để bạn trải nghiệm môi trường làm việc thực tế, nâng tầm năng lực và mang giá trị quốc tế trở về.
      </p>
      <div class="o-actions o-mt-lg">
        <a href="/apply" class="o-btn o-btn--primary">Đăng ký tư vấn</a>
        <a href="#how" class="o-btn o-btn--ghost">Xem lộ trình</a>
      </div>
    </div>
  </section>

  <!-- ===== OVERVIEW + STATS ===== -->
  <section class="o-section o-section--glow">
    <div class="container">
      <div class="o-split o-split--top">
        <div>
          <span class="o-head-eyebrow">Tổng quan</span>
          <p class="o-statement">
            Một chương trình nghề <span class="o-accent">đúng nghĩa</span> — không phải điểm dừng du lịch.
          </p>
        </div>
        <div>
          <ul class="o-checks">
            <li>Làm việc trực tiếp tại host company được Mỹ cấp phép, theo Training Plan rõ ràng.</li>
            <li>Được trả lương bình đẳng như nhân sự bản địa cùng vị trí.</li>
            <li>Bảo trợ bởi Designated Sponsor do Bộ Ngoại giao Mỹ chỉ định.</li>
            <li>SBB và GRP đồng hành từ đánh giá hồ sơ đến ngày khởi hành.</li>
          </ul>
        </div>
      </div>

      <hr class="o-divider" />

      <div class="o-stats">
        {stats.map((s) => (
          <div>
            <div class="o-stat__num">{s.num}</div>
            <div class="o-stat__label">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== INTERN OR TRAINEE ===== -->
  <section class="o-section o-section--tint">
    <div class="container">
      <div class="o-head">
        <span class="o-head-eyebrow">Bạn là ai</span>
        <h2 class="o-head-title">INTERN OR <span class="o-stroke">TRAINEE</span></h2>
        <p class="o-head-desc">Hai hướng đi, hai bộ điều kiện. Xác định đúng nhóm của bạn ngay từ đầu để chuẩn bị hồ sơ thuyết phục nhất.</p>
      </div>

      <div class="o-grid o-grid--2">
        {tracks.map((t) => (
          <article class="o-card">
            <span class="o-card__num">{t.num}</span>
            <h3 class="o-card__title">{t.title}</h3>
            <p class="o-card__body">{t.body}</p>
            <p class="o-card__body" style="margin-top:1rem;color:#fff;font-weight:600;">{t.detail}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== INDUSTRIES ===== -->
  <section class="o-section">
    <div class="container">
      <div class="o-head">
        <span class="o-head-eyebrow">Ngành nghề</span>
        <h2 class="o-head-title">WHERE YOU <span class="o-stroke">GO</span></h2>
        <p class="o-head-desc">Mười nhóm ngành chính đang tiếp nhận ứng viên J-1. Suất thực tế tùy thuộc ngành nghề và thời điểm tuyển dụng của host company.</p>
      </div>

      <div class="o-grid o-grid--2">
        {industries.map((name) => (
          <article class="o-card">
            <p class="o-card__body" style="color:#fff;font-weight:600;">{name}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== HOW IT WORKS ===== -->
  <section class="o-section o-section--tint o-section--glow" id="how">
    <div class="container">
      <div class="o-head">
        <span class="o-head-eyebrow">Lộ trình</span>
        <h2 class="o-head-title">HOW IT <span class="o-stroke">WORKS</span></h2>
        <p class="o-head-desc">Năm bước rõ ràng từ buổi nói chuyện đầu tiên đến ngày bạn đặt chân tới Mỹ.</p>
      </div>

      <div class="o-rows">
        {steps.map((s) => (
          <article class="o-row">
            <span class="o-row__num">{s.num}</span>
            <div>
              <h3 class="o-row__title">{s.title}</h3>
              <p class="o-row__body">{s.body}</p>
            </div>
          </article>
        ))}
      </div>

      <p class="o-note o-mt-lg" style="max-width:62ch;">
        <strong style="color:#fff;">Về chi phí:</strong> SBB không đưa ra biểu giá chung chung. Chi phí thực tế phụ thuộc vào ngành nghề, thời lượng và bang bạn làm việc — và sẽ được minh bạch chi tiết ngay từ buổi trao đổi đầu tiên.
      </p>
    </div>
  </section>

  <!-- ===== REALITY CHECK ===== -->
  <section class="o-section">
    <div class="container">
      <div class="o-head">
        <span class="o-head-eyebrow">Reality Check</span>
        <h2 class="o-head-title">THE TRUTH <span class="o-stroke">FIRST</span></h2>
        <p class="o-head-desc">Ba sự thật chúng tôi muốn bạn biết trước khi quyết định — để bạn đi với đôi mắt mở.</p>
      </div>

      <div class="o-grid o-grid--3">
        {truths.map((t) => (
          <article class="o-card">
            <span class="o-card__tag">Lưu ý</span>
            <h3 class="o-card__title">{t.title}</h3>
            <p class="o-card__body">{t.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== SPONSORS ===== -->
  <section class="o-section o-section--tint">
    <div class="container">
      <div class="o-split o-split--top">
        <div>
          <span class="o-head-eyebrow">Sponsors</span>
          <h2 class="o-statement">Được bảo trợ bởi tổ chức <span class="o-accent">chính danh</span>.</h2>
        </div>
        <div>
          <p class="o-note" style="max-width:54ch;margin-bottom:1.6rem;">
            SBB hợp tác chặt chẽ cùng các Designated Sponsor được Bộ Ngoại giao Mỹ cấp phép bảo trợ chương trình:
          </p>
          <div class="o-actions">
            {sponsors.map((name) => (
              <span class="o-pill"><b>{name}</b></span>
            ))}
          </div>
          <p class="o-note" style="margin-top:1.4rem;font-style:italic;">và các tổ chức bảo trợ uy tín khác.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== CTA ===== -->
  <section class="o-cta">
    <div class="container">
      <h2 class="o-cta__title">BẮT ĐẦU HÀNH TRÌNH J-1</h2>
      <p class="o-cta__sub">Đặt lịch nói chuyện trực tiếp để SBB đánh giá hồ sơ cá nhân và tư vấn con đường phù hợp nhất cho bạn.</p>
      <div class="o-actions">
        <a href="/apply" class="o-btn o-btn--primary">Đăng ký tư vấn</a>
        <a href="/programs" class="o-btn o-btn--ghost">Xem chương trình khác</a>
      </div>
    </div>
  </section>
</PageLayout>
