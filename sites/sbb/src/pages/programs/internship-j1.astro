  .rm-timeline { --node: clamp(46px, 4.6vw, 56px); position: relative; display: flex; flex-direction: column; gap: clamp(2rem, 3.5vw, 3.2rem); }
  .rm-timeline::before { content: ''; position: absolute; left: 50%; top: calc(var(--node) / 2); bottom: calc(var(--node) / 2); width: 2px; transform: translateX(-1px); background: linear-gradient(to bottom, rgba(255,92,38,0.75) 0%, rgba(242,66,11,0.4) 55%, rgba(242,66,11,0.10) 100%); }
  .rm-step { position: relative; display: grid; grid-template-columns: 1fr var(--node) 1fr; column-gap: clamp(1.5rem, 3vw, 3rem); align-items: center; }
  .rm-marker { grid-column: 2; display: flex; justify-content: center; position: relative; z-index: 1; }
  .rm-node { width: var(--node); height: var(--node); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-family: var(--font-headline); font-weight: 700; font-size: clamp(0.92rem, 1vw, 1.08rem); color: #fff; background: radial-gradient(circle at 50% 32%, rgba(242,66,11,0.5) 0%, rgba(22,9,4,0.96) 78%); border: 1px solid rgba(255,120,60,0.55); box-shadow: 0 0 0 5px rgba(242,66,11,0.05), 0 0 26px rgba(242,66,11,0.22); transition: transform 0.35s ease, box-shadow 0.35s ease, border-color 0.35s ease; }
  .rm-step:hover .rm-node { transform: scale(1.07); border-color: rgba(255,140,80,0.85); box-shadow: 0 0 0 6px rgba(242,66,11,0.09), 0 0 36px rgba(242,66,11,0.34); }
  .rm-title { margin: 0 0 0.45rem; font-family: var(--font-headline); font-weight: 700; font-size: clamp(1.12rem, 1.35vw, 1.4rem); color: #fff; line-height: 1.15; text-transform: none; }
  .rm-body { margin: 0; font-family: var(--font-body); font-size: 0.95rem; color: rgba(255,255,255,0.6); line-height: 1.55; }
  .rm-step:nth-child(odd) .rm-content { grid-column: 1; text-align: right; }
  .rm-step:nth-child(odd) .rm-body { margin-left: auto; max-width: 27rem; }
  .rm-step:nth-child(even) .rm-content { grid-column: 3; text-align: left; }
  .rm-step:nth-child(even) .rm-body { margin-right: auto; max-width: 27rem; }
  .rm-note { margin: clamp(2.5rem, 4vw, 3.75rem) auto 0; padding-top: clamp(1.5rem, 2.5vw, 2rem); border-top: 1px solid rgba(255,255,255,0.08); max-width: 52rem; text-align: center; font-family: var(--font-body); font-size: 0.95rem; color: rgba(255,255,255,0.55); line-height: 1.6; }
  .rm-note strong { color: #ff7a52; font-weight: 700; }
  @media (max-width: 760px) {
    .rm-timeline::before { left: calc(var(--node) / 2); }
    .rm-step { grid-template-columns: var(--node) 1fr; column-gap: clamp(1.1rem, 3vw, 1.6rem); align-items: start; }
    .rm-marker { grid-column: 1; }
    .rm-step .rm-content { grid-column: 2 !important; text-align: left !important; }
    .rm-step .rm-body { margin: 0 !important; max-width: none !important; }
  }

  .pr-rows { display: flex; flex-direction: column; gap: 0.7rem; }
  .pr-row { display: flex; gap: 1.4rem; align-items: flex-start; padding: 1.3rem 1.5rem; border-radius: 18px; border: 1px solid rgba(255,255,255,0.08); background: rgba(255,255,255,0.02); transition: border-color .3s ease, background .3s ease; }
  .pr-row:hover { border-color: rgba(242,66,11,0.3); background: rgba(242,66,11,0.04); }
  .pr-row__num { flex: 0 0 auto; font-family: var(--font-headline); font-weight: 700; font-size: 1.3rem; color: #f2420b; line-height: 1.4; min-width: 2.2rem; }
  .pr-row__title { font-family: var(--font-headline); font-weight: 700; font-size: 1.1rem; color: #fff; margin: 0 0 0.4rem; text-transform: none; }
  .pr-row__body { font-family: 'Inter', sans-serif; font-weight: 300; font-size: 0.96rem; line-height: 1.6; color: rgba(255,255,255,0.62); margin: 0; }
  .pr-note { margin: clamp(1.6rem, 3vw, 2.2rem) 0 0; max-width: 64ch; font-family: 'Inter', sans-serif; font-weight: 300; font-size: 0.95rem; line-height: 1.7; color: rgba(255,255,255,0.6); }
  .pr-note strong { color: #fff; font-weight: 600; }

  /* ===== PILLS (sponsors) ===== */
  .pr-pills { display: flex; flex-wrap: wrap; gap: 0.7rem; }
  .pr-pill { font-family: var(--font-headline); font-weight: 700; font-size: 0.9rem; color: #fff; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.16); border-radius: 999px; padding: 0.6rem 1.2rem; }

  /* ===== CTA ===== */
  .pr-cta-sec { padding-block: clamp(3rem, 6vw, 6rem) clamp(4rem, 8vw, 8rem); }
  .pr-cta { text-align: center; border-radius: 28px; padding: clamp(2.6rem, 5vw, 4rem) clamp(1.5rem, 4vw, 3rem); background: linear-gradient(135deg, #f2420b, #c2380a); box-shadow: 0 28px 66px -24px rgba(242,66,11,0.6); }
  .pr-cta__title { font-family: var(--font-headline); font-weight: 700; font-size: clamp(1.7rem, 3vw, 2.4rem); color: #fff; margin: 0 0 0.8rem; }
  .pr-cta__sub { font-family: 'Inter', sans-serif; font-weight: 300; font-size: 1.05rem; line-height: 1.6; color: rgba(255,255,255,0.92); margin: 0 auto 1.8rem; max-width: 52ch; }

  /* ===== Responsive ===== */
  @media (max-width: 980px) {
    .cs-line { flex-wrap: wrap; gap: 0.5rem; }
    .cs-line-1 { font-size: clamp(3.5rem, 16.8vw, 4.55rem) !important; letter-spacing: -0.097em !important; line-height: 0.92 !important; white-space: normal; }
    .pr-split { grid-template-columns: 1fr; }
    .pr-stats { grid-template-columns: repeat(2, 1fr); }
    .pr-grid--3 { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 600px) {
    .pr-grid--2, .pr-grid--3 { grid-template-columns: 1fr; }
    .pr-stats { grid-template-columns: 1fr 1fr; }
  }

  /* ===== ABOUT J-1 — card kính + glow đỉnh (kiểu MMRS CO.) ===== */
  /* A: ABOUT = panel kính trầm (không glow cam) · B: +đệm đáy tạo dải tối nghỉ trước INDUSTRIES */
  .about-sec { position: relative; padding-bottom: clamp(1.75rem, 3vw, 2.75rem); }
  .about-card { position: relative; z-index: 1; display: flex; flex-direction: column; justify-content: center; border-radius: clamp(28px, 3vw, 46px); border: 1px solid rgba(255,255,255,0.08); background: linear-gradient(180deg, rgba(255,255,255,0.035) 0%, rgba(255,255,255,0.012) 42%, rgba(255,255,255,0.004) 100%); padding: clamp(3rem, 6vw, 6.5rem) clamp(2rem, 5vw, 5.5rem); min-height: clamp(520px, 58vh, 640px); overflow: hidden; }
  /* tí ánh sáng cam hắt lên từ đáy card (clip theo bo góc) */
  .about-card::after { content: ''; position: absolute; left: 50%; bottom: 0; transform: translateX(-50%); width: min(74%, 58rem); height: clamp(190px, 25vw, 300px); z-index: 0; pointer-events: none; background: radial-gradient(60% 100% at 50% 100%, rgba(255,92,38,0.32) 0%, rgba(242,66,11,0.15) 36%, rgba(242,66,11,0.05) 62%, transparent 78%); filter: blur(14px); }
  .about-card__inner { position: relative; z-index: 1; display: flex; justify-content: space-between; align-items: flex-start; gap: clamp(2rem, 6vw, 6rem); flex-wrap: wrap; }
  .about-title .cs-line-1 { font-size: clamp(4rem, 6.8vw, 7.6rem); letter-spacing: -0.05em; line-height: 0.97; }
  .about-title .cs-line-2 { justify-content: flex-start; margin: 0; }
  .about-body { max-width: 31rem; margin: clamp(0.4rem, 0.8vw, 0.8rem) 0 0; color: rgba(255,255,255,0.60); font-family: var(--font-body); font-size: clamp(1rem, 1.12vw, 1.17rem); line-height: 1.62; }
  @media (max-width: 880px) {
    .about-card__inner { flex-direction: column; gap: clamp(1.4rem, 4vw, 2.4rem); }
    .about-body { max-width: 100%; }
  }

  /* ===== SPONSORS — hàng logo bảo trợ (mono trắng như hub) ===== */
  .spon-sec { text-align: center; padding-top: clamp(4.25rem, 7vw, 6rem); }
  .spon-eyebrow { font-family: var(--font-headline); font-weight: 700; font-size: 0.82rem; letter-spacing: 0.2em; text-transform: uppercase; color: #f2420b; margin: 0 auto clamp(3.75rem, 6vw, 5.25rem); }
  .spon-row { display: flex; flex-wrap: wrap; align-items: center; justify-content: center; gap: clamp(3rem, 6.5vw, 7rem); }
  .spon-logo img { height: clamp(54px, 6.2vw, 82px); width: auto; object-fit: contain; filter: brightness(0) invert(1) opacity(0.62); transition: filter 0.3s ease, transform 0.3s ease; }
  .spon-logo img:hover { filter: brightness(0) invert(1) opacity(1); transform: scale(1.05); }
  .spon-note { margin: clamp(3.75rem, 6vw, 5.25rem) auto 0; max-width: 40rem; font-family: var(--font-body); font-size: 0.95rem; color: rgba(255,255,255,0.5); line-height: 1.55; }

  /* ===== BENEFITS — lợi ích (card phẳng + icon cam, tách biệt với lưới lửa) ===== */
  .ben-sec { padding-top: clamp(5rem, 9vw, 8.5rem); }
  .ben-head { margin-bottom: clamp(4rem, 6.5vw, 6.5rem); }
  .ben-desc { margin: clamp(1rem, 1.6vw, 1.6rem) 0 0; max-width: 42rem; font-family: var(--font-body); font-size: clamp(1rem, 1.1vw, 1.15rem); color: rgba(255,255,255,0.6); line-height: 1.55; }
  .ben-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: clamp(1rem, 1.5vw, 1.6rem); }
  @media (max-width: 920px) { .ben-grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 560px) { .ben-grid { grid-template-columns: 1fr; } }
  .ben-card { position: relative; overflow: hidden; border-radius: 22px; border: 1px solid rgba(255,255,255,0.07); background: rgba(255,255,255,0.016); padding: clamp(2rem, 2.6vw, 2.85rem); min-height: clamp(248px, 26vh, 300px); display: flex; flex-direction: column; transition: transform 0.45s cubic-bezier(0.16,1,0.3,1), border-color 0.45s ease; }
  .ben-card::before { content: ''; position: absolute; left: 0; right: 0; bottom: 0; height: 62%; z-index: 0; opacity: 0; pointer-events: none; transition: opacity 0.5s ease; background: radial-gradient(80% 100% at 50% 100%, rgba(255,92,38,0.22) 0%, rgba(242,66,11,0.07) 46%, transparent 72%); }
  .ben-card:hover { transform: translateY(-5px); border-color: rgba(242,66,11,0.40); }
  .ben-card:hover::before { opacity: 1; }
  .ben-ico, .ben-title, .ben-body { position: relative; z-index: 1; }
  .ben-ico { display: inline-flex; align-self: flex-start; color: #ff5c26; }
  .ben-ico :global(svg) { width: 36px; height: 36px; }
  .ben-idx { position: absolute; z-index: 1; top: clamp(1.4rem, 1.9vw, 2rem); right: clamp(1.5rem, 2vw, 2.1rem); font-family: var(--font-headline); font-weight: 700; font-size: clamp(2.3rem, 3vw, 3.1rem); line-height: 1; color: rgba(255,255,255,0.07); }
  .ben-title { margin: auto 0 0.5rem; font-family: var(--font-headline); font-weight: 700; font-size: clamp(1.24rem, 1.5vw, 1.5rem); line-height: 1.12; color: #fff; }
  .ben-body { margin: 0; font-family: var(--font-body); font-size: 0.96rem; color: rgba(255,255,255,0.6); line-height: 1.55; }

  /* ===== GALLERY J-1 USA — loạt ảnh thật ===== */
  .gal-eyebrow { font-family: var(--font-headline); font-weight: 700; font-size: 0.82rem; letter-spacing: 0.2em; text-transform: uppercase; color: #f2420b; margin: 0 0 clamp(1.6rem, 2.6vw, 2.4rem); }
  .gal-row { display: grid; grid-template-columns: repeat(3, 1fr); gap: clamp(0.8rem, 1.2vw, 1.25rem); }
  .gal-item { position: relative; overflow: hidden; border-radius: 18px; border: 1px solid rgba(255,255,255,0.08); aspect-ratio: 4 / 5; margin: 0; }
  .gal-item img { width: 100%; height: 100%; object-fit: cover; object-position: center 32%; display: block; transition: transform 0.65s cubic-bezier(0.16,1,0.3,1); }
  .gal-item::after { content: ''; position: absolute; inset: 0; pointer-events: none; background: linear-gradient(to top, rgba(8,4,3,0.42) 0%, transparent 42%); }
  .gal-item:hover img { transform: scale(1.05); }
  @media (max-width: 640px) { .gal-row { grid-template-columns: 1fr 1fr; } }

  /* ===== ALL PARTNERS — marquee logo đối tác (bê từ hub) ===== */
  .allp-sec { text-align: center; overflow: clip; }
  .allp-eyebrow { font-family: var(--font-headline); font-weight: 700; font-size: 0.82rem; letter-spacing: 0.2em; text-transform: uppercase; color: #f2420b; margin: 0 auto clamp(1rem, 1.6vw, 1.4rem); }
  .allp-desc { margin: 0 auto clamp(2.75rem, 4.5vw, 4rem); max-width: 44rem; font-family: var(--font-body); font-size: clamp(1rem, 1.1vw, 1.15rem); color: rgba(255,255,255,0.6); line-height: 1.55; }
  .marquee-wrapper { width: 100%; overflow: hidden; position: relative; display: flex; flex-direction: column; gap: clamp(2.5rem, 4vw, 4.5rem); }
  .marquee-wrapper::before, .marquee-wrapper::after { content: ""; position: absolute; top: 0; width: 12%; height: 100%; z-index: 2; pointer-events: none; -webkit-backdrop-filter: blur(8px); backdrop-filter: blur(8px); }
  .marquee-wrapper::before { left: 0; -webkit-mask-image: linear-gradient(to right, black 0%, transparent 100%); mask-image: linear-gradient(to right, black 0%, transparent 100%); }
  .marquee-wrapper::after { right: 0; -webkit-mask-image: linear-gradient(to left, black 0%, transparent 100%); mask-image: linear-gradient(to left, black 0%, transparent 100%); }
  .marquee-track { display: flex; width: max-content; animation: marqueeScroll 45s linear infinite; }
  .marquee-track--reverse { animation-direction: reverse; }
  .marquee-content { display: flex; align-items: center; gap: clamp(3.5rem, 6vw, 7rem); padding-inline: clamp(1.75rem, 3vw, 3.5rem); }
  .partner-logo { display: flex; align-items: center; justify-content: center; user-select: none; }
  .partner-logo img { height: clamp(54px, 6vw, 78px); width: auto; object-fit: contain; image-rendering: -webkit-optimize-contrast; transform: translateZ(0); backface-visibility: hidden; will-change: transform, filter; filter: brightness(0) invert(1) opacity(0.58); transition: filter 0.3s ease, transform 0.3s ease; }
  .partner-logo img:hover { filter: brightness(0) invert(1) opacity(1); transform: scale(1.05) translateZ(0); }
  @keyframes marqueeScroll { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }
  @media (prefers-reduced-motion: reduce) { .marquee-track { animation: none; } }

  /* ===== INDUSTRIES — card từng ngành (quầng lửa đậm như hero stat) ===== */
  .ind-head { margin-bottom: clamp(3.75rem, 6vw, 6rem); }
  .ind-desc { margin: clamp(1rem, 1.6vw, 1.6rem) 0 0; max-width: 42rem; font-family: var(--font-body); font-size: clamp(1rem, 1.1vw, 1.15rem); color: rgba(255,255,255,0.6); line-height: 1.55; }
  .ind-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(15.5rem, 1fr)); gap: clamp(0.9rem, 1.2vw, 1.3rem); }
  .ind-card {
    position: relative; overflow: hidden;
    border-radius: 22px;
    border: 1px solid rgba(255,255,255,0.09);
    min-height: clamp(185px, 20vh, 222px);
    padding: clamp(1.5rem, 1.9vw, 2rem);
    display: flex; flex-direction: column; justify-content: flex-end;
    background:
      radial-gradient(125% 125% at 0% 100%, rgba(255,120,50,0.62) 0%, rgba(248,82,26,0.44) 24%, rgba(242,66,11,0.24) 45%, rgba(20,10,5,0.50) 72%, rgba(10,5,2,0.55) 100%),
      rgba(255,255,255,0.03);
    transition: transform 0.4s cubic-bezier(0.16,1,0.3,1), border-color 0.4s ease, box-shadow 0.4s ease;
  }
  .ind-card:hover { transform: translateY(-5px); border-color: rgba(242,66,11,0.55); box-shadow: 0 20px 44px -16px rgba(242,66,11,0.45); }
  .ind-card__num { margin: 0 0 auto; font-family: var(--font-headline); font-weight: 700; font-size: 0.8rem; letter-spacing: 0.14em; color: rgba(255,255,255,0.55); }
  .ind-card__name { margin: 0 0 0.4rem; font-family: var(--font-headline); font-weight: 700; font-size: clamp(1.12rem, 1.32vw, 1.36rem); line-height: 1.14; color: #fff; }
  .ind-card__vi { margin: 0; font-family: var(--font-body); font-size: 0.9rem; color: rgba(255,255,255,0.68); line-height: 1.4; }
  @media (max-width: 560px) { .ind-grid { grid-template-columns: 1fr 1fr; } }

  /* ===== SECTION VIDEO "LIFE BEYOND BORDERS" — bê từ trang chủ (bản DARK) ===== */
  .moments-section { position: relative; z-index: 8; padding: var(--sec-pad) 0; background: transparent; overflow: visible; }
  /* quầng sáng cam mềm hắt lên từ đáy section video */
  .moments-section::after { content: ''; position: absolute; left: 50%; bottom: 0; transform: translateX(-50%); width: 130%; height: 60%; z-index: 0; pointer-events: none; background: radial-gradient(62% 100% at 50% 100%, rgba(255,92,38,0.30) 0%, rgba(242,66,11,0.16) 34%, rgba(242,66,11,0.06) 60%, transparent 80%); filter: blur(10px); }
  .mv-container { max-width: 120rem; margin: 0 auto; padding: 0 2rem; position: relative; z-index: 1; } /* khớp bề rộng hero (pr-wrap) — header + coverflow rộng như homepage, hết chật chữ */
  .mvh { margin-bottom: clamp(4rem, 7.5vw, 7rem); }
  /* BORDERS = TO bằng LIFE BEYOND (cs-line-1, 175px). Scope trong moments để KHÔNG đụng "J-1 USA" của hero (cũng cs-line-2). */
  .moments-section .cs-line-2 { font-size: clamp(8.5rem, 12vw, 11rem); letter-spacing: -0.085em; }
  .mvh-bottom { display: flex; flex-direction: column; align-items: flex-end; margin-top: 1rem; }
  .mvh-line2 { justify-content: flex-end; }
  .mvh-line2 .mvh-fade { margin-right: clamp(2rem, 5vw, 5rem); }
  .mvh-fade { color: #ffffff; }
  @media (max-width: 820px) { .mvh-bottom { align-items: flex-start; } .mvh-line2 { justify-content: flex-start; } }
  .mv-stage { position: relative; }
  .mv-track { position: relative; height: 560px; perspective: 1600px; overflow: visible; cursor: grab; touch-action: pan-y; }
  .mv-track.is-grabbing { cursor: grabbing; }
  .mv-card { position: absolute; left: 50%; top: 50%; width: 300px; height: 524px; border-radius: 22px; overflow: hidden; border: 1px solid rgba(255, 255, 255, 0.10); background: linear-gradient(160deg, #2a1109, #160a05); transform-origin: center center; backface-visibility: hidden; opacity: 0; transition: box-shadow 0.45s ease, border-color 0.45s ease; will-change: transform, opacity; user-select: none; }
  .mv-card.is-active { box-shadow: 0 18px 48px -12px rgba(0, 0, 0, 0.5), 0 0 70px rgba(242, 66, 11, 0.12); border-color: rgba(242, 66, 11, 0.35); }
  .mv-card--video { appearance: none; -webkit-appearance: none; padding: 0; margin: 0; font: inherit; cursor: pointer; }
  .mv-card--video::after { content: ''; position: absolute; inset: 0; z-index: 1; pointer-events: none; background: radial-gradient(circle at 50% 46%, rgba(0,0,0,0.22), transparent 52%), linear-gradient(to top, rgba(8,4,3,0.55), transparent 42%); }
  .mv-play { position: absolute; inset: 0; margin: auto; z-index: 3; width: 60px; height: 60px; border-radius: 50%; display: flex; align-items: center; justify-content: center; background: rgba(242, 66, 11, 0.92); box-shadow: 0 12px 34px rgba(0,0,0,0.22), inset 0 0 0 1px rgba(255,255,255,0.25); transition: transform 0.35s cubic-bezier(0.16,1,0.3,1), background 0.25s ease; }
  .mv-play::after { content: ''; width: 0; height: 0; margin-left: 4px; border-style: solid; border-width: 10px 0 10px 17px; border-color: transparent transparent transparent #fff; }
  .mv-card--video.is-active .mv-play { transform: scale(1.06); }
  .mv-card--video:hover .mv-play, .mv-card--video:focus-visible .mv-play { background: #f2420b; transform: scale(1.13); }
  .mv-card--video.is-active::after { opacity: 0; }
  .mv-pp { position: absolute; left: 50%; top: 50%; transform: translate(-50%, -50%) scale(0.8); z-index: 200; width: 84px; height: 84px; border-radius: 50%; pointer-events: none; cursor: pointer; background: rgba(242, 66, 11, 0.94); -webkit-backdrop-filter: blur(2px); backdrop-filter: blur(2px); box-shadow: 0 14px 38px rgba(0, 0, 0, 0.22), inset 0 0 0 1px rgba(255, 255, 255, 0.25); display: flex; align-items: center; justify-content: center; opacity: 0; transition: opacity 0.25s ease, transform 0.25s ease, background 0.2s ease; }
  .mv-pp::after { content: ''; width: 0; height: 0; margin-left: 6px; border-style: solid; border-width: 13px 0 13px 22px; border-color: transparent transparent transparent #fff; }
  .mv-stage.is-paused .mv-pp { opacity: 1; transform: translate(-50%, -50%) scale(1); pointer-events: auto; }
  .mv-stage.is-paused .mv-pp:hover { background: #f2420b; transform: translate(-50%, -50%) scale(1.08); }
  .mv-lightbox { position: fixed; inset: 0; z-index: 9999; display: none; flex-direction: column; align-items: center; justify-content: center; gap: 0.9rem; padding: 1.5rem; background: rgba(6, 3, 2, 0.88); -webkit-backdrop-filter: blur(6px); backdrop-filter: blur(6px); }
  .mv-lightbox.is-open { display: flex; }
  .mv-lb-frame { position: relative; width: auto; max-width: 96vw; max-height: 86vh; overflow: hidden; border-radius: 16px; background: transparent; -ms-overflow-style: none; scrollbar-width: none; }
  .mv-lb-frame::-webkit-scrollbar { display: none; }
  .mv-lb-tt { color: rgba(255,255,255,0.82); font-size: 0.9rem; letter-spacing: 0.02em; text-decoration: none; border-bottom: 1px solid rgba(255,255,255,0.35); padding-bottom: 2px; }
  .mv-lb-tt:hover { color: #ff5c26; border-color: #ff5c26; }
  :global(.mv-lb-video) { display: block; width: auto; height: auto; max-width: 96vw; max-height: 86vh; border-radius: 16px; background: #000; }
  :global(.mv-lb-sound) { position: absolute; top: 0.8rem; left: 50%; transform: translateX(-50%); z-index: 3; border: 0; border-radius: 999px; cursor: pointer; background: rgba(242, 66, 11, 0.94); color: #fff; font: 600 0.9rem/1 'Be Vietnam Pro', system-ui, sans-serif; letter-spacing: 0.02em; padding: 0.55rem 1.05rem; box-shadow: 0 6px 18px rgba(0, 0, 0, 0.3); }
  :global(.mv-lb-sound:hover) { background: #f2420b; }
  .mv-lb-close { position: absolute; top: 1.1rem; right: 1.3rem; z-index: 2; width: 2.8rem; height: 2.8rem; border-radius: 50%; border: 1px solid rgba(255,255,255,0.25); background: rgba(20,10,6,0.7); color: #fff; font-size: 1.8rem; line-height: 1; cursor: pointer; display: flex; align-items: center; justify-content: center; }
  .mv-lb-close:hover { background: rgba(242, 66, 11, 0.9); border-color: transparent; }
  .mv-photo { position: absolute; inset: 0; }
  .mv-photo img, .mv-photo video { width: 100%; height: 100%; object-fit: cover; object-position: center 35%; display: block; background: #000; }
  .mv-nav { position: absolute; top: 50%; transform: translateY(-50%); z-index: 6; width: 3rem; height: 3rem; border-radius: 50%; display: flex; align-items: center; justify-content: center; padding-bottom: 0.15rem; border: 1px solid rgba(255, 255, 255, 0.18); background: rgba(255, 255, 255, 0.92); color: #1a1a1a; font-size: 1.6rem; line-height: 1; cursor: pointer; opacity: 0; transition: opacity 0.25s ease, background 0.2s ease, transform 0.2s ease; }
  .mv-stage:hover .mv-nav { opacity: 1; }
  .mv-nav:hover { background: rgba(242, 66, 11, 0.9); border-color: transparent; color: #fff; }
  .mv-nav--prev { left: 0.5rem; }
  .mv-nav--next { right: 0.5rem; }
  @media (max-width: 700px) { .mv-card { width: 76vw; height: 132vw; } .mv-track { height: 138vw; } .mv-nav { display: none; } }
  @media (max-width: 768px) {
    .pr-wrap, .pr-hero__wrap { width: calc(100% - 1rem) !important; }
  }

  /* ===== VISA GALLERY ===== */
  .visa-head { margin-bottom: clamp(2.5rem, 5vw, 4rem); }
  .visa-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: clamp(0.75rem, 1.5vw, 1.25rem);
  }
  .visa-item { border-radius: 18px; overflow: hidden; aspect-ratio: 9 / 16; background: #1a0a04; }
  .visa-item img { width: 100%; height: 100%; object-fit: contain; display: block; }
  .visa-item:hover img { transform: scale(1.02); transition: transform 0.4s ease; }
  @media (max-width: 600px) { .visa-grid { gap: 0.5rem; } .visa-item { border-radius: 12px; } }
</style>

<script>
  /* Coverflow "LIFE BEYOND BORDERS" — bê nguyên từ trang chủ (vòng lặp vô tận + lightbox tự host MP4) */
  (function () {
    const track = document.getElementById('mv-track');
    if (!track) return;
    const cards = Array.prototype.slice.call(track.children).filter((c) => c.classList.contains('mv-card'));
    const N = cards.length;
    if (!N) return;
    const prev = document.getElementById('mv-prev');
    const next = document.getElementById('mv-next');
    const stage = track.closest('.mv-stage');
    let pos = 0, target = 0, raf = null, timer = null, cw = 300, activeI = -1, soundOn = false, inView = false, wantPlay = false;

    function measure() { cw = cards[0].offsetWidth || 300; }
    function wrap(o) { o = ((o % N) + N) % N; if (o > N / 2) o -= N; return o; }

    function place() {
      const spacing = cw * 0.8;
      for (let i = 0; i < N; i++) {
        const off = wrap(i - pos);
        const ao = Math.abs(off);
        const k = ao > 3.2 ? 3.2 : ao;
        const kk = (off < 0 ? -1 : 1) * k;
        const c = cards[i];
        c.style.visibility = ao > 3.6 ? 'hidden' : 'visible';
        c.style.transform = 'translate(-50%, -50%) translateX(' + (kk * spacing).toFixed(1) +
          'px) translateZ(' + (-k * 120).toFixed(0) + 'px) rotateY(' + (-kk * 20).toFixed(1) +
          'deg) scale(' + (1 - k * 0.14).toFixed(3) + ')';
        c.style.opacity = (ao > 3.4 ? 0 : Math.max(0.25, 1 - k * 0.3)).toFixed(2);
        c.style.zIndex = String(100 - Math.round(k * 10));
      }
      const cur = ((Math.round(pos) % N) + N) % N;
      if (cur !== activeI) {
        if (cards[activeI]) { cards[activeI].classList.remove('is-active'); const ov = cards[activeI].querySelector('video'); if (ov) { ov.pause(); try { ov.currentTime = 0; } catch (_) {} } }
        cards[cur].classList.add('is-active');
        activeI = cur;
        wantPlay = false; stage.classList.add('is-paused');
      }
    }
    function frame() {
      raf = null;
      const diff = target - pos;
      if (Math.abs(diff) < 0.001) pos = target; else pos += diff * 0.18;
      place();
      if (pos !== target) raf = requestAnimationFrame(frame);
    }
    function animate() { if (!raf) raf = requestAnimationFrame(frame); }

    function startAuto() {}
    function stopAuto() { if (timer) { clearInterval(timer); timer = null; } }
    prev && prev.addEventListener('click', () => { target -= 1; stopAuto(); startAuto(); animate(); });
    next && next.addEventListener('click', () => { target += 1; stopAuto(); startAuto(); animate(); });
    stage.addEventListener('pointerenter', stopAuto);
    stage.addEventListener('pointerleave', startAuto);

    const lb = document.getElementById('mv-lightbox');
    const lbFrame = document.getElementById('mv-lb-frame');
    const lbClose = document.getElementById('mv-lb-close');
    const lbTt = document.getElementById('mv-lb-tt');
    function openLightbox(card) {
      if (!lb || !card) return;
      stopAuto();
      var img = card.querySelector('img');
      var poster = img ? img.getAttribute('src') : '';
      var src = poster.replace('/images/tiktok/', '/videos/').replace(/\.jpg$/, '.mp4');
      var id = card.getAttribute('data-tt');
      lbFrame.innerHTML =
        '<video class="mv-lb-video" src="' + src + '" poster="' + poster + '" autoplay muted loop playsinline controls preload="auto" style="display:block;width:auto;height:auto;max-width:96vw;max-height:86vh;border-radius:16px;background:#000;"></video>'
        + '<button class="mv-lb-sound" type="button" aria-label="Bật tiếng">&#128266; Bật tiếng</button>';
      if (lbTt) lbTt.href = 'https://www.tiktok.com/@duyendao222/video/' + id;
      lb.classList.add('is-open'); lb.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
      var v = lbFrame.querySelector('video');
      var sb = lbFrame.querySelector('.mv-lb-sound');
      if (v) {
        v.muted = true;
        var p = v.play(); if (p && p.catch) p.catch(function () {});
        if (sb) {
          sb.addEventListener('click', function () { v.muted = false; v.volume = 1; if (v.paused) { var q = v.play(); if (q && q.catch) q.catch(function () {}); } sb.style.display = 'none'; });
          v.addEventListener('volumechange', function () { if (!v.muted) sb.style.display = 'none'; });
        }
      }
    }
    function closeLightbox() {
      if (!lb || !lb.classList.contains('is-open')) return;
      lb.classList.remove('is-open'); lb.setAttribute('aria-hidden', 'true');
      lbFrame.innerHTML = '';
      document.body.style.overflow = '';
      startAuto();
    }
    lbClose && lbClose.addEventListener('click', closeLightbox);
    lb && lb.addEventListener('click', (e) => { if (e.target === lb) closeLightbox(); });
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeLightbox(); });

    let down = false, sx = 0, st = 0, drag = 0, downOnActive = false;
    track.addEventListener('pointerdown', (e) => { down = true; sx = e.clientX; st = target; drag = 0; track.classList.add('is-grabbing'); stopAuto(); const c = e.target.closest && e.target.closest('.mv-card'); downOnActive = !!(c && c.classList.contains('is-active')); try { track.setPointerCapture(e.pointerId); } catch (_) {} });
    track.addEventListener('pointermove', (e) => { if (!down) return; const dx = e.clientX - sx; if (Math.abs(dx) > drag) drag = Math.abs(dx); target = st - dx / (cw * 0.8); pos = target; place(); });
    const up = () => { if (!down) return; down = false; track.classList.remove('is-grabbing'); const wasTap = drag < 10; target = Math.round(target); animate(); if (wasTap && downOnActive) toggleActive(); };
    track.addEventListener('pointerup', up);
    track.addEventListener('pointercancel', up);
    track.addEventListener('dragstart', (e) => e.preventDefault());
    function toggleActive() {
      const v = curVideo(); if (!v) return;
      if (v.paused) { wantPlay = true; soundOn = true; v.muted = false; const p = v.play(); if (p && p.catch) p.catch(function () {}); stage.classList.remove('is-paused'); }
      else { wantPlay = false; v.pause(); stage.classList.add('is-paused'); }
    }
    function curVideo() { return cards[activeI] ? cards[activeI].querySelector('video') : null; }
    const pp = document.getElementById('mv-pp');
    if (pp) pp.addEventListener('click', function (e) { e.stopPropagation(); toggleActive(); });
    cards.forEach(function (card) {
      const cv = card.querySelector('video');
      if (cv) cv.addEventListener('pause', function () {
        if (wantPlay && inView && card.classList.contains('is-active')) { const p = cv.play(); if (p && p.catch) p.catch(function () {}); }
      });
    });
    function checkInView() {
      const r = stage.getBoundingClientRect();
      const vis = r.top < window.innerHeight && r.bottom > 0;
      if (vis !== inView) {
        inView = vis;
        if (!inView) { const v = curVideo(); if (v) v.pause(); wantPlay = false; stage.classList.add('is-paused'); }
      }
    }
    setInterval(checkInView, 300);
    window.addEventListener('resize', checkInView);
    checkInView();

    measure();
    place();
    window.addEventListener('resize', () => { measure(); place(); });
    if (window.ResizeObserver) new ResizeObserver(() => { measure(); place(); }).observe(track);
    startAuto();
  })();
</script>
