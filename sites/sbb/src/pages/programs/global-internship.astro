          <div class="partner-logo"><img src="/images/partners/alliance.png" alt="Alliance Abroad" /></div>
          <div class="partner-logo"><img src="/images/partners/ciee.png" alt="CIEE" /></div>
          <div class="partner-logo"><img src="/images/partners/australian-internships.png" alt="Australian Internships" /></div>
        </div>
