---
// Global Internship — TRANG TỔNG QUAN. Hero + Section logo đối tác + lưới điểm đến.
import PageLayout from '@ui/layouts/PageLayout.astro';

// Các điểm đến thực tập. open:true = card mở (bấm vào trang chi tiết); còn lại = đang cập nhật.
const destinations = [
  { title: 'INTERNSHIP USA',       tag: 'J-1 Visa',  img: '/images/case-studies/cs1.jpg',  href: '/programs/internship-j1', open: true },
  { title: 'INTERNSHIP AUSTRALIA', tag: 'Visa 407',  img: '/images/case-studies/cs4.webp', href: '/programs/407',           open: true },
  { title: 'INTERNSHIP EU',        open: false },
  { title: 'INTERNSHIP SINGAPORE', open: false },
  { title: 'INTERNSHIP CANADA',    open: false },
  { title: 'INTERNSHIP JAPAN',     open: false },
  { title: 'INTERNSHIP KOREA',     open: false },
  { title: 'INTERNSHIP UK',        open: false },
  { title: 'INTERNSHIP UAE',       open: false },
];
---

<PageLayout
  title="Global Internship — Thực tập Quốc tế"
  description="Global Internship của SBB: thực tập quốc tế có trả lương. J-1 Hoa Kỳ là mũi nhọn, và SBB đang mở rộng sang nhiều quốc gia khác."
  site="sbb"
  currentPath="/programs/global-internship"
>
  <!-- ===== HERO ===== -->
  <section class="pr-hero">
    <div class="pr-hero__beam" aria-hidden="true"></div>
    <div class="pr-hero__wrap">
      <div class="cs-header about-hero-head">
        <div class="cs-line cs-line-1">
          <span class="cs-text-white">GLOBAL</span>
          <div class="cs-glass-pill">
            <span class="cs-glass-title">NHIỀU ĐIỂM ĐẾN</span>
            <span class="cs-glass-sub">J-1 Hoa Kỳ dẫn đầu, các nước khác đang mở thêm.</span>
          </div>
        </div>
        <div class="about-line-2">
          <span class="about-verb cs-text-white">INTERNSHIP</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== SECTION LOGO ĐỐI TÁC (marquee, copy từ home) ===== -->
  <section class="partner-marquee-section">
    <div class="partner-text-block">
      <h2 class="partner-headline">
        MINDSET. CONDUCT. CAPABILITY.<br/>
        NĂNG LỰC THỰC CHẤT CHO SỰ NGHIỆP TOÀN CẦU.<br/>
        <span class="headline-dimmed">KIẾN TẠO THẾ HỆ NGƯỜI TRẺ VIỆT ĐƯỢC TIN VÀ ĐƯỢC TRỌNG DỤNG.</span>
      </h2>
      <p class="partner-subtext">
        Mạng lưới đối tác doanh nghiệp uy tín, mở ra cơ hội<br/>
        thực tập và làm việc không giới hạn.
      </p>
    </div>

    <div class="marquee-wrapper">
      <div class="marquee-track">
        <div class="marquee-content">
          <div class="partner-logo"><img src="/images/partners/marriott.png" alt="Marriott" /></div>
