---
// Office Tour — chia theo Tier/khu vực (Bình dân: Singapore, Châu Á · Premium: Anh, Mỹ).
// TRANG ĐANG XÂY DỰNG: hiện chỉ để mô tả, các hạng mục chưa click vào được.
// Hệ dark-fire đồng bộ hub/trang chủ. KHÔNG card trắng.
import PageLayout from '@ui/layouts/PageLayout.astro';

// Phân hạng theo Tier — tạm thời chỉ mô tả, chưa mở từng điểm đến
const tiers = [
  { tag: 'Phổ thông · Đang xây dựng', title: 'Bình dân', region: 'Singapore · Châu Á', body: 'Các điểm đến chi phí hợp lý, dễ tiếp cận. Phù hợp để thử một bước ngắn vào môi trường doanh nghiệp quốc tế ở gần.' },
  { tag: 'Cao cấp · Đang xây dựng', title: 'Premium', region: 'Anh · Mỹ', body: 'Vào tận văn phòng những tập đoàn đầu ngành như JP Morgan. Trải nghiệm chiều sâu, đắt giá, cho người muốn nhìn thẳng vào đỉnh của nghề.' },
];

const overview = [
  { num: '01', title: 'Vào tận văn phòng, không đứng ngoài nhìn', body: 'Bạn không tham quan kiểu khách du lịch. Bạn bước vào văn phòng những tập đoàn toàn cầu, ngồi cùng người làm thật, làm việc thật và quan sát cách một tổ chức lớn vận hành mỗi ngày.' },
  { num: '02', title: 'Đồng sáng lập cùng Career Mates', body: 'Office Tour được SBB đồng sáng lập với Career Mates. Mạng lưới doanh nghiệp và cách tổ chức được dựng để mỗi ngày bạn ở đó đều có giá trị, có người hướng dẫn thật chứ không bỏ mặc.' },
  { num: '03', title: 'Một bước thử trước khi cam kết đường dài', body: 'Chưa chắc mình hợp với môi trường quốc tế? Office Tour là cách thử ngắn hạn, ít rủi ro, để bạn cảm nhận thật trước khi quyết định đi xa hơn với J-1 hay các con đường dài hạn.' },
];

const experiences = [
  { tag: 'Top Global Companies', title: 'Bên trong tập đoàn toàn cầu', body: 'Đặt chân vào những cái tên hàng đầu như JP Morgan và nhiều tập đoàn quốc tế khác, mỗi doanh nghiệp dành trọn 2 ngày để bạn quan sát và trải nghiệm từ bên trong.' },
  { tag: 'Real Work', title: 'Làm việc thật, hướng dẫn thật', body: 'Không phải nghe thuyết trình rồi về. Bạn được giao việc, tham gia nhịp làm việc và có người trong doanh nghiệp dẫn dắt, giải đáp ngay tại chỗ.' },
  { tag: 'Culture & Travel', title: 'Trải nghiệm kết hợp khám phá', body: 'Giữa những ngày trong văn phòng là thời gian khám phá thành phố, văn hóa và con người bản địa, để chuyến đi vừa là bước nghề, vừa là một hành trình đáng nhớ.' },
  { tag: 'Flexible Packages', title: 'Nhiều gói thời gian linh hoạt', body: 'Từ 5 đến 10 ngày, có các gói thời gian khác nhau để bạn chọn theo lịch và mục tiêu của mình, đủ ngắn để bắt đầu, đủ sâu để thấy rõ.' },
];

const stats = [
  { num: '5–10', label: 'Ngày trong doanh nghiệp' },
  { num: '02', label: 'Ngày cho mỗi công ty' },
  { num: '∞', label: 'Góc nhìn về nghề toàn cầu' },
];

const agenda = [
  { num: '01', title: 'Chọn gói và chốt lịch', body: 'Bắt đầu bằng một cuộc trao đổi để hiểu mục tiêu của bạn. SBB tư vấn gói thời gian phù hợp và sắp xếp lịch trình rõ ràng trước khi đi.' },
  { num: '02', title: 'Chuẩn bị trước khi vào doanh nghiệp', body: 'Bạn được hướng dẫn về tác phong, cách quan sát và đặt câu hỏi, để mỗi ngày trong văn phòng đều khai thác được nhiều nhất chứ không lãng phí.' },
  { num: '03', title: 'Vào từng công ty, mỗi nơi 2 ngày', body: 'Lần lượt bước vào các tập đoàn trong lịch trình. Mỗi doanh nghiệp 2 ngày làm việc và quan sát thật, có người hướng dẫn đi cùng bạn suốt quá trình.' },
  { num: '04', title: 'Khám phá và đúc kết', body: 'Đan xen là thời gian trải nghiệm văn hóa bản địa. Khép lại hành trình, bạn nhìn lại điều mình học được và cùng SBB định hình bước đi tiếp theo.' },
];
---

<PageLayout
  title="Office Tour"
  description="5 đến 10 ngày vào doanh nghiệp toàn cầu làm việc thật, có hướng dẫn thật. Chia theo Tier từ bình dân tới premium. Trang đang xây dựng."
  site="sbb"
  currentPath="/programs/office-tour"
>
  <!-- ===== HERO ===== -->
  <section class="pr-hero">
    <div class="pr-hero__beam" aria-hidden="true"></div>
    <div class="pr-hero__wrap">
      <div class="cs-header">
        <div class="cs-line cs-line-1"><span class="cs-text-white">OFFICE TOUR</span></div>
      </div>
      <p class="pr-lead">5 đến 10 ngày bước vào doanh nghiệp toàn cầu, làm việc thật và có người hướng dẫn thật. Một bước thử ngắn, ít rủi ro, trước khi bạn cam kết một con đường dài hơi ra thế giới.</p>
      <span class="pr-build">Trang đang được xây dựng. Thông tin từng điểm đến sẽ sớm cập nhật.</span>
    </div>
  </section>

  <!-- ===== TIERS (chia hạng — chưa click vào được) ===== -->
  <section class="pr-sec pr-sec--beam">
    <div class="pr-beam pr-beam--right" aria-hidden="true"></div>
    <div class="pr-wrap">
      <div class="pr-head">
        <span class="pr-eyebrow">Phân hạng</span>
        <h2 class="pr-h2">Chọn theo <span class="pr-accent">Tier</span></h2>
        <p class="pr-desc">Office Tour chia theo khu vực và mức trải nghiệm, từ bình dân tới premium, để bạn chọn đúng với mục tiêu và ngân sách. Các điểm đến đang được hoàn thiện.</p>
      </div>
      <div class="pr-grid pr-grid--2">
        {tiers.map((t) => (
          <div class="pr-card pr-card--soon" aria-disabled="true">
            <span class="pr-card__tag pr-card__tag--soon">{t.tag}</span>
            <h3 class="pr-card__title">{t.title}</h3>
            <p class="pr-card__region">{t.region}</p>
            <p class="pr-card__body">{t.body}</p>
            <span class="pr-card__more pr-card__more--soon">Đang xây dựng</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== OVERVIEW (THE IDEA) ===== -->
  <section class="pr-sec">
    <div class="pr-wrap">
      <div class="pr-head">
        <span class="pr-eyebrow">Tổng quan</span>
        <h2 class="pr-h2">Ý tưởng <span class="pr-accent">cốt lõi</span></h2>
        <p class="pr-desc">Office Tour không phải một chuyến tham quan. Đây là cách ngắn nhất để cảm nhận nghề nghiệp toàn cầu từ bên trong: thật, gần và có người dẫn đường.</p>
      </div>
      <div class="pr-rows">
        {overview.map((b) => (
          <article class="pr-row">
            <span class="pr-row__num">{b.num}</span>
            <div><h3 class="pr-row__title">{b.title}</h3><p class="pr-row__body">{b.body}</p></div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== WHAT YOU'LL SEE ===== -->
  <section class="pr-sec pr-sec--beam">
    <div class="pr-beam pr-beam--right" aria-hidden="true"></div>
    <div class="pr-wrap">
      <div class="pr-head">
        <span class="pr-eyebrow">Trải nghiệm</span>
        <h2 class="pr-h2">Bạn sẽ <span class="pr-accent">thấy gì</span></h2>
        <p class="pr-desc">Mỗi ngày trong Office Tour được dựng để bạn vừa thấy cách vận hành thật, vừa được làm, vừa được khám phá.</p>
      </div>
      <div class="pr-grid pr-grid--2">
        {experiences.map((e) => (
          <article class="pr-card">
            <span class="pr-card__tag">{e.tag}</span>
            <h3 class="pr-card__title">{e.title}</h3>
            <p class="pr-card__body">{e.body}</p>
          </article>
        ))}
      </div>
      <div class="pr-stats">
        {stats.map((s) => (
          <div class="pr-stat"><span class="pr-stat__num">{s.num}</span><span class="pr-stat__label">{s.label}</span></div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== STATEMENT ===== -->
  <section class="pr-sec">
    <div class="pr-wrap">
      <p class="pr-bigstate">Đi xa không phải để chụp ảnh trước trụ sở đẹp. Đi để hiểu mình <span class="pr-accent">làm được gì</span> trong một môi trường thật, trước khi đặt cược cả một chặng đường.</p>
    </div>
  </section>

  <!-- ===== AGENDA ===== -->
  <section class="pr-sec pr-sec--beam" id="agenda">
    <div class="pr-beam pr-beam--left" aria-hidden="true"></div>
    <div class="pr-wrap">
      <div class="pr-head">
        <span class="pr-eyebrow">Lịch trình</span>
        <h2 class="pr-h2">Cách <span class="pr-accent">diễn ra</span></h2>
        <p class="pr-desc">Một hành trình gọn gàng, có chuẩn bị và có người đi cùng, từ lúc chốt lịch tới khi đúc kết.</p>
      </div>
      <div class="pr-rows">
        {agenda.map((s) => (
          <article class="pr-row">
            <span class="pr-row__num">{s.num}</span>
            <div><h3 class="pr-row__title">{s.title}</h3><p class="pr-row__body">{s.body}</p></div>
          </article>
        ))}
      </div>
      <p class="pr-note">Lưu ý: lịch trình và danh sách doanh nghiệp có thể thay đổi theo từng đợt và từng gói thời gian. Mọi chi tiết và chi phí sẽ được SBB trao đổi minh bạch ngay từ buổi nói chuyện đầu tiên.</p>
    </div>
  </section>

  <!-- ===== CTA ===== -->
  <section class="pr-cta-sec">
    <div class="pr-wrap">
      <div class="pr-cta">
        <h2 class="pr-cta__title">THỬ MỘT BƯỚC RA THẾ GIỚI?</h2>
        <p class="pr-cta__sub">Để lại thông tin để SBB báo bạn ngay khi Office Tour mở từng điểm đến, hoặc xem các chương trình khác để chọn con đường phù hợp nhất.</p>
        <div class="pr-actions pr-actions--center">
          <a href="/apply" class="pr-btn pr-btn--onfire">Đăng ký quan tâm</a>
          <a href="/programs" class="pr-btn pr-btn--light">Xem chương trình khác</a>
        </div>
      </div>
    </div>
  </section>
</PageLayout>

<style>
  .pr-wrap, .pr-hero__wrap { width: calc(100% - 4rem); max-width: 120rem; margin-inline: auto; position: relative; z-index: 2; }
  .pr-eyebrow { display: inline-block; font-family: var(--font-headline); font-weight: 700; font-size: 0.8rem; letter-spacing: 0.18em; text-transform: uppercase; color: #f2420b; margin-bottom: 1.4rem; }
  .pr-accent { color: #f2420b; }

  .pr-hero { position: relative; overflow: clip; padding-top: clamp(7rem, 9vw, 11rem); padding-bottom: clamp(3rem, 6vw, 6rem); min-height: 78vh; display: flex; align-items: center; }
  .pr-hero__beam { position: absolute; top: -40px; left: 84%; transform: translateX(-50%); width: 1180px; height: 860px; pointer-events: none; z-index: 0;
    background: radial-gradient(ellipse 50% 50% at 50% 42%, rgba(255,112,60,0.60) 0%, rgba(248,82,26,0.46) 22%, rgba(242,66,11,0.30) 44%, rgba(242,66,11,0.12) 64%, transparent 84%); filter: blur(76px); }
  .cs-header { font-family: 'Inter', sans-serif; font-weight: 500; line-height: 0.95; letter-spacing: -0.045em; }
  .cs-line { display: flex; align-items: center; gap: 1.5rem; }
  .cs-line-1 { font-size: clamp(3rem, 10.4vw, 10.5rem); letter-spacing: -0.075em; line-height: 0.95; white-space: nowrap; position: relative; z-index: 10; }
  .cs-text-white { color: #ffffff; }

  .pr-lead { margin: clamp(1.6rem, 3vw, 2.6rem) 0 0; max-width: 46ch; font-family: 'Inter', sans-serif; font-weight: 300; font-size: clamp(0.8rem, 0.95vw, 0.92rem); line-height: 1.6; color: rgba(255,255,255,0.66); }
  .pr-build { display: inline-flex; align-items: center; gap: 0.5rem; margin-top: 1.4rem; font-family: 'Inter', sans-serif; font-weight: 500; font-size: 0.82rem; letter-spacing: 0.02em; color: #ffb59c; background: rgba(242,66,11,0.12); border: 1px solid rgba(242,66,11,0.30); border-radius: 999px; padding: 0.5rem 1.1rem; }
  .pr-actions { display: flex; flex-wrap: wrap; gap: 0.9rem; margin-top: clamp(1.6rem, 3vw, 2.4rem); }
  .pr-actions--center { justify-content: center; }
  .pr-btn { display: inline-flex; align-items: center; justify-content: center; font-family: var(--font-headline); font-weight: 700; font-size: 0.9rem; text-decoration: none; border-radius: 999px; padding: 0.85rem 1.7rem; transition: transform .25s ease, background .25s ease, box-shadow .25s ease, border-color .25s ease, color .25s ease; }
  .pr-btn--primary { background: #f2420b; color: #fff; box-shadow: 0 14px 30px -12px rgba(242,66,11,0.7); }
  .pr-btn--primary:hover { background: #ff5c26; transform: translateY(-2px); }
  .pr-btn--ghost { background: rgba(255,255,255,0.04); color: #fff; border: 1px solid rgba(255,255,255,0.2); }
  .pr-btn--ghost:hover { border-color: rgba(242,66,11,0.55); background: rgba(242,66,11,0.08); }
  .pr-btn--onfire { background: #fff; color: #c2380a; }
  .pr-btn--onfire:hover { transform: translateY(-2px); background: #fff5f1; }
  .pr-btn--light { background: transparent; color: #fff; border: 1px solid rgba(255,255,255,0.55); }
  .pr-btn--light:hover { background: rgba(255,255,255,0.12); }

  .pr-sec { position: relative; overflow: clip; padding-block: clamp(3.5rem, 7vw, 7rem); }
  .pr-sec--beam { z-index: 1; }
  .pr-beam { position: absolute; top: -60px; width: 900px; height: 760px; pointer-events: none; z-index: 0; filter: blur(80px);
    background: radial-gradient(ellipse 50% 50% at 50% 42%, rgba(255,112,60,0.30) 0%, rgba(242,66,11,0.16) 40%, rgba(242,66,11,0.05) 66%, transparent 86%); }
  .pr-beam--right { left: 86%; transform: translateX(-50%); }
  .pr-beam--left { left: 14%; transform: translateX(-50%); }

  .pr-bigstate { font-family: var(--font-headline); font-weight: 700; font-size: clamp(1.9rem, 3.8vw, 3.2rem); line-height: 1.18; color: #fff; letter-spacing: -0.015em; margin: 0; max-width: 26ch; }

  .pr-stats { display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 1.5rem; margin-top: clamp(2.5rem, 5vw, 4rem); padding-top: clamp(2rem, 4vw, 3rem); border-top: 1px solid rgba(255,255,255,0.12); }
  .pr-stat__num { display: block; font-family: var(--font-headline); font-weight: 700; font-size: clamp(2rem, 3.5vw, 3rem); color: #f2420b; line-height: 1; }
  .pr-stat__label { display: block; margin-top: 0.5rem; font-family: 'Inter', sans-serif; font-weight: 300; font-size: 0.86rem; color: rgba(255,255,255,0.6); }

  .pr-head { max-width: 60ch; margin-bottom: clamp(2.2rem, 4vw, 3.4rem); }
  .pr-h2 { font-family: var(--font-headline); font-weight: 700; font-size: clamp(2rem, 4vw, 3.4rem); line-height: 1.08; color: #fff; letter-spacing: -0.02em; margin: 0; text-transform: none; }
  .pr-desc { font-family: 'Inter', sans-serif; font-weight: 300; font-size: clamp(0.96rem, 1.1vw, 1.08rem); line-height: 1.65; color: rgba(255,255,255,0.6); margin: 0.9rem 0 0; max-width: 60ch; }

  /* ===== CARD = KÍNH TỐI PHỦ LỬA (đồng bộ .service-card / .case-card hub — KHÔNG nền trắng) ===== */
  .pr-grid { display: grid; gap: clamp(1.2rem, 2vw, 1.8rem); }
  .pr-grid--2 { grid-template-columns: repeat(2, 1fr); }
  .pr-grid--3 { grid-template-columns: repeat(3, 1fr); }
  .pr-card {
    position: relative; display: flex; flex-direction: column; text-decoration: none;
    background: rgba(255,255,255,0.025);
    -webkit-backdrop-filter: blur(10px); backdrop-filter: blur(10px);
    border: 1px solid rgba(255,255,255,0.10); border-radius: 1.6rem;
    padding: clamp(1.6rem, 2.2vw, 2.3rem);
    box-shadow: 0 8px 24px rgba(0,0,0,0.40);
    transition: transform .4s ease, box-shadow .4s ease, border-color .4s ease, background .4s ease;
  }
  .pr-card:hover {
    transform: translateY(-8px);
    background:
      radial-gradient(150% 150% at 100% 100%,
        rgba(255,126,72,0.40) 0%, rgba(255,100,30,0.26) 26%, rgba(242,66,11,0.14) 50%, rgba(20,10,5,0.30) 80%, rgba(10,5,2,0.40) 100%),
      rgba(255,255,255,0.03);
    border-color: rgba(242,66,11,0.40);
    box-shadow: 0 26px 64px -24px rgba(0,0,0,0.55);
  }
  .pr-card--soon { opacity: 0.7; cursor: default; }
  .pr-card--soon:hover { transform: none; background: rgba(255,255,255,0.025); border-color: rgba(255,255,255,0.10); box-shadow: 0 8px 24px rgba(0,0,0,0.40); }
  .pr-card__tag { align-self: flex-start; font-family: 'Inter', sans-serif; font-weight: 600; font-size: 0.66rem; letter-spacing: 0.08em; text-transform: uppercase; color: #ffb59c; background: rgba(242,66,11,0.18); border: 1px solid rgba(242,66,11,0.30); border-radius: 999px; padding: 0.28rem 0.7rem; }
  .pr-card__tag--soon { color: rgba(255,255,255,0.7); background: rgba(255,255,255,0.06); border-color: rgba(255,255,255,0.16); }
  .pr-card__title { font-family: var(--font-headline); font-weight: 700; font-size: clamp(1.2rem, 1.6vw, 1.5rem); color: #F5EDE6; margin: 0.8rem 0 0.7rem; letter-spacing: -0.01em; text-transform: none; }
  .pr-card__region { font-family: var(--font-headline); font-weight: 600; font-size: 0.86rem; letter-spacing: 0.04em; text-transform: uppercase; color: #ff7a52; margin: 0 0 0.7rem; }
  .pr-card__body { font-family: 'Inter', sans-serif; font-weight: 300; font-size: 0.96rem; line-height: 1.6; color: rgba(255,255,255,0.78); margin: 0; }
  .pr-card__more { margin-top: auto; padding-top: 1.4rem; font-family: var(--font-headline); font-weight: 700; font-size: 0.82rem; letter-spacing: 0.04em; text-transform: uppercase; color: #ff7a52; }
  .pr-card__more--soon { color: rgba(255,255,255,0.45); }

  .pr-rows { display: flex; flex-direction: column; gap: 0.7rem; }
  .pr-row { display: flex; gap: 1.4rem; align-items: flex-start; padding: 1.3rem 1.5rem; border-radius: 18px; border: 1px solid rgba(255,255,255,0.08); background: rgba(255,255,255,0.02); transition: border-color .3s ease, background .3s ease; }
  .pr-row:hover { border-color: rgba(242,66,11,0.3); background: rgba(242,66,11,0.04); }
  .pr-row__num { flex: 0 0 auto; font-family: var(--font-headline); font-weight: 700; font-size: 1.3rem; color: #f2420b; line-height: 1.4; min-width: 2.2rem; }
  .pr-row__title { font-family: var(--font-headline); font-weight: 700; font-size: 1.1rem; color: #fff; margin: 0 0 0.4rem; text-transform: none; }
