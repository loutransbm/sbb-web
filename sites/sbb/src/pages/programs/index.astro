---
import PageLayout from '@ui/layouts/PageLayout.astro';

const programs = [
  {
    tag: 'Nền tảng — bắt buộc',
    title: 'GRP Foundation',
    body: 'Nền chuẩn bị bắt buộc trước khi bước ra thế giới. Tư duy, tác phong và năng lực làm việc quốc tế — để bạn được tin và trọng dụng, không chỉ “được đi”.',
    href: '/programs/grp',
  },
  {
    tag: 'Mũi nhọn hiện tại',
    title: 'Thực tập & Tu nghiệp J-1',
    body: 'Đi làm thật ở doanh nghiệp Mỹ theo visa J-1 Exchange Visitor. Không phải du học — đây là con đường nghề nghiệp nghiêm túc để nâng tầm năng lực và mang giá trị quốc tế về.',
    href: '/programs/internship-j1',
  },
  {
    tag: 'Trải nghiệm ngắn',
    title: 'Office Tour',
    body: 'Từ 5 đến 10 ngày vào doanh nghiệp làm việc thật, có người hướng dẫn thật. Một bước thử trước khi bạn cam kết đường dài.',
    href: '/programs/office-tour',
  },
  {
    tag: 'Chuyên biệt — Đường Úc',
    title: 'Chương trình 407',
    body: 'Đường Úc qua visa 407 cho một số mảng như Aged Care, Child Care và Hospitality. Không phải mũi nhọn hiện tại, nhưng nếu bạn nhắm các ngành này, hãy hỏi SBB.',
    href: '/programs/407',
  },
];

const steps = [
  {
    num: '01',
    title: 'Đặt một buổi nói chuyện',
    body: 'Bắt đầu bằng một cuộc trò chuyện thẳng thắn. SBB lắng nghe mục tiêu của bạn và đánh giá hồ sơ một cách trung thực.',
  },
  {
    num: '02',
    title: 'Đi qua GRP Foundation',
    body: 'Mọi con đường đều bắt đầu từ GRP. Đây là phần nền giúp bạn vững tư duy, tác phong và năng lực trước khi bước ra thế giới.',
  },
  {
    num: '03',
    title: 'Chọn đúng con đường',
    body: 'Dựa trên năng lực và mục tiêu, SBB chỉ ra chương trình phù hợp nhất — J-1, Office Tour hay đường Úc 407 — chứ không đẩy bạn vào cái dễ bán.',
  },
  {
    num: '04',
    title: 'Đi thật và được đồng hành',
    body: 'Bạn đi làm thật ở môi trường quốc tế. SBB không buông tay giữa chừng — đồng hành tới khi bạn thật sự vững vàng.',
  },
];

const stats = [
  { num: '300K+', label: 'Người đến Mỹ mỗi năm qua J-1' },
  { num: '01', label: 'Nền chung — GRP bắt buộc' },
  { num: '04', label: 'Con đường ra thế giới' },
];
---

<PageLayout
  title="Chương trình"
  description="Các chương trình trải nghiệm nghề quốc tế của SBB — từ nền tảng GRP đến thực tập J-1, Office Tour và đường Úc 407."
  site="sbb"
  currentPath="/programs"
>
  <!-- ===== HERO ===== -->
  <section class="o-hero">
    <div class="container">
      <span class="o-eyebrow">Programs</span>
      <h1 class="o-mega">GRP LÀ CÁI NỀN.<br />TRÊN ĐÓ, CÁC ĐƯỜNG <span class="o-accent">RA THẾ GIỚI</span></h1>
      <p class="o-lead">Mọi chương trình đều bắt đầu từ GRP, vì SBB không đẩy ai ra thế giới khi họ chưa sẵn sàng. Mũi nhọn hiện tại là thực tập và tu nghiệp quốc tế theo visa J-1 của Mỹ.</p>
    </div>
  </section>

  <!-- ===== WHAT WE OFFER ===== -->
  <section class="o-section">
    <div class="container">
      <div class="o-head">
        <span class="o-head-eyebrow">Các chương trình</span>
        <h2 class="o-head-title">WHAT WE <span class="o-stroke">OFFER</span></h2>
        <p class="o-head-desc">Bốn con đường, một điểm xuất phát. Chọn cái phù hợp với mục tiêu của bạn — hoặc để SBB giúp bạn chọn.</p>
      </div>

      <div class="o-grid o-grid--2">
        {programs.map((p) => (
          <a class="o-card" href={p.href}>
            <span class="o-card__tag">{p.tag}</span>
            <h3 class="o-card__title">{p.title}</h3>
            <p class="o-card__body">{p.body}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== HOW IT WORKS ===== -->
  <section class="o-section o-section--tint o-section--glow">
    <div class="container">
      <div class="o-head">
        <span class="o-head-eyebrow">Lộ trình</span>
        <h2 class="o-head-title">HOW IT <span class="o-stroke">WORKS</span></h2>
        <p class="o-head-desc">Không có đường tắt. Có một lộ trình rõ ràng — và một người đi cùng bạn trên đó.</p>
      </div>

      <div class="o-rows">
        {steps.map((s) => (
          <article class="o-row">
            <span class="o-row__num">{s.num}</span>
            <div>
              <h3 class="o-row__title">{s.title}</h3>
              <p class="o-row__body">{s.body}</p>
            </div>
          </article>
        ))}
      </div>

      <div class="o-stats o-mt-lg">
        {stats.map((st) => (
          <div>
            <div class="o-stat__num">{st.num}</div>
            <div class="o-stat__label">{st.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== CTA ===== -->
  <section class="o-cta">
    <div class="container">
      <h2 class="o-cta__title">CHƯA CHẮC ĐƯỜNG NÀO HỢP?</h2>
      <p class="o-cta__sub">Đặt một buổi nói chuyện. SBB đánh giá hồ sơ và chỉ ra con đường phù hợp nhất với bạn — hoặc ghé cộng đồng để nghe tiếng nói thật từ những người đã đi.</p>
      <div class="o-actions">
        <a href="/apply" class="o-btn o-btn--primary">Đặt lịch nói chuyện</a>
        <a href="/community" class="o-btn o-btn--ghost">Vào cộng đồng</a>
      </div>
    </div>
  </section>
</PageLayout>
