---
import PageLayout from '@ui/layouts/PageLayout.astro';

const caseStudies = [
  { title: 'Từ người được phỏng vấn đến người chọn nhân tài', img: '/images/case-studies/cs1.jpg', body: 'Mong muốn có kinh nghiệm thực tế ngoài giảng đường, bạn ấy đảm nhận công tác tuyển dụng, trực tiếp phỏng vấn và đánh giá ứng viên. Từ vị trí người luôn được phỏng vấn, bạn vươn lên thành người chọn nhân tài, làm chủ cả quy trình tuyển dụng chuyên nghiệp.' },
  { title: 'My Linh Le: nhận việc full‑time ngay sau kỳ thực tập', img: '/images/students/my-linh-le.jpg' },
  { title: 'Từ mơ ước đứng lớp đến giáo viên tự tin thực thụ', img: '/images/case-studies/cs4.webp', body: 'Mang khát khao trở thành giáo viên, bạn ấy bước vào lớp học thật, quan sát nhiều phương pháp rồi tự đứng lớp. Những giờ dạy thực tế giúp bạn làm chủ cách truyền đạt và tìm thấy ngọn lửa đam mê nghề giáo.' },
  { title: 'Khanh Giang: vững tay nghề bếp & tiếng Anh thực chiến', img: '/images/students/khanh-giang.jpg' },
  { title: 'Từ học bổng xuất sắc đến mạng lưới nghề rộng mở', img: '/images/case-studies/cs2.jpg', body: 'Giành học bổng nhờ niềm say mê khám phá, bạn ấy bước vào bộ phận hỗ trợ người học, mỗi ngày tư vấn và phục vụ. Trải nghiệm ấy giúp bạn xây dựng mạng lưới nghề nghiệp vững chắc và một hồ sơ năng lực nổi bật.' },
  { title: 'Victoria Tran: cọ xát marketing thực chiến quốc tế', img: '/images/students/victoria-tran.jpg' },
  { title: 'Mỗi ngày cọ xát thực tế, bản lĩnh nghề nghiệp lớn dần', img: '/images/case-studies/cs3.jpg', body: 'Khao khát mở rộng tầm nhìn và rèn giao tiếp trước khi ra trường, bạn ấy dấn thân vào môi trường làm việc thật. Mỗi ngày được thực hành, bạn tự tin hơn và tích lũy góc nhìn nghề nghiệp quý giá.' },
  { title: 'Vượt qua biến cố, khởi động lại hành trình sự nghiệp', img: '/images/case-studies/cs7.webp', body: 'Sau khi giành vị trí thực tập trong một lĩnh vực kỹ thuật đầy cạnh tranh, bạn ấy phải tạm hoãn vì biến cố cá nhân. Bằng nghị lực và sự chuẩn bị kỹ lưỡng, bạn trở lại, tỏa sáng và tích lũy kỹ năng để lại dấu ấn lâu dài.' },
  { title: 'Tác phẩm đầu tay được đăng tải, đam mê bùng cháy', img: '/images/case-studies/cs8.webp', body: 'Bước vào bộ phận marketing với mong muốn thực chiến, bạn ấy trực tiếp viết nội dung và tin bài để xuất bản. Khoảnh khắc thấy tác phẩm của mình hiện diện trên các nền tảng là niềm hạnh phúc vỡ òa. Một bước tiến nghề nghiệp thật sự.' },
  { title: 'Rèn nghề khách sạn bài bản, vững vàng chuyên môn', img: '/images/case-studies/cs9.webp', body: 'Theo đuổi giấc mơ quản lý khách sạn, bạn ấy được rèn luyện thực tế trong môi trường chuyên nghiệp. Không chỉ thành thạo nghiệp vụ vận hành, bạn còn thấm bài học cốt lõi: tôn trọng người khác chính là cách để được tôn trọng.' },
  { title: 'Lần đầu thử thách môi trường mới, trưởng thành vượt bậc', img: '/images/case-studies/cs10.webp', body: 'Quyết tâm thử thách bản thân trong một môi trường hoàn toàn mới, bạn ấy giao tiếp chuyên nghiệp mỗi ngày và chỉ sau ít tuần đã đủ tự tin dẫn dắt, hướng dẫn người đến sau, học được cách tự giải quyết vấn đề và tích lũy kinh nghiệm thực thụ.' },
  { title: 'Từ con số không đến vững tay nghề phục vụ', img: '/images/case-studies/cs11.webp', body: 'Khởi đầu gần như từ con số không, bạn ấy lăn lộn qua đủ môi trường phục vụ, từ nhà hàng cao cấp, bistro đến các sự kiện lớn. Môi trường đa dạng giúp bạn bứt phá, thu nhận vô số kỹ năng để vững vàng theo nghề.' },
];


---

<PageLayout
  title="Chương trình"
  description="Các chương trình trải nghiệm nghề quốc tế của SBB: GRP, thực tập J-1, Office Tour và đường Úc 407."
  site="sbb"
  currentPath="/programs"
>
  <!-- ===== PROGRAMS SHOWCASE (cascade + pill + beam trái + lưới 4 card) ===== -->
  <section class="o-section pr-programs">
    <!-- Beam sáng đánh từ MÉP TRÁI vào "OUR PROGRAMS" (giống Omni case studies) -->
    <div class="cases-glow-beam" aria-hidden="true"></div>
    <!-- Tiêu đề break-out cascade HỆT hero -->
    <div class="cs-header pr-programs-head">
      <div class="cs-line cs-line-1">
        <span class="cs-text-white">OUR</span>
      </div>
      <div class="about-line-2">
        <span class="prog-verb-wrap">
          <span class="about-verb cs-text-white">PROGRAMS</span>
          <!-- pill RA GIỮA khe S(PROGRAMS) ↔ ONE START, canh giữa chiều dọc dòng -->
          <div class="cs-glass-pill">
            <span class="cs-glass-title">PICK A PATH</span>
            <span class="cs-glass-sub">Chọn cái hợp mục tiêu, hoặc để SBB giúp bạn chọn.</span>
          </div>
        </span>
        <span class="about-tail about-tail--dim">
          <span class="cs-text-white">ONE START</span>
          <span class="cs-text-white">FOUR PATHS</span>
        </span>
      </div>
      <!-- Hàng lọc chương trình — sà đáy hero (giống filter case studies Omni) -->
      <div class="pr-filters" role="group" aria-label="Lọc chương trình">
        <button type="button" class="pr-filter is-active" data-filter="all">All</button>
        <button type="button" class="pr-filter" data-filter="practical">Practical Training</button>
        <button type="button" class="pr-filter" data-filter="learning">Learning</button>
      </div>
    </div>

    <div class="container">
      <div class="services-grid">
        <div class="services-row services-row--top">
        <a class="service-card pr-prog-card s-pos-1" data-cat="practical" href="/programs/global-internship">
          <div class="s-card-number">01</div>
          <div class="s-card-icon-wrapper">
            <img src="/global-3d-nobg.png" alt="Global Internship 3D" class="s-icon-image" />
          </div>
          <div class="s-card-content">
            <h3 class="s-card-title">GLOBAL INTERNSHIP</h3>
            <p class="s-card-desc">Thực tập quốc tế có trả lương. J‑1 Hoa Kỳ là mũi nhọn, và SBB đang mở rộng sang nhiều quốc gia khác.</p>
          </div>
        </a>

        <a class="service-card pr-prog-card s-pos-2" data-cat="learning" href="/programs/office-tour">
          <div class="s-card-number">02</div>
          <div class="s-card-icon-wrapper">
            <img src="/plane-3d-nobg.png" alt="Office Tour 3D Plane" class="s-icon-image" />
          </div>
          <div class="s-card-content">
            <h3 class="s-card-title">OFFICE TOUR</h3>
            <p class="s-card-desc">Đồng sáng lập cùng Career Mates: bước vào văn phòng các tập đoàn toàn cầu (JP Morgan…), trải nghiệm thực tế kết hợp khám phá.</p>
          </div>
        </a>
        </div>

        <div class="services-row services-row--bottom">
        <a class="service-card pr-prog-card s-pos-3" data-cat="learning" href="/learn">
          <div class="s-card-number">03</div>
          <div class="s-card-icon-wrapper">
            <img src="/grp-3d-globe-nobg.png" alt="GRP Foundation 3D" class="s-icon-image" />
          </div>
          <div class="s-card-content">
            <h3 class="s-card-title">GLOBAL READINESS</h3>
            <p class="s-card-desc">Global Readiness Programme (GRP): nền chuẩn bị bắt buộc, học ngay tại trang Learn của SBB.</p>
          </div>
        </a>

        <a class="service-card pr-prog-card s-pos-4" data-cat="practical" href="/programs/career-training">
          <div class="s-card-number">04</div>
          <div class="s-card-icon-wrapper">
            <img src="/career-3d-nobg-v2.png" alt="Career Training 3D" class="s-icon-image" />
          </div>
          <div class="s-card-content">
            <h3 class="s-card-title">CAREER TRAINING</h3>
            <p class="s-card-desc">Đào tạo nghề quốc tế có trả lương cho người đã có nền tảng: J‑1 Trainee (Mỹ) và visa 407 (Úc), và sẽ mở rộng thêm.</p>
          </div>
        </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== CASE STUDIES (kiểu Omni: cascade + pill CONTENT REEL + thẻ, beam đánh từ TRÁI) ===== -->
  <section class="o-section about-cases">
    <!-- Beam đánh từ TRÁI vào "OUR CASE STUDIES" -->
    <div class="about-cases-glow-beam" aria-hidden="true"></div>
    <!-- Tiêu đề break-out cascade HỆT hero/team -->
    <div class="cs-header about-cases-head">
      <div class="cs-line cs-line-1">
        <span class="cs-text-white">OUR<br/>CASE</span>
        <div class="cs-glass-pill">
          <span class="cs-glass-title">CONTENT REEL</span>
          <span class="cs-glass-sub">Lát cắt thật từ hành trình học viên SBB, không tô vẽ.</span>
        </div>
      </div>
      <div class="about-line-2">
        <span class="about-verb cs-text-white">STUDIES</span>
        <span class="about-tail about-tail--dim">
          <span>&amp; REAL</span>
          <span>RESULTS</span>
        </span>
      </div>
    </div>
    <div class="container">
      <div class="cases-track">
        {caseStudies.map((c) => (
          <article class="case-card">
            <h3 class="case-title">{c.title}</h3>
            <div class="case-media" style={`--cs-img:url('${c.img}')`}><img src={c.img} alt={c.title} onerror="this.remove()" /></div>
            <span class="case-arrow" aria-hidden="true">
              <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M8 8 L16 16"/><path d="M16 9 L16 16 L9 16"/></svg>
            </span>
          </article>
        ))}
      </div>
      <div class="cases-dots">
        {caseStudies.map((_, i) => (
          <button class:list={["case-dot", i === 0 && "is-active"]} data-i={i} aria-label={`Case study ${i + 1}`}></button>
        ))}
      </div>
      <div class="cases-more-wrap">
        <a class="cases-more" href="#">SEE MORE CASE STUDIES</a>
      </div>
    </div>
  </section>

  <!-- ============ FINAL CTA · "READY TO SHINE BEYOND BORDERS" (giống Omni "READY TO GROW & SCALE") ============ -->
  <section class="cta-final" id="get-started">
    <div class="container cta-final-inner">
      <!-- Tiêu đề kiểu Omni "READY TO GROW & SCALE": cascade 2 dòng lớn + glass pill -->
      <div class="cs-header cta-header">
        <div class="cs-line cs-line-1">
          <span class="cs-text-white">READY</span>
        </div>
        <div class="cta-line-2">
          <span class="cta-verb">TO SHINE</span>
          <div class="cs-glass-pill">
            <span class="cs-glass-title">LET'S TALK</span>
            <span class="cs-glass-sub">Tư vấn miễn phí 30 phút, cùng SBB vẽ lộ trình rõ ràng cho bạn.</span>
          </div>
        </div>
        <div class="cta-line-3">
          <span class="cta-tail"><span class="cs-text-white">BEYOND BORDERS?</span></span>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ LEAD FORM · (giống Omni contact form: 2 cột, label in hoa, input gạch chân, dropdown, nút pill) ============ -->
  <section class="lead-form" id="lead-form">
    <div class="container">
      <form class="lf-grid" action="#" method="POST" novalidate>
        <!-- Hàng 1: Họ tên | Số điện thoại -->
        <div class="lf-field">
          <label class="lf-label" for="lf-name">HỌ TÊN CỦA BẠN<span class="lf-req">*</span></label>
          <input class="lf-input" id="lf-name" name="name" type="text" required autocomplete="name" placeholder="Nguyễn Văn A" />
        </div>
        <div class="lf-field">
          <label class="lf-label" for="lf-phone">SỐ ĐIỆN THOẠI<span class="lf-req">*</span></label>
          <input class="lf-input" id="lf-phone" name="phone" type="tel" required autocomplete="tel" placeholder="+84 9xx xxx xxx" />
        </div>

        <!-- Hàng 2: Email | Bạn đang là -->
        <div class="lf-field">
          <label class="lf-label" for="lf-email">EMAIL CỦA BẠN<span class="lf-req">*</span></label>
          <input class="lf-input" id="lf-email" name="email" type="email" required autocomplete="email" placeholder="ban@email.com" />
        </div>
        <div class="lf-field">
          <label class="lf-label" for="lf-role">BẠN ĐANG LÀ?</label>
          <div class="lf-select-wrap">
            <select class="lf-input lf-select" id="lf-role" name="role">
              <option value="" disabled selected>Chọn vai trò</option>
              <option>Sinh viên</option>
              <option>Người đi làm</option>
              <option>Phụ huynh</option>
              <option>Khác</option>
            </select>
          </div>
        </div>

        <!-- Hàng 3: Chương trình quan tâm | Mục tiêu -->
        <div class="lf-field">
          <label class="lf-label" for="lf-program">BẠN QUAN TÂM CHƯƠNG TRÌNH NÀO?</label>
          <div class="lf-select-wrap">
            <select class="lf-input lf-select" id="lf-program" name="program">
              <option value="" disabled selected>Chọn chương trình</option>
              <option>GRP — Global Readiness</option>
              <option>Internship J-1</option>
              <option>Office Tour</option>
              <option>407 Training</option>
              <option>Chưa rõ — cần tư vấn</option>
            </select>
          </div>
        </div>
        <div class="lf-field">
          <label class="lf-label" for="lf-goal">MỤC TIÊU CỦA BẠN LÀ GÌ?</label>
          <div class="lf-select-wrap">
            <select class="lf-input lf-select" id="lf-goal" name="goal">
              <option value="" disabled selected>Chọn mục tiêu</option>
              <option>Du học</option>
              <option>Thực tập quốc tế</option>
              <option>Làm việc ở nước ngoài</option>
              <option>Định cư lâu dài</option>
            </select>
          </div>
        </div>

        <!-- Hàng 4: Mốc thời gian | Nút gửi -->
        <div class="lf-field">
          <label class="lf-label" for="lf-timeline">BẠN DỰ ĐỊNH ĐI KHI NÀO?</label>
          <div class="lf-select-wrap">
            <select class="lf-input lf-select" id="lf-timeline" name="timeline">
              <option value="" disabled selected>Chọn mốc thời gian</option>
              <option>Trong 6 tháng tới</option>
              <option>6 – 12 tháng</option>
              <option>Hơn 1 năm</option>
              <option>Chưa xác định</option>
            </select>
          </div>
        </div>
        <div class="lf-field lf-field--submit">
          <button class="lf-submit" type="submit">
            <span class="lf-submit-label">GỬI THÔNG TIN</span>
            <span class="lf-submit-arrow" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" width="26" height="26"><path d="M7 7 17 17"/><path d="M17 7v10H7"/></svg>
            </span>
          </button>
        </div>
      </form>
    </div>
  </section>

  <script>
    /* Dropdown CUSTOM cho form (clean & smooth) — progressive enhancement:
       GIỮ <select> thật (ẩn) để submit + fallback; vẽ UI riêng có animation mượt thay popup native thô. */
    (function () {
      function enhance(select) {
        const wrap = select.closest('.lf-select-wrap');
        if (!wrap || wrap.classList.contains('is-enhanced')) return;

        const opts = Array.prototype.slice.call(select.options);
        const placeholder = opts.filter(function (o) { return o.disabled; })[0] || null;
        const choices = opts.filter(function (o) { return !o.disabled; });

        const dd = document.createElement('div');
        dd.className = 'lf-dd';

        const trigger = document.createElement('button');
        trigger.type = 'button';
        trigger.className = 'lf-dd-trigger';
        trigger.setAttribute('aria-haspopup', 'listbox');
        trigger.setAttribute('aria-expanded', 'false');

        const valueEl = document.createElement('span');
        valueEl.className = 'lf-dd-value';

        const caret = document.createElement('span');
        caret.className = 'lf-dd-caret';
        caret.setAttribute('aria-hidden', 'true');
        caret.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg>';

        trigger.appendChild(valueEl);
        trigger.appendChild(caret);

        const panel = document.createElement('ul');
        panel.className = 'lf-dd-panel';
        panel.setAttribute('role', 'listbox');

        let activeIdx = -1;

        function syncDisplay() {
          const sel = select.options[select.selectedIndex];
          const isPlaceholder = !!(sel && sel.disabled);
          valueEl.textContent = sel ? sel.text : (placeholder ? placeholder.text : '');
          valueEl.classList.toggle('is-placeholder', isPlaceholder);
          const curVal = sel ? sel.value : '';
          Array.prototype.forEach.call(panel.children, function (li) {
            li.classList.toggle('is-selected', !isPlaceholder && li.getAttribute('data-value') === curVal);
          });
        }
        function choose(opt) {
          select.value = opt.value;
          select.dispatchEvent(new Event('change', { bubbles: true }));
          syncDisplay();
        }
        choices.forEach(function (opt) {
          const li = document.createElement('li');
          li.className = 'lf-dd-option';
          li.setAttribute('role', 'option');
          li.setAttribute('data-value', opt.value);
          li.textContent = opt.text;
          li.addEventListener('click', function () { choose(opt); closeDd(); trigger.focus(); });
          panel.appendChild(li);
        });
        function setActive(i) {
          activeIdx = i;
          Array.prototype.forEach.call(panel.children, function (li, idx) { li.classList.toggle('is-active', idx === i); });
          if (i >= 0 && panel.children[i]) panel.children[i].scrollIntoView({ block: 'nearest' });
        }
        function openDd() {
          dd.classList.add('is-open');
          trigger.setAttribute('aria-expanded', 'true');
          let selIdx = -1;
          const cur = select.options[select.selectedIndex];
          if (cur && !cur.disabled) selIdx = choices.map(function (o) { return o.value; }).indexOf(cur.value);
          setActive(selIdx >= 0 ? selIdx : 0);
        }
        function closeDd() { dd.classList.remove('is-open'); trigger.setAttribute('aria-expanded', 'false'); setActive(-1); }
        function isOpen() { return dd.classList.contains('is-open'); }

        trigger.addEventListener('click', function (e) { e.stopPropagation(); isOpen() ? closeDd() : openDd(); });
        trigger.addEventListener('keydown', function (e) {
          switch (e.key) {
            case 'ArrowDown': e.preventDefault(); isOpen() ? setActive(Math.min(choices.length - 1, activeIdx + 1)) : openDd(); break;
            case 'ArrowUp': e.preventDefault(); isOpen() ? setActive(Math.max(0, activeIdx - 1)) : openDd(); break;
            case 'Enter': case ' ': e.preventDefault(); if (!isOpen()) openDd(); else if (activeIdx >= 0) { choose(choices[activeIdx]); closeDd(); } break;
            case 'Escape': if (isOpen()) { e.preventDefault(); closeDd(); } break;
            case 'Tab': if (isOpen()) closeDd(); break;
          }
        });
        document.addEventListener('click', function (e) { if (isOpen() && !dd.contains(e.target)) closeDd(); });

        dd.appendChild(trigger);
        dd.appendChild(panel);
        wrap.appendChild(dd);
        /* Astro scope CSS theo attr data-astro-cid-* (gắn lúc build). Element tạo bằng JS KHÔNG có attr này
           → style scoped không "ăn". Copy cid từ .lf-select-wrap sang mọi element vừa tạo để khớp selector scoped. */
        var cidAttr = null;
        for (var i = 0; i < wrap.attributes.length; i++) { if (wrap.attributes[i].name.indexOf('data-astro-cid-') === 0) { cidAttr = wrap.attributes[i].name; break; } }
        if (cidAttr) { dd.setAttribute(cidAttr, ''); var all = dd.querySelectorAll('*'); for (var j = 0; j < all.length; j++) all[j].setAttribute(cidAttr, ''); }
        wrap.classList.add('is-enhanced');
        syncDisplay();
      }
      function init() { Array.prototype.forEach.call(document.querySelectorAll('.lf-select'), enhance); }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
      else init();
    })();

    /* FAQ: kiểu Omni — mở mục này thì các mục khác tự đóng */
    (function () {
      const items = Array.prototype.slice.call(document.querySelectorAll('.faq-item'));
      items.forEach((it) => it.addEventListener('toggle', () => {
        if (it.open) items.forEach((o) => { if (o !== it) o.open = false; });
      }));
    })();

    /* Testimonials: carousel LƯỚT — kéo/vuốt ngang + nút ‹ › + tab (đồng bộ 2 chiều) */
    (function () {
      const track = document.getElementById('tm-track');
      const stage = document.querySelector('#testimonials .tm-stage');
      const tabs = Array.prototype.slice.call(document.querySelectorAll('#testimonials .tm-tab'));
      const cards = Array.prototype.slice.call(document.querySelectorAll('#testimonials .tm-card'));
      const prevBtn = document.getElementById('tm-prev');
      const nextBtn = document.getElementById('tm-next');
      if (!track || !stage || !cards.length) return;
      const total = cards.length;
      let index = 0;

      function update() {
        track.style.transform = 'translateX(' + (-index * 100) + '%)';
        tabs.forEach(function (t, k) { t.classList.toggle('is-active', k === index); });
        cards.forEach(function (c, k) { c.classList.toggle('is-active', k === index); });
        if (prevBtn) prevBtn.disabled = index === 0;
        if (nextBtn) nextBtn.disabled = index === total - 1;
      }
      function goTo(i) { index = Math.max(0, Math.min(total - 1, i)); update(); }

      // Tab + nút mũi tên đều điều khiển carousel
      tabs.forEach(function (t, i) { t.addEventListener('click', function () { goTo(i); }); });
      prevBtn && prevBtn.addEventListener('click', function () { goTo(index - 1); });
      nextBtn && nextBtn.addEventListener('click', function () { goTo(index + 1); });

      // Kéo chuột / vuốt cảm ứng ngang để lướt card
      var startX = 0, startY = 0, dragging = false, axis = null, dx = 0;
      stage.addEventListener('pointerdown', function (e) {
        if (e.target.closest('.tm-nav')) return;
        startX = e.clientX; startY = e.clientY; dragging = true; axis = null; dx = 0;
        track.style.transition = 'none';
        try { stage.setPointerCapture(e.pointerId); } catch (_) {}
      });
      stage.addEventListener('pointermove', function (e) {
        if (!dragging) return;
        dx = e.clientX - startX;
        var dy = e.clientY - startY;
        if (!axis && (Math.abs(dx) + Math.abs(dy) > 8)) axis = Math.abs(dx) > Math.abs(dy) ? 'x' : 'y';
        if (axis === 'x') {
          if (e.cancelable) e.preventDefault();
          stage.classList.add('is-grabbing');
          var pct = (dx / stage.offsetWidth) * 100;
          track.style.transform = 'translateX(' + (-index * 100 + pct) + '%)';
        }
      });
      function endDrag() {
        if (!dragging) return;
        dragging = false;
        stage.classList.remove('is-grabbing');
        track.style.transition = '';
        if (axis === 'x' && Math.abs(dx) > 60) {
          goTo(index + (dx < 0 ? 1 : -1));
        } else {
          update();
        }
        axis = null; dx = 0;
      }
      stage.addEventListener('pointerup', endDrag);
      stage.addEventListener('pointercancel', endDrag);

      update();
    })();

    /* --sbw = bề rộng scrollbar dọc -> để căn cụm tiêu đề sát 2 mép CHUẨN như thanh nav (tránh lệch do 100vw tính cả scrollbar) */
    (function () {
      var setSbw = function () {
        document.documentElement.style.setProperty('--sbw', (window.innerWidth - document.documentElement.clientWidth) + 'px');
      };
      setSbw();
      window.addEventListener('resize', setSbw, { passive: true });
    })();
  </script>
</PageLayout>

<script>
  // Lọc card chương trình theo hàng pill (Tất cả / Trong nước / Ra thế giới)
  const filterBtns = document.querySelectorAll('.pr-filter');
  const progCards = document.querySelectorAll('.pr-prog-card');
  filterBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const f = btn.getAttribute('data-filter');
      filterBtns.forEach((b) => b.classList.toggle('is-active', b === btn));
      progCards.forEach((card) => {
        const show = f === 'all' || card.getAttribute('data-cat') === f;
        card.toggleAttribute('hidden', !show);
      });
    });
  });

    // Carousel case study: kéo ngang (scroll-snap) + dots đồng bộ vị trí, bấm dot để trượt tới
    const track = document.querySelector('.cases-track');
    if (track) {
      const cards = [...track.querySelectorAll('.case-card')];
      const dots = [...document.querySelectorAll('.cases-dots .case-dot')];
      dots.forEach((d, i) => d.addEventListener('click', () => {
        track.scrollTo({ left: cards[i].offsetLeft - track.offsetLeft, behavior: 'smooth' });
      }));
      let raf = 0;
      track.addEventListener('scroll', () => {
        if (raf) return;
        raf = requestAnimationFrame(() => {
          raf = 0;
          let active = 0, min = Infinity;
          cards.forEach((c, i) => { const d = Math.abs(c.offsetLeft - track.offsetLeft - track.scrollLeft); if (d < min) { min = d; active = i; } });
          dots.forEach((d, i) => d.classList.toggle('is-active', i === active));
        });
      }, { passive: true });
    }
  
  </script>

