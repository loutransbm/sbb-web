---
// J-1 Trainee — TRANG CHI TIẾT (1 hạng mục của Career Training). Nhánh Trainee tại Mỹ.
// Bấm từ trang tổng quan /programs/career-training nhảy sang đây.
// Hệ dark-fire đồng bộ hub/trang chủ. KHÔNG card trắng.
import PageLayout from '@ui/layouts/PageLayout.astro';

const stats = [
  { num: '18', label: 'Tháng tu nghiệp tối đa' },
  { num: 'J-1', label: 'Visa Exchange Visitor' },
  { num: '1+ năm', label: 'Kinh nghiệm liên quan' },
  { num: '10+', label: 'Nhóm ngành tiếp nhận' },
];

const industries = [
  'Hospitality & Tourism · Du lịch, Khách sạn',
  'Business & Commerce · Kinh doanh, Thương mại',
  'Finance & Accounting · Tài chính, Kế toán',
  'Information Technology · Công nghệ thông tin',
  'Engineering · Kỹ thuật',
  'Media & Communications · Truyền thông',
];

const steps = [
  { num: '01', title: 'Tìm hiểu & đánh giá ban đầu', body: 'Nói chuyện thẳng thắn với SBB để xem bằng cấp và kinh nghiệm của bạn có hợp với diện J-1 Trainee hay không.' },
  { num: '02', title: 'Chuẩn bị nền tảng với GRP', body: 'Củng cố tư duy toàn cầu, tác phong chuyên nghiệp và ngoại ngữ trước khi bước vào phỏng vấn vị trí tu nghiệp.' },
  { num: '03', title: 'Kết nối host company tại Mỹ', body: 'Tìm kiếm doanh nghiệp tiếp nhận và phỏng vấn trực tiếp cho vị trí tu nghiệp đúng chuyên môn của bạn.' },
  { num: '04', title: 'Sponsor xét duyệt DS-2019', body: 'Tổ chức bảo trợ được Bộ Ngoại giao Mỹ cấp phép duyệt hồ sơ và cấp DS-2019 cho hành trình tu nghiệp.' },
  { num: '05', title: 'Phỏng vấn visa & khởi hành', body: 'Nhận visa J-1, hoàn tất chuẩn bị và bay sang Mỹ bắt đầu tu nghiệp thật theo Training Plan.' },
];

const truths = [
  { title: 'Đào tạo, không phải lao động giá rẻ', body: 'Diện Trainee được thiết kế để nâng chuyên môn qua một Training Plan chi tiết. Bạn được trả lương bình đẳng, và doanh nghiệp Mỹ có nghĩa vụ đào tạo bạn.' },
  { title: 'Cần bằng cấp và kinh nghiệm', body: 'Khác với nhánh Intern dành cho sinh viên, Trainee đòi hỏi bạn đã có bằng cộng kinh nghiệm, hoặc nhiều năm kinh nghiệm thực tế trong ngành.' },
  { title: 'Chính sách có thể thay đổi', body: 'Quy định nhập cảnh và quản lý visa của Mỹ có thể biến động. SBB cam kết đồng hành và xử lý linh hoạt, nhưng không cam kết trước quyết định pháp lý của cơ quan ngoại giao.' },
];

const sponsors = ['CIEE', 'CETUSA', 'Alliance Abroad (AAG)', 'IEEX'];
---

<PageLayout
  title="J-1 Trainee — Tu nghiệp tại Mỹ"
  description="J-1 Trainee, một hạng mục của Career Training: diện tu nghiệp của visa J-1 dành cho người đã có bằng cấp và kinh nghiệm. Tu nghiệp tối đa 18 tháng tại Mỹ."
  site="sbb"
  currentPath="/programs/j1-trainee"
>
  <!-- ===== HERO (kiểu Omni: tiêu đề lớn + hàng stat card quầng lửa) ===== -->
  <section class="pr-hero">
    <div class="pr-hero__beam" aria-hidden="true"></div>
    <div class="pr-hero__wrap">
      <div class="hero-top">
        <a class="pr-eyebrow pr-eyebrow--back" href="/programs/career-training">← Career Training</a>
        <div class="cs-header">
          <div class="cs-line cs-line-1"><span class="cs-text-white">TRAINEE</span></div>
          <div class="cs-line cs-line-1 cs-line-2"><span class="cs-int-wrap"><span class="cs-text-white">J-1 USA</span></span></div>
        </div>
      </div>
      <div class="hero-stats">
        {stats.map((s) => (
          <div class="hero-stat">
            <div class="hero-stat__num">{s.num}</div>
            <div class="hero-stat__label">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== OVERVIEW + STATS ===== -->
  <section class="pr-sec">
    <div class="pr-wrap">
      <div class="pr-split">
        <div>
          <span class="pr-eyebrow">Tổng quan</span>
          <p class="pr-statement">Tu nghiệp <span class="pr-accent">chuyên sâu</span> cho người đã có nghề.</p>
        </div>
        <ul class="pr-checks">
          <li>Có bằng đại học/cao đẳng cộng ít nhất 1 năm kinh nghiệm liên quan, hoặc 5 năm kinh nghiệm trong lĩnh vực liên quan.</li>
          <li>Thời gian tu nghiệp tối đa 18 tháng. Riêng ngành Hospitality tối đa 12 tháng, trừ vị trí quản lý.</li>
          <li>Được trả lương bình đẳng như nhân sự bản địa cùng vị trí.</li>
          <li>Bảo trợ bởi Designated Sponsor do Bộ Ngoại giao Mỹ chỉ định.</li>
        </ul>
      </div>
      <div class="pr-stats">
        {stats.map((s) => (
          <div class="pr-stat"><span class="pr-stat__num">{s.num}</span><span class="pr-stat__label">{s.label}</span></div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== INDUSTRIES ===== -->
  <section class="pr-sec pr-sec--beam">
    <div class="pr-beam pr-beam--right" aria-hidden="true"></div>
    <div class="pr-wrap">
      <div class="pr-head">
        <span class="pr-eyebrow">Ngành nghề</span>
        <h2 class="pr-h2">Bạn sẽ tu nghiệp <span class="pr-accent">ngành nào</span></h2>
        <p class="pr-desc">Các nhóm ngành chính đang tiếp nhận ứng viên J-1 Trainee. Suất thực tế tùy thuộc ngành nghề và thời điểm tuyển dụng của host company.</p>
      </div>
      <div class="pr-tags">
        {industries.map((name) => <span class="pr-tag">{name}</span>)}
      </div>
    </div>
  </section>

  <!-- ===== HOW IT WORKS ===== -->
  <section class="pr-sec" id="how">
    <div class="pr-wrap">
      <div class="pr-head">
        <span class="pr-eyebrow">Lộ trình</span>
        <h2 class="pr-h2">Cách <span class="pr-accent">vận hành</span></h2>
        <p class="pr-desc">Năm bước rõ ràng từ buổi nói chuyện đầu tiên đến ngày bạn đặt chân tới Mỹ tu nghiệp.</p>
      </div>
      <div class="pr-rows">
        {steps.map((s) => (
          <article class="pr-row">
            <span class="pr-row__num">{s.num}</span>
            <div><h3 class="pr-row__title">{s.title}</h3><p class="pr-row__body">{s.body}</p></div>
          </article>
        ))}
      </div>
      <p class="pr-note"><strong>Về chi phí:</strong> SBB không đưa ra biểu giá chung chung. Chi phí thực tế phụ thuộc vào ngành nghề, thời lượng và bang bạn làm việc, và sẽ được minh bạch chi tiết ngay từ buổi trao đổi đầu tiên.</p>
    </div>
  </section>

  <!-- ===== REALITY CHECK ===== -->
  <section class="pr-sec pr-sec--beam">
    <div class="pr-beam pr-beam--left" aria-hidden="true"></div>
    <div class="pr-wrap">
      <div class="pr-head">
        <span class="pr-eyebrow">Reality Check</span>
        <h2 class="pr-h2">Sự thật <span class="pr-accent">trước</span></h2>
        <p class="pr-desc">Ba sự thật chúng tôi muốn bạn biết trước khi quyết định, để bạn đi với đôi mắt mở.</p>
      </div>
      <div class="pr-grid pr-grid--3">
        {truths.map((t) => (
          <article class="pr-card">
            <span class="pr-card__tag">Lưu ý</span>
            <h3 class="pr-card__title">{t.title}</h3>
            <p class="pr-card__body">{t.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== SPONSORS ===== -->
  <section class="pr-sec">
    <div class="pr-wrap">
      <div class="pr-split">
        <div>
          <span class="pr-eyebrow">Sponsors</span>
          <p class="pr-statement">Được bảo trợ bởi tổ chức <span class="pr-accent">chính danh</span>.</p>
        </div>
        <div>
          <p class="pr-desc" style="margin-bottom:1.4rem;">SBB hợp tác chặt chẽ cùng các Designated Sponsor được Bộ Ngoại giao Mỹ cấp phép bảo trợ chương trình:</p>
          <div class="pr-pills">{sponsors.map((name) => <span class="pr-pill">{name}</span>)}</div>
          <p class="pr-desc" style="margin-top:1.2rem;font-style:italic;">và các tổ chức bảo trợ uy tín khác.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== CTA ===== -->
  <section class="pr-cta-sec">
    <div class="pr-wrap">
      <div class="pr-cta">
        <h2 class="pr-cta__title">BẮT ĐẦU HÀNH TRÌNH TU NGHIỆP</h2>
        <p class="pr-cta__sub">Đặt lịch nói chuyện trực tiếp để SBB đánh giá hồ sơ và kinh nghiệm của bạn, tư vấn con đường phù hợp nhất.</p>
        <div class="pr-actions pr-actions--center">
          <a href="/apply" class="pr-btn pr-btn--onfire">Đăng ký tư vấn</a>
          <a href="/programs/career-training" class="pr-btn pr-btn--light">Xem hạng mục khác</a>
        </div>
      </div>
    </div>
  </section>
</PageLayout>

<style>
  .pr-wrap, .pr-hero__wrap { width: calc(100% - 4rem); max-width: 120rem; margin-inline: auto; position: relative; z-index: 2; }
  .pr-eyebrow { display: inline-block; font-family: var(--font-headline); font-weight: 700; font-size: 0.8rem; letter-spacing: 0.18em; text-transform: uppercase; color: #f2420b; margin-bottom: 1.4rem; }
  .pr-eyebrow--back { text-decoration: none; transition: color .25s ease, transform .25s ease; }
  .pr-eyebrow--back:hover { color: #ff5c26; transform: translateX(-3px); }
  .pr-accent { color: #f2420b; }

  .pr-hero { position: relative; overflow-x: clip; overflow-y: visible; padding-top: clamp(7rem, 9vw, 11rem); padding-bottom: clamp(2.5rem, 5vw, 4rem); min-height: 100vh; display: flex; align-items: stretch; }
  .pr-hero .pr-hero__wrap { display: flex; flex-direction: column; justify-content: space-between; gap: clamp(2.5rem, 6vw, 5rem); }
  .hero-top { display: flex; flex-direction: column; }
  .pr-hero__beam { position: absolute; top: -40px; left: 16%; transform: translateX(-50%); width: 1180px; height: 860px; pointer-events: none; z-index: 0;
    background: radial-gradient(ellipse 50% 50% at 50% 42%, rgba(255,112,60,0.60) 0%, rgba(248,82,26,0.46) 22%, rgba(242,66,11,0.30) 44%, rgba(242,66,11,0.12) 64%, transparent 84%); filter: blur(76px); }
  .cs-header { font-family: 'Inter', sans-serif; font-weight: 500; line-height: 0.95; letter-spacing: -0.045em; }
  .cs-line { display: flex; align-items: center; gap: 1.5rem; }
  .cs-line-1 { font-size: clamp(8.5rem, 12vw, 11rem); letter-spacing: -0.085em; line-height: 0.95; white-space: nowrap; position: relative; z-index: 10; }
  .cs-line-2 { justify-content: flex-end; margin-right: clamp(2rem, 5vw, 5rem); }
  .cs-int-wrap { position: relative; display: inline-flex; }

  /* ===== Hàng STAT CARD kiểu Omni (quầng lửa cam góc dưới-trái, số TRẮNG) ===== */
  .hero-stats { display: grid; grid-template-columns: repeat(4, 1fr); gap: clamp(0.9rem, 1.4vw, 1.4rem); }
  .hero-stat {
    position: relative; overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.10); border-radius: 22px;
    padding: clamp(1.4rem, 2vw, 2.1rem);
    min-height: clamp(150px, 17vh, 188px);
    display: flex; flex-direction: column; justify-content: flex-end; gap: 0.55rem;
    background:
      radial-gradient(125% 125% at 0% 100%,
        rgba(255, 120, 50, 0.62) 0%,
        rgba(248, 82, 26, 0.44) 24%,
        rgba(242, 66, 11, 0.24) 45%,
        rgba(20, 10, 5, 0.50) 72%,
        rgba(10, 5, 2, 0.55) 100%),
      rgba(255, 255, 255, 0.03);
    -webkit-backdrop-filter: blur(6px); backdrop-filter: blur(6px);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.06), 0 18px 40px -22px rgba(0, 0, 0, 0.6);
    transition: transform .4s ease, border-color .4s ease;
  }
  .hero-stat:hover { transform: translateY(-4px); border-color: rgba(242, 66, 11, 0.45); }
  .hero-stat__num { font-family: var(--font-headline); font-weight: 700; font-size: clamp(2.4rem, 3.6vw, 3.4rem); color: #ffffff; line-height: 1; letter-spacing: -0.02em; }
  .hero-stat__label { font-family: 'Inter', sans-serif; font-weight: 400; font-size: clamp(0.78rem, 0.95vw, 0.9rem); color: rgba(255, 255, 255, 0.72); line-height: 1.4; }
  @media (max-width: 980px) { .hero-stats { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 560px) { .hero-stats { grid-template-columns: 1fr; } }
  .cs-text-white { color: #ffffff; }

  .pr-lead { margin: clamp(1.6rem, 3vw, 2.6rem) 0 0; max-width: 46ch; font-family: 'Inter', sans-serif; font-weight: 300; font-size: clamp(0.8rem, 0.95vw, 0.92rem); line-height: 1.6; color: rgba(255,255,255,0.66); }
  .pr-actions { display: flex; flex-wrap: wrap; gap: 0.9rem; margin-top: clamp(1.6rem, 3vw, 2.4rem); }
  .pr-actions--center { justify-content: center; }
  .pr-btn { display: inline-flex; align-items: center; justify-content: center; font-family: var(--font-headline); font-weight: 700; font-size: 0.9rem; text-decoration: none; border-radius: 999px; padding: 0.85rem 1.7rem; transition: transform .25s ease, background .25s ease, box-shadow .25s ease, border-color .25s ease, color .25s ease; }
  .pr-btn--primary { background: #f2420b; color: #fff; box-shadow: 0 14px 30px -12px rgba(242,66,11,0.7); }
  .pr-btn--primary:hover { background: #ff5c26; transform: translateY(-2px); }
  .pr-btn--ghost { background: rgba(255,255,255,0.04); color: #fff; border: 1px solid rgba(255,255,255,0.2); }
  .pr-btn--ghost:hover { border-color: rgba(242,66,11,0.55); background: rgba(242,66,11,0.08); }
  .pr-btn--onfire { background: #fff; color: #c2380a; }
  .pr-btn--onfire:hover { transform: translateY(-2px); background: #fff5f1; }
  .pr-btn--light { background: transparent; color: #fff; border: 1px solid rgba(255,255,255,0.55); }
  .pr-btn--light:hover { background: rgba(255,255,255,0.12); }

  .pr-sec { position: relative; overflow: clip; padding-block: clamp(3.5rem, 7vw, 7rem); }
  .pr-sec--beam { z-index: 1; }
  .pr-beam { position: absolute; top: -60px; width: 900px; height: 760px; pointer-events: none; z-index: 0; filter: blur(80px);
    background: radial-gradient(ellipse 50% 50% at 50% 42%, rgba(255,112,60,0.30) 0%, rgba(242,66,11,0.16) 40%, rgba(242,66,11,0.05) 66%, transparent 86%); }
  .pr-beam--right { left: 86%; transform: translateX(-50%); }
  .pr-beam--left { left: 14%; transform: translateX(-50%); }

  .pr-split { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(2rem, 4vw, 4rem); align-items: start; }
  .pr-statement { font-family: var(--font-headline); font-weight: 700; font-size: clamp(1.7rem, 3vw, 2.6rem); line-height: 1.15; color: #fff; margin: 0; letter-spacing: -0.01em; }
  .pr-checks { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.9rem; }
  .pr-checks li { position: relative; padding-left: 1.8rem; font-family: 'Inter', sans-serif; font-weight: 300; font-size: 1rem; line-height: 1.6; color: rgba(255,255,255,0.72); }
  .pr-checks li::before { content: ''; position: absolute; left: 0; top: 0.55em; width: 0.65rem; height: 0.65rem; border-radius: 999px; background: #f2420b; box-shadow: 0 0 0 4px rgba(242,66,11,0.18); }

  .pr-stats { display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 1.5rem; margin-top: clamp(2.5rem, 5vw, 4rem); padding-top: clamp(2rem, 4vw, 3rem); border-top: 1px solid rgba(255,255,255,0.12); }
  .pr-stat__num { display: block; font-family: var(--font-headline); font-weight: 700; font-size: clamp(2rem, 3.5vw, 3rem); color: #f2420b; line-height: 1; }
  .pr-stat__label { display: block; margin-top: 0.5rem; font-family: 'Inter', sans-serif; font-weight: 300; font-size: 0.86rem; color: rgba(255,255,255,0.6); }

  .pr-head { max-width: 60ch; margin-bottom: clamp(2.2rem, 4vw, 3.4rem); }
  .pr-h2 { font-family: var(--font-headline); font-weight: 700; font-size: clamp(2rem, 4vw, 3.4rem); line-height: 1.08; color: #fff; letter-spacing: -0.02em; margin: 0; text-transform: none; }
  .pr-desc { font-family: 'Inter', sans-serif; font-weight: 300; font-size: clamp(0.96rem, 1.1vw, 1.08rem); line-height: 1.65; color: rgba(255,255,255,0.6); margin: 0.9rem 0 0; max-width: 60ch; }

  /* ===== CARD = KÍNH TỐI PHỦ LỬA (KHÔNG nền trắng) ===== */
  .pr-grid { display: grid; gap: clamp(1.2rem, 2vw, 1.8rem); }
  .pr-grid--2 { grid-template-columns: repeat(2, 1fr); }
  .pr-grid--3 { grid-template-columns: repeat(3, 1fr); }
  .pr-card {
    position: relative; display: flex; flex-direction: column;
    background: rgba(255,255,255,0.025);
    -webkit-backdrop-filter: blur(10px); backdrop-filter: blur(10px);
    border: 1px solid rgba(255,255,255,0.10); border-radius: 1.6rem;
    padding: clamp(1.6rem, 2.2vw, 2.3rem);
    box-shadow: 0 8px 24px rgba(0,0,0,0.40);
    transition: transform .4s ease, box-shadow .4s ease, border-color .4s ease, background .4s ease;
  }
  .pr-card:hover {
    transform: translateY(-8px);
    background:
      radial-gradient(150% 150% at 100% 100%,
        rgba(255,126,72,0.40) 0%, rgba(255,100,30,0.26) 26%, rgba(242,66,11,0.14) 50%, rgba(20,10,5,0.30) 80%, rgba(10,5,2,0.40) 100%),
      rgba(255,255,255,0.03);
    border-color: rgba(242,66,11,0.40);
    box-shadow: 0 26px 64px -24px rgba(0,0,0,0.55);
  }
  .pr-card__tag { align-self: flex-start; font-family: 'Inter', sans-serif; font-weight: 600; font-size: 0.66rem; letter-spacing: 0.08em; text-transform: uppercase; color: #ffb59c; background: rgba(242,66,11,0.18); border: 1px solid rgba(242,66,11,0.30); border-radius: 999px; padding: 0.28rem 0.7rem; }
  .pr-card__title { font-family: var(--font-headline); font-weight: 700; font-size: clamp(1.2rem, 1.6vw, 1.5rem); color: #F5EDE6; margin: 0.8rem 0 0.7rem; letter-spacing: -0.01em; text-transform: none; }
  .pr-card__body { font-family: 'Inter', sans-serif; font-weight: 300; font-size: 0.96rem; line-height: 1.6; color: rgba(255,255,255,0.78); margin: 0; }

  /* ===== TAGS ===== */
  .pr-tags { display: flex; flex-wrap: wrap; gap: 0.7rem; }
  .pr-tag { font-family: 'Inter', sans-serif; font-weight: 400; font-size: 0.92rem; color: rgba(255,255,255,0.85); background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.12); border-radius: 999px; padding: 0.6rem 1.1rem; transition: border-color .25s ease, background .25s ease; }
  .pr-tag:hover { border-color: rgba(242,66,11,0.45); background: rgba(242,66,11,0.07); }

  /* ===== ROWS ===== */
  .pr-rows { display: flex; flex-direction: column; gap: 0.7rem; }
  .pr-row { display: flex; gap: 1.4rem; align-items: flex-start; padding: 1.3rem 1.5rem; border-radius: 18px; border: 1px solid rgba(255,255,255,0.08); background: rgba(255,255,255,0.02); transition: border-color .3s ease, background .3s ease; }
  .pr-row:hover { border-color: rgba(242,66,11,0.3); background: rgba(242,66,11,0.04); }
  .pr-row__num { flex: 0 0 auto; font-family: var(--font-headline); font-weight: 700; font-size: 1.3rem; color: #f2420b; line-height: 1.4; min-width: 2.2rem; }
