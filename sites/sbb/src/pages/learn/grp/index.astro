---
// Trang TỔNG QUAN khóa GRP — liệt kê 5 vùng năng lực + 15 bài trụ.
// Style DARK FIRE đồng bộ catalog (learn/index.astro): cascade heading, glow cam, card hover bloom.
import PageLayout from '@ui/layouts/PageLayout.astro';
import { getCollection } from 'astro:content';

// Lấy 15 bài, sort theo order.
const lessons = (await getCollection('grp')).sort((a, b) => a.data.order - b.data.order);
const first = lessons[0];
const firstSlug = first.data.module.replace('.', '-');

// Gom theo zone (1..5) -> mảng zones [{ zone, zoneTitle, lessons:[...] }]
const zoneMap = new Map<number, { zone: number; zoneTitle: string; lessons: typeof lessons }>();
for (const l of lessons) {
  const z = l.data.zone;
  if (!zoneMap.has(z)) zoneMap.set(z, { zone: z, zoneTitle: l.data.zoneTitle, lessons: [] });
  zoneMap.get(z)!.lessons.push(l);
}
const zones = Array.from(zoneMap.values()).sort((a, b) => a.zone - b.zone);

const pad2 = (n: number) => String(n).padStart(2, '0');
---

<PageLayout
  title="GRP — Global Readiness Program"
  description="Chương trình chuẩn bị năng lực toàn cầu cho học sinh sinh viên Việt Nam trước khi ra nước ngoài học và làm. 15 bài trụ, 5 vùng năng lực, chứng nhận SBB."
  site="sbb"
  currentPath="/learn"
>
  <!-- ===== HERO ===== -->
  <section class="grp-hero">
    <div class="grp-glow-beam" aria-hidden="true"></div>
    <div class="container">
      <div class="cs-header">
        <div class="cs-line cs-line-1">
          <span class="cs-text-white">GLOBAL READINESS</span>
        </div>
      </div>
      <p class="grp-intro">
        Chương trình chuẩn bị năng lực cho học sinh sinh viên Việt Nam trước khi ra nước ngoài học và làm.
        Tới nơi hoà nhập được từ tuần đầu, học tốt, làm tốt, sống tự chủ và an toàn.
      </p>
      <div class="grp-meta">
        <span>15 bài trụ</span>
        <span>5 vùng năng lực</span>
        <span>Chứng nhận SBB</span>
      </div>
      <a href={`/learn/grp/${firstSlug}`} class="o-btn o-btn--primary grp-cta">Bắt đầu học</a>
    </div>
  </section>

  <!-- ===== SYLLABUS: 5 vùng ===== -->
  <section class="o-section grp-syllabus">
    <div class="container">
      {zones.map((zg) => (
        <div class="grp-zone">
          <h2 class="grp-zone__title">
            <span class="grp-zone__num">Vùng {zg.zone}</span>
            <span class="grp-zone__name">{zg.zoneTitle}</span>
          </h2>
          <ul class="grp-lessons">
            {zg.lessons.map((l) => (
              <li>
                <a href={`/learn/grp/${l.data.module.replace('.', '-')}`} class="grp-lesson">
                  <span class="grp-lesson__order">{pad2(l.data.order)}</span>
                  <span class="grp-lesson__mod">{l.data.module}</span>
                  <span class="grp-lesson__text">
                    <span class="grp-lesson__title">{l.data.title}</span>
                    {l.data.subtitle && <span class="grp-lesson__sub">{l.data.subtitle}</span>}
                  </span>
                  <span class="grp-lesson__arrow" aria-hidden="true">
                    <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M13 6l6 6-6 6"/></svg>
                  </span>
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}

      <div class="grp-foot-cta">
        <a href={`/learn/grp/${firstSlug}`} class="o-btn o-btn--primary">Bắt đầu học</a>
      </div>
    </div>
  </section>
</PageLayout>

<style>
  /* ===== HERO (cascade đồng bộ catalog) ===== */
  .grp-hero {
    position: relative; overflow: visible;
    padding-top: clamp(7rem, 8vw, 10rem);
    padding-bottom: clamp(2rem, 4vw, 3.5rem);
    background: transparent;
  }
  .grp-hero .container { position: relative; z-index: 1; }
  .grp-glow-beam {
    position: absolute; top: 10px; left: 80%; transform: translateX(-50%);
    width: 1080px; height: 720px; pointer-events: none; z-index: 0;
    background: radial-gradient(ellipse 50% 50% at 50% 42%,
      rgba(255, 112, 60, 0.50) 0%,
      rgba(248, 82, 26, 0.38) 22%,
      rgba(242, 66, 11, 0.24) 44%,
      rgba(242, 66, 11, 0.10) 64%,
      transparent 84%);
    filter: blur(76px);
  }

  /* heading cascade — copy từ catalog */
  .cs-header { margin-bottom: 0; font-weight: 500; line-height: 0.95; letter-spacing: -0.045em; font-family: 'Inter', sans-serif; }
  .cs-line { display: flex; align-items: center; gap: 1.5rem; }
  .cs-line-1 { font-size: clamp(4rem, 9vw, 9rem); letter-spacing: -0.06em; white-space: nowrap; position: relative; z-index: 10; }
  .cs-text-white { color: #ffffff !important; }

  .grp-intro {
    position: relative; z-index: 1;
    margin: clamp(1.2rem, 2vw, 1.8rem) 0 0;
    max-width: 56ch; text-align: left;
    color: rgba(255, 255, 255, 0.7); font-family: 'Inter', sans-serif; font-weight: 300;
    font-size: clamp(0.95rem, 1.1vw, 1.12rem); line-height: 1.65;
  }
  /* Hàng meta chip */
  .grp-meta {
    position: relative; z-index: 1;
    display: flex; flex-wrap: wrap; align-items: center; gap: 0.4rem 1rem;
    margin-top: clamp(1.1rem, 1.8vw, 1.5rem);
    font-family: 'Inter', sans-serif; font-size: 0.85rem;
    color: rgba(217, 195, 171, 0.85);
  }
  .grp-meta span { position: relative; }
  .grp-meta span:not(:last-child)::after {
    content: ''; position: absolute; right: -0.55rem; top: 50%; transform: translateY(-50%);
    width: 1px; height: 0.9em; background: rgba(217, 195, 171, 0.35);
  }
  .grp-cta { margin-top: clamp(1.6rem, 2.4vw, 2.2rem); }

  /* ===== SYLLABUS ===== */
  .grp-syllabus { padding-top: clamp(2rem, 4vw, 3.5rem); }
  .grp-zone { margin-bottom: clamp(2.5rem, 4vw, 3.5rem); }
  .grp-zone__title {
    display: flex; flex-wrap: wrap; align-items: baseline; gap: 0.6rem 0.9rem;
    margin: 0 0 1.4rem; padding-bottom: 0.9rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    font-family: var(--font-headline);
  }
  .grp-zone__num {
    font-weight: 700; font-size: 0.8rem; letter-spacing: 0.1em; text-transform: uppercase;
    color: #f2420b;
  }
  .grp-zone__name {
    font-weight: 700; font-size: clamp(1.25rem, 2vw, 1.7rem); line-height: 1.2;
    color: #D9C3AB; letter-spacing: -0.01em;
  }

  .grp-lessons { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.55rem; }
  .grp-lesson {
    display: flex; align-items: center; gap: clamp(0.8rem, 1.5vw, 1.3rem);
    padding: clamp(0.85rem, 1.4vw, 1.15rem) clamp(1rem, 1.6vw, 1.4rem);
    border: 1px solid rgba(255, 255, 255, 0.08); border-radius: 16px;
    background: rgba(255, 255, 255, 0.02); text-decoration: none;
    transition: border-color .3s ease, background .3s ease, transform .3s ease;
  }
  .grp-lesson:hover {
    border-color: rgba(242, 66, 11, 0.55);
    background: rgba(242, 66, 11, 0.08);
    transform: translateX(4px);
  }
  .grp-lesson__order {
    flex: 0 0 auto; font-family: var(--font-headline); font-weight: 800;
    font-size: clamp(1.1rem, 1.8vw, 1.5rem); color: rgba(242, 66, 11, 0.65);
    line-height: 1; min-width: 1.8em;
  }
  .grp-lesson:hover .grp-lesson__order { color: #ff5c26; }
  .grp-lesson__mod {
    flex: 0 0 auto; font-family: var(--font-headline); font-weight: 600;
    font-size: 0.72rem; letter-spacing: 0.05em; color: rgba(217, 195, 171, 0.75);
    border: 1px solid rgba(255, 255, 255, 0.14); border-radius: 999px;
    padding: 0.2rem 0.6rem;
  }
  .grp-lesson__text { display: flex; flex-direction: column; gap: 0.15rem; flex: 1 1 auto; min-width: 0; }
  .grp-lesson__title {
    font-family: 'Inter', sans-serif; font-weight: 500; font-size: clamp(0.98rem, 1.2vw, 1.1rem);
    color: #fff; line-height: 1.35;
  }
  .grp-lesson__sub {
    font-family: 'Inter', sans-serif; font-weight: 300; font-size: 0.82rem; font-style: italic;
    color: rgba(255, 255, 255, 0.45); line-height: 1.4;
  }
  .grp-lesson__arrow {
    flex: 0 0 auto; display: inline-flex; align-items: center; justify-content: center;
    color: rgba(255, 255, 255, 0.35); transition: color .3s ease, transform .3s ease;
  }
  .grp-lesson:hover .grp-lesson__arrow { color: #ff5c26; transform: translateX(3px); }

  .grp-foot-cta { margin-top: clamp(2rem, 4vw, 3rem); text-align: center; }

  /* ===== Mobile ===== */
  @media (max-width: 991px) {
    .cs-line { flex-wrap: wrap; gap: 0.4rem; }
    .cs-line-1 { font-size: clamp(2.6rem, 12vw, 4.5rem); white-space: normal; }
  }
  @media (max-width: 560px) {
    .grp-lesson { flex-wrap: wrap; }
    .grp-lesson__mod { order: 3; }
    .grp-lesson__arrow { display: none; }
  }
</style>
