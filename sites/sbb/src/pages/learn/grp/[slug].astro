---
// Trang BÀI HỌC GRP — 2 cột: sidebar mục lục (sticky) + nội dung markdown.
// Style DARK FIRE; .grp-prose dùng :global() vì <Content/> render HTML không có data-astro-cid.
import PageLayout from '@ui/layouts/PageLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const lessons = (await getCollection('grp')).sort((a, b) => a.data.order - b.data.order);
  return lessons.map((lesson, idx) => ({
    params: { slug: lesson.data.module.replace('.', '-') },
    props: {
      lesson,
      idx,
      prev: idx > 0 ? lessons[idx - 1] : null,
      next: idx < lessons.length - 1 ? lessons[idx + 1] : null,
      all: lessons,
    },
  }));
}

const { lesson, prev, next, all } = Astro.props;
const { Content } = await render(lesson);

const slugOf = (m: string) => m.replace('.', '-');
const pad2 = (n: number) => String(n).padStart(2, '0');

// Gom danh sách bài theo zone cho sidebar.
type Lesson = typeof all[number];
const zoneMap = new Map<number, { zone: number; zoneTitle: string; lessons: Lesson[] }>();
for (const l of all) {
  const z = l.data.zone;
  if (!zoneMap.has(z)) zoneMap.set(z, { zone: z, zoneTitle: l.data.zoneTitle, lessons: [] });
  zoneMap.get(z)!.lessons.push(l);
}
const zones = Array.from(zoneMap.values()).sort((a, b) => a.zone - b.zone);
---

<PageLayout
  title={lesson.data.title}
  description={lesson.data.subtitle || `GRP — Bài ${lesson.data.module}: ${lesson.data.title}`}
  site="sbb"
  currentPath="/learn"
>
  <script is:inline>document.body.classList.add('grp-light');</script>
  <section class="o-section grp-lesson-page">
    <div class="container">
      <div class="grp-layout">
        <!-- ===== SIDEBAR (mục lục) ===== -->
        <aside class="grp-sidebar">
          <div class="grp-sidebar__inner">
            <a href="/learn" class="grp-sidebar__home">
              <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5"/><path d="M11 6l-6 6 6 6"/></svg>
              Tất cả khóa học
            </a>
            <nav class="grp-toc" aria-label="Mục lục bài học">
              {zones.map((zg) => (
                <div class="grp-toc__zone">
                  <p class="grp-toc__zonetitle">Vùng {zg.zone} · {zg.zoneTitle}</p>
                  <ul>
                    {zg.lessons.map((l) => (
                      <li>
                        <a
                          href={`/learn/grp/${slugOf(l.data.module)}`}
                          class:list={["grp-toc__link", l.data.module === lesson.data.module && "is-current"]}
                          aria-current={l.data.module === lesson.data.module ? 'page' : undefined}
                          data-lesson-id={`l1-${slugOf(l.data.module)}`}
                        >
                          <span class="grp-toc__num">{pad2(l.data.order)}</span>
                          <span class="grp-toc__t">{l.data.title}</span>
                          <svg class="grp-toc__check" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              ))}
            </nav>
          </div>
        </aside>

        <!-- ===== MAIN ===== -->
        <div class="grp-main">
          <p class="grp-breadcrumb">
            <a href="/learn">Học viện</a>
            <span aria-hidden="true">›</span>
            <span class="grp-breadcrumb__prog">GRP</span>
            <span aria-hidden="true">›</span>
            Vùng {lesson.data.zone} — {lesson.data.zoneTitle}
          </p>

          <header class="grp-lesson-head">
            <h1 class="grp-lesson-title">
              <span class="grp-lesson-title__num">{lesson.data.order}.</span>
              {lesson.data.title}
            </h1>
            {lesson.data.subtitle && <p class="grp-lesson-subtitle">{lesson.data.subtitle}</p>}
          </header>

          <article class="grp-prose">
            <Content />
          </article>

          <!-- ĐÁNH DẤU ĐÃ HỌC (localStorage) -->
          <div class="grp-done">
            <button type="button" class="grp-done__btn" id="grpDoneBtn" data-lesson-id={`l1-${slugOf(lesson.data.module)}`} aria-pressed="false">
              <svg class="grp-done__icon" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle class="grp-done__ring" cx="12" cy="12" r="9"/><path class="grp-done__tick" d="M8.5 12.5l2.5 2.5 4.5-5"/></svg>
              <span class="grp-done__label">Đánh dấu đã học</span>
            </button>
            <p class="grp-done__hint">Lưu trên trình duyệt này để bạn theo dõi tiến độ.</p>
          </div>

          <!-- PREV / NEXT -->
          <nav class="grp-pager" aria-label="Điều hướng bài">
            {prev ? (
              <a href={`/learn/grp/${slugOf(prev.data.module)}`} class="grp-pager__btn grp-pager__btn--prev">
                <span class="grp-pager__dir">‹ Bài trước</span>
                <span class="grp-pager__name">{prev.data.title}</span>
              </a>
            ) : <span></span>}
            {next ? (
              <a href={`/learn/grp/${slugOf(next.data.module)}`} class="grp-pager__btn grp-pager__btn--next">
                <span class="grp-pager__dir">Bài sau ›</span>
                <span class="grp-pager__name">{next.data.title}</span>
              </a>
            ) : <span></span>}
          </nav>
        </div>
      </div>
    </div>
  </section>
</PageLayout>

<style>
  /* ===== LIGHT MODE: trang bài học chuyển nền sáng (paper ấm), chữ tối ===== */
  :global(body.grp-light) { background: #f7f3ec !important; }
  /* Nav nổi: ép pill TỐI luôn hiện để logo + link trắng đọc rõ trên nền sáng */
  :global(body.grp-light .site-header .header-inner) {
    background: rgba(20, 8, 4, 0.92) !important;
    -webkit-backdrop-filter: blur(14px) !important;
    backdrop-filter: blur(14px) !important;
    border-color: rgba(255, 255, 255, 0.10) !important;
    box-shadow: 0 10px 30px -12px rgba(0, 0, 0, 0.35) !important;
  }

  .grp-lesson-page { padding-top: clamp(6rem, 9vw, 9rem); }
  .grp-layout {
    display: grid;
    grid-template-columns: 280px minmax(0, 1fr);
    gap: clamp(2rem, 4vw, 4rem);
    align-items: start;
  }

  /* ===== SIDEBAR ===== */
  .grp-sidebar__inner {
    position: sticky; top: clamp(5rem, 8vw, 7rem);
    max-height: calc(100vh - 6rem); overflow-y: auto;
    padding-right: 0.5rem;
  }
  .grp-sidebar__home {
    display: inline-flex; align-items: center; gap: 0.5rem;
    font-family: var(--font-headline); font-weight: 700; font-size: 0.78rem;
    letter-spacing: 0.08em; text-transform: uppercase; color: #c2380a;
    text-decoration: none; margin-bottom: 1.4rem;
    transition: color .25s ease;
  }
  .grp-sidebar__home:hover { color: #f2420b; }
  .grp-toc__zone { margin-bottom: 1.4rem; }
  .grp-toc__zonetitle {
    margin: 0 0 0.5rem; font-family: 'Inter', sans-serif; font-weight: 600;
    font-size: 0.72rem; letter-spacing: 0.04em; text-transform: uppercase;
    color: rgba(60, 44, 34, 0.55);
  }
  .grp-toc ul { list-style: none; margin: 0; padding: 0; }
  .grp-toc__link {
    display: flex; align-items: baseline; gap: 0.6rem;
    padding: 0.4rem 0.6rem; border-radius: 9px; text-decoration: none;
    border-left: 2px solid transparent;
    transition: background .25s ease, border-color .25s ease;
  }
  .grp-toc__num {
    flex: 0 0 auto; font-family: var(--font-headline); font-weight: 700;
    font-size: 0.7rem; color: rgba(36, 23, 16, 0.34);
  }
  .grp-toc__t {
    font-family: 'Inter', sans-serif; font-weight: 400; font-size: 0.85rem;
    line-height: 1.4; color: rgba(36, 23, 16, 0.66);
  }
  .grp-toc__link:hover { background: rgba(36, 23, 16, 0.05); }
  .grp-toc__link:hover .grp-toc__t { color: rgba(36, 23, 16, 0.92); }
  .grp-toc__link.is-current {
    background: rgba(242, 66, 11, 0.1); border-left-color: #f2420b;
  }
  .grp-toc__link.is-current .grp-toc__t { color: #241710; font-weight: 600; }
  .grp-toc__link.is-current .grp-toc__num { color: #d2380a; }

  /* ===== MAIN ===== */
  .grp-main { min-width: 0; }
  .grp-breadcrumb {
    margin: 0 0 1.2rem; font-family: 'Inter', sans-serif; font-size: 0.82rem;
    color: rgba(60, 44, 34, 0.7); display: flex; flex-wrap: wrap; gap: 0.5rem; align-items: center;
  }
  .grp-breadcrumb a { color: #c2380a; text-decoration: none; }
  .grp-breadcrumb a:hover { color: #f2420b; }
  .grp-breadcrumb__prog { color: rgba(36, 23, 16, 0.55); font-weight: 500; }

  .grp-lesson-head { margin-bottom: clamp(1.8rem, 3vw, 2.6rem); }
  .grp-lesson-title {
    font-family: var(--font-headline); font-weight: 700;
    font-size: clamp(1.9rem, 3.6vw, 3rem); line-height: 1.12;
    color: #1f140d; letter-spacing: -0.015em; margin: 0; max-width: 22ch;
  }
  .grp-lesson-title__num { color: #f2420b; }
  .grp-lesson-subtitle {
    margin: 0.7rem 0 0; font-family: 'Inter', sans-serif; font-weight: 400; font-style: italic;
    font-size: clamp(0.98rem, 1.3vw, 1.18rem); color: rgba(60, 44, 34, 0.6); line-height: 1.5;
  }

  /* ===== PROSE (dùng :global cho thẻ con vì <Content/> không có data-astro-cid) ===== */
  .grp-prose { max-width: 70ch; }
  .grp-prose :global(h2) {
    font-family: var(--font-headline); font-weight: 700;
    font-size: clamp(1.4rem, 2.3vw, 1.85rem); line-height: 1.25;
    color: #20140d; letter-spacing: -0.01em;
    margin: clamp(2.4rem, 4vw, 3.2rem) 0 1rem;
  }
  .grp-prose :global(h3) {
    font-family: var(--font-headline); font-weight: 700;
    font-size: clamp(1.1rem, 1.6vw, 1.35rem); line-height: 1.3;
    color: #c2380a; margin: 2rem 0 0.8rem;
  }
  .grp-prose :global(p) {
    font-family: 'Inter', sans-serif; font-weight: 400;
    font-size: 1.05rem; line-height: 1.8; color: rgba(36, 23, 16, 0.82);
    margin: 0 0 1.3rem;
  }
  .grp-prose :global(strong) { color: #1f140d; font-weight: 600; }
  .grp-prose :global(em) { font-style: italic; color: rgba(36, 23, 16, 0.7); }
  .grp-prose :global(a) { color: #d2380a; text-decoration: underline; text-underline-offset: 3px; }
  .grp-prose :global(a:hover) { color: #f2420b; }
  .grp-prose :global(ul),
  .grp-prose :global(ol) {
    margin: 0 0 1.4rem; padding-left: 1.5rem;
    color: rgba(36, 23, 16, 0.82); font-family: 'Inter', sans-serif; font-weight: 400;
    font-size: 1.05rem; line-height: 1.8;
  }
  .grp-prose :global(li) { margin-bottom: 0.55rem; }
  .grp-prose :global(li)::marker { color: #f2420b; }
  /* Hộp "Lưu ý theo nước" = blockquote */
  .grp-prose :global(blockquote) {
    margin: 1.8rem 0; padding: 1.2rem 1.4rem;
    background: rgba(242, 66, 11, 0.07);
    border-left: 3px solid #f2420b; border-radius: 12px;
  }
  .grp-prose :global(blockquote p) {
    margin: 0 0 0.5rem; font-size: 0.98rem; line-height: 1.65; color: rgba(36, 23, 16, 0.82);
  }
  .grp-prose :global(blockquote p:last-child) { margin-bottom: 0; }
  .grp-prose :global(hr) {
    border: 0; height: 1px; background: rgba(36, 23, 16, 0.12);
    margin: clamp(2.4rem, 4vw, 3.2rem) 0;
  }
  .grp-prose :global(code) {
    font-family: ui-monospace, 'SF Mono', monospace; font-size: 0.9em;
    background: rgba(36, 23, 16, 0.07); padding: 0.12em 0.4em; border-radius: 6px; color: #b23207;
  }

  /* ===== Mục lục: dấu ✓ bài đã học ===== */
  .grp-toc__check {
    flex: 0 0 auto; margin-left: auto; color: #f2420b;
    opacity: 0; transform: scale(0.6); transition: opacity .2s ease, transform .2s ease;
  }
  .grp-toc__link.is-done .grp-toc__check { opacity: 1; transform: scale(1); }
  .grp-toc__link.is-done:not(.is-current) .grp-toc__t { color: rgba(36, 23, 16, 0.46); }

  /* ===== Nút đánh dấu đã học ===== */
  .grp-done { margin-top: clamp(2.4rem, 4vw, 3.2rem); display: flex; flex-direction: column; align-items: flex-start; gap: 0.55rem; }
  .grp-done__btn {
    display: inline-flex; align-items: center; gap: 0.6rem; cursor: pointer;
    font-family: var(--font-headline); font-weight: 700; font-size: 0.92rem;
    color: #c2380a; background: transparent; border: 1.5px solid rgba(242, 66, 11, 0.45);
    border-radius: 999px; padding: 0.7rem 1.4rem;
    transition: background .25s ease, border-color .25s ease, color .25s ease, box-shadow .25s ease;
  }
  .grp-done__btn:hover { background: rgba(242, 66, 11, 0.07); border-color: rgba(242, 66, 11, 0.7); }
  .grp-done__icon { flex: 0 0 auto; }
  .grp-done__tick { stroke-dasharray: 14; stroke-dashoffset: 14; transition: stroke-dashoffset .35s ease .05s; }
  .grp-done__btn.is-done {
    background: #f2420b; border-color: #f2420b; color: #fff;
    box-shadow: 0 12px 26px -12px rgba(242, 66, 11, 0.7);
  }
  .grp-done__btn.is-done:hover { background: #ff5c26; border-color: #ff5c26; }
  .grp-done__btn.is-done .grp-done__tick { stroke-dashoffset: 0; }
  .grp-done__hint { margin: 0; font-family: 'Inter', sans-serif; font-weight: 300; font-size: 0.8rem; color: rgba(60, 44, 34, 0.5); }

  /* ===== PREV / NEXT ===== */
  .grp-pager {
    display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;
    margin-top: clamp(2.5rem, 5vw, 4rem); padding-top: clamp(1.5rem, 3vw, 2.2rem);
    border-top: 1px solid rgba(36, 23, 16, 0.12);
  }
  .grp-pager__btn {
    display: flex; flex-direction: column; gap: 0.35rem;
    padding: 1rem 1.3rem; border-radius: 16px; text-decoration: none;
    border: 1px solid rgba(36, 23, 16, 0.12); background: rgba(255, 255, 255, 0.55);
    transition: border-color .3s ease, background .3s ease, box-shadow .3s ease;
  }
  .grp-pager__btn:hover { border-color: rgba(242, 66, 11, 0.5); background: rgba(242, 66, 11, 0.06); box-shadow: 0 12px 28px -16px rgba(0,0,0,.3); }
  .grp-pager__btn--next { text-align: right; }
  .grp-pager__dir {
    font-family: var(--font-headline); font-weight: 700; font-size: 0.74rem;
    letter-spacing: 0.05em; text-transform: uppercase; color: #c2380a;
  }
  .grp-pager__name {
    font-family: 'Inter', sans-serif; font-weight: 500; font-size: 0.95rem;
    color: rgba(36, 23, 16, 0.85); line-height: 1.35;
  }

  /* ===== Mobile (≤900px): ẩn sidebar, 1 cột ===== */
  @media (max-width: 900px) {
    .grp-layout { grid-template-columns: 1fr; }
    .grp-sidebar { display: none; }
  }
  @media (max-width: 560px) {
    .grp-pager { grid-template-columns: 1fr; }
    .grp-pager__btn--next { text-align: left; }
  }
</style>

<script>
  // Đánh dấu "đã học" cho bài Lớp 1, lưu localStorage. Đồng bộ sidebar + nút.
  (() => {
    const KEY = 'sbb:grp:done';
    const read = () => { try { return new Set(JSON.parse(localStorage.getItem(KEY) || '[]')); } catch { return new Set(); } };
    const write = (set) => { try { localStorage.setItem(KEY, JSON.stringify([...set])); } catch {} };

    const done = read();
    const btn = document.getElementById('grpDoneBtn');
    const label = btn?.querySelector('.grp-done__label');

    document.querySelectorAll('.grp-toc__link[data-lesson-id]').forEach((a) => {
      if (done.has(a.dataset.lessonId)) a.classList.add('is-done');
    });

    const sync = () => {
      if (!btn) return;
      const isDone = done.has(btn.dataset.lessonId);
      btn.classList.toggle('is-done', isDone);
      btn.setAttribute('aria-pressed', String(isDone));
      if (label) label.textContent = isDone ? 'Đã học' : 'Đánh dấu đã học';
    };
    sync();

    btn?.addEventListener('click', () => {
      const id = btn.dataset.lessonId;
      if (done.has(id)) done.delete(id); else done.add(id);
      write(done);
      document.querySelectorAll(`.grp-toc__link[data-lesson-id="${id}"]`).forEach((a) => a.classList.toggle('is-done', done.has(id)));
      sync();
    });
  })();
</script>
