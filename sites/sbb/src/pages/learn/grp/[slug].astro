---
// Trang BÀI HỌC GRP — 2 cột: sidebar mục lục (sticky) + nội dung markdown.
// Style DARK FIRE; .grp-prose dùng :global() vì <Content/> render HTML không có data-astro-cid.
import PageLayout from '@ui/layouts/PageLayout.astro';
import { getCollection, render } from 'astro:content';
import { quizFor } from '../../../data/grpQuizzes';

export async function getStaticPaths() {
  const lessons = (await getCollection('grp')).sort((a, b) => a.data.order - b.data.order);
  return lessons.map((lesson, idx) => ({
    params: { slug: lesson.data.module.replace('.', '-') },
    props: {
      lesson,
      idx,
      prev: idx > 0 ? lessons[idx - 1] : null,
      next: idx < lessons.length - 1 ? lessons[idx + 1] : null,
      all: lessons,
    },
  }));
}

const { lesson, prev, next, all } = Astro.props;
const { Content } = await render(lesson);

const slugOf = (m: string) => m.replace('.', '-');
const pad2 = (n: number) => String(n).padStart(2, '0');

// Quiz + gate tuần tự
const curSlug = slugOf(lesson.data.module);
const quiz = quizFor(curSlug);
const curId = `l1-${curSlug}`;
const prevId = prev ? `l1-${slugOf(prev.data.module)}` : '';

// Gom danh sách bài theo zone cho sidebar.
type Lesson = typeof all[number];
const zoneMap = new Map<number, { zone: number; zoneTitle: string; lessons: Lesson[] }>();
for (const l of all) {
  const z = l.data.zone;
  if (!zoneMap.has(z)) zoneMap.set(z, { zone: z, zoneTitle: l.data.zoneTitle, lessons: [] });
  zoneMap.get(z)!.lessons.push(l);
}
const zones = Array.from(zoneMap.values()).sort((a, b) => a.zone - b.zone);
---

<PageLayout
  title={lesson.data.title}
  description={lesson.data.subtitle || `GRP — Bài ${lesson.data.module}: ${lesson.data.title}`}
  site="sbb"
  currentPath="/learn"
>
  <script is:inline>document.body.classList.add('grp-light');</script>
  <section class="o-section grp-lesson-page" data-lesson-id={curId} data-prev-id={prevId}>
    <div class="container">
      <div class="grp-layout">
        <!-- ===== SIDEBAR (mục lục) ===== -->
        <aside class="grp-sidebar">
          <div class="grp-sidebar__inner">
            <a href="/learn" class="grp-sidebar__home">
              <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5"/><path d="M11 6l-6 6 6 6"/></svg>
              Tất cả khóa học
            </a>
            <nav class="grp-toc" aria-label="Mục lục bài học">
              {zones.map((zg) => (
                <div class="grp-toc__zone">
                  <p class="grp-toc__zonetitle">Vùng {zg.zone} · {zg.zoneTitle}</p>
                  <ul>
                    {zg.lessons.map((l) => (
                      <li>
                        <a
                          href={`/learn/grp/${slugOf(l.data.module)}`}
                          class:list={["grp-toc__link", l.data.module === lesson.data.module && "is-current"]}
                          aria-current={l.data.module === lesson.data.module ? 'page' : undefined}
                          data-lesson-id={`l1-${slugOf(l.data.module)}`}
                        >
                          <span class="grp-toc__num">{pad2(l.data.order)}</span>
                          <span class="grp-toc__t">{l.data.title}</span>
                          <svg class="grp-toc__check" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                          <svg class="grp-toc__lock" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="5" y="11" width="14" height="9" rx="2"/><path d="M8 11V8a4 4 0 0 1 8 0v3"/></svg>
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              ))}
            </nav>
          </div>
        </aside>

        <!-- ===== MAIN ===== -->
        <div class="grp-main">
          <p class="grp-breadcrumb">
            <a href="/learn">Học viện</a>
            <span aria-hidden="true">›</span>
            <span class="grp-breadcrumb__prog">GRP</span>
            <span aria-hidden="true">›</span>
            Vùng {lesson.data.zone} — {lesson.data.zoneTitle}
          </p>

          <header class="grp-lesson-head">
            <h1 class="grp-lesson-title">
              <span class="grp-lesson-title__num">{lesson.data.order}.</span>
              {lesson.data.title}
            </h1>
            {lesson.data.subtitle && <p class="grp-lesson-subtitle">{lesson.data.subtitle}</p>}
          </header>

          <!-- KHÓA: chưa hoàn thành bài trước -->
          <div class="grp-locked" id="grpLocked" hidden>
            <svg viewBox="0 0 24 24" width="38" height="38" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="5" y="11" width="14" height="9" rx="2"/><path d="M8 11V8a4 4 0 0 1 8 0v3"/></svg>
            <h2 class="grp-locked__title">Bài này đang khóa</h2>
            <p class="grp-locked__sub">Hoàn thành bài trước và làm đạt bài kiểm tra của bài đó để mở bài này.</p>
            <div class="grp-locked__actions">
              {prev && <a href={`/learn/grp/${slugOf(prev.data.module)}`} class="grp-locked__btn grp-locked__btn--prev">← Về bài trước</a>}
              <a href="/learn" class="grp-locked__btn">Tất cả khóa học</a>
            </div>
          </div>

          <article class="grp-prose">
            <Content />
          </article>

          <!-- QUIZ (đạt ≥80% để mở bài sau) -->
          {quiz.length > 0 && (
            <section class="grp-quiz" id="grpQuiz">
              <div class="grp-quiz__head">
                <h2 class="grp-quiz__title">Bài kiểm tra</h2>
                <p class="grp-quiz__sub">Chọn đáp án cho cả 5 câu rồi nộp. Đúng tối thiểu 4/5 để mở bài tiếp theo — làm lại được nếu chưa đạt.</p>
              </div>
              <form id="grpQuizForm" novalidate>
                {quiz.map((item, qi) => (
                  <fieldset class="grp-q" data-answer={item.answer}>
                    <legend class="grp-q__q"><span class="grp-q__n">{qi + 1}</span><span>{item.q}</span></legend>
                    <div class="grp-q__opts">
                      {item.options.map((opt, oi) => (
                        <label class="grp-q__opt">
                          <input type="radio" name={`q${qi}`} value={oi} />
                          <span class="grp-q__box" aria-hidden="true"></span>
                          <span class="grp-q__text">{opt}</span>
                        </label>
                      ))}
                    </div>
                  </fieldset>
                ))}
                <div class="grp-quiz__foot">
                  <button type="submit" class="grp-quiz__submit" id="grpQuizSubmit">Nộp bài</button>
                  <button type="button" class="grp-quiz__retry" id="grpQuizRetry" hidden>Làm lại</button>
                </div>
                <p class="grp-quiz__result" id="grpQuizResult" role="status" aria-live="polite" hidden></p>
              </form>
            </section>
          )}

          <!-- PREV / NEXT -->
          <nav class="grp-pager" aria-label="Điều hướng bài">
            {prev ? (
              <a href={`/learn/grp/${slugOf(prev.data.module)}`} class="grp-pager__btn grp-pager__btn--prev">
                <span class="grp-pager__dir">‹ Bài trước</span>
                <span class="grp-pager__name">{prev.data.title}</span>
              </a>
            ) : <span></span>}
            {next ? (
              <a href={`/learn/grp/${slugOf(next.data.module)}`} id="grpNext" class="grp-pager__btn grp-pager__btn--next">
                <span class="grp-pager__dir">Bài sau ›</span>
                <span class="grp-pager__name">{next.data.title}</span>
                <span class="grp-pager__lock" aria-hidden="true">
                  <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="11" width="14" height="9" rx="2"/><path d="M8 11V8a4 4 0 0 1 8 0v3"/></svg>
                  Làm quiz để mở
                </span>
              </a>
            ) : <span></span>}
          </nav>
        </div>
      </div>
    </div>
  </section>
</PageLayout>

<style>
  /* ===== LIGHT MODE: trang bài học chuyển nền sáng (paper ấm), chữ tối ===== */
  :global(body.grp-light) { background: #f7f3ec !important; }
  /* Nav nổi: ép pill TỐI luôn hiện để logo + link trắng đọc rõ trên nền sáng */
  :global(body.grp-light .site-header .header-inner) {
    background: rgba(20, 8, 4, 0.92) !important;
    -webkit-backdrop-filter: blur(14px) !important;
    backdrop-filter: blur(14px) !important;
    border-color: rgba(255, 255, 255, 0.10) !important;
    box-shadow: 0 10px 30px -12px rgba(0, 0, 0, 0.35) !important;
  }

  .grp-lesson-page { padding-top: clamp(6rem, 9vw, 9rem); }
  .grp-layout {
    display: grid;
    grid-template-columns: 280px minmax(0, 1fr);
    gap: clamp(2rem, 4vw, 4rem);
    align-items: start;
  }

  /* ===== SIDEBAR ===== */
  .grp-sidebar__inner {
    position: sticky; top: clamp(5rem, 8vw, 7rem);
    max-height: calc(100vh - 6rem); overflow-y: auto;
    padding-right: 0.5rem;
  }
  .grp-sidebar__home {
    display: inline-flex; align-items: center; gap: 0.5rem;
    font-family: var(--font-headline); font-weight: 700; font-size: 0.78rem;
    letter-spacing: 0.08em; text-transform: uppercase; color: #c2380a;
    text-decoration: none; margin-bottom: 1.4rem;
    transition: color .25s ease;
  }
  .grp-sidebar__home:hover { color: #f2420b; }
  .grp-toc__zone { margin-bottom: 1.4rem; }
  .grp-toc__zonetitle {
    margin: 0 0 0.5rem; font-family: 'Inter', sans-serif; font-weight: 600;
    font-size: 0.72rem; letter-spacing: 0.04em; text-transform: uppercase;
    color: rgba(60, 44, 34, 0.55);
  }
  .grp-toc ul { list-style: none; margin: 0; padding: 0; }
  .grp-toc__link {
    display: flex; align-items: baseline; gap: 0.6rem;
    padding: 0.4rem 0.6rem; border-radius: 9px; text-decoration: none;
    border-left: 2px solid transparent;
    transition: background .25s ease, border-color .25s ease;
  }
  .grp-toc__num {
    flex: 0 0 auto; font-family: var(--font-headline); font-weight: 700;
    font-size: 0.7rem; color: rgba(36, 23, 16, 0.34);
  }
  .grp-toc__t {
    font-family: 'Inter', sans-serif; font-weight: 400; font-size: 0.85rem;
    line-height: 1.4; color: rgba(36, 23, 16, 0.66);
  }
  .grp-toc__link:hover { background: rgba(36, 23, 16, 0.05); }
  .grp-toc__link:hover .grp-toc__t { color: rgba(36, 23, 16, 0.92); }
  .grp-toc__link.is-current {
    background: rgba(242, 66, 11, 0.1); border-left-color: #f2420b;
  }
  .grp-toc__link.is-current .grp-toc__t { color: #241710; font-weight: 600; }
  .grp-toc__link.is-current .grp-toc__num { color: #d2380a; }

  /* ===== MAIN ===== */
  .grp-main { min-width: 0; }
  .grp-breadcrumb {
    margin: 0 0 1.2rem; font-family: 'Inter', sans-serif; font-size: 0.82rem;
    color: rgba(60, 44, 34, 0.7); display: flex; flex-wrap: wrap; gap: 0.5rem; align-items: center;
  }
  .grp-breadcrumb a { color: #c2380a; text-decoration: none; }
  .grp-breadcrumb a:hover { color: #f2420b; }
  .grp-breadcrumb__prog { color: rgba(36, 23, 16, 0.55); font-weight: 500; }

  .grp-lesson-head { margin-bottom: clamp(1.8rem, 3vw, 2.6rem); }
  .grp-lesson-title {
    font-family: var(--font-headline); font-weight: 700;
    font-size: clamp(1.9rem, 3.6vw, 3rem); line-height: 1.12;
    color: #1f140d; letter-spacing: -0.015em; margin: 0; max-width: 22ch;
  }
  .grp-lesson-title__num { color: #f2420b; }
  .grp-lesson-subtitle {
    margin: 0.7rem 0 0; font-family: 'Inter', sans-serif; font-weight: 400; font-style: italic;
    font-size: clamp(0.98rem, 1.3vw, 1.18rem); color: rgba(60, 44, 34, 0.6); line-height: 1.5;
  }

  /* ===== PROSE (dùng :global cho thẻ con vì <Content/> không có data-astro-cid) ===== */
  .grp-prose { max-width: 70ch; }
  .grp-prose :global(h2) {
    font-family: var(--font-headline); font-weight: 700;
    font-size: clamp(1.4rem, 2.3vw, 1.85rem); line-height: 1.25;
    color: #20140d; letter-spacing: -0.01em;
    margin: clamp(2.4rem, 4vw, 3.2rem) 0 1rem;
  }
  .grp-prose :global(h3) {
    font-family: var(--font-headline); font-weight: 700;
    font-size: clamp(1.1rem, 1.6vw, 1.35rem); line-height: 1.3;
    color: #c2380a; margin: 2rem 0 0.8rem;
  }
  .grp-prose :global(p) {
    font-family: 'Inter', sans-serif; font-weight: 400;
    font-size: 1.05rem; line-height: 1.8; color: rgba(36, 23, 16, 0.82);
    margin: 0 0 1.3rem;
  }
  .grp-prose :global(strong) { color: #1f140d; font-weight: 600; }
  .grp-prose :global(em) { font-style: italic; color: rgba(36, 23, 16, 0.7); }
  .grp-prose :global(a) { color: #d2380a; text-decoration: underline; text-underline-offset: 3px; }
  .grp-prose :global(a:hover) { color: #f2420b; }
  .grp-prose :global(ul),
  .grp-prose :global(ol) {
    margin: 0 0 1.4rem; padding-left: 1.5rem;
    color: rgba(36, 23, 16, 0.82); font-family: 'Inter', sans-serif; font-weight: 400;
    font-size: 1.05rem; line-height: 1.8;
  }
  .grp-prose :global(li) { margin-bottom: 0.55rem; }
  .grp-prose :global(li)::marker { color: #f2420b; }
  /* Hộp "Lưu ý theo nước" = blockquote */
  .grp-prose :global(blockquote) {
    margin: 1.8rem 0; padding: 1.2rem 1.4rem;
    background: rgba(242, 66, 11, 0.07);
    border-left: 3px solid #f2420b; border-radius: 12px;
  }
  .grp-prose :global(blockquote p) {
    margin: 0 0 0.5rem; font-size: 0.98rem; line-height: 1.65; color: rgba(36, 23, 16, 0.82);
  }
  .grp-prose :global(blockquote p:last-child) { margin-bottom: 0; }
  .grp-prose :global(hr) {
    border: 0; height: 1px; background: rgba(36, 23, 16, 0.12);
    margin: clamp(2.4rem, 4vw, 3.2rem) 0;
  }
  .grp-prose :global(code) {
    font-family: ui-monospace, 'SF Mono', monospace; font-size: 0.9em;
    background: rgba(36, 23, 16, 0.07); padding: 0.12em 0.4em; border-radius: 6px; color: #b23207;
  }

  /* ===== Mục lục: ✓ đã học / khóa ===== */
  .grp-toc__check, .grp-toc__lock {
    flex: 0 0 auto; margin-left: auto;
    opacity: 0; transform: scale(0.6); transition: opacity .2s ease, transform .2s ease;
  }
  .grp-toc__check { color: #f2420b; }
  .grp-toc__lock { color: rgba(36, 23, 16, 0.4); }
  .grp-toc__link.is-done .grp-toc__check { opacity: 1; transform: scale(1); }
  .grp-toc__link.is-done:not(.is-current) .grp-toc__t { color: rgba(36, 23, 16, 0.46); }
  .grp-toc__link.is-locked { opacity: 0.55; cursor: not-allowed; }
  .grp-toc__link.is-locked:hover { background: transparent; }
  .grp-toc__link.is-locked .grp-toc__lock { opacity: 1; transform: scale(1); }
  .grp-toc__link.is-locked .grp-toc__t { color: rgba(36, 23, 16, 0.5); }

  /* ===== Khóa bài (chưa qua bài trước) ===== */
  .grp-locked {
    text-align: center; max-width: 30rem; margin: clamp(1.5rem, 4vw, 3rem) auto;
    padding: clamp(2rem, 4vw, 3rem) 1.5rem; border-radius: 20px; color: #b06a3a;
    border: 1px dashed rgba(36, 23, 16, 0.2); background: rgba(36, 23, 16, 0.025);
  }
  .grp-locked__title { font-family: var(--font-headline); font-weight: 700; color: #1f140d; font-size: 1.4rem; margin: 0.7rem 0 0.5rem; }
  .grp-locked__sub { font-family: 'Inter', sans-serif; font-weight: 400; font-size: 0.98rem; line-height: 1.6; color: rgba(36, 23, 16, 0.7); margin: 0 0 1.4rem; }
  .grp-locked__actions { display: flex; flex-wrap: wrap; gap: 0.7rem; justify-content: center; }
  .grp-locked__btn {
    font-family: var(--font-headline); font-weight: 700; font-size: 0.85rem; text-decoration: none;
    padding: 0.65rem 1.2rem; border-radius: 999px; border: 1px solid rgba(36, 23, 16, 0.18);
    color: rgba(36, 23, 16, 0.8); transition: border-color .25s ease, color .25s ease, background .25s ease;
  }
  .grp-locked__btn:hover { border-color: rgba(242, 66, 11, 0.5); color: #f2420b; }
  .grp-locked__btn--prev { background: #f2420b; color: #fff; border-color: #f2420b; }
  .grp-locked__btn--prev:hover { background: #ff5c26; border-color: #ff5c26; color: #fff; }

  /* ===== QUIZ ===== */
  .grp-quiz { margin-top: clamp(2.4rem, 4vw, 3.4rem); padding-top: clamp(1.8rem, 3vw, 2.4rem); border-top: 1px solid rgba(36, 23, 16, 0.12); }
  .grp-quiz__title { font-family: var(--font-headline); font-weight: 700; color: #20140d; font-size: clamp(1.4rem, 2.3vw, 1.8rem); margin: 0 0 0.5rem; }
  .grp-quiz__sub { font-family: 'Inter', sans-serif; font-weight: 400; font-size: 0.95rem; line-height: 1.6; color: rgba(36, 23, 16, 0.62); margin: 0 0 1.6rem; }
  .grp-q { border: 0; margin: 0 0 1.4rem; padding: 0; min-width: 0; }
  .grp-q__q { display: flex; gap: 0.6rem; font-family: 'Inter', sans-serif; font-weight: 600; font-size: 1.02rem; line-height: 1.5; color: #20140d; margin-bottom: 0.7rem; padding: 0; }
  .grp-q__n {
    flex: 0 0 auto; display: inline-flex; align-items: center; justify-content: center;
    width: 1.5rem; height: 1.5rem; border-radius: 999px; background: rgba(242, 66, 11, 0.12);
    color: #c2380a; font-family: var(--font-headline); font-weight: 700; font-size: 0.8rem;
  }
  .grp-q__opts { display: flex; flex-direction: column; gap: 0.5rem; padding-left: 2.1rem; }
  .grp-q__opt {
    position: relative; display: flex; align-items: flex-start; gap: 0.65rem; cursor: pointer;
    padding: 0.7rem 0.9rem; border-radius: 12px; border: 1px solid rgba(36, 23, 16, 0.14);
    background: rgba(255, 255, 255, 0.5); transition: border-color .2s ease, background .2s ease;
  }
  .grp-q__opt:hover { border-color: rgba(242, 66, 11, 0.4); background: rgba(242, 66, 11, 0.04); }
  .grp-q__opt input { position: absolute; opacity: 0; width: 0; height: 0; }
  .grp-q__box {
    flex: 0 0 auto; width: 18px; height: 18px; border-radius: 999px; margin-top: 1px;
    border: 2px solid rgba(36, 23, 16, 0.3); position: relative; transition: border-color .2s ease;
  }
  .grp-q__opt input:checked + .grp-q__box { border-color: #f2420b; }
  .grp-q__opt input:checked + .grp-q__box::after { content: ''; position: absolute; inset: 3px; border-radius: 999px; background: #f2420b; }
  .grp-q__opt input:focus-visible + .grp-q__box { box-shadow: 0 0 0 3px rgba(242, 66, 11, 0.25); }
  .grp-q__text { font-family: 'Inter', sans-serif; font-weight: 400; font-size: 0.96rem; line-height: 1.5; color: rgba(36, 23, 16, 0.85); }
  /* Sau khi nộp: tô đúng (xanh) / sai đã chọn (đỏ) */
  .grp-q.is-correct .grp-q__n { background: rgba(26, 143, 74, 0.16); color: #1a8f4a; }
  .grp-q.is-wrong .grp-q__n { background: rgba(204, 43, 43, 0.16); color: #cc2b2b; }
  .grp-q__opt.is-answer { border-color: #1a8f4a; background: rgba(26, 143, 74, 0.08); }
  .grp-q__opt.is-answer .grp-q__box { border-color: #1a8f4a; }
  .grp-q__opt.is-wrong-pick { border-color: #cc2b2b; background: rgba(204, 43, 43, 0.07); }
  .grp-q__opt.is-wrong-pick .grp-q__box { border-color: #cc2b2b; }
  .grp-quiz.is-graded .grp-q__opt { pointer-events: none; }

  .grp-quiz__foot { display: flex; flex-wrap: wrap; align-items: center; gap: 0.8rem; margin-top: 1.6rem; }
  .grp-quiz__submit, .grp-quiz__retry {
    font-family: var(--font-headline); font-weight: 700; font-size: 0.92rem; cursor: pointer;
    border-radius: 999px; padding: 0.75rem 1.6rem; transition: background .25s ease, box-shadow .25s ease, transform .2s ease;
  }
  .grp-quiz__submit { background: #f2420b; color: #fff; border: 0; box-shadow: 0 12px 26px -12px rgba(242, 66, 11, 0.7); }
  .grp-quiz__submit:hover { background: #ff5c26; transform: translateY(-1px); }
  .grp-quiz__submit:disabled { background: #1a8f4a; box-shadow: none; cursor: default; transform: none; }
  .grp-quiz__retry { background: transparent; color: #c2380a; border: 1.5px solid rgba(242, 66, 11, 0.45); }
  .grp-quiz__retry:hover { background: rgba(242, 66, 11, 0.07); }
  .grp-quiz__result { width: 100%; margin: 0.5rem 0 0; font-family: 'Inter', sans-serif; font-weight: 600; font-size: 0.96rem; }
  .grp-quiz__result.is-pass { color: #1a8f4a; }
  .grp-quiz__result.is-fail { color: #cc2b2b; }

  /* ===== Nút "Bài sau" khóa ===== */
  .grp-pager__lock {
    display: none; align-items: center; gap: 0.35rem; margin-top: 0.4rem;
    font-family: 'Inter', sans-serif; font-weight: 500; font-size: 0.74rem; color: rgba(36, 23, 16, 0.45);
  }
  .grp-pager__btn--next.is-locked { opacity: 0.6; cursor: not-allowed; }
  .grp-pager__btn--next.is-locked:hover { border-color: rgba(36, 23, 16, 0.12); background: rgba(255, 255, 255, 0.55); box-shadow: none; }
  .grp-pager__btn--next.is-locked .grp-pager__lock { display: inline-flex; justify-content: flex-end; }

  /* ===== PREV / NEXT ===== */
  .grp-pager {
    display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;
    margin-top: clamp(2.5rem, 5vw, 4rem); padding-top: clamp(1.5rem, 3vw, 2.2rem);
    border-top: 1px solid rgba(36, 23, 16, 0.12);
  }
  .grp-pager__btn {
    display: flex; flex-direction: column; gap: 0.35rem;
    padding: 1rem 1.3rem; border-radius: 16px; text-decoration: none;
    border: 1px solid rgba(36, 23, 16, 0.12); background: rgba(255, 255, 255, 0.55);
    transition: border-color .3s ease, background .3s ease, box-shadow .3s ease;
  }
  .grp-pager__btn:hover { border-color: rgba(242, 66, 11, 0.5); background: rgba(242, 66, 11, 0.06); box-shadow: 0 12px 28px -16px rgba(0,0,0,.3); }
  .grp-pager__btn--next { text-align: right; }
  .grp-pager__dir {
    font-family: var(--font-headline); font-weight: 700; font-size: 0.74rem;
    letter-spacing: 0.05em; text-transform: uppercase; color: #c2380a;
  }
  .grp-pager__name {
    font-family: 'Inter', sans-serif; font-weight: 500; font-size: 0.95rem;
    color: rgba(36, 23, 16, 0.85); line-height: 1.35;
  }

  /* ===== Mobile (≤900px): ẩn sidebar, 1 cột ===== */
  @media (max-width: 900px) {
    .grp-layout { grid-template-columns: 1fr; }
    .grp-sidebar { display: none; }
  }
  @media (max-width: 560px) {
    .grp-pager { grid-template-columns: 1fr; }
    .grp-pager__btn--next { text-align: left; }
  }
</style>

<script>
  // Gate tuần tự GRP Lớp 1: khóa bài chưa tới, quiz đạt ≥80% mới mở bài sau. localStorage.
  (() => {
    const KEY = 'sbb:grp:done';
    const PASS = 0.8;
    const read = () => { try { return new Set<string>(JSON.parse(localStorage.getItem(KEY) || '[]')); } catch { return new Set<string>(); } };
    const write = (s: Set<string>) => { try { localStorage.setItem(KEY, JSON.stringify([...s])); } catch {} };

    const root = document.querySelector<HTMLElement>('.grp-lesson-page');
    if (!root) return;
    const curId = root.dataset.lessonId || '';
    const prevId = root.dataset.prevId || '';

    const tocLinks = Array.from(document.querySelectorAll<HTMLAnchorElement>('.grp-toc__link[data-lesson-id]'));
    const orderedIds = tocLinks.map((a) => a.dataset.lessonId || '');
    const reachOf = (done: Set<string>) => { let r = 0; while (r < orderedIds.length && done.has(orderedIds[r])) r++; return r; };

    const paintSidebar = () => {
      const done = read();
      const reach = reachOf(done);
      tocLinks.forEach((a, i) => {
        const isDone = done.has(a.dataset.lessonId || '');
        const locked = i > reach && !a.classList.contains('is-current');
        a.classList.toggle('is-done', isDone);
        a.classList.toggle('is-locked', locked);
        if (locked) a.setAttribute('aria-disabled', 'true'); else a.removeAttribute('aria-disabled');
      });
    };
    tocLinks.forEach((a) => a.addEventListener('click', (e) => { if (a.classList.contains('is-locked')) e.preventDefault(); }));

    // Khóa cả trang nếu bài trước chưa qua
    const unlocked = !prevId || read().has(prevId);
    if (!unlocked) {
      document.querySelector('.grp-prose')?.setAttribute('hidden', '');
      document.getElementById('grpQuiz')?.setAttribute('hidden', '');
      document.querySelector('.grp-pager')?.setAttribute('hidden', '');
      const ln = document.getElementById('grpLocked'); if (ln) ln.hidden = false;
    }

    // Gate nút "Bài sau"
    const nextBtn = document.getElementById('grpNext');
    const syncNext = () => { if (nextBtn) nextBtn.classList.toggle('is-locked', !read().has(curId)); };
    nextBtn?.addEventListener('click', (e) => { if (!read().has(curId)) e.preventDefault(); });

    // ===== Quiz =====
    const quizEl = document.getElementById('grpQuiz');
    const form = document.getElementById('grpQuizForm') as HTMLFormElement | null;
    const submitBtn = document.getElementById('grpQuizSubmit') as HTMLButtonElement | null;
    const retryBtn = document.getElementById('grpQuizRetry') as HTMLButtonElement | null;
    const resultEl = document.getElementById('grpQuizResult');

    if (read().has(curId) && submitBtn) {
      submitBtn.disabled = true; submitBtn.textContent = 'Đã đạt ✓';
      if (resultEl) { resultEl.hidden = false; resultEl.className = 'grp-quiz__result is-pass'; resultEl.textContent = 'Bạn đã đạt bài kiểm tra này. Bài tiếp theo đã mở — có thể làm lại để ôn.'; }
    }

    form?.addEventListener('submit', (e) => {
      e.preventDefault();
      const qs = Array.from(form.querySelectorAll<HTMLElement>('.grp-q'));
      let correct = 0;
      qs.forEach((fs) => {
        const ans = Number(fs.dataset.answer);
        fs.classList.remove('is-correct', 'is-wrong');
        const opts = Array.from(fs.querySelectorAll<HTMLElement>('.grp-q__opt'));
        opts.forEach((o) => o.classList.remove('is-answer', 'is-wrong-pick'));
        if (opts[ans]) opts[ans].classList.add('is-answer');
        const sel = fs.querySelector<HTMLInputElement>('input:checked');
        const v = sel ? Number(sel.value) : -1;
        if (v === ans) { correct++; fs.classList.add('is-correct'); }
        else { fs.classList.add('is-wrong'); if (sel) sel.closest('.grp-q__opt')?.classList.add('is-wrong-pick'); }
      });
      const total = qs.length;
      quizEl?.classList.add('is-graded');
      if (resultEl) resultEl.hidden = false;
      if (correct / total >= PASS) {
        const d = read(); d.add(curId); write(d);
        if (resultEl) { resultEl.className = 'grp-quiz__result is-pass'; resultEl.textContent = `Đạt — đúng ${correct}/${total}. Bài tiếp theo đã mở.`; }
        if (submitBtn) { submitBtn.disabled = true; submitBtn.textContent = 'Đã đạt ✓'; }
        if (retryBtn) retryBtn.hidden = true;
        syncNext(); paintSidebar();
      } else {
        if (resultEl) { resultEl.className = 'grp-quiz__result is-fail'; resultEl.textContent = `Đúng ${correct}/${total}. Cần ít nhất 4/5. Xem đáp án đúng (xanh) rồi làm lại nhé.`; }
        if (retryBtn) retryBtn.hidden = false;
      }
    });

    retryBtn?.addEventListener('click', () => {
      form?.reset();
      form?.querySelectorAll('.grp-q').forEach((fs) => fs.classList.remove('is-correct', 'is-wrong'));
      form?.querySelectorAll('.grp-q__opt').forEach((o) => o.classList.remove('is-answer', 'is-wrong-pick'));
      quizEl?.classList.remove('is-graded');
      if (resultEl) { resultEl.hidden = true; resultEl.textContent = ''; }
      retryBtn.hidden = true;
      if (submitBtn && !read().has(curId)) { submitBtn.disabled = false; submitBtn.textContent = 'Nộp bài'; }
    });

    paintSidebar();
    syncNext();
  })();
</script>
