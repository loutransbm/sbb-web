      z-index: 0;
    }
    /* Người: BẰNG bề rộng card + clip KHÍT viền card (teamPersonN remap [0.12,1]) -> phủ tới viền, KHÔNG vạch chia; CAO hơn card (aspect 1/1.614 vs card 1/1.42) -> ĐẦU CHÌA ra ngoài card; KHÔNG cắt đầu (đỉnh hở) */
    .team-cutout {
      position: absolute; bottom: 0; left: 50%; transform: translateX(-50%);
      width: clamp(245px, 19.5vw, 345px); aspect-ratio: 1 / 1.28; /* = tỉ lệ ảnh portrait (có headroom) -> không crop, đầu không cụt */
      object-fit: cover; object-position: 50% 0%;
      z-index: 1;
    }
    .team-photo-label {
      position: absolute; left: 50%; top: 44%; transform: translate(-50%, -50%); z-index: 1;
      color: rgba(255, 255, 255, 0.85); font-family: 'Inter', sans-serif;
      font-size: 0.82rem; letter-spacing: 0.12em; text-transform: uppercase;
    }
    /* Blob (card nền) clip dáng FULL organic; ảnh người clip dáng OPEN-TOP cùng họ -> đáy người ăn khớp card, đầu trồi lên */
    .team-member:nth-child(1) .team-blob { clip-path: url(#teamBlob1); }
    .team-member:nth-child(2) .team-blob { clip-path: url(#teamBlob2); }
    .team-member:nth-child(3) .team-blob { clip-path: url(#teamBlob3); }
    .team-member:nth-child(4) .team-blob { clip-path: url(#teamBlob4); }
    .team-member:nth-child(5) .team-blob { clip-path: url(#teamBlob5); }
    .team-member:nth-child(6) .team-blob { clip-path: url(#teamBlob6); }
    /* Người clip "open-top KHÍT card": thân khít viền card (hết vạch), đầu chìa ra ngoài card, không cắt đầu */
    .team-member:nth-child(1) .team-cutout { clip-path: url(#teamPerson1); }
    .team-member:nth-child(2) .team-cutout { clip-path: url(#teamPerson2); }
    .team-member:nth-child(3) .team-cutout { clip-path: url(#teamPerson3); }
    .team-member:nth-child(4) .team-cutout { clip-path: url(#teamPerson4); }
    .team-member:nth-child(5) .team-cutout { clip-path: url(#teamPerson5); }
    .team-member:nth-child(6) .team-cutout { clip-path: url(#teamPerson6); }
    /* Sắp lại bố cục: Lou(c1) Mai(c2) giữ nguyên; Duong lên CỘT 4 (chỗ cũ của Quang); Quang xuống HÀNG 2 thẳng cột Duong; Rosie CẠNH Quang (cột 3, hàng 2); Diep CỘT 1 HÀNG 3 (thẳng dưới Lou) */
    .team-member:nth-child(3) { grid-column: 4; grid-row: 1; } /* Duong */
    .team-member:nth-child(4) { grid-column: 4; grid-row: 2; } /* Quang */
    .team-member:nth-child(5) { grid-column: 3; grid-row: 2; } /* Rosie — cạnh trái Quang */
    .team-member:nth-child(6) { grid-column: 1; grid-row: 3; } /* Diep — thẳng dưới Lou */
    .team-name {
      font-family: var(--font-headline); font-weight: 500; color: var(--ink);
      font-size: clamp(1.15rem, 1.7vw, 1.55rem); text-transform: uppercase; letter-spacing: 0.01em;
      line-height: 1.2;
      margin: 0 0 0.4rem; /* tên sát chức danh (bỏ min-height thừa từ hồi tên 2 dòng) */
    }
    /* Chức danh = ĐÚNG font phụ đề pill (.cs-glass-sub): Inter 400 (KHÔNG để font body render dày -> trông như in đậm) */
    .team-role {
      font-family: 'Inter', sans-serif; font-weight: 400;
      font-size: 0.95rem; line-height: 1.65; letter-spacing: normal; text-transform: none;
      color: var(--ink-soft); margin: 0;
    }

    /* ===== SECTION 2: PARTNER MARQUEE — CSS bê NGUYÊN từ homepage (index.astro) ===== */
    /* Cầu nối seam = HỆT .hero-seam-bridge homepage, nhưng đặt TRONG section logo (top:-60px) vì hero có overflow:hidden sẽ cắt mất nếu để trong hero. 1 khối #150b07+quầng duy nhất vắt qua ranh giới -> không còn boundary 2 lớp -> hết hairline ở DPR 1.755. */
    .partner-marquee-section .hero-seam-bridge {
      position: absolute;
      left: 0;
      right: 0;
      top: -60px;
      height: 120px;
      z-index: 0;
      pointer-events: none;
      background:
        radial-gradient(ellipse 56% 305px at 45% 50%, rgba(242, 66, 11, 0.06) 0%, transparent 60%),
        #D9D1CA;
      -webkit-mask-image: linear-gradient(to bottom, transparent 0%, #000 28%, #000 72%, transparent 100%);
      mask-image: linear-gradient(to bottom, transparent 0%, #000 28%, #000 72%, transparent 100%);
    }
    .partner-marquee-section {
      min-height: auto;
      padding-top: var(--sec-pad);
      padding-bottom: var(--sec-pad);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 4rem;
      position: relative;
      z-index: 1;
      margin-top: -1px; /* chồng nhẹ 1px để không bao giờ hở mạch sub-pixel */
      /* Bắt đầu ĐÚNG bằng màu đáy hero (#D9D1CA) nối liền mạch -> không còn đường kẻ */
      background: #D9D1CA;
    }
    /* Quầng sáng cam mờ cho thoáng (kiểu Omni) — nằm trên nền, dưới nội dung */
    .partner-marquee-section::before {
      content: '';
      position: absolute;
      inset: 0;
      z-index: -1;
      pointer-events: none;
      background:
        radial-gradient(ellipse 56% 305px at 45% 0%, rgba(242, 66, 11, 0.06) 0%, transparent 60%),
        radial-gradient(ellipse 85% 55% at 50% 34%, rgba(242, 66, 11, 0.03) 0%, transparent 62%);
    }

    .partner-text-block {
      text-align: center;
      max-width: 1200px;
      width: 100%;
      margin-inline: auto;
      padding-inline: var(--space-4);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
    }

    .partner-headline {
      font-family: system-ui, -apple-system, 'Inter', sans-serif;
      font-size: clamp(1.2rem, 2.2vw, 1.8rem);
      font-weight: 300;
      letter-spacing: 0.02em;
      line-height: 1.25;
      color: var(--ink);
      margin-bottom: 2.5rem;
      text-transform: uppercase;
      text-align: center;
    }

    .headline-dimmed {
      color: var(--ink-muted);
      white-space: nowrap;
    }

    .partner-subtext {
      font-family: system-ui, -apple-system, 'Inter', sans-serif;
      font-size: 0.85rem;
      font-weight: 300;
      color: var(--ink-soft);
      line-height: 1.4;
      letter-spacing: -0.01em;
      text-align: center;
    }

    .marquee-wrapper {
      width: 100%;
      overflow: hidden;
      position: relative;
      display: flex;
      flex-direction: column;
      gap: 4.5rem;
    }

    /* Dynamic Edge Blur (Motion Blur Illusion) */
    .marquee-wrapper::before,
    .marquee-wrapper::after {
      content: "";
      position: absolute;
      top: 0;
      width: 15%;
      height: 100%;
      z-index: 2;
      pointer-events: none;
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
    }

    .marquee-wrapper::before {
      left: 0;
      -webkit-mask-image: linear-gradient(to right, black 0%, transparent 100%);
      mask-image: linear-gradient(to right, black 0%, transparent 100%);
    }

    .marquee-wrapper::after {
      right: 0;
      -webkit-mask-image: linear-gradient(to left, black 0%, transparent 100%);
      mask-image: linear-gradient(to left, black 0%, transparent 100%);
    }

    .marquee-track {
      display: flex;
      width: max-content;
      animation: marqueeScroll 45s linear infinite;
    }

    .marquee-track--reverse {
      animation-direction: reverse;
    }

    .marquee-content {
      display: flex;
      align-items: center;
      gap: 7rem;
      padding-inline: 3.5rem;
    }

    .partner-logo {
      display: flex;
      align-items: center;
      justify-content: center;
      user-select: none;
    }

    .partner-logo img {
      height: 85px;
      width: auto;
      object-fit: contain;
      image-rendering: -webkit-optimize-contrast;
      image-rendering: crisp-edges;
      transform: translateZ(0);
      backface-visibility: hidden;
      will-change: transform, filter;
      /* Logos đen mờ trên nền sáng (đổi từ trắng -> đen vì nền giờ sáng) */
      filter: brightness(0) opacity(0.45);
      transition: all 0.3s ease;
    }

    .partner-logo img:hover {
      filter: brightness(0) opacity(0.85);
      transform: scale(1.05) translateZ(0);
    }

    @keyframes marqueeScroll {
      0% { transform: translateX(0); }
      100% { transform: translateX(-50%); }
    }

