---
import PageLayout from '@ui/layouts/PageLayout.astro';

const blocks = [
  {
    num: '01',
    title: 'Vì sao SBB tồn tại',
    body: 'Vì đi ra thế giới không nên là đặc quyền. Nhưng đi mà không sẵn sàng thì phí. SBB tồn tại để rút ngắn khoảng cách giữa “muốn đi” và “đi được thật”.',
  },
  {
    num: '02',
    title: 'Vai trò trong cộng đồng',
    body: 'SBB kết nối những người trẻ muốn đi thật với những cơ hội nghề thật ở nước ngoài — đồng thời xây dựng cộng đồng để người đi trước dẫn đường cho người đi sau.',
  },
];

const notWhat = ['Công ty du học', 'Môi giới visa', 'Đội sale chạy số'];

const values = [
  { t: 'Nói thật', d: 'Đủ thẳng để nói điều bạn cần nghe, chứ không phải điều bạn muốn nghe.' },
  { t: 'Trọng năng lực', d: 'Chuẩn bị để bạn được tin tưởng và trọng dụng — không chỉ “được đi”.' },
  { t: 'Không buông tay', d: 'Đồng hành tới khi bạn vững vàng, không bỏ bạn lại giữa chừng.' },
];
---

<PageLayout
  title="Về SBB"
  description="SBB là ai, vì sao tồn tại, và điều SBB không phải."
  site="sbb"
  currentPath="/about"
>
  <!-- ===== HERO ===== -->
  <section class="o-hero">
    <div class="container">
      <span class="o-eyebrow">About SBB</span>
      <h1 class="o-mega">NHỮNG NGƯỜI<br /><span class="o-accent">ĐI TRƯỚC</span> BẠN</h1>
      <p class="o-lead">SBB là những người đã đi trước bạn một đoạn đường. Đủ gần để hiểu bạn đang lo gì, đủ thẳng để nói thật, và đủ trách nhiệm để không buông tay bạn giữa chừng.</p>
    </div>
  </section>

  <!-- ===== WHY / ROLE ===== -->
  <section class="o-section">
    <div class="container">
      <div class="o-head">
        <span class="o-head-eyebrow">Lý do tồn tại</span>
        <h2 class="o-head-title">WHY WE <span class="o-stroke">EXIST</span></h2>
      </div>
      <div class="o-rows">
        {blocks.map((b) => (
          <article class="o-row">
            <span class="o-row__num">{b.num}</span>
            <div>
              <h3 class="o-row__title">{b.title}</h3>
              <p class="o-row__body">{b.body}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== REALITY CHECK ===== -->
  <section class="o-section o-section--tint o-section--glow">
    <div class="container">
      <div class="o-split">
        <div>
          <span class="o-head-eyebrow">Reality Check</span>
          <h2 class="o-statement">Điều SBB <span class="o-accent">không phải</span>.</h2>
        </div>
        <div>
          <ul class="o-deny">
            {notWhat.map((n) => (
              <li><span class="o-deny-x">✕</span><span class="o-deny-text">{n}</span></li>
            ))}
          </ul>
          <p class="o-note">SBB là một viện đào tạo năng lực — đồng hành để bạn được tin và trọng dụng ở môi trường quốc tế, chứ không chạy theo những con số ngắn hạn.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== PHILOSOPHY ===== -->
  <section class="o-section">
    <div class="container">
      <div class="o-head">
        <span class="o-head-eyebrow">Triết lý</span>
        <h2 class="o-head-title">HOW WE <span class="o-stroke">THINK</span></h2>
      </div>
      <p class="o-statement o-statement--full o-mb-lg">
        SBB làm kinh doanh để nuôi được việc chúng tôi tin. Nếu một chương trình kiếm ra tiền nhưng <span class="o-accent">không tốt cho người học</span>, đó không phải con đường SBB đi.
      </p>

      <div class="o-grid o-grid--3">
        {values.map((v) => (
          <article class="o-card">
            <h3 class="o-card__title">{v.t}</h3>
            <p class="o-card__body">{v.d}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== CTA ===== -->
  <section class="o-cta">
    <div class="container">
      <h2 class="o-cta__title">SẴN SÀNG ĐI XA?</h2>
      <p class="o-cta__sub">Xem chương trình phù hợp, hoặc ghé cộng đồng để nghe tiếng nói thật từ những người đã đi.</p>
      <div class="o-actions">
        <a href="/programs" class="o-btn o-btn--primary">Xem chương trình</a>
        <a href="/community" class="o-btn o-btn--ghost">Vào cộng đồng</a>
      </div>
    </div>
  </section>
</PageLayout>
