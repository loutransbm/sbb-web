  <script>
    /* Dropdown CUSTOM cho form (clean & smooth) — progressive enhancement:
       GIỮ <select> thật (ẩn) để submit + fallback; vẽ UI riêng có animation mượt thay popup native thô. */
    (function () {
      function enhance(select) {
        const wrap = select.closest('.lf-select-wrap');
        if (!wrap || wrap.classList.contains('is-enhanced')) return;

        const opts = Array.prototype.slice.call(select.options);
        const placeholder = opts.filter(function (o) { return o.disabled; })[0] || null;
        const choices = opts.filter(function (o) { return !o.disabled; });

        const dd = document.createElement('div');
        dd.className = 'lf-dd';

        const trigger = document.createElement('button');
        trigger.type = 'button';
        trigger.className = 'lf-dd-trigger';
        trigger.setAttribute('aria-haspopup', 'listbox');
        trigger.setAttribute('aria-expanded', 'false');

        const valueEl = document.createElement('span');
        valueEl.className = 'lf-dd-value';

        const caret = document.createElement('span');
        caret.className = 'lf-dd-caret';
        caret.setAttribute('aria-hidden', 'true');
        caret.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg>';

        trigger.appendChild(valueEl);
        trigger.appendChild(caret);

        const panel = document.createElement('ul');
        panel.className = 'lf-dd-panel';
        panel.setAttribute('role', 'listbox');

        let activeIdx = -1;

        function syncDisplay() {
          const sel = select.options[select.selectedIndex];
          const isPlaceholder = !!(sel && sel.disabled);
          valueEl.textContent = sel ? sel.text : (placeholder ? placeholder.text : '');
          valueEl.classList.toggle('is-placeholder', isPlaceholder);
          const curVal = sel ? sel.value : '';
          Array.prototype.forEach.call(panel.children, function (li) {
            li.classList.toggle('is-selected', !isPlaceholder && li.getAttribute('data-value') === curVal);
          });
        }
        function choose(opt) {
          select.value = opt.value;
          select.dispatchEvent(new Event('change', { bubbles: true }));
          syncDisplay();
        }
        choices.forEach(function (opt) {
          const li = document.createElement('li');
          li.className = 'lf-dd-option';
          li.setAttribute('role', 'option');
          li.setAttribute('data-value', opt.value);
          li.textContent = opt.text;
          li.addEventListener('click', function () { choose(opt); closeDd(); trigger.focus(); });
          panel.appendChild(li);
        });
        function setActive(i) {
          activeIdx = i;
          Array.prototype.forEach.call(panel.children, function (li, idx) { li.classList.toggle('is-active', idx === i); });
          if (i >= 0 && panel.children[i]) panel.children[i].scrollIntoView({ block: 'nearest' });
        }
        function openDd() {
          dd.classList.add('is-open');
          trigger.setAttribute('aria-expanded', 'true');
          let selIdx = -1;
          const cur = select.options[select.selectedIndex];
          if (cur && !cur.disabled) selIdx = choices.map(function (o) { return o.value; }).indexOf(cur.value);
          setActive(selIdx >= 0 ? selIdx : 0);
        }
        function closeDd() { dd.classList.remove('is-open'); trigger.setAttribute('aria-expanded', 'false'); setActive(-1); }
        function isOpen() { return dd.classList.contains('is-open'); }

        trigger.addEventListener('click', function (e) { e.stopPropagation(); isOpen() ? closeDd() : openDd(); });
        trigger.addEventListener('keydown', function (e) {
          switch (e.key) {
            case 'ArrowDown': e.preventDefault(); isOpen() ? setActive(Math.min(choices.length - 1, activeIdx + 1)) : openDd(); break;
            case 'ArrowUp': e.preventDefault(); isOpen() ? setActive(Math.max(0, activeIdx - 1)) : openDd(); break;
            case 'Enter': case ' ': e.preventDefault(); if (!isOpen()) openDd(); else if (activeIdx >= 0) { choose(choices[activeIdx]); closeDd(); } break;
            case 'Escape': if (isOpen()) { e.preventDefault(); closeDd(); } break;
            case 'Tab': if (isOpen()) closeDd(); break;
          }
        });
        document.addEventListener('click', function (e) { if (isOpen() && !dd.contains(e.target)) closeDd(); });

        dd.appendChild(trigger);
        dd.appendChild(panel);
        wrap.appendChild(dd);
        /* Astro scope CSS theo attr data-astro-cid-* (gắn lúc build). Element tạo bằng JS KHÔNG có attr này
           → style scoped không "ăn". Copy cid từ .lf-select-wrap sang mọi element vừa tạo để khớp selector scoped. */
        var cidAttr = null;
        for (var i = 0; i < wrap.attributes.length; i++) { if (wrap.attributes[i].name.indexOf('data-astro-cid-') === 0) { cidAttr = wrap.attributes[i].name; break; } }
        if (cidAttr) { dd.setAttribute(cidAttr, ''); var all = dd.querySelectorAll('*'); for (var j = 0; j < all.length; j++) all[j].setAttribute(cidAttr, ''); }
        wrap.classList.add('is-enhanced');
        syncDisplay();
      }
      function init() { Array.prototype.forEach.call(document.querySelectorAll('.lf-select'), enhance); }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
      else init();
    })();

    /* FAQ: kiểu Omni — mở mục này thì các mục khác tự đóng */
    (function () {
      const items = Array.prototype.slice.call(document.querySelectorAll('.faq-item'));
      items.forEach((it) => it.addEventListener('toggle', () => {
        if (it.open) items.forEach((o) => { if (o !== it) o.open = false; });
      }));
    })();

    /* Testimonials: carousel LƯỚT — kéo/vuốt ngang + nút ‹ › + tab (đồng bộ 2 chiều) */
    (function () {
      const track = document.getElementById('tm-track');
      const stage = document.querySelector('#testimonials .tm-stage');
      const tabs = Array.prototype.slice.call(document.querySelectorAll('#testimonials .tm-tab'));
      const cards = Array.prototype.slice.call(document.querySelectorAll('#testimonials .tm-card'));
      const prevBtn = document.getElementById('tm-prev');
      const nextBtn = document.getElementById('tm-next');
      if (!track || !stage || !cards.length) return;
      const total = cards.length;
      let index = 0;

      function update() {
        track.style.transform = 'translateX(' + (-index * 100) + '%)';
        tabs.forEach(function (t, k) { t.classList.toggle('is-active', k === index); });
        cards.forEach(function (c, k) { c.classList.toggle('is-active', k === index); });
        if (prevBtn) prevBtn.disabled = index === 0;
        if (nextBtn) nextBtn.disabled = index === total - 1;
      }
      function goTo(i) { index = Math.max(0, Math.min(total - 1, i)); update(); }

      // Tab + nút mũi tên đều điều khiển carousel
      tabs.forEach(function (t, i) { t.addEventListener('click', function () { goTo(i); }); });
      prevBtn && prevBtn.addEventListener('click', function () { goTo(index - 1); });
      nextBtn && nextBtn.addEventListener('click', function () { goTo(index + 1); });

      // Kéo chuột / vuốt cảm ứng ngang để lướt card
      var startX = 0, startY = 0, dragging = false, axis = null, dx = 0;
      stage.addEventListener('pointerdown', function (e) {
        if (e.target.closest('.tm-nav')) return;
        startX = e.clientX; startY = e.clientY; dragging = true; axis = null; dx = 0;
        track.style.transition = 'none';
        try { stage.setPointerCapture(e.pointerId); } catch (_) {}
      });
      stage.addEventListener('pointermove', function (e) {
        if (!dragging) return;
        dx = e.clientX - startX;
        var dy = e.clientY - startY;
        if (!axis && (Math.abs(dx) + Math.abs(dy) > 8)) axis = Math.abs(dx) > Math.abs(dy) ? 'x' : 'y';
        if (axis === 'x') {
          if (e.cancelable) e.preventDefault();
          stage.classList.add('is-grabbing');
          var pct = (dx / stage.offsetWidth) * 100;
          track.style.transform = 'translateX(' + (-index * 100 + pct) + '%)';
        }
      });
      function endDrag() {
        if (!dragging) return;
        dragging = false;
        stage.classList.remove('is-grabbing');
        track.style.transition = '';
        if (axis === 'x' && Math.abs(dx) > 60) {
          goTo(index + (dx < 0 ? 1 : -1));
        } else {
          update();
        }
        axis = null; dx = 0;
      }
      stage.addEventListener('pointerup', endDrag);
      stage.addEventListener('pointercancel', endDrag);

      update();
