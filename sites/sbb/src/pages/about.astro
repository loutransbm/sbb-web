<PageLayout
  title="Về SBB"
  description="SBB là ai, vì sao tồn tại, và điều SBB không phải."
  site="sbb"
  currentPath="/about"
>
  <!-- ===== HERO (cascade 2x2 + glass pill — KHỚP Omni about, giữ NGÔN NGỮ thiết kế homepage) ===== -->
  <section class="o-hero about-hero">
    <div class="hero-glow-beam" aria-hidden="true"></div>
    <div class="about-hero-wrap">
      <div class="cs-header about-hero-head">
        <!-- Dòng 1: ABOUT SBB (trắng lớn) + glass pill chườm cuối chữ (như Omni "WORK FLOW") -->
        <div class="cs-line cs-line-1">
          <span class="cs-text-white">ABOUT SBB</span>
          <div class="cs-glass-pill">
            <span class="cs-glass-title">CÁCH SBB LÀM</span>
            <span class="cs-glass-sub">Nói thật trước, chuẩn bị năng lực thật, đồng hành tới cùng.</span>
          </div>
        </div>
        <!-- Dòng 2: INSTITUTE (trắng lớn, trái) + đuôi "& THE WAY WE / WORK SMART" (phải, 2 dòng) -->
        <div class="about-line-2">
          <span class="about-verb cs-text-white">INSTITUTE</span>
          <span class="about-tail">
            <span class="cs-text-white">&amp; THE WAY WE</span>
            <span class="cs-text-white">WORK SMART</span>
          </span>
        </div>
      </div>
      <!-- Đoạn mô tả dưới-phải (như Omni). Canh TRÁI thẳng mép chữ "W" của WORK SMART:
           thước đo ẩn = đúng chữ "WORK SMART" (cùng font/size) ép khối rộng = bề ngang tiêu đề, lead 42ch nằm sát mép trái khối. -->
      <div class="about-hero-lead-wrap">
        <span class="lead-width-driver" aria-hidden="true">WORK SMART</span>
        <p class="o-lead about-hero-lead">SBB là những người đã đi trước bạn một đoạn đường. Đủ gần để hiểu bạn đang lo gì, đủ thẳng để nói thật, và đủ trách nhiệm để không buông tay bạn giữa chừng.</p>
      </div>
    </div>
  </section>

  <!-- ===== SECTION 2: PARTNER MARQUEE (bê NGUYÊN từ homepage — cụm tiêu đề + logo đối tác) ===== -->
  <section class="partner-marquee-section">
