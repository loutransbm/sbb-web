  /* Right Agency Box */
  .agency-box {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    text-align: left;
  }
  .agency-heading {
    font-family: var(--font-headline);
    font-size: clamp(3.2rem, 5vw, 5.5rem); /* Adjusted to be large but not so large that it expands the column and shifts the center image */
    line-height: 0.95;
    color: #f2420b; /* GLOBAL EDUCATION -> xanh, đối trọng với PRACTICAL TRAINING cam */
    font-weight: 600;
    text-transform: uppercase;
    margin-bottom: 2.5rem;
    letter-spacing: -0.03em;
  }
  .action-pill-row {
