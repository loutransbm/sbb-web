    /* ============================================
     Immersive Omni Hero Section
     ============================================ */
  .omni-hero {
    height: 100vh;
    min-height: 650px;
    position: relative;
    z-index: 2; /* Nâng Hero lên trên để ánh sáng lan xuống phần dưới */
    /* Dark background with subtle ambient reflection (hắt sáng nhẹ) from the top.
       Lớp linear phủ đáy: ép mép đáy hero phẳng đều #150b07 (xoá lệch màu radial ở giữa)
       -> khớp tuyệt đối với section 2, không còn đường kẻ. Vầng cam phía trên giữ nguyên. */
    background:
      /* Quầng sáng tương tự trang About */
      radial-gradient(ellipse 56% 305px at 45% 100%, rgba(242, 66, 11, 0.06) 0%, transparent 60%),
      radial-gradient(circle at top center, rgba(242, 66, 11, 0.04) 0%, var(--paper) 96%);
    display: flex;
    align-items: center;
    padding-top: 6rem;
    padding-bottom: 0;
    box-sizing: border-box;
  }
  
  /* Matte Noise Filter for Header */
  .omni-hero::after {
    content: "";
    position: absolute;
    inset: 0;
    opacity: 0.03; /* Giảm noise để bề mặt trong và sạch hơn trên nền sáng */
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='2' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
    /* Hết noise TỪ 72% trở xuống -> đáy hero (≈10% cuối) sạch noise, KHỚP Section 2 (vốn không có noise).
       Xoá bất đối xứng grain ở mạch nối -> không còn hairline khi DPR lẻ (1.755). */
    -webkit-mask-image: linear-gradient(to bottom, black 0%, black 72%, transparent 90%);
    mask-image: linear-gradient(to bottom, black 0%, black 72%, transparent 90%);
    pointer-events: none;
    z-index: 1;
    mix-blend-mode: overlay;
  }

  /* Vignette: dồn sáng vào GIỮA, rìa 2 BÊN tối lại -> chiều sâu kiểu Omni.
     Nằm TRÊN quầng sáng (z1) nhưng DƯỚI nội dung (z2) nên không làm tối chữ/ảnh. */
  .omni-hero::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    /* Đã xoá quầng viền (vignette) để nền sạch hoàn toàn (clean) như trang about */
    display: none;
    /* Tắt HẲN vignette ở 38% dưới cùng (kể cả rìa 2 bên) -> đáy hero = #150b07 thuần, khớp tuyệt đối Section 2, không còn vệt mờ ở mạch nối */
    -webkit-mask-image: linear-gradient(to bottom, #000 0%, #000 40%, transparent 62%);
    mask-image: linear-gradient(to bottom, #000 0%, #000 40%, transparent 62%);
  }
  
  /* Top-down Spotlight Beam */
  .hero-glow-beam {
    position: absolute;
    top: -8%;
    left: 65%;
    transform-origin: top center;
    transform: translateX(-50%) rotate(23deg); /* Đỉnh sáng dịch sang PHẢI (qua bên phải cô gái), rồi đánh chéo xuống dưới-trái về phía chữ SBB */
    width: 1040px;
    height: 178%; /* kéo dài XUYÊN xuống Section 2 -> 2 section liền khối */
    /* Lõi RỰC (amber gần trắng-cam), đuôi sáng DÀI giữ ấm xuống tận Section 2. Ít blur -> nét căng 8k */
    background: radial-gradient(
      ellipse 50% 50% at 50% 19%,
      rgba(242, 66, 11, 0.16) 0%,
      rgba(242, 66, 11, 0.13) 17%,
      rgba(242, 66, 11, 0.10) 37%,
      rgba(242, 66, 11, 0.07) 55%,
      rgba(242, 66, 11, 0.04) 71%,
      rgba(242, 66, 11, 0.02) 85%,
      transparent 98%
    );
    filter: blur(28px); /* nét, căng, không nhòe */
    pointer-events: none;
    z-index: 1;
    opacity: 1;
  }

  .hero-glow-beam::after {
    display: none;
  }

  /* CẦU NỐI BULLETPROOF: 1 khối ĐỤC liền mạch vắt qua đáy hero, KHỚP HỆT nền+quầng (#150b07 + quầng ấm tâm 45%, bán kính dọc 305px).
     z-index:0 -> nằm TRÊN nền hero & section 2 (vì hero là stacking-context z2 > section2 z1) nhưng DƯỚI beam(z1) => beam vẫn hắt qua, không bị đục.
     Vì là MỘT element duy nhất ngay tại ranh giới, không còn boundary 2-layer để DPR lẻ (1.755) tạo hairline. Mép trên/dưới feather nhiều px -> không sinh vệt mới. */
  .hero-seam-bridge {
    position: absolute;
    left: 0;
    right: 0;
    bottom: -60px;
    height: 120px;
    z-index: 0;
    pointer-events: none;
    background:
      radial-gradient(ellipse 56% 305px at 45% 50%, rgba(242, 66, 11, 0.06) 0%, transparent 60%),
      #D9D1CA;
    -webkit-mask-image: linear-gradient(to bottom, transparent 0%, #000 28%, #000 72%, transparent 100%);
    mask-image: linear-gradient(to bottom, transparent 0%, #000 28%, #000 72%, transparent 100%);
  }

  .omni-hero__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-10);
    align-items: center;
    z-index: 2;
    position: relative;
    width: calc(100% - 4rem) !important;   /* Khớp mép thanh nav: chừa 2rem mỗi bên */
    max-width: 120rem !important;          /* Khớp cap thanh nav để SBB & EDUCATION thẳng hàng với mép nav */
    padding-inline: 0 !important;
  }

