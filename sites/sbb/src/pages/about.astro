---
import PageLayout from '@ui/layouts/PageLayout.astro';

const blocks = [
  {
    num: '01',
    title: 'Vì sao SBB tồn tại',
    body: 'Vì đi ra thế giới không nên là đặc quyền. Nhưng đi mà không sẵn sàng thì phí. SBB tồn tại để rút ngắn khoảng cách giữa “muốn đi” và “đi được thật”.',
  },
  {
    num: '02',
    title: 'Vai trò trong cộng đồng',
    body: 'SBB kết nối những người trẻ muốn đi thật với những cơ hội nghề thật ở nước ngoài — đồng thời xây dựng cộng đồng để người đi trước dẫn đường cho người đi sau.',
  },
];

// Case studies — kiểu Omni: tiêu đề (câu chuyện) + ẢNH. Card hiển thị TIÊU ĐỀ + nút mũi tên (body để dành trang chi tiết).
// 3 card đầu = case study homepage. Sau đó là các câu chuyện riêng (ẩn danh: KHÔNG tên nước ngoài / KHÔNG quốc gia / KHÔNG nguồn).
// MỖI NGƯỜI = 1 card + 1 câu chuyện + 1 ảnh khớp chủ đề (public/images/case-studies/). cs10 = kế toán (ảnh văn phòng), cs11 = phục vụ FOH (ảnh set bàn).
// ĐÃ BỎ ảnh lộ địa điểm: cs5.webp (koala) + cs6.webp (Study Gold Coast/$30,000) → thay bằng cs3.jpg (2 bạn F&B) + cs2.jpg (bạn nam ở Vessel). 2 file cs5/cs6.webp còn trên disk nhưng KHÔNG còn dùng.
const caseStudies = [
  { title: 'Từ người được phỏng vấn đến người chọn nhân tài', img: '/images/case-studies/cs1.jpg', body: 'Mong muốn có kinh nghiệm thực tế ngoài giảng đường, bạn ấy đảm nhận công tác tuyển dụng — trực tiếp phỏng vấn và đánh giá ứng viên. Từ vị trí người luôn được phỏng vấn, bạn vươn lên thành người chọn nhân tài, làm chủ cả quy trình tuyển dụng chuyên nghiệp.' },
  { title: 'My Linh Le: nhận việc full‑time ngay sau kỳ thực tập', img: '/images/students/my-linh-le.jpg' },
  { title: 'Từ mơ ước đứng lớp đến giáo viên tự tin thực thụ', img: '/images/case-studies/cs4.webp', body: 'Mang khát khao trở thành giáo viên, bạn ấy bước vào lớp học thật, quan sát nhiều phương pháp rồi tự đứng lớp. Những giờ dạy thực tế giúp bạn làm chủ cách truyền đạt và tìm thấy ngọn lửa đam mê nghề giáo.' },
  { title: 'Khanh Giang: vững tay nghề bếp & tiếng Anh thực chiến', img: '/images/students/khanh-giang.jpg' },
  { title: 'Từ học bổng xuất sắc đến mạng lưới nghề rộng mở', img: '/images/case-studies/cs2.jpg', body: 'Giành học bổng nhờ niềm say mê khám phá, bạn ấy bước vào bộ phận hỗ trợ người học, mỗi ngày tư vấn và phục vụ. Trải nghiệm ấy giúp bạn xây dựng mạng lưới nghề nghiệp vững chắc và một hồ sơ năng lực nổi bật.' },
  { title: 'Victoria Tran: cọ xát marketing thực chiến quốc tế', img: '/images/students/victoria-tran.jpg' },
  { title: 'Mỗi ngày cọ xát thực tế, bản lĩnh nghề nghiệp lớn dần', img: '/images/case-studies/cs3.jpg', body: 'Khao khát mở rộng tầm nhìn và rèn giao tiếp trước khi ra trường, bạn ấy dấn thân vào môi trường làm việc thật. Mỗi ngày được thực hành, bạn tự tin hơn và tích lũy góc nhìn nghề nghiệp quý giá.' },
  { title: 'Vượt qua biến cố, khởi động lại hành trình sự nghiệp', img: '/images/case-studies/cs7.webp', body: 'Sau khi giành vị trí thực tập trong một lĩnh vực kỹ thuật đầy cạnh tranh, bạn ấy phải tạm hoãn vì biến cố cá nhân. Bằng nghị lực và sự chuẩn bị kỹ lưỡng, bạn trở lại, tỏa sáng và tích lũy kỹ năng để lại dấu ấn lâu dài.' },
  { title: 'Tác phẩm đầu tay được đăng tải, đam mê bùng cháy', img: '/images/case-studies/cs8.webp', body: 'Bước vào bộ phận marketing với mong muốn thực chiến, bạn ấy trực tiếp viết nội dung và tin bài để xuất bản. Khoảnh khắc thấy tác phẩm của mình hiện diện trên các nền tảng là niềm hạnh phúc vỡ òa — một bước tiến nghề nghiệp thật sự.' },
  { title: 'Rèn nghề khách sạn bài bản, vững vàng chuyên môn', img: '/images/case-studies/cs9.webp', body: 'Theo đuổi giấc mơ quản lý khách sạn, bạn ấy được rèn luyện thực tế trong môi trường chuyên nghiệp. Không chỉ thành thạo nghiệp vụ vận hành, bạn còn thấm bài học cốt lõi: tôn trọng người khác chính là cách để được tôn trọng.' },
  { title: 'Lần đầu thử thách môi trường mới, trưởng thành vượt bậc', img: '/images/case-studies/cs10.webp', body: 'Quyết tâm thử thách bản thân trong một môi trường hoàn toàn mới, bạn ấy giao tiếp chuyên nghiệp mỗi ngày và chỉ sau ít tuần đã đủ tự tin dẫn dắt, hướng dẫn người đến sau — học được cách tự giải quyết vấn đề và tích lũy kinh nghiệm thực thụ.' },
  { title: 'Từ con số không đến vững tay nghề phục vụ', img: '/images/case-studies/cs11.webp', body: 'Khởi đầu gần như từ con số không, bạn ấy lăn lộn qua đủ môi trường phục vụ — từ nhà hàng cao cấp, bistro đến các sự kiện lớn. Môi trường đa dạng giúp bạn bứt phá, thu nhận vô số kỹ năng để vững vàng theo nghề.' },
];

const notWhat = ['Công ty du học', 'Môi giới visa', 'Đội sale chạy số'];

const values = [
  { t: 'Nói thật', d: 'Đủ thẳng để nói điều bạn cần nghe, chứ không phải điều bạn muốn nghe.' },
  { t: 'Trọng năng lực', d: 'Chuẩn bị để bạn được tin tưởng và trọng dụng — không chỉ “được đi”.' },
  { t: 'Không buông tay', d: 'Đồng hành tới khi bạn vững vàng, không bỏ bạn lại giữa chừng.' },
];

// Đội ngũ — PLACEHOLDER (user sẽ gửi ảnh + tên thật sau). Vai trò để gợi ý cấu trúc.
const team = [
  // Ảnh xóa nền + crop CHÂN DUNG NGỰC-HẮT-LÊN đồng đều (4:5) trong /images/team/*-portrait.png
  { name: 'Lou Tran', role: 'Founder & CEO', img: '/images/team/lou-portrait.png' },
  { name: 'Mai', role: 'Co-Founder & Director of Enrollment', img: '/images/team/mai-portrait.png' },
