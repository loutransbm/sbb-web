      position: relative;
      z-index: 10;
      transform: translateY(-2.5rem); /* Lifted the heading up further as requested */
    }
    .agency-box {
      padding-right: 0 !important;
      position: relative;
      z-index: 1; /* Put text back behind the card */
    }
  }

  /* Left Campaign Box */
  .campaign-box {
