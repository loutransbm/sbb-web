  /* ============================================================
     OMNI PERFECT SHINE (Requested by User)
     Tạo hiệu ứng hào quang trung tâm cực mạnh, rực rỡ như Omni
     ============================================================ */

  /* 1) Nền Nâu Đen (Pitch Brown) kết hợp Linear Gradient (Ánh sáng hắt từ trên xuống) */
  .omni-hero {
    background: radial-gradient(circle at 50% 50%, rgba(60, 15, 0, 0.2) 0%, rgba(25, 8, 4, 1) 50%, rgba(18, 5, 2, 1) 100%) !important; /* Đánh sáng nền cực nhẹ để xóa vùng đen kịt */ 
  }

  /* 2) Khôi phục độ nhiễu hạt (Film Grain) siêu mạnh của Omni để tạo texture điện ảnh */
    .omni-hero::after {
      display: block !important; /* Bật lại layer noise */
      opacity: 0.07 !important; /* Giảm noise xuống mốc cực dịu */
        z-index: 3 !important;
        pointer-events: none !important;
        mix-blend-mode: overlay !important; /* Overlay giúp noise ăn sâu vào màu sắc */
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='2' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E") !important;
    }

  /* 3) Xóa sạch các tia sáng chéo rác */
