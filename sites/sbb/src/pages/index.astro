        </div>
      </div>

      <div class="cs-tabs reveal">
        <button class="cs-tab active" data-tab="1">CASE STUDY #1</button>
        <button class="cs-tab" data-tab="2">CASE STUDY #2</button>
        <button class="cs-tab" data-tab="3">CASE STUDY #3</button>
      </div>

      <div class="cs-cards-wrapper reveal">
        <div class="cs-card active" id="cs-card-1">
