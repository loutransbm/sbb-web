<script>
  // Dynamic Scroll-Linked Door Opening Animation
  document.addEventListener('DOMContentLoaded', () => {
    const closedDoorImg = document.querySelector('.card-doors .card-image-closed') as HTMLElement;
    if (!closedDoorImg) return;

    window.addEventListener('scroll', () => {
      const rect = closedDoorImg.getBoundingClientRect();
      const viewHeight = window.innerHeight;
      
      const cardCenter = rect.top + rect.height / 2;
      const distFromCenter = Math.abs(viewHeight / 2 - cardCenter);
      
      const maxDist = viewHeight / 2;
      let opacity = distFromCenter / maxDist;
      
      opacity = Math.max(0.1, Math.min(1, opacity));
      
      closedDoorImg.style.opacity = opacity.toString();
    });
  });
</script>












































