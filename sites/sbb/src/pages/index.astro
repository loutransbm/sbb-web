    image-rendering: -webkit-optimize-contrast;
    image-rendering: crisp-edges;
    transform: translateZ(0);
    backface-visibility: hidden;
    will-change: transform, filter;

    /* Make it pure white and slightly transparent normally */
    filter: brightness(0) invert(1) opacity(0.5);
    
    transition: all 0.3s ease;
  }
  
  .partner-logo img:hover {
    /* Make it fully opaque and slightly glowing on hover */
    filter: brightness(0) invert(1) opacity(1) drop-shadow(0 0 10px rgba(255, 255, 255, 0.4));
    transform: scale(1.05) translateZ(0); /* Slight pop out effect */
  }


  
  @keyframes marqueeScroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  /* Bottom Row: Giant Heading & Social Links */
  .hero-bottom-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    width: 100%;
    grid-column: 1 / -1;
    margin-top: -3rem; /* Lowered so SBB text isn't too high */
    z-index: 10; /* Higher than artwork-frame so SBB sits IN FRONT of the girl to hide her legs */
    pointer-events: auto;
    border-top: none;
    padding-inline: 1.5rem; /* Aligns SBB and social links perfectly with the header logo edge */
    padding-top: var(--space-2);
    padding-bottom: 2.5rem; /* Added to push SBB and social logos up from the bottom edge */
    position: relative;
  }
  
  /* --- Hero Entrance Animation --- */
  @keyframes heroElementIn {
    0% { opacity: 0; filter: blur(16px); }
    100% { opacity: 1; filter: blur(0); }
  }
  .hero-anim {
    animation: heroElementIn 1.8s cubic-bezier(0.16, 1, 0.3, 1) backwards;
  }
  
  .giant-bg-text {
    font-family: var(--font-headline);
    font-size: clamp(6rem, 12vw, 13rem);
    color: #FFFFFF;
    font-weight: 600;
    line-height: 0.75;
    letter-spacing: -0.04em;
    margin-left: -5px;
    pointer-events: none;
    user-select: none;
    position: relative;
    z-index: 10;
    transform: translateY(1rem);
  }
  @media (min-width: 992px) {
    .giant-bg-text {
      transform: translateY(0); /* Neutral vertical transform to sit perfectly under the card */
    }
  }
  .social-links {
    display: flex;
    gap: var(--space-5);
    margin-bottom: var(--space-2);
    align-items: center;
  }
  .social-links a {
    display: inline-flex;
    color: rgba(255, 255, 255, 0.7);
    transition: color 0.3s ease, transform 0.3s ease;
  }
  .social-links a svg {
    width: 22px;
    height: 22px;
    fill: currentColor;
  }
  .social-links a:hover {
    color: #FFFFFF;
    transform: translateY(-2px);
  }

  /* ============================================
     Visual Agency Header & Footer (For Grid)
     ============================================ */
  .agency-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-block: var(--space-6);
    border-bottom: none; /* Removed the hard line to create a fluid, continuous flow */
    font-size: var(--text-xs);
    font-weight: var(--weight-bold);
    letter-spacing: var(--tracking-wider);
    color: var(--text-secondary);
    text-transform: uppercase;
    margin-top: var(--space-4); /* Reduced margin to pull the content up slightly into the fade */
  }
  .agency-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-block: var(--space-6);
    border-top: 2px solid var(--text-primary);
    font-size: var(--text-xs);
    font-weight: var(--weight-bold);
    letter-spacing: var(--tracking-wider);
    color: var(--text-secondary);
    text-transform: uppercase;
    margin-top: var(--space-12);
  }

  /* ============================================
     3x3 Agency Grid Layout
     ============================================ */
  .agency-grid-container {
    padding-block: var(--space-12);
  }
  .agency-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
  }
  @media (min-width: 768px) {
    .agency-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-6);
    }
  }

  /* ============================================
     Universal Card Styles
     ============================================ */
  .agency-card {
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: var(--space-8);
    aspect-ratio: 3 / 4;
    text-decoration: none;
    background-color: #070201;
    background-image: radial-gradient(circle at center, rgba(235, 75, 0, 0.95) 0%, rgba(235, 75, 0, 0.25) 30%, rgba(235, 75, 0, 0.05) 65%, transparent 100%);
    border: 1px solid rgba(255, 255, 255, 0.08);
    color: #FFFFFF;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1),
                box-shadow 0.4s cubic-bezier(0.16, 1, 0.3, 1),
                border-color var(--duration-medium) var(--ease-out);
    box-shadow: inset 0 0 80px rgba(0, 0, 0, 0.95), inset 0 0 2px rgba(255, 255, 255, 0.15), 0 10px 30px rgba(0,0,0,0.5);
    border-radius: 40px;
  }
  .agency-card::before {
    content: "";
    position: absolute;
    inset: 0;
    opacity: 0.25;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 1;
    mix-blend-mode: overlay;
  }
  .agency-card > * {
    z-index: 2;
  }
  .agency-card:hover {
    transform: translateY(-8px);
    box-shadow: inset 0 0 80px rgba(0, 0, 0, 0.95), inset 0 0 2px rgba(255, 255, 255, 0.3), 0 20px 40px rgba(0,0,0,0.8);
  }

  /* Image Backgrounds */
  .card-image-bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-size: cover;
    background-position: center;
    z-index: 0;
    transition: transform var(--duration-slow) var(--ease-out);
  }
  .agency-card:hover .card-image-bg {
    transform: scale(1.05);
  }

  /* Overlays */
  .card-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(180deg, rgba(26, 26, 26, 0.2) 0%, rgba(26, 26, 26, 0.7) 100%);
    z-index: 1;
  }

  /* Header row inside card */
  .card-top-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    z-index: 2;
    position: relative;
  }
  .card-tag {
    background-color: rgba(26, 26, 26, 0.75);
    backdrop-filter: blur(5px);
    border: 1px solid rgba(255, 255, 255, 0.15);
    padding: var(--space-1) var(--space-3);
    font-size: var(--text-xs);
    font-weight: var(--weight-bold);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: #FFFFFF;
  }
  .arrow-indicator {
    font-size: var(--text-xl);
    color: rgba(255, 255, 255, 0.8);
    transition: transform var(--duration-fast) var(--ease-out), color var(--duration-fast) var(--ease-out);
  }
  .agency-card:hover .arrow-indicator {
    transform: translate(2px, 2px);
    color: var(--accent);
  }

  /* Bottom content info */
  .card-bottom-info {
    z-index: 2;
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .card-title {
    font-family: var(--font-headline);
    font-size: var(--text-2xl);
    font-weight: var(--weight-regular);
    line-height: var(--leading-tight);
    text-transform: uppercase;
    margin: 0;
    color: #FFFFFF;
  }
  .card-title-lg {
    font-family: var(--font-headline);
    font-size: var(--text-3xl);
    font-weight: var(--weight-light);
    line-height: var(--leading-tight);
    text-transform: uppercase;
    margin: 0;
    color: #FFFFFF;
  }
  .card-desc {
    font-size: var(--text-sm);
    color: rgba(255, 255, 255, 0.85);
    line-height: var(--leading-normal);
    margin: 0;
    max-width: 38ch;
  }

  /* ============================================
     Specific Card Configurations
     ============================================ */

  /* Card 1: Hero */
  .card-hero {
    border-color: var(--text-primary);
  }
  .card-hero-text {
    z-index: 2;
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  /* Card 2: GRP Vision (Cream layout) */
  .card-vision {
    /* Removed background and color overrides to inherit unified orange style */
  }
  .card-vision .arrow-indicator {
    color: var(--ink);
  }
  .card-label-orange {
    font-weight: var(--weight-bold);
    font-size: var(--text-sm);
    letter-spacing: var(--tracking-wider);
    color: var(--accent);
    text-transform: uppercase;
  }
  .card-vision-images {
    display: flex;
    justify-content: space-around;
    align-items: center;
    z-index: 2;
    position: relative;
    padding-block: var(--space-4);
  }
  .vision-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2);
  }
  .vision-shape {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background-color: rgba(255, 94, 58, 0.08);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--accent);
    transition: transform var(--duration-medium) var(--ease-out);
  }
  .card-vision:hover .vision-shape {
    transform: scale(1.1);
    background-color: rgba(255, 94, 58, 0.15);
  }
  .vision-label {
    font-size: var(--text-xs);
    font-weight: var(--weight-bold);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--text-secondary);
  }
  .card-footer-label {
    font-weight: var(--weight-bold);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-wider);
    color: var(--text-muted);
    text-transform: uppercase;
    z-index: 2;
  }

  /* Card 3: Doors opening animation */
  .card-doors {
    /* Inherits base orange style */
  }
  .card-image-open {
    z-index: 0;
  }
  .card-image-closed {
    z-index: 1;
    transition: opacity 0.5s ease-in-out;
  }
  .card-doors:hover .card-image-closed {
    opacity: 0; /* open the door on hover */
  }

  /* Card 4: Reality Check */
  .card-reality {
    justify-content: flex-start;
    gap: var(--space-8);
  }
  .reality-statement-box {
    background: rgba(255, 255, 255, 0.03);
    backdrop-filter: blur(15px);
    -webkit-backdrop-filter: blur(15px);
    border: 1px solid rgba(255, 255, 255, 0.08);
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    z-index: 2;
    margin-top: auto;
  }
  .reality-title {
    font-family: var(--font-headline);
    font-size: var(--text-lg);
    font-weight: var(--weight-bold);
    color: #FFFFFF;
    letter-spacing: var(--tracking-wider);
    margin: 0;
  }
  .reality-desc {
    font-size: var(--text-sm);
    color: rgba(255, 255, 255, 0.7);
    line-height: var(--leading-normal);
    margin: 0;
  }
  .reality-btn {
    font-size: var(--text-xs);
    font-weight: var(--weight-bold);
    letter-spacing: var(--tracking-wider);
    color: var(--accent);
  }

  /* Card 5: Trends */
  .card-trends {
    background-color: #1A1A1A;
  }
  .card-trends .card-overlay {
    background: linear-gradient(180deg, rgba(255, 94, 58, 0.1) 0%, rgba(255, 94, 58, 0.7) 100%);
  }

  /* Card 6: Parents Corner */
  .card-parents {
    background-color: var(--bg-secondary);
    color: var(--ink);
    box-shadow: var(--shadow-md);
  }
  .card-parents .arrow-indicator {
    color: var(--ink);
  }
  .circle-graphic {
    width: 100px;
    height: 100px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(255, 94, 58, 0.05) 0%, rgba(255, 94, 58, 0.15) 100%);
    border: 2px solid var(--accent);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-inline: auto;
    z-index: 2;
    position: relative;
    transition: transform var(--duration-medium) var(--ease-out);
  }
  .card-parents:hover .circle-graphic {
    transform: scale(1.08) rotate(90deg);
  }
  .circle-text {
    font-size: var(--text-xs);
    font-weight: var(--weight-bold);
    letter-spacing: var(--tracking-wider);
    color: var(--accent);
  }
  .parents-desc {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: var(--leading-normal);
    text-align: center;
    z-index: 2;
    position: relative;
    margin: 0;
  }

  /* Card 8: Learn / Case Studies (Folder Tab) */
  .card-learn {
    background: linear-gradient(135deg, var(--accent) 0%, #B85B38 100%);
    border-color: var(--text-primary);
  }
  .folder-tab {
    background: rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(15px);
    -webkit-backdrop-filter: blur(15px);
    border: 1px solid rgba(255, 255, 255, 0.15);
    padding: var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    z-index: 2;
    margin-top: auto;
  }
  .folder-tab__top {
    font-size: 10px;
    font-weight: var(--weight-bold);
    letter-spacing: var(--tracking-wider);
    color: rgba(255, 255, 255, 0.8);
    text-transform: uppercase;
  }
  .folder-tab__body {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  .folder-title {
    font-family: var(--font-headline);
    font-size: var(--text-lg);
    font-weight: var(--weight-bold);
    color: #FFFFFF;
    margin: 0;
    text-transform: uppercase;
  }
  .folder-meta {
    font-size: 10px;
    font-weight: var(--weight-bold);
    letter-spacing: var(--tracking-wider);
    color: rgba(255, 255, 255, 0.6);
  }
  .folder-btn {
    font-size: var(--text-xs);
    font-weight: var(--weight-bold);
    letter-spacing: var(--tracking-wider);
    color: #FFFFFF;
    text-decoration: underline;
  }

  /* ============================================
     Micro-Animations (Smooth Alive Vibe)
     ============================================ */

  /* Card 1 Hero Step-Walk Camera shake */
  .card-hero:hover .card-image-bg {
    animation: camera-step-hero 1.2s ease-in-out infinite alternate;
  }
  @keyframes camera-step-hero {
    0% { transform: scale(1.02) translate(0, 0); }
    100% { transform: scale(1.07) translate(-1%, -1%); }
  }

  /* Card 2 GRP Vision dashboard spin & letter expansion */
  .card-vision:hover .vision-shape svg {
    animation: dashboard-spin 2.5s linear infinite;
  }
  .card-vision .vision-label {
    transition: all var(--duration-medium) var(--ease-out);
  }
  .card-vision:hover .vision-label {
    letter-spacing: 0.15em;
    color: var(--accent);
  }
  @keyframes dashboard-spin {
    to { transform: rotate(360deg); }
  }

  /* Card 5 Eye Contact natural reveal */
  .card-trends .card-image-bg {
    filter: grayscale(1) contrast(1.15) brightness(0.85);
    transition: filter 0.6s ease, transform 0.6s ease;
  }
  .card-trends:hover .card-image-bg {
    filter: grayscale(0) contrast(1.2) brightness(1.05);
    transform: scale(1.06);
  }

  /* Card 7 Workspace Camera Pan */
  .card-growth:hover .card-image-bg {
    animation: camera-pan-workspace 6s ease-in-out infinite alternate;
  }
  @keyframes camera-pan-workspace {
    0% { transform: scale(1.03) translateX(-1.5%); }
    100% { transform: scale(1.03) translateX(1.5%); }
  }

  /* Card 9 Saturation Boost */
  .card-contact .card-image-bg {
    filter: saturate(0.85);
    transition: transform var(--duration-slow) var(--ease-out), filter var(--duration-slow) var(--ease-out);
  }
  .card-contact:hover .card-image-bg {
    transform: scale(1.05);
    filter: saturate(1.15) contrast(1.1);
  }
  /* ============================================
     Cinema Results Section (Omni Clone)
     ============================================ */
 .cinema-results-section {
  padding-top: 9rem; /* Đẩy TV xa dải logo hơn cho đỡ dày (6rem -> 9rem, gap ~208px) */
  padding-bottom: 5rem; /* Thu hẹp khoảng cách xuống Programs (8rem -> 5rem) */
  display: flex;
  justify-content: center;
  position: relative;
  z-index: 15;
  /* Đáy cinema tối dần nhẹ để nối liền độ tối với Programs (xoá Mach band ở biên, hết vạch kẻ) */
  background: linear-gradient(to bottom, #070201 0%, #070201 55%, #040100 100%);
}

  /* Ambient wall lights that spill from the screen */
  .wall-glow-top, .wall-glow-left, .wall-glow-right {
    position: absolute;
    pointer-events: none;
    z-index: 1;
    opacity: 0.6;
  }
  .wall-glow-top {
    top: -5%;
    left: 50%;
    transform: translateX(-50%);
    width: 60vw;
    height: 30%;
    background: radial-gradient(ellipse at center top, rgba(230, 74, 25, 0.25) 0%, transparent 70%);
    filter: blur(60px);
  }
  .wall-glow-left, .wall-glow-right {
    bottom: 0;
    width: 25vw;
    height: 100%;
    filter: blur(80px);
  }
  .wall-glow-left {
    left: 0;
    background: radial-gradient(ellipse at left center, #bd340b 0%, transparent 60%);
  }
  .wall-glow-right {
    right: 0;
    background: radial-gradient(ellipse at right center, #3d1004 0%, transparent 60%);
  }

  .cinema-stage {
    position: relative;
    width: 92vw;
    max-width: 1600px;
    margin-inline: auto;
    perspective: 2000px;
    z-index: 2;
  }

  /* Ultra Premium Display Container */
  .premium-display {
    position: relative;
    width: 100%;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    /* 3D Depth */
    transform: rotateX(4deg) scale(0.98);
    transform-origin: center bottom;
    transition: transform 0.5s ease-out;
  }

  .premium-display:hover {
    transform: rotateX(2deg) scale(1);
  }

  /* Sleek Metallic Bezel (Pro Display / OLED style) */
  .display-bezel {
    width: 100%;
    padding: 2px; /* Ultra-thin OLED bezel */
    background: #000;
    border-radius: 8px;
    border: 1px solid #222; /* Just a whisper of a metal edge */
    border-top: 1px solid #444; /* light catching the top edge */
    border-bottom: 1px solid transparent; /* bỏ viền đáy xám #222 để không để lại vạch 1px ở biên */
    box-shadow:
      0 55px 150px rgba(0,0,0,0.95), /* enhanced depth shadow */
      0 -45px 130px -10px rgba(230, 74, 25, 0.22), /* warm glow chỉ hắt LÊN trên */
      -75px -10px 130px -25px rgba(230, 74, 25, 0.16), /* và sang hai bên */
      75px -10px 130px -25px rgba(230, 74, 25, 0.16);
      /* CỐ Ý không có quầng hắt xuống: quầng cũ `0 0 150px` ôm sát mép đáy nên vẽ ra vạch — ánh ấm bên dưới để .program-light-spill lo */
    position: relative;
    z-index: 3;
  }

  /* The actual screen inside */
  .cinema-screen {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 7;
    /* Lớp 1 (trên): tối dần đều TOÀN chiều ngang ở đáy -> mép đáy đồng nhất màu tối, không còn góc cam sáng tạo vạch.
       Lớp 2 (dưới): gradient chéo gốc của màn hình. Chữ là foreground nên KHÔNG bị tối. */
    background:
      linear-gradient(to bottom, rgba(5,2,1,0) 0%, rgba(5,2,1,0) 46%, rgba(5,2,1,0.85) 74%, #050201 90%),
      linear-gradient(110deg, #982F10 0%, #E64A19 35%, #050201 85%);
    border-radius: 6px;
    /* Deep screen shadow + vignette đáy fade về đúng màu nền (xoá hẳn vạch ở cạnh đáy TV; text nằm cao hơn 42px nên không bị tối) */
    box-shadow: inset 0 0 60px rgba(0,0,0,0.95), inset 0 -78px 55px -30px #040100;
    overflow: hidden;
  }

  /* Matte Screen Noise Texture */
  .cinema-screen::after {
    content: "";
    position: absolute;
    inset: 0;
    opacity: 0.25;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 20;
    mix-blend-mode: overlay;
  }

  /* Glass Glare Overlay for Realism */
  .glass-glare {
    position: absolute;
    top: 0;
    left: 0;
    width: 200%;
    height: 200%;
    background: linear-gradient(105deg, rgba(255,255,255,0.08) 0%, rgba(255,255,255,0) 40%);
    transform: translateY(-20%) translateX(-20%);
    pointer-events: none;
    z-index: 10;
  }



  /* 3D Floor Reflection */
  .cinema-floor {
    position: absolute;
    bottom: -15%;
    left: 50%;
    transform: translateX(-50%) rotateX(75deg);
    width: 120vw;
    height: 400px;
    background: radial-gradient(ellipse at top, rgba(230, 74, 25, 0.15) 0%, transparent 60%);
    pointer-events: none;
    z-index: 0;
  }

  .screen-content {
    display: flex;
    width: 100%;
    height: 100%;
    position: relative;
    z-index: 3;
  }

  .screen-left {
    flex: 1.4;
    padding: 8% 4% 8% 8%;
