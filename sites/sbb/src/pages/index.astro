    z-index: -1 !important;
  }

  /* 8) MOMENTS + FAQ — quầng cam/đỏ nối mạch liền khối */
  .moments-section::before { display: none !important; }
  .moments-section::after {
    content: ''; position: absolute; left: 0; right: 0; pointer-events: none;
