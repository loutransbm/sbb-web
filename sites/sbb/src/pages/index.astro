---
import PageLayout from '@ui/layouts/PageLayout.astro';
---

<PageLayout
  title="Trang chủ"
  description="SBB chuẩn bị cho người trẻ Việt đủ sức được tin, được trọng dụng, không chỉ được đi."
  site="sbb"
  currentPath="/"
>

  <section class="omni-hero">
    <div class="hero-seam-bridge"></div>
    <div class="hero-glow-beam"></div>

    <div class="container omni-hero__inner">
      
      <div class="hero-col hero-col--left">
        <div class="campaign-box hero-anim" style="animation-delay: 0.2s">
          <h2 class="campaign-heading">PRACTICAL<br/>TRAINING</h2>
          <p class="campaign-sub">
            Chúng tôi đồng hành cùng bạn kiến tạo lộ trình sự nghiệp toàn cầu.
          </p>
          <a href="#case-studies" class="campaign-link">CASE STUDIES</a>
        </div>

        <div class="stat-card stat-card--left hero-anim" style="animation-delay: 0.6s">
          <div class="stat-number">86%</div>
          <p class="stat-text">Học viên đạt tăng trưởng thu nhập >50% trong 12 tháng hoặc thăng tiến lên quản lý quốc tế.</p>
        </div>
      </div>

      <div class="hero-col hero-col--center hero-anim" style="animation-delay: 0.4s">
        <div class="central-artwork-frame">
          <div class="artwork-image" style="background-image: url('/images/hero_student_transparent.png');"></div>
          <div class="artwork-glow"></div>
        </div>
      </div>

      <div class="hero-col hero-col--right">
        <div class="stat-card stat-card--right hero-anim" style="animation-delay: 1.0s">
          <div class="stat-number">5,000+</div>
          <p class="stat-text">Cơ hội thực tập &amp; làm việc thực chất qua mạng lưới đối tác toàn cầu.</p>
        </div>

        <div class="agency-box hero-anim" style="animation-delay: 0.8s">
          <h2 class="agency-heading">GLOBAL<br/>EDUCATION</h2>
          
          <div class="action-pill-row">
            <a href="/apply" class="action-pill-btn" aria-label="Đăng ký ứng tuyển">
              <span class="pill-arrow">↘</span>
            </a>
            <span class="action-pill-text">Chúng tôi cùng bạn tự tin vươn ra thế giới<br/>bằng năng lực thực chất.</span>
          </div>
        </div>
      </div>

      <div class="hero-bottom-row">
        <div class="giant-bg-text hero-anim" style="animation-delay: 1.2s">SBB</div>
        <div class="social-links hero-anim" style="animation-delay: 1.4s">
          <a href="https://linkedin.com" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
