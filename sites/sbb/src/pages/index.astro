  <script>
    /* Dropdown CUSTOM cho form (clean & smooth) — progressive enhancement:
       GIỮ <select> thật (ẩn) để submit + fallback; vẽ UI riêng có animation mượt thay popup native thô. */
    (function () {
      function enhance(select) {
        const wrap = select.closest('.lf-select-wrap');
        if (!wrap || wrap.classList.contains('is-enhanced')) return;

        const opts = Array.prototype.slice.call(select.options);
        const placeholder = opts.filter(function (o) { return o.disabled; })[0] || null;
        const choices = opts.filter(function (o) { return !o.disabled; });

        const dd = document.createElement('div');
        dd.className = 'lf-dd';

        const trigger = document.createElement('button');
        trigger.type = 'button';
        trigger.className = 'lf-dd-trigger';
        trigger.setAttribute('aria-haspopup', 'listbox');
        trigger.setAttribute('aria-expanded', 'false');

        const valueEl = document.createElement('span');
        valueEl.className = 'lf-dd-value';

        const caret = document.createElement('span');
        caret.className = 'lf-dd-caret';
        caret.setAttribute('aria-hidden', 'true');
        caret.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg>';

        trigger.appendChild(valueEl);
        trigger.appendChild(caret);

        const panel = document.createElement('ul');
        panel.className = 'lf-dd-panel';
        panel.setAttribute('role', 'listbox');

        let activeIdx = -1;

        function syncDisplay() {
          const sel = select.options[select.selectedIndex];
          const isPlaceholder = !!(sel && sel.disabled);
          valueEl.textContent = sel ? sel.text : (placeholder ? placeholder.text : '');
          valueEl.classList.toggle('is-placeholder', isPlaceholder);
          const curVal = sel ? sel.value : '';
          Array.prototype.forEach.call(panel.children, function (li) {
            li.classList.toggle('is-selected', !isPlaceholder && li.getAttribute('data-value') === curVal);
          });
        }
        function choose(opt) {
          select.value = opt.value;
          select.dispatchEvent(new Event('change', { bubbles: true }));
          syncDisplay();
        }
        choices.forEach(function (opt) {
          const li = document.createElement('li');
          li.className = 'lf-dd-option';
          li.setAttribute('role', 'option');
          li.setAttribute('data-value', opt.value);
          li.textContent = opt.text;
          li.addEventListener('click', function () { choose(opt); closeDd(); trigger.focus(); });
          panel.appendChild(li);
        });
        function setActive(i) {
          activeIdx = i;
          Array.prototype.forEach.call(panel.children, function (li, idx) { li.classList.toggle('is-active', idx === i); });
          if (i >= 0 && panel.children[i]) panel.children[i].scrollIntoView({ block: 'nearest' });
        }
        function openDd() {
          dd.classList.add('is-open');
          trigger.setAttribute('aria-expanded', 'true');
          let selIdx = -1;
          const cur = select.options[select.selectedIndex];
          if (cur && !cur.disabled) selIdx = choices.map(function (o) { return o.value; }).indexOf(cur.value);
          setActive(selIdx >= 0 ? selIdx : 0);
        }
        function closeDd() { dd.classList.remove('is-open'); trigger.setAttribute('aria-expanded', 'false'); setActive(-1); }
        function isOpen() { return dd.classList.contains('is-open'); }

        trigger.addEventListener('click', function (e) { e.stopPropagation(); isOpen() ? closeDd() : openDd(); });
        trigger.addEventListener('keydown', function (e) {
          switch (e.key) {
            case 'ArrowDown': e.preventDefault(); isOpen() ? setActive(Math.min(choices.length - 1, activeIdx + 1)) : openDd(); break;
            case 'ArrowUp': e.preventDefault(); isOpen() ? setActive(Math.max(0, activeIdx - 1)) : openDd(); break;
            case 'Enter': case ' ': e.preventDefault(); if (!isOpen()) openDd(); else if (activeIdx >= 0) { choose(choices[activeIdx]); closeDd(); } break;
            case 'Escape': if (isOpen()) { e.preventDefault(); closeDd(); } break;
            case 'Tab': if (isOpen()) closeDd(); break;
          }
        });
        document.addEventListener('click', function (e) { if (isOpen() && !dd.contains(e.target)) closeDd(); });

        dd.appendChild(trigger);
        dd.appendChild(panel);
        wrap.appendChild(dd);
        /* Astro scope CSS theo attr data-astro-cid-* (gắn lúc build). Element tạo bằng JS KHÔNG có attr này
           → style scoped không "ăn". Copy cid từ .lf-select-wrap sang mọi element vừa tạo để khớp selector scoped. */
        var cidAttr = null;
        for (var i = 0; i < wrap.attributes.length; i++) { if (wrap.attributes[i].name.indexOf('data-astro-cid-') === 0) { cidAttr = wrap.attributes[i].name; break; } }
        if (cidAttr) { dd.setAttribute(cidAttr, ''); var all = dd.querySelectorAll('*'); for (var j = 0; j < all.length; j++) all[j].setAttribute(cidAttr, ''); }
        wrap.classList.add('is-enhanced');
        syncDisplay();
      }
      function init() { Array.prototype.forEach.call(document.querySelectorAll('.lf-select'), enhance); }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
      else init();
    })();
  </script>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const wrapper = document.querySelector('.cs-cards-wrapper');
      const track = document.getElementById('cs-track');
      const tabs = [...document.querySelectorAll('.cs-tab')];
      const cards = [...document.querySelectorAll('.cs-card')];
      const prevBtn = document.getElementById('cs-prev');
      const nextBtn = document.getElementById('cs-next');
      if (!wrapper || !track || !cards.length) return;

      const total = cards.length;
      let index = 0;

      function update() {
        track.style.transform = `translateX(${-index * 100}%)`;
        tabs.forEach((t, k) => t.classList.toggle('active', k === index));
        cards.forEach((c, k) => c.classList.toggle('active', k === index));
        if (prevBtn) prevBtn.disabled = index === 0;
        if (nextBtn) nextBtn.disabled = index === total - 1;
      }
      function goTo(i) {
        index = Math.max(0, Math.min(total - 1, i));
        update();
      }

      // Tabs trên đầu + nút ‹ › đều điều khiển slider (đồng bộ 2 chiều)
      tabs.forEach((tab, k) => tab.addEventListener('click', () => goTo(k)));
      prevBtn && prevBtn.addEventListener('click', () => goTo(index - 1));
      nextBtn && nextBtn.addEventListener('click', () => goTo(index + 1));

      // Kéo chuột / vuốt cảm ứng
      let startX = 0, startY = 0, dragging = false, axis = null, dx = 0;
      wrapper.addEventListener('pointerdown', (e) => {
        if (e.target.closest('.cs-nav')) return; // để nút tự xử lý
        startX = e.clientX; startY = e.clientY;
        dragging = true; axis = null; dx = 0;
      });
      wrapper.addEventListener('pointermove', (e) => {
        if (!dragging) return;
        const mx = e.clientX - startX, my = e.clientY - startY;
        if (axis === null && (Math.abs(mx) > 8 || Math.abs(my) > 8)) {
          axis = Math.abs(mx) > Math.abs(my) ? 'x' : 'y';
          if (axis === 'x') {
            track.classList.add('is-dragging');
            try { wrapper.setPointerCapture(e.pointerId); } catch (_) {}
          }
        }
        if (axis === 'x') {
          e.preventDefault();
          dx = mx;
          const pct = -index * 100 + (mx / wrapper.offsetWidth) * 100;
          track.style.transform = `translateX(${pct}%)`;
        }
      });
      function endDrag() {
        if (!dragging) return;
        dragging = false;
        if (axis === 'x') {
          track.classList.remove('is-dragging');
          const threshold = wrapper.offsetWidth * 0.16;
          if (dx < -threshold) goTo(index + 1);
          else if (dx > threshold) goTo(index - 1);
          else update(); // chưa đủ ngưỡng -> bật về chỗ cũ
        }
        axis = null; dx = 0;
      }
      wrapper.addEventListener('pointerup', endDrag);
      wrapper.addEventListener('pointercancel', endDrag);
      wrapper.addEventListener('dragstart', (e) => e.preventDefault()); // chặn kéo ảnh/text

      // Phím mũi tên ← → khi slider trong tầm nhìn
      window.addEventListener('keydown', (e) => {
        const r = wrapper.getBoundingClientRect();
        const visible = r.top < window.innerHeight * 0.8 && r.bottom > window.innerHeight * 0.2;
        if (!visible) return;
        if (e.key === 'ArrowRight') goTo(index + 1);
        else if (e.key === 'ArrowLeft') goTo(index - 1);
      });

      update();
    });
  </script>

  <script>
    /* Coverflow "LIFE BEYOND BORDERS" — VÒNG LẶP vô tận (virtual ring): mỗi card định vị quanh tâm theo offset modulo N -> luôn cân 2 bên, không trống */
    (function () {
      const track = document.getElementById('mv-track');
      if (!track) return;
      const cards = Array.prototype.slice.call(track.children).filter((c) => c.classList.contains('mv-card'));
      const N = cards.length;
      if (!N) return;
      const prev = document.getElementById('mv-prev');
      const next = document.getElementById('mv-next');
      const stage = track.closest('.mv-stage');
      let pos = 0, target = 0, raf = null, timer = null, cw = 300, activeI = -1, soundOn = false, inView = false, wantPlay = false;

      function measure() { cw = cards[0].offsetWidth || 300; }
      function wrap(o) { o = ((o % N) + N) % N; if (o > N / 2) o -= N; return o; }  // -> khoảng (-N/2, N/2]

      function place() {   // render mọi card theo pos hiện tại — ĐỒNG BỘ, không cần rAF
        const spacing = cw * 0.8;   // dải clip rộng hơn, bám gần 2 mép hơn
        for (let i = 0; i < N; i++) {
          const off = wrap(i - pos);
          const ao = Math.abs(off);
          const k = ao > 3.2 ? 3.2 : ao;
          const kk = (off < 0 ? -1 : 1) * k;
          const c = cards[i];
          c.style.visibility = ao > 3.6 ? 'hidden' : 'visible';
          c.style.transform = 'translate(-50%, -50%) translateX(' + (kk * spacing).toFixed(1) +
            'px) translateZ(' + (-k * 120).toFixed(0) + 'px) rotateY(' + (-kk * 20).toFixed(1) +
            'deg) scale(' + (1 - k * 0.14).toFixed(3) + ')';
          c.style.opacity = (ao > 3.4 ? 0 : Math.max(0.25, 1 - k * 0.3)).toFixed(2);
          c.style.zIndex = String(100 - Math.round(k * 10));
        }
        const cur = ((Math.round(pos) % N) + N) % N;
        if (cur !== activeI) {
          if (cards[activeI]) { cards[activeI].classList.remove('is-active'); const ov = cards[activeI].querySelector('video'); if (ov) { ov.pause(); try { ov.currentTime = 0; } catch (_) {} } }
          cards[cur].classList.add('is-active');
          activeI = cur;
          wantPlay = false; stage.classList.add('is-paused');   // clip mới ĐỨNG YÊN, hiện nút ▶ — chỉ chạy khi bấm
        }
      }
      function frame() {   // ease pos -> target (qua rAF, cho autoplay/mũi tên)
        raf = null;
        const diff = target - pos;
        if (Math.abs(diff) < 0.001) pos = target; else pos += diff * 0.18;
        place();
        if (pos !== target) raf = requestAnimationFrame(frame);
      }
      function animate() { if (!raf) raf = requestAnimationFrame(frame); }

      function startAuto() {}   // đã tắt tự xoay -> đứng yên để xem trọn clip (điều hướng: kéo / mũi tên)
      function stopAuto() { if (timer) { clearInterval(timer); timer = null; } }
      prev && prev.addEventListener('click', () => { target -= 1; stopAuto(); startAuto(); animate(); });
      next && next.addEventListener('click', () => { target += 1; stopAuto(); startAuto(); animate(); });
      stage.addEventListener('pointerenter', stopAuto);
      stage.addEventListener('pointerleave', startAuto);

      // Lightbox: bấm card -> mở player TikTok (chỉ tải 1 iframe khi xem -> trang vẫn nhẹ)
      const lb = document.getElementById('mv-lightbox');
      const lbFrame = document.getElementById('mv-lb-frame');
      const lbClose = document.getElementById('mv-lb-close');
      const lbTt = document.getElementById('mv-lb-tt');
      function openLightbox(card) {
        if (!lb || !card) return;
        stopAuto();
        // Tự host MP4 (H.264, faststart) -> phát NGAY trong trang, không phụ thuộc TikTok
        var img = card.querySelector('img');
        var poster = img ? img.getAttribute('src') : '';
        var src = poster.replace('/images/tiktok/', '/videos/').replace(/\.jpg$/, '.mp4');
        var id = card.getAttribute('data-tt');
        // muted + autoplay -> phát NGAY trên MỌI thiết bị (mobile/khách mới chặn autoplay-có-tiếng) -> bắt đầu CÂM rồi cho bật tiếng
        lbFrame.innerHTML =
          '<video class="mv-lb-video" src="' + src + '" poster="' + poster + '" autoplay muted loop playsinline controls preload="auto" style="display:block;width:auto;height:auto;max-width:96vw;max-height:86vh;border-radius:16px;background:#000;"></video>'
          + '<button class="mv-lb-sound" type="button" aria-label="Bật tiếng">&#128266; Bật tiếng</button>';
        if (lbTt) lbTt.href = 'https://www.tiktok.com/@duyendao222/video/' + id;
        lb.classList.add('is-open'); lb.setAttribute('aria-hidden', 'false');
        document.body.style.overflow = 'hidden';
        var v = lbFrame.querySelector('video');
        var sb = lbFrame.querySelector('.mv-lb-sound');
        if (v) {
          v.muted = true;
          var p = v.play(); if (p && p.catch) p.catch(function () {});   // autoplay câm -> luôn chạy
          if (sb) {
            sb.addEventListener('click', function () { v.muted = false; v.volume = 1; if (v.paused) { var q = v.play(); if (q && q.catch) q.catch(function () {}); } sb.style.display = 'none'; });
            v.addEventListener('volumechange', function () { if (!v.muted) sb.style.display = 'none'; });  // tự bật tiếng qua control -> ẩn nút
          }
        }
      }
      function closeLightbox() {
        if (!lb || !lb.classList.contains('is-open')) return;
        lb.classList.remove('is-open'); lb.setAttribute('aria-hidden', 'true');
        lbFrame.innerHTML = '';                       // gỡ iframe -> dừng video
        document.body.style.overflow = '';
        startAuto();
      }
      lbClose && lbClose.addEventListener('click', closeLightbox);
      lb && lb.addEventListener('click', (e) => { if (e.target === lb) closeLightbox(); });
      document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeLightbox(); });

      // Kéo ngang để xoay vòng; phân biệt KÉO vs CHẠM (chạm mới mở clip)
      let down = false, sx = 0, st = 0, drag = 0, downOnActive = false;
      track.addEventListener('pointerdown', (e) => { down = true; sx = e.clientX; st = target; drag = 0; track.classList.add('is-grabbing'); stopAuto(); const c = e.target.closest && e.target.closest('.mv-card'); downOnActive = !!(c && c.classList.contains('is-active')); try { track.setPointerCapture(e.pointerId); } catch (_) {} });
      track.addEventListener('pointermove', (e) => { if (!down) return; const dx = e.clientX - sx; if (Math.abs(dx) > drag) drag = Math.abs(dx); target = st - dx / (cw * 0.8); pos = target; place(); });
      const up = () => { if (!down) return; down = false; track.classList.remove('is-grabbing'); const wasTap = drag < 10; target = Math.round(target); animate(); if (wasTap && downOnActive) toggleActive(); };
      track.addEventListener('pointerup', up);
      track.addEventListener('pointercancel', up);
      track.addEventListener('dragstart', (e) => e.preventDefault());
      // CHẠM card giữa -> play/pause (hiện overlay ▶ khi pause). Dùng pointerup (đáng tin hơn 'click' với pointer-capture)
      function toggleActive() {
        const v = curVideo(); if (!v) return;
        if (v.paused) { wantPlay = true; soundOn = true; v.muted = false; const p = v.play(); if (p && p.catch) p.catch(function () {}); stage.classList.remove('is-paused'); }
        else { wantPlay = false; v.pause(); stage.classList.add('is-paused'); }
      }
      // --- Clip card GIỮA: KHÔNG autoplay — chỉ phát khi user bấm nút ▶ ---
      function curVideo() { return cards[activeI] ? cards[activeI].querySelector('video') : null; }
      // Bấm nút ▶ (overlay giữa stage) -> phát/dừng clip đang ở giữa (có tiếng)
      const pp = document.getElementById('mv-pp');
      if (pp) pp.addEventListener('click', function (e) { e.stopPropagation(); toggleActive(); });
      // Chống Chrome (coverflow 3D) TỰ pause giữa chừng: chỉ phát lại khi user ĐÃ bấm play (wantPlay) & clip còn trong tầm.
      cards.forEach(function (card) {
        const cv = card.querySelector('video');
        if (cv) cv.addEventListener('pause', function () {
          if (wantPlay && inView && card.classList.contains('is-active')) { const p = cv.play(); if (p && p.catch) p.catch(function () {}); }
        });
      });
      // Section còn dính viewport thì phát; chỉ DỪNG khi cuộn HẲN ra ngoài (ngưỡng rộng -> không nháy khi Lenis cuộn mượt)
      // Dùng getBoundingClientRect (CHUẨN với smooth-scroll Lenis) — KHÔNG tự phát khi cuộn vào;
      // chỉ DỪNG clip & hiện lại nút ▶ khi cuộn HẲN ra ngoài.
      function checkInView() {
        const r = stage.getBoundingClientRect();
        const vis = r.top < window.innerHeight && r.bottom > 0;
        if (vis !== inView) {
          inView = vis;
          if (!inView) { const v = curVideo(); if (v) v.pause(); wantPlay = false; stage.classList.add('is-paused'); }
        }
      }
      setInterval(checkInView, 300);
      window.addEventListener('resize', checkInView);
      checkInView();

      measure();
      place();   // render nghỉ ban đầu (đồng bộ, không phụ thuộc rAF)
      window.addEventListener('resize', () => { measure(); place(); });
      if (window.ResizeObserver) new ResizeObserver(() => { measure(); place(); }).observe(track);
      startAuto();
    })();
  </script>

  <script>
    /* FAQ: kiểu Omni — mở mục này thì các mục khác tự đóng */
    (function () {
      const items = Array.prototype.slice.call(document.querySelectorAll('.faq-item'));
      items.forEach((it) => it.addEventListener('toggle', () => {
        if (it.open) items.forEach((o) => { if (o !== it) o.open = false; });
      }));
    })();

    /* Testimonials: carousel LƯỚT — kéo/vuốt ngang + nút ‹ › + tab (đồng bộ 2 chiều) */
    (function () {
      const track = document.getElementById('tm-track');
      const stage = document.querySelector('#testimonials .tm-stage');
      const tabs = Array.prototype.slice.call(document.querySelectorAll('#testimonials .tm-tab'));
      const cards = Array.prototype.slice.call(document.querySelectorAll('#testimonials .tm-card'));
      const prevBtn = document.getElementById('tm-prev');
      const nextBtn = document.getElementById('tm-next');
      if (!track || !stage || !cards.length) return;
      const total = cards.length;
      let index = 0;

      function update() {
        track.style.transform = 'translateX(' + (-index * 100) + '%)';
        tabs.forEach(function (t, k) { t.classList.toggle('is-active', k === index); });
        cards.forEach(function (c, k) { c.classList.toggle('is-active', k === index); });
        if (prevBtn) prevBtn.disabled = index === 0;
        if (nextBtn) nextBtn.disabled = index === total - 1;
      }
      function goTo(i) { index = Math.max(0, Math.min(total - 1, i)); update(); }

      // Tab + nút mũi tên đều điều khiển carousel
      tabs.forEach(function (t, i) { t.addEventListener('click', function () { goTo(i); }); });
      prevBtn && prevBtn.addEventListener('click', function () { goTo(index - 1); });
      nextBtn && nextBtn.addEventListener('click', function () { goTo(index + 1); });

      // Kéo chuột / vuốt cảm ứng ngang để lướt card
      var startX = 0, startY = 0, dragging = false, axis = null, dx = 0;
      stage.addEventListener('pointerdown', function (e) {
        if (e.target.closest('.tm-nav')) return;
        startX = e.clientX; startY = e.clientY; dragging = true; axis = null; dx = 0;
        track.style.transition = 'none';
        try { stage.setPointerCapture(e.pointerId); } catch (_) {}
      });
      stage.addEventListener('pointermove', function (e) {
        if (!dragging) return;
        dx = e.clientX - startX;
        var dy = e.clientY - startY;
        if (!axis && (Math.abs(dx) + Math.abs(dy) > 8)) axis = Math.abs(dx) > Math.abs(dy) ? 'x' : 'y';
        if (axis === 'x') {
          if (e.cancelable) e.preventDefault();
          stage.classList.add('is-grabbing');
          var pct = (dx / stage.offsetWidth) * 100;
          track.style.transform = 'translateX(' + (-index * 100 + pct) + '%)';
        }
      });
      function endDrag() {
        if (!dragging) return;
        dragging = false;
        stage.classList.remove('is-grabbing');
        track.style.transition = '';
        if (axis === 'x' && Math.abs(dx) > 60) {
          goTo(index + (dx < 0 ? 1 : -1));
        } else {
          update();
        }
        axis = null; dx = 0;
      }
      stage.addEventListener('pointerup', endDrag);
      stage.addEventListener('pointercancel', endDrag);

      update();
    })();

    /* Đồng bộ chiều cao card testimonials = ĐÚNG chiều cao card case-studies (.cs-cards-wrapper) — chỉ desktop */
    (function () {
      var csw = document.querySelector('#case-studies .cs-cards-wrapper');
      var cards = Array.prototype.slice.call(document.querySelectorAll('#testimonials .tm-card'));
      if (!csw || !cards.length) return;
      function syncH() {
        if (window.innerWidth >= 992) {
          var h = Math.round(csw.getBoundingClientRect().height);
          cards.forEach(function (c) { c.style.minHeight = h + 'px'; });
        } else {
          cards.forEach(function (c) { c.style.minHeight = ''; });
        }
      }
      syncH();
      window.addEventListener('load', syncH);
      window.addEventListener('resize', syncH, { passive: true });
    })();

    /* --sbw = bề rộng scrollbar dọc -> để căn cụm tiêu đề sát 2 mép CHUẨN như thanh nav (tránh lệch do 100vw tính cả scrollbar) */
    (function () {
      var setSbw = function () {
        document.documentElement.style.setProperty('--sbw', (window.innerWidth - document.documentElement.clientWidth) + 'px');
      };
      setSbw();
      window.addEventListener('resize', setSbw, { passive: true });
    })();
  </script>
</PageLayout>

<style>
  /* === KHOẢNG CÁCH DỌC CHUẨN giữa các section: padding ~120px mỗi đầu → gap 240px ở desktop
     (= ĐÚNG gap Programs ↔ Real Results mà user chọn làm chuẩn 2026-06-14). Sửa 1 chỗ = áp cho mọi section. === */
  :global(:root) { --sec-pad: clamp(4rem, 8.5vw, 7.5rem); }
  /* ============================================
     Immersive Omni Hero Section
     ============================================ */
  .omni-hero {
    height: 100vh;
    min-height: 650px;
    position: relative;
    z-index: 2; /* Nâng Hero lên trên để ánh sáng lan xuống phần dưới */
    /* Dark background with subtle ambient reflection (hắt sáng nhẹ) from the top.
       Lớp linear phủ đáy: ép mép đáy hero phẳng đều #150b07 (xoá lệch màu radial ở giữa)
       -> khớp tuyệt đối với section 2, không còn đường kẻ. Vầng cam phía trên giữ nguyên. */
    background:
      /* Quầng sáng tương tự trang About */
      radial-gradient(ellipse 56% 305px at 45% 100%, rgba(242, 66, 11, 0.06) 0%, transparent 60%),
      radial-gradient(circle at top center, rgba(242, 66, 11, 0.04) 0%, var(--paper) 96%);
    display: flex;
    align-items: center;
    padding-top: 6rem;
    padding-bottom: 0;
    box-sizing: border-box;
  }
  
  /* Matte Noise Filter for Header */
  .omni-hero::after {
    content: "";
    position: absolute;
    inset: 0;
    opacity: 0.03; /* Giảm noise để bề mặt trong và sạch hơn trên nền sáng */
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='2' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
    /* Hết noise TỪ 72% trở xuống -> đáy hero (≈10% cuối) sạch noise, KHỚP Section 2 (vốn không có noise).
       Xoá bất đối xứng grain ở mạch nối -> không còn hairline khi DPR lẻ (1.755). */
    -webkit-mask-image: linear-gradient(to bottom, black 0%, black 72%, transparent 90%);
    mask-image: linear-gradient(to bottom, black 0%, black 72%, transparent 90%);
    pointer-events: none;
    z-index: 1;
    mix-blend-mode: overlay;
  }

  /* Vignette: dồn sáng vào GIỮA, rìa 2 BÊN tối lại -> chiều sâu kiểu Omni.
     Nằm TRÊN quầng sáng (z1) nhưng DƯỚI nội dung (z2) nên không làm tối chữ/ảnh. */
  .omni-hero::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    /* Đã xoá quầng viền (vignette) để nền sạch hoàn toàn (clean) như trang about */
    display: none;
    /* Tắt HẲN vignette ở 38% dưới cùng (kể cả rìa 2 bên) -> đáy hero = #150b07 thuần, khớp tuyệt đối Section 2, không còn vệt mờ ở mạch nối */
    -webkit-mask-image: linear-gradient(to bottom, #000 0%, #000 40%, transparent 62%);
    mask-image: linear-gradient(to bottom, #000 0%, #000 40%, transparent 62%);
  }
  
  /* Top-down Spotlight Beam */
  .hero-glow-beam {
    position: absolute;
    top: -8%;
    left: 65%;
    transform-origin: top center;
    transform: translateX(-50%) rotate(23deg); /* Đỉnh sáng dịch sang PHẢI (qua bên phải cô gái), rồi đánh chéo xuống dưới-trái về phía chữ SBB */
    width: 1040px;
    height: 178%; /* kéo dài XUYÊN xuống Section 2 -> 2 section liền khối */
    /* Lõi RỰC (amber gần trắng-cam), đuôi sáng DÀI giữ ấm xuống tận Section 2. Ít blur -> nét căng 8k */
    background: radial-gradient(
      ellipse 50% 50% at 50% 19%,
      rgba(242, 66, 11, 0.16) 0%,
      rgba(242, 66, 11, 0.13) 17%,
      rgba(242, 66, 11, 0.10) 37%,
      rgba(242, 66, 11, 0.07) 55%,
      rgba(242, 66, 11, 0.04) 71%,
      rgba(242, 66, 11, 0.02) 85%,
      transparent 98%
    );
    filter: blur(28px); /* nét, căng, không nhòe */
    pointer-events: none;
    z-index: 1;
    opacity: 1;
  }

  .hero-glow-beam::after {
    display: none;
  }

  /* CẦU NỐI BULLETPROOF: 1 khối ĐỤC liền mạch vắt qua đáy hero, KHỚP HỆT nền+quầng (#150b07 + quầng ấm tâm 45%, bán kính dọc 305px).
     z-index:0 -> nằm TRÊN nền hero & section 2 (vì hero là stacking-context z2 > section2 z1) nhưng DƯỚI beam(z1) => beam vẫn hắt qua, không bị đục.
     Vì là MỘT element duy nhất ngay tại ranh giới, không còn boundary 2-layer để DPR lẻ (1.755) tạo hairline. Mép trên/dưới feather nhiều px -> không sinh vệt mới. */
  .hero-seam-bridge {
    position: absolute;
    left: 0;
    right: 0;
