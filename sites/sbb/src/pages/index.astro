    z-index: -1 !important;
  }
  .faq-section::before { display: none !important; }

  /* 9) CTA + FORM (đáy) — đều cam/đỏ (KHÔNG còn xanh) */
  .cta-final { overflow: visible !important; }
  .cta-final::before { 
    display: block !important; 
    width: 100vw !important; height: 130% !important;
    left: 50% !important; top: 50% !important;
    background: radial-gradient(circle 470px at 25% 45%,
      rgba(255, 112, 60, 0.80) 0%,
      rgba(248, 82, 26, 0.70) 30%,
      rgba(242, 66, 11, 0.50) 55%,
      rgba(20, 10, 5, 0.85) 85%,
      rgba(10, 5, 2, 0.95) 100%) !important;
    -webkit-mask-image: linear-gradient(to bottom, transparent 0%, black 15%, black 85%, transparent 100%) !important;
    mask-image: linear-gradient(to bottom, transparent 0%, black 15%, black 85%, transparent 100%) !important;
  }
  .lead-form::before { display: none !important; } /* bỏ ánh sáng thừa ở góc trái form (user 2026-06-20) */

  /* 10) CHỮ = TRẮNG sáng trên nền nâu trầm (như OMNI) */
  .campaign-heading, .agency-heading, .giant-bg-text, .partner-headline,
  .services-heading, .faq-mega, .cta-verb, .cs-text-white, .mvh-fade, .faq-a strong { color: #ffffff !important; }
  
