---
import PageLayout from '@ui/layouts/PageLayout.astro';

const categories = [
  {
    tag: 'Câu chuyện',
    title: 'Câu chuyện học viên',
    body: 'Hành trình thật của những người đã đi — từ ngày còn loay hoay đến lúc đứng vững ở môi trường quốc tế.',
  },
  {
    tag: 'Reality Check',
    title: 'Reality Check',
    body: 'Sự thật trần trụi về làm việc ở nước ngoài. Đủ thẳng để bạn chuẩn bị đúng, không vỡ mộng giữa đường.',
  },
  {
    tag: 'Tiếng nói SV',
    title: 'Tiếng nói sinh viên',
    body: 'Góc nhìn chưa qua chỉnh sửa từ chính người trẻ đang đi — điều họ tiếc, điều họ học, điều họ muốn nhắn lại.',
  },
  {
    tag: 'Cập nhật',
    title: 'Cập nhật chương trình',
    body: 'Thông tin mới nhất về các chương trình Internship J-1, GRP Foundation và lịch tuyển sinh từng kỳ.',
  },
];

const featured = [
  {
    tag: 'Câu chuyện',
    date: '12.06.2026',
    title: 'Từ phòng trọ Hà Nội đến gian bếp ở Colorado',
    body: 'Minh kể lại 6 tháng đầu trên đất Mỹ: cú sốc ngôn ngữ, ca làm 10 tiếng, và khoảnh khắc nhận ra mình đã thật sự trưởng thành.',
  },
  {
    tag: 'Reality Check',
    date: '08.06.2026',
    title: 'Lương cao ở nước ngoài: phần họ không kể bạn nghe',
    body: 'Con số trên giấy và số tiền thật sự còn lại sau thuế, nhà ở, đi lại. Một bài tính sòng phẳng để bạn không ảo tưởng.',
  },
  {
    tag: 'Tiếng nói SV',
    date: '03.06.2026',
    title: '"Mình ước có ai nói thật với mình sớm hơn"',
    body: 'Ba bạn sinh viên vừa kết thúc kỳ thực tập chia sẻ thẳng điều họ tiếc nhất — và điều họ sẽ làm khác nếu được quay lại.',
  },
  {
    tag: 'Cập nhật',
    date: '01.06.2026',
    title: 'Internship J-1 mùa Thu 2026 chính thức mở đơn',
    body: 'Toàn bộ thông tin về vị trí, thời gian, điều kiện và lộ trình chuẩn bị cho kỳ tuyển sinh sắp tới của chương trình.',
  },
  {
    tag: 'Câu chuyện',
    date: '27.05.2026',
    title: 'Cô gái Quảng Nam và bài học từ lần bị từ chối visa',
    body: 'Thất bại lần đầu không phải dấu chấm hết. Hành trình làm lại hồ sơ, luyện phỏng vấn và đậu ở lần thứ hai.',
  },
  {
    tag: 'Reality Check',
    date: '21.05.2026',
    title: 'Đi để trải nghiệm hay đi để xây sự nghiệp?',
    body: 'Hai con đường rất khác nhau, đòi hỏi sự chuẩn bị rất khác nhau. Xác định đúng trước khi bạn đặt chân lên máy bay.',
  },
];
---

<PageLayout
  title="News"
  description="Câu chuyện thật của học viên, reality check không tô vẽ, và tiếng nói sinh viên trên hành trình bước ra thế giới."
  site="sbb"
  currentPath="/news"
>
    <!-- ===== HERO ===== -->
  <section class="news-hero">
    <div class="container">
      <div class="cs-header about-hero-head">
        <div class="cs-line cs-line-1">
          <span class="cs-text-white">OUR BLOG</span>
          <div class="cs-glass-pill" style="margin-left: 2rem;">
            <span class="cs-glass-title">CONTENT HUB</span>
            <span class="cs-glass-sub" style="max-width: 250px;">A collection of guides, trends, and ideas for marketing and growth.</span>
          </div>
        </div>
        <div class="about-line-2" style="justify-content: flex-start; gap: 0;">
          <span class="about-verb cs-text-white" style="margin-left: clamp(2.5rem, 7.5vw, 7.5rem);">INSIGHTS</span>
          <span class="about-tail" style="margin-left: 1.5rem; text-align: left; align-items: flex-start;">
            <span style="color: rgba(255, 255, 255, 0.55);">&amp; MARKETING</span>
            <span class="cs-text-white">TRENDS</span>
          </span>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== CATEGORIES ===== -->
  <section class="o-section">
    <div class="container">
      <div class="o-head">
        <span class="o-head-eyebrow">Chuyên mục</span>
        <h2 class="o-head-title">WHAT WE <span class="o-stroke">COVER</span></h2>
        <p class="o-head-desc">Bốn dòng nội dung, một mục tiêu: cho bạn thấy bức tranh thật trước khi bạn quyết định đi.</p>
      </div>
      <div class="o-grid o-grid--4">
        {categories.map((c) => (
          <article class="o-card">
            <span class="o-card__tag">{c.tag}</span>
            <h3 class="o-card__title">{c.title}</h3>
            <p class="o-card__body">{c.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== FEATURED STORIES ===== -->
  <section class="o-section o-section--tint o-section--glow">
    <div class="container">
      <div class="o-head">
        <span class="o-head-eyebrow">Mới nhất</span>
        <h2 class="o-head-title">FEATURED <span class="o-stroke">STORIES</span></h2>
        <p class="o-head-desc">Những bài đáng đọc nhất tuần này — chọn lọc từ chính trải nghiệm của cộng đồng SBB.</p>
      </div>
      <div class="o-grid o-grid--3">
        {featured.map((a) => (
          <a href="/news" class="o-card">
            <span class="o-card__tag">{a.tag}</span>
            <h3 class="o-card__title">{a.title}</h3>
            <p class="o-card__body">{a.body}</p>
            <p class="o-card__body" style="margin-top:1.1rem;font-size:0.82rem;color:var(--ink-muted);letter-spacing:0.04em;text-transform:uppercase;">{a.date}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== STATEMENT ===== -->
  <section class="o-section">
    <div class="container">
      <p class="o-statement o-statement--full">
        Chúng tôi không kể chuyện cổ tích. Chúng tôi kể <span class="o-accent">sự thật</span> — để bạn đi với đôi mắt mở to.
      </p>
    </div>
  </section>

  <!-- ===== CTA ===== -->
  <section class="o-cta">
    <div class="container">
      <h2 class="o-cta__title">ĐỪNG BỎ LỠ</h2>
      <p class="o-cta__sub">Đăng ký nhận tin để không lỡ câu chuyện nào: reality check định kỳ, lịch tuyển sinh và những bài viết thật từ người đã đi.</p>
      <div class="o-actions">
        <a href="/apply" class="o-btn o-btn--primary">Đăng ký nhận tin</a>
        <a href="/learn" class="o-btn o-btn--ghost">Khám phá hành trình</a>
      </div>
    </div>
  </section>
</PageLayout>

<style>
  .news-hero {
    position: relative;
    padding-top: clamp(6rem, 8vw, 9rem);
    padding-bottom: clamp(3rem, 5vw, 5rem);
    background: transparent;
  }
.cs-header { margin-bottom: 0; font-weight: 500; line-height: 0.95; letter-spacing: -0.045em; font-family: 'Inter', sans-serif; }
    .cs-line { display: flex; align-items: center; gap: 1.5rem; }
    /* Cụm "ABOUT SBB INSTITUTE" = HỆT cỡ DÒNG 1 các section homepage (.cs-line-1) */
    .cs-line-1 { font-size: clamp(8.5rem, 12vw, 11rem); letter-spacing: -0.085em; white-space: nowrap; position: relative; z-index: 10; }
.about-line-2 { display: flex; justify-content: space-between; align-items: center; gap: 1.5rem; margin-top: 0.5rem; }
    .about-verb { font-size: clamp(8.5rem, 12vw, 11rem); letter-spacing: -0.085em; line-height: 0.9; white-space: nowrap; margin-left: clamp(2.5rem, 7.5vw, 7.5rem); }
.about-tail { display: flex; flex-direction: column; align-items: flex-end; gap: 0.3rem; font-size: clamp(3rem, 5vw, 6.5rem); letter-spacing: -0.07em; line-height: 0.92; text-align: right; }
    .about-tail span { display: block; white-space: nowrap; }

  .cs-text-white { color: #ffffff !important; }
  .cs-glass-pill {
    background: rgba(255, 255, 255, 0.03);
    backdrop-filter: blur(14px); -webkit-backdrop-filter: blur(14px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 100px;
    padding: clamp(0.6rem, 1vw, 1.2rem) clamp(1rem, 2vw, 1.8rem);
    display: inline-flex; flex-direction: column; gap: 0.2rem;
    box-shadow: 0 12px 30px rgba(0, 0, 0, 0.12);
  }
  .cs-glass-title {
    font-family: var(--font-headline); font-weight: 600; font-size: 0.8rem;
    letter-spacing: 0.15em; color: #F5EDE6; text-transform: uppercase;
  }
  .cs-glass-sub {
    font-family: 'Inter', sans-serif; font-weight: 400; font-size: clamp(0.85rem, 1vw, 0.95rem);
    line-height: 1.45; color: rgba(255, 255, 255, 0.65); white-space: normal;
  }


@media (max-width: 991px) {
      .about-hero-wrap { width: calc(100% - 3rem); }  /* mobile: lề 1.5rem mỗi bên cho khớp nav */
      .cs-line { flex-wrap: wrap; gap: 0.4rem; }
      .cs-line-1, .about-verb { font-size: clamp(3rem, 13vw, 5rem); white-space: normal; }
      .about-verb { margin-left: 0; }
      .about-hero-head .cs-glass-pill { transform: translateY(0); margin-left: 0; margin-top: 1rem; }
      /* dòng 2 xếp dọc, canh trái cho gọn trên mobile */
      .about-line-2 { flex-direction: column; align-items: flex-start; margin-top: 0.5rem; gap: 0.2rem; }
      .about-tail { align-items: flex-start; text-align: left; font-size: clamp(1.9rem, 9vw, 3.4rem); margin-top: 0.4rem; }
      /* Mobile: tắt thước đo ẩn, lead full-width canh trái như cũ */
      .about-hero-lead-wrap { width: 100%; max-width: 100%; margin-left: 0; }
      .lead-width-driver { display: none; }
      .about-hero-lead { margin-left: 0; max-width: 100%; }
    }
</style>
