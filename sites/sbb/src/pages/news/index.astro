---
import PageLayout from '@ui/layouts/PageLayout.astro';

// Danh mục lọc cho lưới blog (Omni style). 'all' = Tất cả.
const blogCats = [
  { id: 'all', label: 'Tất cả' },
  { id: 'tin-tuc', label: 'Tin tức' },
  { id: 'blog-insight', label: 'Blog Insight' },
  { id: 'hanh-trinh', label: 'Hành trình học viên' },
  { id: 'reality-check', label: 'Reality Check' },
];

// 18 bài = 6 hàng x 3 cột. (Tiêu đề/ảnh tạm dùng pool sẵn có; thay nội dung & link thật sau.)
const posts = [
  { cat: 'hanh-trinh',    catLabel: 'Hành trình học viên', title: 'Từ phòng trọ Hà Nội đến gian bếp ở Colorado',         img: '/images/hero_student.png',            href: '/news' },
  { cat: 'reality-check', catLabel: 'Reality Check',        title: 'Lương cao ở nước ngoài: phần họ không kể bạn nghe',    img: '/images/reality_face.png',            href: '/news' },
  { cat: 'tin-tuc',       catLabel: 'Tin tức',              title: 'Internship J-1 mùa Thu 2026 chính thức mở đơn',        img: '/images/office_tour.png',             href: '/news' },
  { cat: 'hanh-trinh',    catLabel: 'Hành trình học viên', title: 'Cô gái Quảng Nam và bài học từ lần bị từ chối visa',   img: '/images/students/khanh-giang.jpg',    href: '/news' },
  { cat: 'blog-insight',  catLabel: 'Blog Insight',         title: 'Chọn J-1 hay GRP? Bảng so sánh sòng phẳng cho người mới', img: '/images/case-studies/cs3.jpg',     href: '/news' },
  { cat: 'reality-check', catLabel: 'Reality Check',        title: 'Đi để trải nghiệm hay đi để xây sự nghiệp?',           img: '/images/case-studies/cs5.webp',       href: '/news' },
  { cat: 'tin-tuc',       catLabel: 'Tin tức',              title: 'GRP Foundation khai giảng khóa mùa Hè: lịch học & học phí', img: '/images/case-studies/cs1.jpg',   href: '/news' },
  { cat: 'hanh-trinh',    catLabel: 'Hành trình học viên', title: '"Mình ước có ai nói thật với mình sớm hơn"',           img: '/images/students/my-linh-le.jpg',     href: '/news' },
  { cat: 'blog-insight',  catLabel: 'Blog Insight',         title: '5 sai lầm khiến hồ sơ phỏng vấn visa bị đánh trượt',   img: '/images/mentorship.png',              href: '/news' },
  { cat: 'reality-check', catLabel: 'Reality Check',        title: "Ca làm 10 tiếng và sự thật về 'giấc mơ Mỹ'",          img: '/images/case-studies/cs6.webp',       href: '/news' },
  { cat: 'tin-tuc',       catLabel: 'Tin tức',              title: 'SBB mở thêm tuyến visa 407 sang Úc cho ngành Aged Care', img: '/images/case-studies/cs4.webp',     href: '/news' },
  { cat: 'hanh-trinh',    catLabel: 'Hành trình học viên', title: 'Victoria và hành trình từ sinh viên tỉnh lẻ đến JP Morgan', img: '/images/students/victoria-tran.jpg', href: '/news' },
  { cat: 'blog-insight',  catLabel: 'Blog Insight',         title: 'Tiền lương thật sự còn lại sau thuế, nhà ở và đi lại', img: '/images/workspace_laptop.png',        href: '/news' },
  { cat: 'reality-check', catLabel: 'Reality Check',        title: 'Cô đơn nơi xứ người: điều không brochure nào nói',     img: '/images/cinema_silhouette.png',       href: '/news' },
  { cat: 'tin-tuc',       catLabel: 'Tin tức',              title: 'Lịch hội thảo định hướng du học nghề quý III/2026',    img: '/images/modern_office_workspace.png', href: '/news' },
  { cat: 'hanh-trinh',    catLabel: 'Hành trình học viên', title: 'Từ thất bại IELTS đến hợp đồng thực tập tại Singapore', img: '/images/case-studies/cs7.webp',     href: '/news' },
  { cat: 'blog-insight',  catLabel: 'Blog Insight',         title: 'Checklist chuẩn bị 90 ngày trước khi bay',             img: '/images/case-studies/cs8.webp',       href: '/news' },
  { cat: 'reality-check', catLabel: 'Reality Check',        title: 'Về nước sau 2 năm: được gì, mất gì, học gì',           img: '/images/case-studies/cs9.webp',       href: '/news' },
];
---

<PageLayout
  title="News"
  description="Câu chuyện thật của học viên, reality check không tô vẽ, và tiếng nói sinh viên trên hành trình bước ra thế giới."
  site="sbb"
  currentPath="/news"
>
    <!-- ===== HERO ===== -->
  <section class="news-hero">
    <!-- Quầng sáng cam LỚN-RỰC đánh từ PHẢI vào "& REAL STORIES" (giống Omni blog hero) -->
    <div class="news-glow-beam" aria-hidden="true"></div>
    <div class="about-hero-wrap">
      <div class="cs-header about-hero-head">
        <div class="cs-line cs-line-1">
          <span class="cs-text-white">OUR BLOG</span>
          <div class="cs-glass-pill">
            <span class="cs-glass-title">CONTENT HUB</span>
            <span class="cs-glass-sub">Câu chuyện thật và reality check cho hành trình bước ra thế giới.</span>
          </div>
        </div>
        <div class="about-line-2">
          <span class="about-verb cs-text-white">INSIGHTS</span>
          <span class="about-tail">
            <span class="cs-text-white">&amp; REAL</span>
            <span class="cs-text-white">STORIES</span>
          </span>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== BLOG GRID (Omni style: lọc danh mục + tìm kiếm + card ảnh) ===== -->
  <section class="o-section blog-section">
    <div class="container">
      <!-- Toolbar: pill lọc danh mục + ô tìm kiếm -->
      <div class="blog-toolbar">
        <div class="blog-filters" role="group" aria-label="Lọc theo danh mục">
          {blogCats.map((c, i) => (
            <button type="button" class:list={["blog-filter", i === 0 && "is-active"]} data-filter={c.id}>{c.label}</button>
          ))}
        </div>
        <label class="blog-search">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4.2-4.2"/></svg>
          <input type="search" id="blogSearch" placeholder="Tìm bài viết..." autocomplete="off" aria-label="Tìm bài viết" />
        </label>
      </div>

      <!-- Lưới card (prototype: 1 hàng 3 card) -->
      <div class="blog-grid">
        {posts.map((p) => (
          <a href={p.href} class="blog-card" data-cat={p.cat} data-title={p.title.toLowerCase()}>
            <span class="blog-card__tag">{p.catLabel}</span>
            <h3 class="blog-card__title">{p.title}</h3>
            <div class="blog-card__media">
              <img src={p.img} alt={p.title} loading="lazy" onerror="this.style.display='none'" />
            </div>
            <span class="blog-card__cta" aria-label="Đọc bài">
              <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M8 8 L16 16"/><path d="M16 9 L16 16 L9 16"/></svg>
            </span>
          </a>
        ))}
      </div>
      <p class="blog-empty" hidden>Không tìm thấy bài viết phù hợp với bộ lọc.</p>
    </div>
  </section>

  <!-- ============ FINAL CTA · "READY TO SHINE BEYOND BORDERS" (giống Omni "READY TO GROW & SCALE") ============ -->
  <section class="cta-final" id="get-started">
    <div class="container cta-final-inner">
      <!-- Tiêu đề kiểu Omni "READY TO GROW & SCALE": cascade 3 dòng lớn + glass pill (y hệt homepage) -->
      <div class="cs-header cta-header">
        <div class="cs-line cs-line-1">
          <span class="cs-text-white">READY</span>
        </div>
        <div class="cta-line-2">
          <span class="cta-verb">TO SHINE</span>
          <div class="cs-glass-pill">
            <span class="cs-glass-title">LET'S TALK</span>
            <span class="cs-glass-sub">Tư vấn miễn phí 30 phút — cùng SBB vẽ lộ trình rõ ràng cho bạn.</span>
          </div>
        </div>
        <div class="cta-line-3">
          <span class="cta-tail"><span class="cs-text-white">BEYOND BORDERS?</span></span>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ LEAD FORM · (giống Omni contact form: 2 cột, label in hoa, input gạch chân, dropdown, nút pill) ============ -->
  <section class="lead-form" id="lead-form">
    <div class="container">
      <form class="lf-grid" action="#" method="POST" novalidate>
        <!-- Hàng 1: Họ tên | Số điện thoại -->
        <div class="lf-field">
          <label class="lf-label" for="lf-name">HỌ TÊN CỦA BẠN<span class="lf-req">*</span></label>
          <input class="lf-input" id="lf-name" name="name" type="text" required autocomplete="name" placeholder="Nguyễn Văn A" />
        </div>
        <div class="lf-field">
          <label class="lf-label" for="lf-phone">SỐ ĐIỆN THOẠI<span class="lf-req">*</span></label>
          <input class="lf-input" id="lf-phone" name="phone" type="tel" required autocomplete="tel" placeholder="+84 9xx xxx xxx" />
        </div>

        <!-- Hàng 2: Email | Bạn đang là -->
        <div class="lf-field">
          <label class="lf-label" for="lf-email">EMAIL CỦA BẠN<span class="lf-req">*</span></label>
          <input class="lf-input" id="lf-email" name="email" type="email" required autocomplete="email" placeholder="ban@email.com" />
        </div>
        <div class="lf-field">
          <label class="lf-label" for="lf-role">BẠN ĐANG LÀ?</label>
          <div class="lf-select-wrap">
            <select class="lf-input lf-select" id="lf-role" name="role">
              <option value="" disabled selected>Chọn vai trò</option>
              <option>Sinh viên</option>
              <option>Người đi làm</option>
              <option>Phụ huynh</option>
              <option>Khác</option>
            </select>
          </div>
        </div>

        <!-- Hàng 3: Chương trình quan tâm | Mục tiêu -->
        <div class="lf-field">
          <label class="lf-label" for="lf-program">BẠN QUAN TÂM CHƯƠNG TRÌNH NÀO?</label>
          <div class="lf-select-wrap">
            <select class="lf-input lf-select" id="lf-program" name="program">
              <option value="" disabled selected>Chọn chương trình</option>
              <option>GRP — Global Readiness</option>
              <option>Internship J-1</option>
              <option>Office Tour</option>
              <option>407 Training</option>
              <option>Chưa rõ — cần tư vấn</option>
            </select>
          </div>
        </div>
        <div class="lf-field">
          <label class="lf-label" for="lf-goal">MỤC TIÊU CỦA BẠN LÀ GÌ?</label>
          <div class="lf-select-wrap">
            <select class="lf-input lf-select" id="lf-goal" name="goal">
              <option value="" disabled selected>Chọn mục tiêu</option>
              <option>Du học</option>
              <option>Thực tập quốc tế</option>
              <option>Làm việc ở nước ngoài</option>
              <option>Định cư lâu dài</option>
            </select>
          </div>
        </div>

        <!-- Hàng 4: Mốc thời gian | Nút gửi -->
        <div class="lf-field">
          <label class="lf-label" for="lf-timeline">BẠN DỰ ĐỊNH ĐI KHI NÀO?</label>
          <div class="lf-select-wrap">
            <select class="lf-input lf-select" id="lf-timeline" name="timeline">
              <option value="" disabled selected>Chọn mốc thời gian</option>
              <option>Trong 6 tháng tới</option>
              <option>6 – 12 tháng</option>
              <option>Hơn 1 năm</option>
              <option>Chưa xác định</option>
            </select>
          </div>
        </div>
        <div class="lf-field lf-field--submit">
          <button class="lf-submit" type="submit">
            <span class="lf-submit-label">GỬI THÔNG TIN</span>
            <span class="lf-submit-arrow" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" width="26" height="26"><path d="M7 7 17 17"/><path d="M17 7v10H7"/></svg>
            </span>
          </button>
        </div>
      </form>
    </div>
  </section>
</PageLayout>

<style>
  .news-hero {
    position: relative;
    /* Hero chiếm trọn 1 màn hình: chỉ có chữ to. Cuộn xuống mới tới toolbar + tin tức. */
    min-height: 100vh;
    display: flex; flex-direction: column; justify-content: center;
    padding-top: clamp(7rem, 8vw, 9rem); /* chừa nav (nội dung đã canh giữa dọc) */
    padding-bottom: clamp(3rem, 5vw, 5rem);
    background: transparent;
    overflow: visible;
  }
  /* wrapper y hệt about: lề 4rem mỗi bên desktop, z nổi trên glow beam */
  .news-hero .about-hero-wrap { position: relative; z-index: 1; width: calc(100% - 4rem); max-width: 120rem; margin-inline: auto; }
  /* pill đè cuối "OUR BLOG" (desktop) — xóa inline style, dùng CSS */
  .about-hero-head .cs-glass-pill { margin-left: -1rem; transform: translateY(2.6rem); }
  /* SPOTLIGHT kiểu OMNI cho "OUR BLOG": quầng cam LỚN-RỰC LỆCH PHẢI (sau "& MARKETING TRENDS"),
     nửa trái "OUR BLOG / INSIGHTS" để TỐI. Khớp 100% độ rực/màu các trang (about/programs).
     Màu = ramp footer: peach 255,112,60 -> cam 248,82,26 -> brand #f2420b. */
  .news-glow-beam {
    position: absolute; top: 20px; left: 88%; transform-origin: center;
    transform: translateX(-50%);
    width: 1180px; height: 900px; pointer-events: none; z-index: 0;
    background: radial-gradient(ellipse 50% 50% at 50% 42%,
      rgba(255, 112, 60, 0.66) 0%,
      rgba(248, 82, 26, 0.54) 22%,
      rgba(242, 66, 11, 0.38) 44%,
      rgba(242, 66, 11, 0.16) 64%,
      transparent 84%);
    filter: blur(76px);
  }
.cs-header { margin-bottom: 0; font-weight: 500; line-height: 0.95; letter-spacing: -0.045em; font-family: 'Inter', sans-serif; }
    .cs-line { display: flex; align-items: center; gap: 1.5rem; }
    /* Cụm "ABOUT SBB INSTITUTE" = HỆT cỡ DÒNG 1 các section homepage (.cs-line-1) */
    .cs-line-1 { font-size: clamp(8.5rem, 12vw, 11rem); letter-spacing: -0.085em; white-space: nowrap; position: relative; z-index: 10; }
.about-line-2 { display: flex; justify-content: space-between; align-items: center; gap: 1.5rem; margin-top: 0.5rem; }
    .about-verb { font-size: clamp(8.5rem, 12vw, 11rem); letter-spacing: -0.085em; line-height: 0.9; white-space: nowrap; margin-left: clamp(2.5rem, 7.5vw, 7.5rem); }
.about-tail { display: flex; flex-direction: column; align-items: flex-end; gap: 0.3rem; font-size: clamp(3rem, 5vw, 6.5rem); letter-spacing: -0.07em; line-height: 0.92; text-align: right; }
    .about-tail span { display: block; white-space: nowrap; }

  .cs-text-white { color: #ffffff !important; }
  /* PILL KÍNH = Y HỆT about/programs (dark): chữ nhật bo 20px, 210px cố định, nền kính tối + viền sáng.
     (Trước đây bo 100px stadium + ôm chữ -> khác hình dạng các trang kia.) */
  .cs-glass-pill {
    display: inline-flex; flex-direction: column; flex-shrink: 0;
    gap: var(--space-2);
    background: rgba(255, 255, 255, 0.045);
    backdrop-filter: blur(14px); -webkit-backdrop-filter: blur(14px);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 20px;
    padding: var(--space-4) var(--space-5);
    width: 240px; min-height: 7.25rem; /* 240 (border-box) = khớp render pill about/programs (210 content-box + padding) */
    justify-content: center; text-align: left;
    box-shadow:
      0 30px 44px -10px rgba(0, 0, 0, 0.78),  /* bóng đổ MẠNH xuống chữ tiêu đề dưới pill */
      0 14px 24px -8px rgba(0, 0, 0, 0.55),
      0 0 40px rgba(242, 66, 11, 0.12),
      inset 0 1px 1px rgba(255, 255, 255, 0.12);
  }
  .cs-glass-title {
    font-family: var(--font-headline);
    font-size: clamp(1.15rem, 1.5vw, 1.5rem);
    font-weight: 600; color: #ffffff; line-height: 1;
    letter-spacing: -0.01em; /* reset spacing âm kế thừa + siết nhẹ cho 1 dòng */
    white-space: nowrap; text-transform: uppercase;
  }
  .cs-glass-sub {
    font-family: 'Inter', sans-serif; font-weight: 400; font-size: 11px;
    line-height: 1.45; color: rgba(255, 255, 255, 0.62); white-space: normal;
    max-width: 25ch; margin: 0;
    /* RESET letter-spacing: nếu không, sub kế thừa -0.085em (≈ -15px) từ .cs-line-1 cỡ chữ khổng lồ
       -> spacing âm khủng -> glyph chồng/lật ngược. */
    letter-spacing: normal;
  }

  /* ===== BLOG GRID (Omni style: toolbar lọc + tìm kiếm + card ảnh) ===== */
  /* Bỏ tiêu đề "ĐỌC GÌ HÔM NAY" -> siết top để vào là thấy tin tức luôn */
  .blog-section { padding-top: clamp(1rem, 2vw, 2.2rem); }
  /* TRÀN 2 MÉP như Omni: phá container hẹp, chỉ chừa lề mỏng ~3rem (không co vào giữa) */
  .blog-section .container {
    max-width: none; width: 100%;
    padding-inline: clamp(1.5rem, 3.2vw, 3.25rem);
  }
  .blog-toolbar {
    display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between;
    gap: 1rem 1.5rem; margin-bottom: clamp(3.5rem, 6vw, 5.5rem);
  }
  .blog-filters { display: flex; flex-wrap: wrap; gap: clamp(0.5rem, 0.9vw, 0.85rem); }
  .blog-filter {
    font-family: 'Inter', sans-serif; font-size: 0.88rem; font-weight: 500;
    letter-spacing: 0.03em; color: rgba(255, 255, 255, 0.78); cursor: pointer;
    padding: 0.6rem 1.2rem; border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.14); background: rgba(255, 255, 255, 0.05);
    -webkit-backdrop-filter: blur(6px); backdrop-filter: blur(6px);
    transition: background .25s ease, border-color .25s ease, color .25s ease;
  }
  .blog-filter:hover { border-color: rgba(242, 66, 11, 0.5); background: rgba(242, 66, 11, 0.10); color: #fff; }
  .blog-filter.is-active {
    border-color: transparent; color: #fff;
    background: linear-gradient(180deg, #ff5c26 0%, #f2420b 100%);
    box-shadow: 0 12px 30px -10px rgba(242, 66, 11, 0.45), inset 0 1px 1px rgba(255, 255, 255, 0.25);
  }
  .blog-search {
    display: inline-flex; align-items: center; gap: 0.6rem;
    padding: 0.55rem 1.1rem; border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.14); background: rgba(255, 255, 255, 0.04);
    color: rgba(255, 255, 255, 0.55); min-width: min(280px, 100%);
    transition: border-color .25s ease, color .25s ease;
  }
  .blog-search:focus-within { border-color: rgba(242, 66, 11, 0.55); color: #fff; }
  .blog-search input {
    border: 0; background: transparent; outline: none; color: #fff; width: 100%;
    font-family: 'Inter', sans-serif; font-size: 0.92rem;
  }
  .blog-search input::placeholder { color: rgba(255, 255, 255, 0.45); }
  .blog-search input::-webkit-search-cancel-button { filter: invert(0.7); }

  .blog-grid {
    display: grid; gap: clamp(1.5rem, 2vw, 2.4rem);
    grid-template-columns: repeat(3, 1fr);
  }
  /* TỐI mặc định, CHỈ SÁNG KHI HOVER — dùng ĐÚNG ánh sáng card case-studies trang programs:
     bloom cam từ góc dưới-phải (radial 180% 150% at 100% 100%), peach -> cam -> tối. */
  .blog-card {
    position: relative; display: flex; flex-direction: column;
    border: 1px solid rgba(255, 255, 255, 0.10); border-radius: 28px;
    background: transparent;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.4);
    padding: clamp(1.9rem, 2.6vw, 2.9rem);
    text-decoration: none; overflow: hidden;
    transition: border-color .4s ease, background .4s ease, box-shadow .4s ease, transform .4s ease;
  }
  .blog-card:hover {
    background:
      radial-gradient(180% 150% at 100% 100%,
        rgba(255, 126, 72, 0.90) 0%,
        rgba(255, 100, 30, 0.80) 25%,
        rgba(242, 66, 11, 0.60) 50%,
        rgba(20, 10, 5, 0.90) 80%,
        rgba(10, 5, 2, 0.98) 100%);
    border-color: #f2420b;
    box-shadow: 0 26px 64px -24px rgba(0, 0, 0, 0.5);
    transform: translateY(-4px);
  }
  .blog-card__tag {
    display: inline-block; align-self: flex-start;
    font-family: var(--font-headline); font-weight: 600; font-size: 0.68rem;
    letter-spacing: 0.1em; text-transform: uppercase; color: #f2420b;
    border: 1px solid rgba(242, 66, 11, 0.4); border-radius: 999px; padding: 0.28rem 0.75rem;
    margin-bottom: 0.95rem;
  }
  .blog-card__title {
    font-family: var(--font-headline); font-weight: 700;
