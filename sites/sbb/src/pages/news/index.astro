---
import PageLayout from '@ui/layouts/PageLayout.astro';
import { getCollection } from 'astro:content';

// Danh mục + bài News lấy từ content collection (build spec mục 7).
const cumLabels = {
  'internship-j1': 'Internship J-1', 'reality-check': 'Reality Check',
  'tu-duy-ra-the-gioi': 'Tư duy ra thế giới', 'grp': 'GRP',
  'office-tour': 'Office Tour', 'tieng-noi-hanh-trinh': 'Tiếng nói hành trình',
};
// Gom bài J-1 theo chủ đề cho bộ lọc gọn; bài cụm khác dùng nhãn cụm.
function themeOf(slug, cum) {
  if (cum !== 'internship-j1') return cumLabels[cum] || 'Khác';
  if (/thue|fica|hoan-thue|khai-thue|luong|thuc-nhan|chi-phi|gui-tien/.test(slug)) return 'Chi phí & Thuế';
  if (/sau-j1|212e|ve-nuoc|dinh-cu|grace/.test(slug)) return 'Sau chương trình';
  if (/mo-tai-khoan|ssn|sim|thue-nha|di-lai|tuan-dau|tips/.test(slug)) return 'Cuộc sống ở Mỹ';
  if (/nganh|host|bao-hiem|khong-duoc-lam/.test(slug)) return 'Ngành & Công việc';
  return 'Visa & Hồ sơ';
}
const fmtDate = (dt) => dt.toLocaleDateString('vi-VN', { day: '2-digit', month: '2-digit', year: 'numeric' });
const entries = await getCollection('news');
const posts = entries
  .map((e) => ({
    slug: e.id,
    img: e.data.image,
    title: e.data.title,
    desc: e.data.description || '',
    cat: themeOf(e.id, e.data.cum_chinh),
    catLabel: themeOf(e.id, e.data.cum_chinh),
    date: fmtDate(e.data.published),
    ts: e.data.published.getTime(),
    href: `/news/${e.id}`,
  }))
  .sort((a, b) => b.ts - a.ts);
const catOrder = ['Visa & Hồ sơ', 'Ngành & Công việc', 'Chi phí & Thuế', 'Cuộc sống ở Mỹ', 'Sau chương trình'];
const present = Array.from(new Set(posts.map((p) => p.cat)));
present.sort((a, b) => ((catOrder.indexOf(a) + 1) || 99) - ((catOrder.indexOf(b) + 1) || 99));
const blogCats = [{ id: 'all', label: 'Tất cả' }, ...present.map((c) => ({ id: c, label: c }))];

// Mobile = kiểu tạp chí: carousel bài nổi bật (lướt ngang) + chip đổi chủ đề + mỗi chủ đề vài bài mới nhất.
const featured = posts.slice(0, 5);
const groups = present
  .map((theme) => ({ theme, posts: posts.filter((p) => p.cat === theme) }))
  .filter((g) => g.posts.length);
const CAP = 4; // overview: mỗi chủ đề chỉ hiện 4 bài mới nhất, còn lại ẩn sau nút "Xem tất cả"
---

<PageLayout
  title="News"
  description="Câu chuyện thật của học viên, reality check không tô vẽ, và tiếng nói sinh viên trên hành trình bước ra thế giới."
  site="sbb"
  currentPath="/news"
>
    <!-- ===== HERO ===== -->
  <section class="news-hero">
    <!-- Quầng sáng cam LỚN-RỰC đánh từ PHẢI vào "& REAL STORIES" (giống Omni blog hero) -->
    <div class="news-glow-beam" aria-hidden="true"></div>
    <div class="about-hero-wrap">
      <div class="cs-header about-hero-head">
        <div class="cs-line cs-line-1">
          <span class="cs-text-white">OUR BLOG</span>
          <div class="cs-glass-pill">
            <span class="cs-glass-title">CONTENT HUB</span>
            <span class="cs-glass-sub">Câu chuyện thật và reality check cho hành trình bước ra thế giới.</span>
          </div>
        </div>
        <div class="about-line-2">
          <span class="about-verb cs-text-white">INSIGHTS</span>
          <span class="about-tail">
            <span class="cs-text-white">&amp; REAL</span>
            <span class="cs-text-white">STORIES</span>
          </span>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== BLOG GRID (Omni style: lọc danh mục + tìm kiếm + card ảnh) ===== -->
  <section class="o-section blog-section">
    <div class="container">
      <!-- Toolbar: pill lọc danh mục + ô tìm kiếm -->
      <div class="blog-toolbar">
        <div class="blog-filters" role="group" aria-label="Lọc theo danh mục">
          {blogCats.map((c, i) => (
            <button type="button" class:list={["blog-filter", i === 0 && "is-active"]} data-filter={c.id}>{c.label}</button>
          ))}
        </div>
        <label class="blog-search">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4.2-4.2"/></svg>
          <input type="search" id="blogSearch" placeholder="Tìm bài viết..." autocomplete="off" aria-label="Tìm bài viết" />
        </label>
      </div>

      <!-- Lưới card (prototype: 1 hàng 3 card) -->
      <div class="blog-grid">
        {posts.map((p) => (
          <a href={p.href} class="blog-card" data-cat={p.cat} data-title={p.title.toLowerCase()}>
            <div class="blog-card__media"><img src={p.img} alt={p.title} loading="lazy" onerror="this.closest('.blog-card__media').style.display='none'" /></div>
            <span class="blog-card__tag">{p.catLabel}</span>
            <h3 class="blog-card__title">{p.title}</h3>
            {p.desc && <p class="blog-card__desc">{p.desc}</p>}
            <div class="blog-card__foot">
              <time class="blog-card__date">{p.date}</time>
              <span class="blog-card__cta" aria-label="Đọc bài">
                <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="M13 6l6 6-6 6"/></svg>
              </span>
            </div>
          </a>
        ))}
      </div>
      <p class="blog-empty" hidden>Không tìm thấy bài viết phù hợp với bộ lọc.</p>

      <!-- ===== MAGAZINE (chỉ mobile ≤680px): chip đổi chủ đề + carousel nổi bật + mỗi chủ đề vài bài ===== -->
      <div class="blog-mag" data-mode="overview">
        <!-- Chip đổi chủ đề: ngay đầu, thấy hết chủ đề, vuốt ngang, chạm để lọc -->
        <div class="mag-chips" role="tablist" aria-label="Chọn chủ đề">
          <button type="button" class="mag-chip is-active" data-theme="all">Tất cả</button>
          {groups.map((g) => (
            <button type="button" class="mag-chip" data-theme={g.theme}>{g.theme}</button>
          ))}
        </div>

        <!-- Nổi bật: carousel LƯỚT NGANG (scroll-snap) + chấm chỉ vị trí -->
        <div class="mag-feat" data-overview-only>
          <div class="mag-feat__rail">
            {featured.map((p) => (
              <a href={p.href} class="mag-featcard">
                <div class="mag-featcard__media"><img src={p.img} alt={p.title} loading="lazy" onerror="this.closest('.mag-featcard__media').style.display='none'" /></div>
                <div class="mag-featcard__body">
                  <span class="mag-featcard__tag">{p.catLabel}</span>
                  <h3 class="mag-featcard__title">{p.title}</h3>
                  <time class="mag-featcard__date">{p.date}</time>
                </div>
              </a>
            ))}
          </div>
          <div class="mag-dots" aria-hidden="true">
            {featured.map((_, i) => (<span class:list={["mag-dot", i === 0 && "is-active"]}></span>))}
          </div>
        </div>

        <!-- Các chủ đề: overview chỉ hiện CAP bài mới nhất, còn lại ẩn sau "Xem tất cả" -->
        {groups.map((g) => (
          <section class="blog-group" data-theme={g.theme}>
            <h2 class="blog-group__title">{g.theme}</h2>
            <div class="blog-row">
              {g.posts.map((p, i) => (
                <a href={p.href} class="blog-rowcard" data-extra={i >= CAP ? "1" : undefined}>
                  <span class="blog-rowcard__thumb"><img src={p.img} alt="" loading="lazy" onerror="this.style.display='none'" /></span>
                  <span class="blog-rowcard__body">
                    <span class="blog-rowcard__title">{p.title}</span>
                    <time class="blog-rowcard__date">{p.date}</time>
                  </span>
                  <span class="blog-rowcard__arrow" aria-hidden="true">
                    <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6l6 6-6 6"/></svg>
                  </span>
                </a>
              ))}
            </div>
            {g.posts.length > CAP && (
              <button type="button" class="blog-more" data-theme={g.theme}>Xem tất cả {g.posts.length} bài →</button>
            )}
          </section>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ FINAL CTA · "READY TO SHINE BEYOND BORDERS" (giống Omni "READY TO GROW & SCALE") ============ -->
  <section class="cta-final" id="get-started">
    <div class="container cta-final-inner">
      <!-- Tiêu đề kiểu Omni "READY TO GROW & SCALE": cascade 3 dòng lớn + glass pill (y hệt homepage) -->
      <div class="cs-header cta-header">
        <div class="cs-line cs-line-1">
          <span class="cs-text-white">READY</span>
        </div>
        <div class="cta-line-2">
          <span class="cta-verb">TO SHINE</span>
          <div class="cs-glass-pill">
            <span class="cs-glass-title">LET'S TALK</span>
            <span class="cs-glass-sub">Tư vấn miễn phí 30 phút, cùng SBB vẽ lộ trình rõ ràng cho bạn.</span>
          </div>
        </div>
        <div class="cta-line-3">
          <span class="cta-tail"><span class="cs-text-white">BEYOND BORDERS?</span></span>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ LEAD FORM · (giống Omni contact form: 2 cột, label in hoa, input gạch chân, dropdown, nút pill) ============ -->
  <section class="lead-form" id="lead-form">
    <div class="container">
      <form class="lf-grid" action="#" method="POST" novalidate>
        <!-- Hàng 1: Họ tên | Số điện thoại -->
        <div class="lf-field">
          <label class="lf-label" for="lf-name">HỌ TÊN CỦA BẠN<span class="lf-req">*</span></label>
          <input class="lf-input" id="lf-name" name="name" type="text" required autocomplete="name" placeholder="Nguyễn Văn A" />
        </div>
        <div class="lf-field">
          <label class="lf-label" for="lf-phone">SỐ ĐIỆN THOẠI<span class="lf-req">*</span></label>
          <input class="lf-input" id="lf-phone" name="phone" type="tel" required autocomplete="tel" placeholder="+84 9xx xxx xxx" />
        </div>

        <!-- Hàng 2: Email | Bạn đang là -->
        <div class="lf-field">
          <label class="lf-label" for="lf-email">EMAIL CỦA BẠN<span class="lf-req">*</span></label>
          <input class="lf-input" id="lf-email" name="email" type="email" required autocomplete="email" placeholder="ban@email.com" />
        </div>
        <div class="lf-field">
          <label class="lf-label" for="lf-role">BẠN ĐANG LÀ?</label>
          <div class="lf-select-wrap">
            <select class="lf-input lf-select" id="lf-role" name="role">
              <option value="" disabled selected>Chọn vai trò</option>
              <option>Sinh viên</option>
              <option>Người đi làm</option>
              <option>Phụ huynh</option>
              <option>Khác</option>
            </select>
          </div>
        </div>

        <!-- Hàng 3: Chương trình quan tâm | Mục tiêu -->
        <div class="lf-field">
          <label class="lf-label" for="lf-program">BẠN QUAN TÂM CHƯƠNG TRÌNH NÀO?</label>
          <div class="lf-select-wrap">
            <select class="lf-input lf-select" id="lf-program" name="program">
              <option value="" disabled selected>Chọn chương trình</option>
              <option>GRP — Global Readiness</option>
              <option>Internship J-1</option>
              <option>Office Tour</option>
              <option>407 Training</option>
              <option>Chưa rõ — cần tư vấn</option>
            </select>
          </div>
        </div>
        <div class="lf-field">
          <label class="lf-label" for="lf-goal">MỤC TIÊU CỦA BẠN LÀ GÌ?</label>
          <div class="lf-select-wrap">
            <select class="lf-input lf-select" id="lf-goal" name="goal">
              <option value="" disabled selected>Chọn mục tiêu</option>
              <option>Du học</option>
              <option>Thực tập quốc tế</option>
              <option>Làm việc ở nước ngoài</option>
              <option>Định cư lâu dài</option>
            </select>
          </div>
        </div>

        <!-- Hàng 4: Mốc thời gian | Nút gửi -->
        <div class="lf-field">
          <label class="lf-label" for="lf-timeline">BẠN DỰ ĐỊNH ĐI KHI NÀO?</label>
          <div class="lf-select-wrap">
            <select class="lf-input lf-select" id="lf-timeline" name="timeline">
              <option value="" disabled selected>Chọn mốc thời gian</option>
              <option>Trong 6 tháng tới</option>
              <option>6 – 12 tháng</option>
              <option>Hơn 1 năm</option>
              <option>Chưa xác định</option>
            </select>
          </div>
        </div>
        <div class="lf-field lf-field--submit">
          <button class="lf-submit" type="submit">
            <span class="lf-submit-label">GỬI THÔNG TIN</span>
            <span class="lf-submit-arrow" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" width="26" height="26"><path d="M7 7 17 17"/><path d="M17 7v10H7"/></svg>
            </span>
          </button>
        </div>
      </form>
    </div>
  </section>
</PageLayout>

<style>
  .news-hero {
    position: relative;
    /* Hero chiếm trọn 1 màn hình: chỉ có chữ to. Cuộn xuống mới tới toolbar + tin tức. */
    min-height: 100vh;
    display: flex; flex-direction: column; justify-content: center;
    padding-top: clamp(7rem, 8vw, 9rem); /* chừa nav (nội dung đã canh giữa dọc) */
    padding-bottom: clamp(3rem, 5vw, 5rem);
    background: transparent;
    overflow: visible;
  }
  /* wrapper y hệt about: lề 4rem mỗi bên desktop, z nổi trên glow beam */
  .news-hero .about-hero-wrap { position: relative; z-index: 1; width: calc(100% - 4rem); max-width: 120rem; margin-inline: auto; }
  /* pill đè cuối "OUR BLOG" (desktop) — xóa inline style, dùng CSS */
  .about-hero-head .cs-glass-pill { margin-left: -1rem; transform: translateY(2.6rem); }
  /* SPOTLIGHT kiểu OMNI cho "OUR BLOG": quầng cam LỚN-RỰC LỆCH PHẢI (sau "& MARKETING TRENDS"),
     nửa trái "OUR BLOG / INSIGHTS" để TỐI. Khớp 100% độ rực/màu các trang (about/programs).
     Màu = ramp footer: peach 255,112,60 -> cam 248,82,26 -> brand #f2420b. */
  .news-glow-beam {
    position: absolute; top: 20px; left: 88%; transform-origin: center;
    transform: translateX(-50%);
    width: 1180px; height: 900px; pointer-events: none; z-index: 0;
    background: radial-gradient(ellipse 50% 50% at 50% 42%,
      rgba(255, 112, 60, 0.66) 0%,
      rgba(248, 82, 26, 0.54) 22%,
      rgba(242, 66, 11, 0.38) 44%,
      rgba(242, 66, 11, 0.16) 64%,
      transparent 84%);
    filter: blur(76px);
  }
.cs-header { margin-bottom: 0; font-weight: 500; line-height: 0.95; letter-spacing: -0.045em; font-family: 'Inter', sans-serif; }
    .cs-line { display: flex; align-items: center; gap: 1.5rem; }
    /* Cụm "ABOUT SBB INSTITUTE" = HỆT cỡ DÒNG 1 các section homepage (.cs-line-1) */
    .cs-line-1 { font-size: clamp(8.5rem, 12vw, 11rem); letter-spacing: -0.085em; white-space: nowrap; position: relative; z-index: 10; }
.about-line-2 { display: flex; justify-content: space-between; align-items: center; gap: 1.5rem; margin-top: 0.5rem; }
    .about-verb { font-size: clamp(8.5rem, 12vw, 11rem); letter-spacing: -0.085em; line-height: 0.9; white-space: nowrap; margin-left: clamp(2.5rem, 7.5vw, 7.5rem); }
.about-tail { display: flex; flex-direction: column; align-items: flex-end; gap: 0.3rem; font-size: clamp(3rem, 5vw, 6.5rem); letter-spacing: -0.07em; line-height: 0.92; text-align: right; }
    .about-tail span { display: block; white-space: nowrap; }

  .cs-text-white { color: #ffffff !important; }
  /* PILL KÍNH = Y HỆT about/programs (dark): chữ nhật bo 20px, 210px cố định, nền kính tối + viền sáng.
     (Trước đây bo 100px stadium + ôm chữ -> khác hình dạng các trang kia.) */
  .cs-glass-pill {
    display: inline-flex; flex-direction: column; flex-shrink: 0;
    gap: var(--space-2);
    background: rgba(255, 255, 255, 0.045);
    backdrop-filter: blur(14px); -webkit-backdrop-filter: blur(14px);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 20px;
    padding: var(--space-4) var(--space-5);
    width: 240px; min-height: 7.25rem; /* 240 (border-box) = khớp render pill about/programs (210 content-box + padding) */
    justify-content: center; text-align: left;
    box-shadow:
      0 30px 44px -10px rgba(0, 0, 0, 0.78),  /* bóng đổ MẠNH xuống chữ tiêu đề dưới pill */
      0 14px 24px -8px rgba(0, 0, 0, 0.55),
      0 0 40px rgba(242, 66, 11, 0.12),
      inset 0 1px 1px rgba(255, 255, 255, 0.12);
  }
  .cs-glass-title {
    font-family: var(--font-headline);
    font-size: clamp(1.15rem, 1.5vw, 1.5rem);
    font-weight: 600; color: #ffffff; line-height: 1;
    letter-spacing: -0.01em; /* reset spacing âm kế thừa + siết nhẹ cho 1 dòng */
    white-space: nowrap; text-transform: uppercase;
  }
  .cs-glass-sub {
    font-family: 'Inter', sans-serif; font-weight: 400; font-size: 11px;
    line-height: 1.45; color: rgba(255, 255, 255, 0.62); white-space: normal;
    max-width: 25ch; margin: 0;
    /* RESET letter-spacing: nếu không, sub kế thừa -0.085em (≈ -15px) từ .cs-line-1 cỡ chữ khổng lồ
       -> spacing âm khủng -> glyph chồng/lật ngược. */
    letter-spacing: normal;
  }

  /* ===== BLOG GRID (Omni style: toolbar lọc + tìm kiếm + card ảnh) ===== */
  /* Bỏ tiêu đề "ĐỌC GÌ HÔM NAY" -> siết top để vào là thấy tin tức luôn */
  .blog-section { padding-top: clamp(1rem, 2vw, 2.2rem); }
  /* TRÀN 2 MÉP như Omni: phá container hẹp, chỉ chừa lề mỏng ~3rem (không co vào giữa) */
  .blog-section .container {
    max-width: none; width: 100%;
    padding-inline: clamp(1.5rem, 3.2vw, 3.25rem);
  }
  .blog-toolbar {
    display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between;
    gap: 1rem 1.5rem; margin-bottom: clamp(3.5rem, 6vw, 5.5rem);
  }
  .blog-filters { display: flex; flex-wrap: wrap; gap: clamp(0.5rem, 0.9vw, 0.85rem); }
  .blog-filter {
    font-family: 'Inter', sans-serif; font-size: 0.88rem; font-weight: 500;
    letter-spacing: 0.03em; color: rgba(255, 255, 255, 0.78); cursor: pointer;
    padding: 0.6rem 1.2rem; border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.14); background: rgba(255, 255, 255, 0.05);
    -webkit-backdrop-filter: blur(6px); backdrop-filter: blur(6px);
    transition: background .25s ease, border-color .25s ease, color .25s ease;
  }
  .blog-filter:hover { border-color: rgba(242, 66, 11, 0.5); background: rgba(242, 66, 11, 0.10); color: #fff; }
  .blog-filter.is-active {
    border-color: transparent; color: #fff;
    background: linear-gradient(180deg, #ff5c26 0%, #f2420b 100%);
    box-shadow: 0 12px 30px -10px rgba(242, 66, 11, 0.45), inset 0 1px 1px rgba(255, 255, 255, 0.25);
  }
  .blog-search {
    display: inline-flex; align-items: center; gap: 0.6rem;
    padding: 0.55rem 1.1rem; border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.14); background: rgba(255, 255, 255, 0.04);
    color: rgba(255, 255, 255, 0.55); min-width: min(280px, 100%);
    transition: border-color .25s ease, color .25s ease;
  }
  .blog-search:focus-within { border-color: rgba(242, 66, 11, 0.55); color: #fff; }
  .blog-search input {
    border: 0; background: transparent; outline: none; color: #fff; width: 100%;
    font-family: 'Inter', sans-serif; font-size: 0.92rem;
  }
  .blog-search input::placeholder { color: rgba(255, 255, 255, 0.45); }
  .blog-search input::-webkit-search-cancel-button { filter: invert(0.7); }

  .blog-grid {
    display: grid; gap: clamp(1.5rem, 2vw, 2.4rem);
    grid-template-columns: repeat(3, 1fr);
  }
  /* TỐI mặc định, CHỈ SÁNG KHI HOVER — dùng ĐÚNG ánh sáng card case-studies trang programs:
     bloom cam từ góc dưới-phải (radial 180% 150% at 100% 100%), peach -> cam -> tối. */
  .blog-card {
    position: relative; display: flex; flex-direction: column;
    border: 1px solid rgba(255, 255, 255, 0.10); border-radius: 28px;
    background: transparent;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.4);
    padding: clamp(1.9rem, 2.6vw, 2.9rem);
    text-decoration: none; overflow: hidden;
    transition: border-color .4s ease, background .4s ease, box-shadow .4s ease, transform .4s ease;
  }
  .blog-card:hover {
    background:
      radial-gradient(180% 150% at 100% 100%,
        rgba(255, 126, 72, 0.90) 0%,
        rgba(255, 100, 30, 0.80) 25%,
        rgba(242, 66, 11, 0.60) 50%,
        rgba(20, 10, 5, 0.90) 80%,
        rgba(10, 5, 2, 0.98) 100%);
    border-color: #f2420b;
    box-shadow: 0 26px 64px -24px rgba(0, 0, 0, 0.5);
    transform: translateY(-4px);
  }
  .blog-card__tag {
    display: inline-block; align-self: flex-start;
    font-family: var(--font-headline); font-weight: 600; font-size: 0.68rem;
    letter-spacing: 0.1em; text-transform: uppercase; color: #f2420b;
    border: 1px solid rgba(242, 66, 11, 0.4); border-radius: 999px; padding: 0.28rem 0.75rem;
    margin-bottom: 0.95rem;
  }
    .blog-card__title {
    font-family: 'Inter', sans-serif; font-weight: 500;
    font-size: clamp(1.1rem, 1.45vw, 1.4rem); line-height: 1.3;
    color: #fff; text-transform: none; letter-spacing: -0.015em;
    margin: 0 0 0.85rem;
  }
  .blog-card__desc {
    font-family: 'Inter', sans-serif; font-weight: 300;
    font-size: 0.92rem; line-height: 1.6; color: rgba(255,255,255,0.6);
    margin: 0 0 clamp(1.4rem, 2vw, 1.8rem);
    display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;
  }
  .blog-card__foot { margin-top: auto; display: flex; align-items: center; justify-content: space-between; gap: 1rem; }
  .blog-card__date { font-family: 'Inter', sans-serif; font-weight: 300; font-size: 0.8rem; color: rgba(255,255,255,0.45); }
  .blog-card__media {
    position: relative; border-radius: 18px; overflow: hidden;
    aspect-ratio: 16 / 11; background: linear-gradient(160deg, #2a1109, #160a05);
    margin-bottom: clamp(1.6rem, 2.2vw, 2.2rem);
  }
  .blog-card__media img { width: 100%; height: 100%; object-fit: cover; display: block; }
    .blog-card__cta {
    flex: 0 0 auto; display: flex; align-items: center; justify-content: center;
    width: 2.4rem; height: 2.4rem; border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.18); color: rgba(255, 255, 255, 0.85);
    transition: background .3s ease, border-color .3s ease, color .3s ease, transform .3s ease;
  }
  .blog-card:hover .blog-card__cta {
    border-color: rgba(255, 255, 255, 0.34); background: rgba(255, 255, 255, 0.06); color: #fff;
  }
  .blog-card[hidden] { display: none !important; }
  .blog-empty { text-align: center; color: rgba(255, 255, 255, 0.55); padding: 2.5rem 0 0; font-size: 1rem; }
  /* Magazine chỉ hiện ở mobile ≤680px (bật trong media query bên dưới) */
  .blog-mag { display: none; }

  @media (max-width: 980px) { .blog-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 680px) {
    /* ===== MOBILE = KIỂU TẠP CHÍ: ẩn toolbar + lưới card, hiện magazine ===== */
    .blog-toolbar, .blog-grid, .blog-empty { display: none !important; }
    .blog-mag { display: block; }
    .blog-section { padding-top: clamp(0.5rem, 2vw, 1.5rem); }

    /* --- Chip đổi chủ đề: dải vuốt ngang, tràn 2 mép, ngay đầu trang --- */
    .mag-chips {
      display: flex; gap: 0.5rem; overflow-x: auto; scroll-snap-type: x proximity;
      -webkit-overflow-scrolling: touch; scrollbar-width: none;
      margin: 0 -1.5rem 1.7rem; padding: 0 1.5rem 0.15rem; scroll-margin-top: 82px;
    }
    .mag-chips::-webkit-scrollbar { display: none; }
    .mag-chip {
      flex: 0 0 auto; scroll-snap-align: start; cursor: pointer;
      font-family: 'Inter', sans-serif; font-size: 0.82rem; font-weight: 500; letter-spacing: 0.01em;
      color: rgba(255, 255, 255, 0.8); white-space: nowrap;
      padding: 0.5rem 1rem; border-radius: 999px;
      border: 1px solid rgba(255, 255, 255, 0.14); background: rgba(255, 255, 255, 0.05);
      transition: background .25s ease, border-color .25s ease, color .25s ease;
    }
    .mag-chip.is-active {
      color: #fff; border-color: transparent;
      background: linear-gradient(180deg, #ff5c26 0%, #f2420b 100%);
      box-shadow: 0 10px 24px -10px rgba(242, 66, 11, 0.5);
    }

    /* --- Nổi bật: carousel LƯỚT NGANG (peek card kế) + chấm --- */
    .mag-feat { margin: 0 -1.5rem 2.3rem; }
    .mag-feat__rail {
      display: flex; gap: 0.9rem; overflow-x: auto; scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch; scrollbar-width: none; padding: 0 1.5rem 0.2rem;
    }
    .mag-feat__rail::-webkit-scrollbar { display: none; }
    .mag-featcard {
      flex: 0 0 84%; scroll-snap-align: center; text-decoration: none; overflow: hidden;
      border: 1px solid rgba(255, 255, 255, 0.10); border-radius: 20px; background: transparent;
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.4);
    }
    .mag-featcard__media { aspect-ratio: 16 / 10; background: linear-gradient(160deg, #2a1109, #160a05); }
    .mag-featcard__media img { width: 100%; height: 100%; object-fit: cover; display: block; }
    .mag-featcard__body { padding: 1rem 1.05rem 1.2rem; }
    .mag-featcard__tag {
      display: inline-block; font-family: var(--font-headline); font-weight: 600;
      font-size: 0.62rem; letter-spacing: 0.1em; text-transform: uppercase; color: #f2420b;
      border: 1px solid rgba(242, 66, 11, 0.4); border-radius: 999px; padding: 0.22rem 0.65rem; margin-bottom: 0.6rem;
    }
    .mag-featcard__title {
      font-family: 'Inter', sans-serif; font-weight: 500; font-size: 1.2rem; line-height: 1.28;
      color: #fff; letter-spacing: -0.02em; margin: 0 0 0.5rem;
      display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
    }
    .mag-featcard__date { font-family: 'Inter', sans-serif; font-weight: 300; font-size: 0.76rem; color: rgba(255, 255, 255, 0.45); }
    .mag-dots { display: flex; justify-content: center; gap: 0.4rem; margin-top: 0.9rem; }
    .mag-dot { width: 6px; height: 6px; border-radius: 999px; background: rgba(255, 255, 255, 0.25); transition: width .25s ease, background .25s ease; }
    .mag-dot.is-active { width: 18px; background: #f2420b; }

    /* --- Nhóm chủ đề: tiêu đề nhỏ + đường kẻ --- */
    .blog-group { margin-bottom: 1.9rem; }
    .blog-group__title {
      display: flex; align-items: center; gap: 0.75rem;
      font-family: var(--font-headline); font-weight: 600; font-size: 0.72rem;
      letter-spacing: 0.12em; text-transform: uppercase; color: #f2420b; margin: 0 0 0.35rem;
    }
    .blog-group__title::after { content: ''; flex: 1; height: 1px; background: rgba(255, 255, 255, 0.14); }

    /* --- Hàng bài gọn: thumbnail trái, tiêu đề + ngày phải --- */
    .blog-row { display: flex; flex-direction: column; }
    .blog-rowcard {
      display: flex; align-items: center; gap: 0.9rem; text-decoration: none;
      padding: 0.9rem 0; border-bottom: 1px solid rgba(255, 255, 255, 0.08);
      transition: background .25s ease;
    }
    .blog-rowcard:active { background: rgba(242, 66, 11, 0.06); }
    .blog-rowcard__thumb {
      flex: 0 0 auto; width: 88px; height: 64px; border-radius: 12px; overflow: hidden;
      background: linear-gradient(160deg, #2a1109, #160a05);
    }
    .blog-rowcard__thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }
    .blog-rowcard__body { display: flex; flex-direction: column; gap: 0.3rem; min-width: 0; flex: 1; }
    .blog-rowcard__title {
      font-family: 'Inter', sans-serif; font-weight: 500; font-size: 0.95rem; line-height: 1.3;
      color: #fff; letter-spacing: -0.01em;
      display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
    }
    .blog-rowcard__date { font-family: 'Inter', sans-serif; font-weight: 300; font-size: 0.72rem; color: rgba(255, 255, 255, 0.42); }
    .blog-rowcard__arrow { flex: 0 0 auto; display: flex; color: rgba(255, 255, 255, 0.4); }

    /* --- Nút "Xem tất cả" cuối mỗi nhóm --- */
    .blog-more {
      margin-top: 1rem; cursor: pointer; display: inline-flex; align-items: center;
      font-family: 'Inter', sans-serif; font-size: 0.82rem; font-weight: 500; letter-spacing: 0.01em;
      color: #f2420b; background: transparent; border: 1px solid rgba(242, 66, 11, 0.4);
      border-radius: 999px; padding: 0.5rem 1.1rem;
    }
    .blog-more:active { background: rgba(242, 66, 11, 0.10); }

    /* --- OVERVIEW: mỗi chủ đề chỉ hiện CAP bài; ẩn bài dư --- */
    .blog-mag[data-mode="overview"] .blog-rowcard[data-extra] { display: none; }

    /* --- FILTERED (đã chọn 1 chủ đề): ẩn carousel + chủ đề khác; hiện ĐỦ bài chủ đề đang chọn --- */
    .blog-mag[data-mode="filtered"] [data-overview-only] { display: none; }
    .blog-mag[data-mode="filtered"] .blog-group { display: none; }
    .blog-mag[data-mode="filtered"] .blog-group.is-active { display: block; }
    .blog-mag[data-mode="filtered"] .blog-group.is-active .blog-rowcard[data-extra] { display: flex; }
    .blog-mag[data-mode="filtered"] .blog-group.is-active .blog-more { display: none; }
  }

  /* ============================================
     FINAL CTA  (giống Omni "READY TO GROW & SCALE") — bê từ programs
     ============================================ */
  .cta-final {
    position: relative;
    /* Nửa DƯỚI của CÙNG vầng sáng với .tm-section: neo TÂM ẢO ở -250px (250px trên mép đỉnh = đúng
       điểm tâm bên kia seam) + bán kính dọc tuyệt đối 780px ⇒ vầng sáng từ testimonials chảy liền xuống,
       đơn điệu qua seam, ôm xuống chữ READY TO. Highlight quanh READY TO do ::before lo (user 2026-06-14). */
    margin-top: -1px; /* CHỒNG 1px khử "vạch tóc" do mép 2 block lệch nửa pixel ở DPR lẻ (paper html lọt qua khe) */
    background:
      radial-gradient(60% 780px at 41% -250px, rgba(242, 66, 11, 0.12) 0%, rgba(242, 66, 11, 0.07) 32%, rgba(242, 66, 11, 0.04) 60%, rgba(242, 66, 11, 0.02) 78%, transparent 92%),
      #D9D1CA;
    padding: var(--sec-pad) 0 clamp(2rem, 4vw, 3.5rem); /* top = gap chuẩn 240px; bottom NHỎ để form sát tiêu đề */
    overflow: hidden;
    text-align: left;
  }
  .cta-final::before {
    content: ''; position: absolute; left: 28%; top: 56%;
    transform: translate(-50%, -50%);
    width: 95%; height: 120%; pointer-events: none; z-index: 0;
    background: radial-gradient(ellipse 50% 44% at 40% 60%, rgba(242, 66, 11, 0.06) 0%, transparent 62%);
  }
  .cta-final-inner { position: relative; z-index: 1; display: flex; flex-direction: column; align-items: flex-start; }
  /* Dòng 2 CTA: động từ LỚN (cỡ cs-line-1) + đuôi XÁM nhỏ (cỡ cs-line-2) nằm sát phải — giống Omni GROW + & SCALE */
  .cta-header { margin-bottom: clamp(2.5rem, 5vw, 4rem); }
  /* Tiêu đề CTA phá khung ra 2rem-từ-mép-màn-hình (đồng bộ HOMEPAGE: thẳng hero, hết lệch container) */
  @media (min-width: 992px) {
    .cta-final .cs-header {
      width: calc(100vw - var(--sbw, 0px) - 4rem);
      max-width: 120rem;
      margin-left: calc(50% - (50vw - var(--sbw, 0px) / 2) + 2rem);
      margin-right: auto;
      box-sizing: border-box;
    }
  }
  /* space-between: SHINE thụt phải (margin-left ≈ 1/3 READY TO → nằm dưới 2/3 phải),
     đuôi xám canh phải nhưng bù margin-right để MÉP TRÁI thẳng cột 916 = REAL GROWTH/SAY ABOUT US/BORDERS */
  /* margin-top 1.25rem = ĐÚNG khoảng dòng1↔dòng2 các section trên (cs-header-bottom). align last baseline → đáy SHINE = đáy BORDERS? */
  .cta-line-2 { display: flex; justify-content: space-between; align-items: last baseline; margin-top: 1.25rem; } /* đồng bộ homepage */
  .cta-verb {
    font-family: 'Inter', sans-serif; font-weight: 500;
    font-size: clamp(8.5rem, 12vw, 11rem); letter-spacing: -0.085em; line-height: 0.9;
    color: #f2420b; white-space: nowrap;
  }
  .cta-line-3 { margin-top: 0.5rem; }
  .cta-tail {
    font-family: 'Inter', sans-serif; font-weight: 500;
    font-size: clamp(3rem, 5vw, 6.5rem); letter-spacing: -0.07em; line-height: 0.9;
  }
  .cta-tail span { display: block; }
  /* Pill "LET'S TALK": dịch xuống theo dòng TO SHINE (y hệt homepage) */
  .cta-final .cs-glass-pill { transform: translateY(2.6rem); }
  .cta-eyebrow {
    font-family: var(--font-headline); font-weight: 600;
    font-size: 0.8rem; letter-spacing: 0.3em; text-transform: uppercase;
    color: var(--accent); margin: 0 0 1.4rem;
  }
  .cta-final-title {
    font-family: var(--font-headline); font-weight: 800;
    font-size: clamp(2.8rem, 8.5vw, 8rem); line-height: 0.96;
    letter-spacing: -0.02em; margin: 0; text-transform: uppercase;
  }
  .cta-final-title span { display: block; }
  .cta-fill { color: #f2420b; }
  .cta-stroke { color: transparent; -webkit-text-stroke: 1.5px rgba(242, 66, 11, 0.45); }

  /* ============================================
     LEAD FORM (giống Omni contact form) — bê từ programs
     ============================================ */
  .lead-form {
    position: relative;
    background: #D9D1CA;
    padding: clamp(2rem, 4vw, 4rem) 0 var(--sec-pad); /* top NHỎ (form sát tiêu đề); bottom = gap chuẩn xuống footer */
    overflow: visible; /* để panel dropdown custom KHÔNG bị cắt */
  }
  /* quầng ấm rất nhẹ cho đỡ phẳng — tàn hẳn trước mọi mép nên không chạm seam */
  .lead-form::before {
    content: ''; position: absolute; inset: 0; pointer-events: none; z-index: 0;
    background: radial-gradient(58% 42% at 32% 30%, rgba(242, 66, 11, 0.04) 0%, transparent 60%);
  }
  .lead-form .container { position: relative; z-index: 1; }
  .lf-grid {
    display: grid; grid-template-columns: 1fr 1fr;
    column-gap: clamp(2.5rem, 6vw, 7rem);
    row-gap: clamp(2.2rem, 4vw, 3.4rem);
  }
  .lf-field { display: flex; flex-direction: column; min-width: 0; }
  .lf-label {
    font-family: 'Inter', sans-serif; font-weight: 400; /* không in đậm — chữ thường (user) */
    font-size: clamp(1.05rem, 1.7vw, 1.65rem); line-height: 1.15;
    letter-spacing: -0.01em; text-transform: uppercase;
    color: #1a1a1a; margin: 0 0 clamp(1rem, 1.8vw, 1.7rem);
  }
  .lf-req { color: var(--accent); margin-left: 0.12em; }
  .lf-input {
    width: 100%; box-sizing: border-box;
    background: transparent; border: none;
    border-bottom: 1px solid rgba(0, 0, 0, 0.20);
    color: #1a1a1a; font-family: 'Inter', sans-serif; font-weight: 400;
    font-size: clamp(1rem, 1.25vw, 1.15rem);
    padding: 0.55rem 0 0.95rem; line-height: 1.4;
    transition: border-color 0.25s ease;
  }
  .lf-input::placeholder { color: #A7A7A7; }
  .lf-input:focus { outline: none; border-bottom-color: var(--accent); }
  .lf-select-wrap { position: relative; }
  .lf-select-wrap::after { /* caret ▾ cho dropdown */
    content: ''; position: absolute; right: 0.25rem; top: 42%;
    width: 0.62rem; height: 0.62rem; pointer-events: none;
    border-right: 1.5px solid rgba(0, 0, 0, 0.45);
    border-bottom: 1.5px solid rgba(0, 0, 0, 0.45);
    transform: translateY(-50%) rotate(45deg);
  }
  .lf-select {
    appearance: none; -webkit-appearance: none; -moz-appearance: none;
    padding-right: 2rem; cursor: pointer; border-radius: 0;
  }
  .lf-select option { color: #16100c; }   /* fallback khi JS chưa nâng cấp */
  /* ===== Dropdown CUSTOM: ẩn select native + caret cũ khi đã nâng cấp ===== */
  .lf-select-wrap.is-enhanced > .lf-select { position: absolute; inset: 0; opacity: 0; pointer-events: none; }
  .lf-select-wrap.is-enhanced::after { display: none; }
  .lf-dd { position: relative; }
  .lf-dd-trigger {
    width: 100%; box-sizing: border-box;
    display: flex; align-items: center; justify-content: space-between; gap: 1rem;
    background: transparent; border: none; border-bottom: 1px solid rgba(0, 0, 0, 0.20);
    color: #1a1a1a; font-family: 'Inter', sans-serif; font-weight: 400;
    font-size: clamp(1rem, 1.25vw, 1.15rem); line-height: 1.4;
    padding: 0.55rem 0 0.95rem; cursor: pointer; text-align: left;
    transition: border-color 0.25s ease;
  }
  .lf-dd-trigger:focus-visible, .lf-dd.is-open .lf-dd-trigger { outline: none; border-bottom-color: var(--accent); }
  .lf-dd-value { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .lf-dd-value.is-placeholder { color: #A7A7A7; }
  .lf-dd-caret { display: flex; flex: 0 0 auto; color: rgba(0, 0, 0, 0.45); transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1), color 0.25s ease; }
  .lf-dd-caret svg { width: 1.15rem; height: 1.15rem; }
  .lf-dd.is-open .lf-dd-caret { transform: rotate(180deg); color: var(--accent); }
  .lf-dd-panel {
    list-style: none; margin: 0; padding: 0.4rem;
    position: absolute; top: calc(100% + 0.6rem); left: 0; right: 0; z-index: 60;
    background: rgba(255, 255, 255, 0.98);
    -webkit-backdrop-filter: blur(16px); backdrop-filter: blur(16px);
    border: 1px solid rgba(0, 0, 0, 0.10); border-radius: 14px;
    box-shadow: 0 26px 64px -20px rgba(0, 0, 0, 0.18), 0 4px 14px rgba(0, 0, 0, 0.10);
    max-height: 16rem; overflow-y: auto; overscroll-behavior: contain;
    opacity: 0; transform: translateY(-8px) scale(0.985); transform-origin: top center; pointer-events: none;
    transition: opacity 0.24s cubic-bezier(0.16, 1, 0.3, 1), transform 0.24s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .lf-dd.is-open .lf-dd-panel { opacity: 1; transform: translateY(0) scale(1); pointer-events: auto; }
  .lf-dd-option {
    padding: 0.8rem 0.95rem; border-radius: 9px; cursor: pointer;
    color: #1a1a1a; font-size: clamp(0.95rem, 1.1vw, 1.05rem); line-height: 1.25;
    transition: background 0.16s ease, color 0.16s ease;
  }
  .lf-dd-option:hover, .lf-dd-option.is-active { background: rgba(242, 66, 11, 0.10); color: #f2420b; }
  .lf-dd-option.is-selected { color: var(--accent); font-weight: 500; }
  .lf-dd-panel::-webkit-scrollbar { width: 8px; }
  .lf-dd-panel::-webkit-scrollbar-thumb { background: rgba(0, 0, 0, 0.18); border-radius: 8px; }
  .lf-field--submit { justify-content: flex-end; }
  .lf-submit {
    display: flex; align-items: center; justify-content: space-between; gap: 1rem;
    width: 100%; cursor: pointer; color: #fff; background: var(--accent);
    border: 1px solid var(--accent); border-radius: 100px;
    padding: clamp(1.1rem, 1.6vw, 1.5rem) clamp(1.8rem, 2.4vw, 2.4rem);
    font-family: 'Inter', sans-serif; font-weight: 600;
    font-size: clamp(0.95rem, 1.1vw, 1.1rem); letter-spacing: 0.08em; text-transform: uppercase;
    transition: background 0.3s ease, border-color 0.3s ease, transform 0.3s ease, box-shadow 0.3s ease;
  }
  .lf-submit:hover {
    background: var(--accent-2); border-color: var(--accent-2); transform: translateY(-2px);
    box-shadow: 0 16px 44px -16px rgba(242, 66, 11, 0.5);
  }
  .lf-submit-arrow { display: flex; }
  /* Đẩy form về BÊN PHẢI + thu hẹp (giống Omni): chừa khoảng trống trái, form chiếm ~78% phải */
  @media (min-width: 1024px) {
    .lf-grid { width: 78%; margin-left: auto; }
  }
  @media (max-width: 720px) {
    .lf-grid { grid-template-columns: 1fr; row-gap: 2rem; }
    .lf-field--submit { margin-top: 0.5rem; }
  }

  /* ============================================
     DARK OVERRIDE cho CTA + FORM (bê từ about.astro) — News là dark theme
     ============================================ */
  .cta-final { overflow: visible !important; }
  /* quầng sáng cam của tiêu đề CTA (spotlight) */
  .cta-final::before {
    display: block !important;
    width: 100vw !important; height: 130% !important;
    left: 50% !important; top: 50% !important;
    background: radial-gradient(circle 470px at 25% 45%,
      rgba(255, 112, 60, 0.80) 0%,
      rgba(248, 82, 26, 0.70) 30%,
      rgba(242, 66, 11, 0.50) 55%,
      rgba(20, 10, 5, 0.85) 85%,
      rgba(10, 5, 2, 0.95) 100%) !important;
    -webkit-mask-image: linear-gradient(to bottom, transparent 0%, black 15%, black 85%, transparent 100%) !important;
    mask-image: linear-gradient(to bottom, transparent 0%, black 15%, black 85%, transparent 100%) !important;
  }
  /* Form + CTA: nền TRANSPARENT (lộ nền tối body) thay nền kem light của base -> chữ trắng đọc được */
  .cta-final, .lead-form { background: transparent !important; background-image: none !important; }
